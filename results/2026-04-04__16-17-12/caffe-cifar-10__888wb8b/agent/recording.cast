[850.066991, "i", "cat examples/cifar10/create_cifar10.sh; printf '%s\\n' '__CMDEND__16__'\n"]
[850.068229, "o", "cat examples/cifar10/create_cifar10.sh; printf '%s\\n' '__CMDEND__16__'\r\n\u001b[?2004l\r"]
[850.072363, "o", "#!/usr/bin/env sh\r\n# This script converts the cifar data into leveldb format.\r\nset -e\r\n\r\nEXAMPLE=examples/cifar10\r\nDATA=data/cifar10\r\nDBTYPE=lmdb\r\n\r\necho \"Creating $DBTYPE...\"\r\n\r\nrm -rf $EXAMPLE/cifar10_train_$DBTYPE $EXAMPLE/cifar10_test_$DBTYPE\r\n\r\n./build/examples/cifar10/convert_cifar_data.bin $DATA $EXAMPLE $DBTYPE\r\n\r\necho \"Computing image mean...\"\r\n\r\n./build/tools/compute_image_mean -backend=$DBTYPE \\\r\n  $EXAMPLE/cifar10_train_$DBTYPE $EXAMPLE/mean.binaryproto\r\n\r\necho \"Done.\"\r\n"]
[850.073325, "o", "__CMDEND__16__\r\n\u001b[?2004hroot@13952671d5fd:/app/caffe# "]
[850.728448, "i", "cat examples/cifar10/train_quick.sh; printf '%s\\n' '__CMDEND__17__'\n"]
[850.729199, "o", "cat examples/cifar10/train_quick.sh; printf '%s\\n' '__CMDEND__17__'\r\n\u001b[?2004l\r"]
[850.732602, "o", "#!/usr/bin/env sh\r\nset -e\r\n\r\nTOOLS=./build/tools\r\n\r\n$TOOLS/caffe train \\\r\n  --solver=examples/cifar10/cifar10_quick_solver.prototxt $@\r\n\r\n# reduce learning rate by factor of 10 after 8 epochs\r\n$TOOLS/caffe train \\\r\n  --solver=examples/cifar10/cifar10_quick_solver_lr1.prototxt \\\r\n  --snapshot=examples/cifar10/cifar10_quick_iter_4000.solverstate $@\r\n"]
[850.733029, "o", "__CMDEND__17__\r\n"]
[850.733334, "o", "\u001b[?2004hroot@13952671d5fd:/app/caffe# "]
[870.301221, "i", "cat examples/cifar10/cifar10_quick_solver.prototxt; printf '%s\\n' '__CMDEND__18__'\n"]
[870.302081, "o", "cat examples/cifar10/cifar10_quick_solver.prototxt; printf '%s\\n' '__CMDEND__18__'\r\n\u001b[?2004l\r"]
[870.304933, "o", "# reduce the learning rate after 8 epochs (4000 iters) by a factor of 10\r\n\r\n# The train/test net protocol buffer definition\r\nnet: \"examples/cifar10/cifar10_quick_train_test.prototxt\"\r\n# test_iter specifies how many forward passes the test should carry out.\r\n# In the case of MNIST, we have test batch size 100 and 100 test iterations,\r\n# covering the full 10,000 testing images.\r\ntest_iter: 100\r\n# Carry out testing every 500 training iterations.\r\ntest_interval: 500\r\n# The base learning rate, momentum and the weight decay of the network.\r\nbase_lr: 0.001\r\nmomentum: 0.9\r\nweight_decay: 0.004\r\n# The learning rate policy\r\nlr_policy: \"fixed\"\r\n# Display every 100 iterations\r\ndisplay: 100\r\n# The maximum number of iterations\r\nmax_iter: 4000\r\n# snapshot intermediate results\r\nsnapshot: 4000\r\nsnapshot_prefix: \"examples/cifar10/cifar10_quick\"\r\n# solver mode: CPU or GPU\r\nsolver_mode: GPU\r\n"]
[870.305659, "o", "__CMDEND__18__\r\n\u001b[?2004hroot@13952671d5fd:/app/caffe# "]
[875.888108, "i", "ls -la data/cifar10/; printf '%s\\n' '__CMDEND__19__'\n"]
[875.888884, "o", "ls -la data/cifar10/; printf '%s\\n' '__CMDEND__19__'\r\n\u001b[?2004l\r"]
[875.892958, "o", "total 12\r\n"]
[875.893106, "o", "drwxr-xr-x 2 root root 4096 Apr  4 23:19 \u001b[0m\u001b[01;34m.\u001b[0m\r\ndrwxr-xr-x 5 root root 4096 Apr  4 23:19 \u001b[01;34m..\u001b[0m\r\n-rwxr-xr-x 1 root root  506 Apr  4 23:19 \u001b[01;32mget_cifar10.sh\u001b[0m\r\n"]
[875.894521, "o", "__CMDEND__19__\r\n\u001b[?2004hroot@13952671d5fd:/app/caffe# "]
[881.557792, "i", "cat data/cifar10/get_cifar10.sh; printf '%s\\n' '__CMDEND__20__'\n"]
[881.558496, "o", "cat data/cifar10/get_cifar10.sh; printf '%s\\n' '__CMDEND__20__'\r\n\u001b[?2004l\r"]
[881.56148, "o", "#!/usr/bin/env sh\r\n# This scripts downloads the CIFAR10 (binary version) data and unzips it.\r\n\r\nDIR=\"$( cd \"$(dirname \"$0\")\" ; pwd -P )\"\r\ncd \"$DIR\"\r\n\r\necho \"Downloading...\"\r\n\r\nwget --no-check-certificate http://www.cs.toronto.edu/~kriz/cifar-10-binary.tar.gz\r\n\r\necho \"Unzipping...\"\r\n\r\ntar -xf cifar-10-binary.tar.gz && rm -f cifar-10-binary.tar.gz\r\nmv cifar-10-batches-bin/* . && rm -rf cifar-10-batches-bin\r\n\r\n# Creation is split out because leveldb sometimes causes segfault\r\n# and needs to be re-created.\r\n\r\necho \"Done.\"\r\n"]
[881.561985, "o", "__CMDEND__20__\r\n\u001b[?2004h"]
[881.56229, "o", "root@13952671d5fd:/app/caffe# "]
[882.283243, "i", "cd data/cifar10 && ./get_cifar10.sh\n"]
[882.284005, "o", "cd data/cifar10 && ./get_cifar10.sh\r\n\u001b[?2004l\r"]
