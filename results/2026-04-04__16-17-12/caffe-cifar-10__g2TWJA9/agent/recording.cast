[118.208192, "o", "# \u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K choice:\r\n# atlas for ATLAS (default)\r\n# mkl for MKL\r\n# open for OpenBlas\r\n\u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K := atlas\r\n# Custom (MKL/ATLAS/Open\u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K) include and lib directories.\r\n# Leave commented to accept the defaults for your choice of \u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K\r\n# (which should work)!\r\n# \u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K_INCLUDE := /path/to/your/blas\r\n# \u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K_LIB := /path/to/your/blas\r\n"]
[118.208551, "o", "\r\n# Homebrew puts openblas in a directory that is not on the standard search path\r\n# \u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K_INCLUDE := $(shell brew --prefix openblas)/include\r\n# \u001b[01;31m\u001b[KBLAS\u001b[m\u001b[K_LIB := $(shell brew --prefix openblas)/lib\r\n\r\n# This is required only if you will compile the matlab interface.\r\n# MATLAB directory should contain the mex binary in /bin.\r\n# MATLAB_DIR := /usr/local\r\n# MATLAB_DIR := /Applications/MATLAB_R2012b.app\r\n"]
[118.208972, "o", "\u001b[?2004hroot@992220af5336:/app/caffe# "]
