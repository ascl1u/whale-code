[725.916125, "o", "\u001b[?2004h> "]
[725.916373, "o", "def replace_word(text, old_word, new_word):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.916793, "o", "    pattern = r'\\b' + re.escape(old_word) + r'\\b'\r\n\u001b[?2004l\r\u001b[?2004h"]
[725.917072, "o", "> "]
[725.917322, "o", "    return re.sub(pattern, new_word, text)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.917585, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.917735, "o", "def check_overfull():\r\n\u001b[?2004l\r\u001b[?2004h"]
[725.917896, "o", "> "]
[725.918404, "o", "    result = subprocess.run(['pdflatex', '-interaction=nonstopmode', 'main.tex'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.91894, "o", "                          capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.919387, "o", "    output = result.stdout + result.stderr\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.92014, "o", "    overfull_lines = [line for line in output.split('\\n') if 'Overfull' in line]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.920462, "o", "    return overfull_lines\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.920707, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.921108, "o", "synonym_map = parse_synonyms('synonyms.txt')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.921289, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.921945, "o", "with open('input.tex', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.922216, "o", "    text = f.read()\r\n\u001b[?2004l\r"]
[725.922478, "o", "\u001b[?2004h> "]
[725.922689, "o", "\r\n\u001b[?2004l\r"]
[725.922944, "o", "\u001b[?2004h> "]
[725.92315, "o", "# Replace awareness with reaction\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.923454, "o", "print(\"Applying last fix...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.923812, "o", "old, new = 'awareness', 'reaction'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.924465, "o", "if old in synonym_map and new in synonym_map[old]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.924997, "o", "    text = replace_word(text, old, new)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.925552, "o", "    print(f\"  {old} ({len(old)}) -> {new} ({len(new)}), saves {len(old)-len(new)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[725.925782, "o", "\u001b[?2004h> "]
[725.926189, "o", "with open('input.tex', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.926415, "o", "    f.write(text)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.926786, "o", "print(\"\\nChecking compilation...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.927067, "o", "overfull = check_overfull()\r\n\u001b[?2004l\r\u001b[?2004h"]
[725.92732, "o", "> if overfull:\r\n\u001b[?2004l\r"]
[725.927475, "o", "\u001b[?2004h> "]
[725.927866, "o", "    print(f\"\\nStill have {len(overfull)} overfull warnings:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[725.928042, "o", "> "]
[725.928244, "o", "    for line in overfull:\r\n\u001b[?2004l\r\u001b[?2004h"]
[725.928538, "o", ">         print(line)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.928671, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.929144, "o", "    print(\"\\n✓ SUCCESS! No overfull hbox warnings!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[725.929426, "o", "EOF\r\n\u001b[?2004l\r"]
[725.932049, "o", "\u001b[?2004hroot@b419d4b4dbd9:/app# "]
[725.932315, "o", "python3 last_fix.py\r\n\u001b[?2004l\r"]
[725.967767, "o", "Applying last fix...\r\n"]
[725.968157, "o", "  awareness (9) -> reaction (8), saves 1\r\n"]
[725.968394, "o", "\r\nChecking compilation...\r\n"]
[726.133171, "o", "\r\n✓ SUCCESS! No overfull hbox warnings!\r\n"]
[726.139821, "o", "\u001b[?2004hroot@b419d4b4dbd9:/app# "]
[738.406605, "i", "pdflatex main.tex 2>&1 | grep -i 'overfull\\|warning'\n"]
[738.407279, "o", "pdflatex main.tex 2>&1 | grep -i 'overfull\\|warning'\r\n\u001b[?2004l\r"]
[738.565183, "o", "\u001b[?2004hroot@b419d4b4dbd9:/app# "]
