[98.921406, "i", "cat > fix_overfull.py << 'EOF'\nimport re\nimport subprocess\nimport os\n\n# Parse synonyms.txt\ndef parse_synonyms(filename):\n    synonym_map = {}\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            words = [w.strip() for w in line.split(',')]\n            # Create mapping from each word to all its synonyms\n            for word in words:\n                synonym_map[word] = words\n    return synonym_map\n\n# Read input.tex\ndef read_input():\n    with open('input.tex', 'r') as f:\n        return f.read()\n\n# Write input.tex\ndef write_input(content):\n    with open('input.tex', 'w') as f:\n        f.write(content)\n\n# Compile and check for overfull hbox\ndef check_overfull():\n    result = subprocess.run(['pdflatex', '-interaction=nonstopmode', 'main.tex'],\n                          capture_output=True, text=True)\n    output = result.stdout + result.stderr\n    overfull_lines = [line for line in output.split('\\n') if 'Overfull' in line]\n    return overfull_lines\n\n# Replace a word with a shorter synonym\ndef replace_word(text, old_word, new_word):\n    # Use word boundaries to avoid partial replacements\n    pattern = r'\\b' + re.escape(old_word) + r'\\b'\n    return re.sub(pattern, new_word, text)\n\nsynonym_map = parse_synonyms('synonyms.txt')\noriginal_text = read_input()\n\n# Strategy: Replace specific problematic words with shorter synonyms\nreplacements = [\n    # Line 5-6 issues\n    ('curious', 'odd'),  # curious (7 chars) -> odd (3 chars)\n    ('natures', 'traits'),  # natures (7 chars) -> traits (6 chars) \n    ('confidences', 'secrets'),  # confidences (11 chars) -> secrets (7 chars)\n    ('unsought', 'unwanted'),  # unsought (8 chars) -> unwanted (8 chars) - same, try another\n    \n    # Line 7-8 issues\n    ('riotous', 'wild'),  # riotous (7 chars) -> wild (4 chars)\n    ('excursions', 'trips'),  # excursions (10 chars) -> trips (5 chars)\n    ('responsiveness', 'awareness'),  # responsiveness (15 chars) -> awareness (9 chars)\n    ('temperament', 'nature'),  # temperament (11 chars) -> nature (6 chars)\n    \n    # Line 13-14 issue\n    ('wisdom', 'insight'),  # wisdom (6 chars) -> insight (7 chars) - longer, try knowledge\n    \n    # Line 19 issue  \n    ('pathfinder', 'pioneer'),  # pathfinder (10 chars) -> pioneer (7 chars)\n]\n\ntext = original_text\n\nprint(\"Attempting replacements...\")\nfor old, new in replacements:\n    if old in synonym_map and new in synonym_map[old]:\n        text = replace_word(text, old, new)\n        print(f\"Replaced '{old}' with '{new}'\")\n    else:\n        print(f\"Warning: '{new}' not a valid synonym for '{old}'\")\n\nwrite_input(text)\nprint(\"\\nChecking compilation...\")\noverfull = check_overfull()\nif overfull:\n    print(f\"Still have {len(overfull)} overfull warnings:\")\n    for line in overfull:\n        print(line)\nelse:\n    print(\"No overfull hbox warnings!\")\nEOF\n"]
