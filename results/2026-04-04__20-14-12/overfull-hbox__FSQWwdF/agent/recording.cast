[98.9235, "o", "def parse_synonyms(filename):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.923734, "o", "    synonym_map = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.924605, "o", "    with open(filename, 'r') as f:\r\n\u001b[?2004l\r"]
[98.924698, "o", "\u001b[?2004h>         for line in f:\r\n\u001b[?2004l\r\u001b[?2004h>             line = line.strip()\r\n\u001b[?2004l\r"]
[98.924866, "o", "\u001b[?2004h> "]
[98.925599, "o", "            if not line:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.925829, "o", "                continue\r\n\u001b[?2004l\r"]
[98.926038, "o", "\u001b[?2004h> "]
[98.927175, "o", "            words = [w.strip() for w in line.split(',')]\r\n\u001b[?2004l\r"]
[98.927518, "o", "\u001b[?2004h> "]
[98.927992, "o", "            # Create mapping from each word to all its synonyms\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.928283, "o", "            for word in words:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.928865, "o", "                synonym_map[word] = words\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.928992, "o", "    return synonym_map\r\n\u001b[?2004l\r"]
[98.929103, "o", "\u001b[?2004h> \r\n"]
[98.929498, "o", "\u001b[?2004l\r\u001b[?2004h> # Read input.tex\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.929938, "o", "def read_input():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.930237, "o", "    with open('input.tex', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.930588, "o", "        return f.read()\r\n\u001b[?2004l\r\u001b[?2004h"]
[98.930846, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> # Write input.tex\r\n\u001b[?2004l\r"]
[98.931025, "o", "\u001b[?2004h> "]
[98.931314, "o", "def write_input(content):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.931847, "o", "    with open('input.tex', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.932332, "o", "        f.write(content)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Compile and check for overfull hbox\r\n\u001b[?2004l\r"]
[98.932645, "o", "\u001b[?2004h> def check_overfull():\r\n\u001b[?2004l\r"]
[98.932893, "o", "\u001b[?2004h> "]
[98.933589, "o", "    result = subprocess.run(['pdflatex', '-interaction=nonstopmode', 'main.tex'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.934052, "o", "                          capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h"]
[98.934152, "o", "> "]
[98.934455, "o", "    output = result.stdout + result.stderr\r\n\u001b[?2004l\r"]
[98.934772, "o", "\u001b[?2004h> "]
[98.935084, "o", "    overfull_lines = [line for line in output.split('\\n') if 'Overfull' in line]\r\n\u001b[?2004l\r\u001b[?2004h"]
[98.935386, "o", "> "]
[98.935832, "o", "    return overfull_lines\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.93653, "o", "# Replace a word with a shorter synonym\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.937009, "o", "def replace_word(text, old_word, new_word):\r\n\u001b[?2004l\r\u001b[?2004h"]
[98.937142, "o", "> "]
[98.93793, "o", "    # Use word boundaries to avoid partial replacements\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.938673, "o", "    pattern = r'\\b' + re.escape(old_word) + r'\\b'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.939429, "o", "    return re.sub(pattern, new_word, text)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[98.939705, "o", "\u001b[?2004h> "]
[98.940068, "o", "synonym_map = parse_synonyms('synonyms.txt')\r\n\u001b[?2004l\r"]
[98.940558, "o", "\u001b[?2004h> original_text = read_input()\r\n"]
[98.940834, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[98.941244, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.941479, "o", "# Strategy: Replace specific problematic words with shorter synonyms\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.941775, "o", "replacements = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.942397, "o", "    # Line 5-6 issues\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.942728, "o", "    ('curious', 'odd'),  # curious (7 chars) -> odd (3 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.943432, "o", "    ('natures', 'traits'),  # natures (7 chars) -> traits (6 chars) \r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.944076, "o", "    ('confidences', 'secrets'),  # confidences (11 chars) -> secrets (7 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.944828, "o", "    ('unsought', 'unwanted'),  # unsought (8 chars) -> unwanted (8 chars) - same, try another\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.945116, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[98.945444, "o", ">     # Line 7-8 issues\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.946159, "o", "    ('riotous', 'wild'),  # riotous (7 chars) -> wild (4 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.946845, "o", "    ('excursions', 'trips'),  # excursions (10 chars) -> trips (5 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.947531, "o", "    ('responsiveness', 'awareness'),  # responsiveness (15 chars) -> awareness (9 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.948051, "o", "    ('temperament', 'nature'),  # temperament (11 chars) -> nature (6 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.948419, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.948656, "o", "    # Line 13-14 issue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.949232, "o", "    ('wisdom', 'insight'),  # wisdom (6 chars) -> insight (7 chars) - longer, try knowledge\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.949645, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.950008, "o", "    # Line 19 issue  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.950429, "o", "    ('pathfinder', 'pioneer'),  # pathfinder (10 chars) -> pioneer (7 chars)\r\n\u001b[?2004l\r\u001b[?2004h> ]"]
[98.950557, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[98.950937, "o", "> text = original_text\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[98.951172, "o", "\u001b[?2004h> "]
[98.951467, "o", "print(\"Attempting replacements...\")\r\n\u001b[?2004l\r"]
[98.951818, "o", "\u001b[?2004h> "]
[98.952168, "o", "for old, new in replacements:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.952369, "o", "    if old in synonym_map and new in synonym_map[old]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.952812, "o", "        text = replace_word(text, old, new)\r\n\u001b[?2004l\r\u001b[?2004h"]
[98.953012, "o", "> "]
[98.953368, "o", "        print(f\"Replaced '{old}' with '{new}'\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.953707, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.954389, "o", "        print(f\"Warning: '{new}' not a valid synonym for '{old}'\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.954665, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.955072, "o", "write_input(text)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.955293, "o", "print(\"\\nChecking compilation...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.955724, "o", "overfull = check_overfull()\r\n\u001b[?2004l\r\u001b[?2004h> if overfull:\r\n\u001b[?2004l\r\u001b[?2004h"]
[98.956052, "o", "> "]
[98.956398, "o", "    print(f\"Still have {len(overfull)} overfull warnings:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[98.956641, "o", "> "]
[98.956958, "o", "    for line in overfull:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.957295, "o", "        print(line)\r\n\u001b[?2004l\r\u001b[?2004h> else:\r\n\u001b[?2004l\r"]
[98.957574, "o", "\u001b[?2004h> "]
[98.958045, "o", "    print(\"No overfull hbox warnings!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[98.958278, "o", "EOF\r\n\u001b[?2004l\r"]
[98.961627, "o", "\u001b[?2004hroot@b419d4b4dbd9:/app# "]
[103.806897, "i", "python3 fix_overfull.py; printf '%s\\n' '__CMDEND__5__'\n"]
[103.807513, "o", "python3 fix_overfull.py; printf '%s\\n' '__CMDEND__5__'\r\n\u001b[?2004l\r"]
[103.843651, "o", "Attempting replacements...\r\n"]
[103.843844, "o", "Replaced 'curious' with 'odd'\r\nWarning: 'traits' not a valid synonym for 'natures'\r\nWarning: 'secrets' not a valid synonym for 'confidences'\r\n"]
[103.844076, "o", "Replaced 'unsought' with 'unwanted'\r\n"]
[103.844603, "o", "Replaced 'riotous' with 'wild'\r\n"]
[103.844803, "o", "Replaced 'excursions' with 'trips'\r\nReplaced 'responsiveness' with 'awareness'\r\n"]
[103.845048, "o", "Replaced 'temperament' with 'nature'\r\n"]
[103.845279, "o", "Replaced 'wisdom' with 'insight'\r\n"]
[103.845417, "o", "Replaced 'pathfinder' with 'pioneer'\r\n"]
[103.845634, "o", "\r\nChecking compilation...\r\n"]
[104.030741, "o", "Still have 3 overfull warnings:\r\nOverfull \\hbox (20.20493pt too wide) in paragraph at lines 5--6\r\nOverfull \\hbox (25.24203pt too wide) in paragraph at lines 7--8\r\nOverfull \\hbox (0.46426pt too wide) in paragraph at lines 13--14\r\n"]
[104.038125, "o", "__CMDEND__5__\r\n\u001b[?2004hroot@b419d4b4dbd9:/app# "]
