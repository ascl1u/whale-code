[396.334304, "o", "# Key replacements to fix overfull warnings\r\n\u001b[?2004l\r"]
[396.334543, "o", "\u001b[?2004h> "]
[396.33484, "o", "replacements = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.335397, "o", "    # Fix the biggest issue: \"creative temperament\" (54.68pt overfull)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.336146, "o", "    ('temperament', 'mood'),  # temperament (11) -> mood (4), saves 7 chars\r\n\u001b[?2004l\r\u001b[?2004h>     "]
[396.336243, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.33651, "o", "    # Fix other issues\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.337179, "o", "    ('curious', 'odd'),  # curious (7) -> odd (3), saves 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.337609, "o", "    ('riotous', 'wild'),  # riotous (7) -> wild (4), saves 3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.338832, "o", "    ('excursions', 'trips'),  # excursions (10) -> trips (5), saves 5\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.339568, "o", "    ('responsiveness', 'awareness'),  # responsiveness (14) -> awareness (9), saves 5\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.340073, "o", "    ('pathfinder', 'pioneer'),  # pathfinder (10) -> pioneer (7), saves 3\r\n\u001b[?2004l\r"]
[396.340552, "o", "\u001b[?2004h> "]
[396.340864, "o", "    ('wisdom', 'insight'),  # wisdom (6) -> insight (7), +1 but might help with hyphenation\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.341197, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.341389, "o", "    # Additional replacements to help\r\n"]
[396.341676, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[396.342666, "o", "    ('talent', 'gift'),  # Reverse my earlier change: talent (6) -> gift (4), saves 2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.343247, "o", "    ('dreamy', 'loving'),  # dreamy (6) -> loving (6), same but different hyphenation"]
[396.343548, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> ]\r\n\u001b[?2004l\r"]
[396.344132, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.34456, "o", "print(\"Applying targeted fixes...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.345018, "o", "for old, new in replacements:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.345399, "o", "    if old in synonym_map and new in synonym_map[old]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.345678, "o", "        old_text = text\r\n\u001b[?2004l\r"]
[396.345995, "o", "\u001b[?2004h> "]
[396.346139, "o", "        text = replace_word(text, old, new)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.346447, "o", "        if text != old_text:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.346804, "o", "            print(f\"  {old} -> {new}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.347202, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.347407, "o", "with open('input.tex', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.347633, "o", "    f.write(text)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.347916, "o", "print(\"\\nChecking compilation...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.348159, "o", "> overfull = check_overfull()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.348442, "o", "if overfull:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.34893, "o", "    print(f\"\\nStill have {len(overfull)} overfull warnings:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.349303, "o", "    for line in overfull:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.349617, "o", "        print(line)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.350001, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.350222, "o", "    print(\"\\n✓ SUCCESS! No overfull hbox warnings!\")\r\n\u001b[?2004l\r"]
[396.350474, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
