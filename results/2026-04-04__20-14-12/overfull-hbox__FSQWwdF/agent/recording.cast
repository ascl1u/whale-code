[396.331051, "o", "    result = subprocess.run(['pdflatex', '-interaction=nonstopmode', 'main.tex'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.331417, "o", "                          capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.331664, "o", "> "]
[396.332044, "o", "    output = result.stdout + result.stderr\r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.332595, "o", "    overfull_lines = [line for line in output.split('\\n') if 'Overfull' in line]\r\n\u001b[?2004l\r\u001b[?2004h>     return overfull_lines\r\n\u001b[?2004l\r\u001b[?2004h"]
[396.33285, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[396.333219, "o", "synonym_map = parse_synonyms('synonyms.txt')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
