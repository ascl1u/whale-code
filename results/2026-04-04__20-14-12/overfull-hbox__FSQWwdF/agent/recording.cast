[279.372405, "i", "cat > restore_original.py << 'EOF'\n# Restore original words that were changed\nimport re\n\ndef replace_word(text, old_word, new_word):\n    pattern = r'\\b' + re.escape(old_word) + r'\\b'\n    return re.sub(pattern, new_word, text)\n\nwith open('input.tex', 'r') as f:\n    text = f.read()\n\n# Reverse the changes made by the first script\nreversals = [\n    ('odd', 'curious'),\n    ('unwanted', 'unsought'),\n    ('wild', 'riotous'),\n    ('trips', 'excursions'),\n    ('awareness', 'responsiveness'),\n    ('nature', 'temperament'),\n    ('insight', 'wisdom'),\n    ('pioneer', 'pathfinder'),\n]\n\nfor old, new in reversals:\n    text = replace_word(text, old, new)\n\nwith open('input.tex', 'w') as f:\n    f.write(text)\n\nprint(\"Restored original input.tex\")\nEOF\npython3 restore_original.py\n"]
