[308.04316, "i", "cat > fix_overfull_v3.py << 'EOF'\nimport re\nimport subprocess\n\ndef parse_synonyms(filename):\n    synonym_map = {}\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            words = [w.strip() for w in line.split(',')]\n            for word in words:\n                synonym_map[word] = words\n    return synonym_map\n\ndef read_file(filename):\n    with open(filename, 'r') as f:\n        return f.read()\n\ndef write_file(filename, content):\n    with open(filename, 'w') as f:\n        f.write(content)\n\ndef check_overfull():\n    result = subprocess.run(['pdflatex', '-interaction=nonstopmode', 'main.tex'],\n                          capture_output=True, text=True)\n    output = result.stdout + result.stderr\n    overfull_lines = [line for line in output.split('\\n') if 'Overfull' in line]\n    return overfull_lines\n\ndef replace_word(text, old_word, new_word):\n    pattern = r'\\b' + re.escape(old_word) + r'\\b'\n    return re.sub(pattern, new_word, text)\n\nsynonym_map = parse_synonyms('synonyms.txt')\ntext = read_file('input.tex')\n\n# Only use replacements that make words SHORTER\nreplacements = [\n    # Biggest savings first\n    ('extraordinary', 'amazing'),  # 13 -> 7, saves 6\n    ('responsiveness', 'awareness'),  # 15 -> 9, saves 6  \n    ('plagiaristic', 'copied'),  # 12 -> 6, saves 6\n    ('temperament', 'nature'),  # 11 -> 6, saves 5\n    ('excursions', 'trips'),  # 10 -> 5, saves 5\n    ('pathfinder', 'pioneer'),  # 10 -> 7, saves 3\n    ('practical', 'useful'),  # 9 -> 6, saves 3\n    ('readiness', 'zeal'),  # Check if zeal is valid\n    ('intimate', 'close'),  # 8 -> 5, saves 3\n    ('curious', 'odd'),  # 7 -> 3, saves 4\n    ('veteran', 'old'),  # 7 -> 3, saves 4\n    ('riotous', 'wild'),  # 7 -> 4, saves 3\n    ('infinite', 'endless'),  # 8 -> 7, saves 1\n    ('original', 'initial'),  # 8 -> 7, saves 1\n    ('quality', 'trait'),  # 7 -> 5, saves 2\n    ('natures', 'traits'),  # 7 -> 6, saves 1\n    ('victim', 'prey'),  # 6 -> 4, saves 2\n    ('romantic', 'dreamy'),  # 8 -> 6, saves 2\n    ('habit', 'custom'),  # 5 -> 6, WORSE - skip\n]\n\nprint(\"Applying strategic replacements (shorter words only)...\")\nfor item in replacements:\n    if len(item) == 2:\n        old, new = item\n        if old in synonym_map and new in synonym_map[old]:\n            if len(new) < len(old):  # Only if shorter\n                old_text = text\n                text = replace_word(text, old, new)\n                if text != old_text:\n                    print(f\"  {old} ({len(old)}) -> {new} ({len(new)}), saves {len(old)-len(new)}\")\n\nwrite_file('input.tex', text)\nprint(\"\\nChecking compilation...\")\noverfull = check_overfull()\nif overfull:\n    print(f\"\\nStill have {len(overfull)} overfull warnings:\")\n    for line in overfull:\n        print(line)\nelse:\n    print(\"\\n✓ SUCCESS! No overfull hbox warnings!\")\nEOF\n"]
