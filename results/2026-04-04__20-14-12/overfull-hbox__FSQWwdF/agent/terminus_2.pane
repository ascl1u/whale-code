[?2004l[?2004h> import re
[?2004l[?2004h> import subprocess
[?2004l[?2004h> import os
[?2004l[?2004h> 
[?2004l[?2004h> # Parse synonyms.txt
[?2004l[?2004h> def parse_synonyms(filename):
[?2004l[?2004h>     synonym_map = {}
[?2004l[?2004h>     with open(filename, 'r') as f:
[?2004l[?2004h>         for line in f:
[?2004l[?2004h>             line = line.strip()
[?2004l[?2004h>             if not line:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             words = [w.strip() for w in line.split(',')]
[?2004l[?2004h>             # Create mapping from each word to all its synonyms
[?2004l[?2004h>             for word in words:
[?2004l[?2004h>                 synonym_map[word] = words
[?2004l[?2004h>     return synonym_map
[?2004l[?2004h> 
[?2004l[?2004h> # Read input.tex
[?2004l[?2004h> def read_input():
[?2004l[?2004h>     with open('input.tex', 'r') as f:
[?2004l[?2004h>         return f.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Write input.tex
[?2004l[?2004h> def write_input(content):
[?2004l[?2004h>     with open('input.tex', 'w') as f:
[?2004l[?2004h>         f.write(content)
[?2004l[?2004h> 
[?2004l[?2004h> # Compile and check for overfull hbox
[?2004l[?2004h> def check_overfull():
[?2004l[?2004h>     result = subprocess.run(['pdflatex', '-interaction=nonstopmode', 'main.tex'],
[?2004l[?2004h>                           capture_output=True, text=True)
[?2004l[?2004h>     output = result.stdout + result.stderr
[?2004l[?2004h>     overfull_lines = [line for line in output.split('\n') if 'Overfull' in line]
[?2004l[?2004h>     return overfull_lines
[?2004l[?2004h> 
[?2004l[?2004h> # Replace a word with a shorter synonym
[?2004l[?2004h> def replace_word(text, old_word, new_word):
[?2004l[?2004h>     # Use word boundaries to avoid partial replacements
[?2004l[?2004h>     pattern = r'\b' + re.escape(old_word) + r'\b'
[?2004l[?2004h>     return re.sub(pattern, new_word, text)
[?2004l[?2004h> 
[?2004l[?2004h> synonym_map = parse_synonyms('synonyms.txt')
[?2004l[?2004h> original_text = read_input()
[?2004l[?2004h> 
[?2004l[?2004h> # Strategy: Replace specific problematic words with shorter synonyms
[?2004l[?2004h> replacements = [
[?2004l[?2004h>     # Line 5-6 issues
[?2004l[?2004h>     ('curious', 'odd'),  # curious (7 chars) -> odd (3 chars)
[?2004l[?2004h>     ('natures', 'traits'),  # natures (7 chars) -> traits (6 chars) 
[?2004l[?2004h>     ('confidences', 'secrets'),  # confidences (11 chars) -> secrets (7 chars)
[?2004l[?2004h>     ('unsought', 'unwanted'),  # unsought (8 chars) -> unwanted (8 chars) - same, try another
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 7-8 issues
[?2004l[?2004h>     ('riotous', 'wild'),  # riotous (7 chars) -> wild (4 chars)
[?2004l[?2004h>     ('excursions', 'trips'),  # excursions (10 chars) -> trips (5 chars)
[?2004l[?2004h>     ('responsiveness', 'awareness'),  # responsiveness (15 chars) -> awareness (9 chars)
[?2004l[?2004h>     ('temperament', 'nature'),  # temperament (11 chars) -> nature (6 chars)
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 13-14 issue
[?2004l[?2004h>     ('wisdom', 'insight'),  # wisdom (6 chars) -> insight (7 chars) - longer, try knowledge
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 19 issue  
[?2004l[?2004h>     ('pathfinder', 'pioneer'),  # pathfinder (10 chars) -> pioneer (7 chars)
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> text = original_text
[?2004l[?2004h> 
[?2004l[?2004h> print("Attempting replacements...")
[?2004l[?2004h> for old, new in replacements:
[?2004l[?2004h>     if old in synonym_map and new in synonym_map[old]:
[?2004l[?2004h>         text = replace_word(text, old, new)
[?2004l[?2004h>         print(f"Replaced '{old}' with '{new}'")
[?2004l[?2004h>     else:
[?2004l[?2004h>         print(f"Warning: '{new}' not a valid synonym for '{old}'")
[?2004l[?2004h> 
[?2004l[?2004h> write_input(text)
[?2004l[?2004h> print("\nChecking compilation...")
