[100.908633, "i", "cat > fix_overfull.py << 'EOF'\nimport re\n\n# Read synonyms\nsynonyms = {}\nwith open('synonyms.txt', 'r') as f:\n    for line in f:\n        words = [w.strip() for w in line.strip().split(',')]\n        for word in words:\n            synonyms[word.lower()] = [w for w in words]\n\n# Read input.tex\nwith open('input.tex', 'r') as f:\n    content = f.read()\n\n# Target replacements to fix overfull hbox issues\n# Replace longer words with shorter synonyms\nreplacements = [\n    ('curious', 'odd'),  # Line 5: curious (7 chars) -> odd (3 chars)\n    ('confidences', 'secrets'),  # Not in synonyms, skip\n    ('unsought', 'unwanted'),  # Line 5: unsought (8 chars) -> unwanted (8 chars) - same length, try uninvited\n    ('riotous', 'wild'),  # Line 7: riotous (7 chars) -> wild (4 chars)\n    ('excursions', 'trips'),  # Line 7: excursions (10 chars) -> trips (5 chars)\n    ('responsiveness', 'awareness'),  # Line 7: responsiveness (14 chars) -> awareness (9 chars)\n    ('creative', 'artistic'),  # Line 7: creative (8 chars) -> artistic (8 chars) - try inventive\n    ('temperament', 'nature'),  # Line 7: temperament (11 chars) -> nature (6 chars)\n    ('wisdom', 'insight'),  # Line 13: wisdom (6 chars) -> insight (7 chars) - longer! Try knowledge\n    ('pathfinder', 'pioneer'),  # Line 19: pathfinder (10 chars) -> pioneer (7 chars)\n]\n\nprint(\"Checking which words can be replaced:\")\nfor old, new in replacements:\n    if old.lower() in synonyms:\n        print(f\"{old} -> {new}: {new in [w.lower() for w in synonyms[old.lower()]]}\")\n    else:\n        print(f\"{old} not in synonyms\")\n\nEOF\n"]
[100.909439, "o", "cat > fix_overfull.py << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
