[328.836103, "o", "Shortest synonyms for key words:\r\ncurious (7) -> odd (3)\r\nunsought (8) -> unsought (8)\r\nveteran (7) -> dated (5)\r\nabnormal (8) -> unusual (7)\r\ncollege (7) -> school (6)\r\n"]
[328.836224, "o", "unknown (7) -> unknown (7)\r\nhostile (7) -> hostile (7)\r\nintimate (8) -> close (5)\r\nplagiaristic (12) -> copied (6)\r\nsuppressions (12) -> censorings (10)\r\ninfinite (8) -> endless (7)\r\nfundamental (11) -> basic (5)\r\ndecencies (9) -> manners (7)\r\n"]
[328.836582, "o", "admission (9) -> admission (9)\r\nConduct (7) -> conduct (7)\r\nmarshes (7) -> bogs (4)\r\nattention (9) -> focus (5)\r\nforever (7) -> always (6)\r\nbook (4) -> book (4)\r\nscorn (5) -> scorn (5)\r\nseries (6) -> set (3)\r\nsuccessful (10) -> winning (7)\r\ngorgeous (8) -> lovely (6)\r\nheightened (10) -> enhanced (8)\r\npromises (8) -> vows (4)\r\nintricate (9) -> complex (7)\r\nmachines (8) -> devices (7)\r\ncreative (8) -> creative (8)\r\ntemperament (11) -> mood (4)\r\n"]
[328.836766, "o", "extraordinary (13) -> amazing (7)\r\ngift (4) -> gift (4)\r\nromantic (8) -> dreamy (6)\r\nreadiness (9) -> readiness (9)\r\nfoul (4) -> foul (4)\r\ndust (4) -> dust (4)\r\ndreams (6) -> hopes (5)\r\nabortive (8) -> failed (6)\r\nelations (8) -> joys (4)\r\nresponsiveness (14) -> reaction (8)\r\nriotous (7) -> wild (4)\r\nexcursions (10) -> trips (5)\r\npathfinder (10) -> scout (5)\r\n"]
[328.83701, "o", "practical (9) -> useful (6)\r\nrooms (5) -> rooms (5)\r\ncountry (7) -> land (4)\r\nwide (4) -> wide (4)\r\nfriendly (8) -> kind (4)\r\nyoung (5) -> new (3)\r\noffice (6) -> study (5)\r\nhouse (5) -> home (4)\r\ntown (4) -> town (4)\r\nidea (4) -> idea (4)\r\nweatherbeaten (13) -> worn (4)\r\nfirm (4) -> firm (4)\r\nold (3) -> old (3)\r\nelectric (8) -> powered (7)\r\nwisdom (6) -> wisdom (6)\r\n"]
[328.842375, "o", "__CMDEND__9__\r\n"]
