[100.916604, "o", "    ('unsought', 'unwanted'),  # Line 5: unsought (8 chars) -> unwanted (8 chars) - same length, try uninvited\r\n\u001b[?2004l\r"]
[100.916855, "o", "\u001b[?2004h> "]
[100.917159, "o", "    ('riotous', 'wild'),  # Line 7: riotous (7 chars) -> wild (4 chars)\r\n\u001b[?2004l\r\u001b[?2004h"]
[100.917289, "o", "> "]
[100.918039, "o", "    ('excursions', 'trips'),  # Line 7: excursions (10 chars) -> trips (5 chars)\r\n\u001b[?2004l\r"]
[100.91817, "o", "\u001b[?2004h> "]
[100.919079, "o", "    ('responsiveness', 'awareness'),  # Line 7: responsiveness (14 chars) -> awareness (9 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[100.919944, "o", "    ('creative', 'artistic'),  # Line 7: creative (8 chars) -> artistic (8 chars) - try inventive\r\n\u001b[?2004l\r\u001b[?2004h> "]
[100.920624, "o", "    ('temperament', 'nature'),  # Line 7: temperament (11 chars) -> nature (6 chars)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[100.92136, "o", "    ('wisdom', 'insight'),  # Line 13: wisdom (6 chars) -> insight (7 chars) - longer! Try knowledge\r\n\u001b[?2004l\r\u001b[?2004h> "]
