[?2004l__CMDEND__8__
[?2004hroot@bc17e3cbd220:/app# cat > smart_fix.py << 'EOF'
[?2004l[?2004h> import re
[?2004l[?2004h> import subprocess
[?2004l[?2004h> 
[?2004l[?2004h> # Read synonyms and find shortest option for each word
[?2004l[?2004h> synonym_map = {}
[?2004l[?2004h> with open('synonyms.txt', 'r') as f:
[?2004l[?2004h>     for line in f:
[?2004l[?2004h>         words = [w.strip() for w in line.strip().split(',')]
[?2004l[?2004h>         # For each word, map it to the shortest synonym in its family
[?2004l[?2004h>         shortest = min(words, key=len)
[?2004l[?2004h>         for word in words:
[?2004l[?2004h>             synonym_map[word.lower()] = shortest.lower()
[?2004l[?2004h> 
[?2004l[?2004h> print("Shortest synonyms for key words:")
[?2004l[?2004h> key_words = ['curious', 'unsought', 'veteran', 'abnormal', 'college', 'unknown', 
[?2004l[?2004h>              'hostile', 'intimate', 'plagiaristic', 'suppressions', 'infinite',
[?2004l[?2004h>              'fundamental', 'decencies', 'admission', 'Conduct', 'marshes', 
[?2004l[?2004h>              'attention', 'forever', 'book', 'scorn', 'series', 'successful',
[?2004l[?2004h>              'gorgeous', 'heightened', 'promises', 'intricate', 'machines',
[?2004l[?2004h>              'creative', 'temperament', 'extraordinary', 'gift', 'romantic',
[?2004l[?2004h>              'readiness', 'foul', 'dust', 'dreams', 'abortive', 'elations',
[?2004l[?2004h>              'responsiveness', 'riotous', 'excursions', 'pathfinder',
[?2004l[?2004h>              'practical', 'rooms', 'country', 'wide', 'friendly', 'young',
[?2004l[?2004h>              'office', 'house', 'town', 'idea', 'weatherbeaten', 'firm',
[?2004l[?2004h>              'old', 'electric', 'wisdom']
[?2004l[?2004h> 
[?2004l[?2004h> for word in key_words:
[?2004l[?2004h>     if word.lower() in synonym_map:
[?2004l[?2004h>         print(f"{word} ({len(word)}) -> {synonym_map[word.lower()]} ({len(synonym_map[word.lower()])})")
[?2004l[?2004h> 
