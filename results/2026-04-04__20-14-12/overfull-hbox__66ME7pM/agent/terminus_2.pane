[?2004l[?2004h> 
[?2004l[?2004h> # Apply replacements - use word boundaries to avoid partial matches
[?2004l[?2004h> # Prioritize the biggest issues first
[?2004l[?2004h> replacements = [
[?2004l[?2004h>     # Line 7-8: biggest issue (54.68pt) - "creative temperament"
[?2004l[?2004h>     (r'\bcreative\b', 'artistic'),  # creative (8) -> artistic (8) same, but try inventive
[?2004l[?2004h>     (r'\btemperament\b', 'nature'),  # temperament (11) -> nature (6) saves 5 chars
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 5-6: "unsought" issue (18.03pt)
[?2004l[?2004h>     (r'\bunsought\b', 'unwanted'),  # unsought (8) -> unwanted (8) same length
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 19: "pathfinder" issue (8.45pt)
[?2004l[?2004h>     (r'\bpathfinder\b', 'pioneer'),  # pathfinder (10) -> pioneer (7) saves 3 chars
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 13-14: "wisdom" issue (6.07pt)
[?2004l[?2004h>     (r'\bwisdom\b', 'insight'),  # wisdom (6) -> insight (7) adds 1 char - bad!
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 7-8: "responsiveness" issue (3.24pt)
[?2004l[?2004h>     (r'\bresponsiveness\b', 'awareness'),  # responsiveness (14) -> awareness (9) saves 5 chars
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 7-8: "riotous excursions" issue (1.90pt)
[?2004l[?2004h>     (r'\briotous\b', 'wild'),  # riotous (7) -> wild (4) saves 3 chars
[?2004l[?2004h>     (r'\bexcursions\b', 'trips'),  # excursions (10) -> trips (5) saves 5 chars
[?2004l[?2004h>     
[?2004l[?2004h>     # Line 5-6: "curious" issue (0.10pt)
[?2004l[?2004h>     (r'\bcurious\b', 'odd'),  # curious (7) -> odd (3) saves 4 chars
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> for pattern, replacement in replacements:
[?2004l[?2004h>     content = re.sub(pattern, replacement, content)
[?2004l[?2004h> 
[?2004l[?2004h> # Write the modified content
[?2004l[?2004h> with open('input.tex', 'w') as f:
[?2004l[?2004h>     f.write(content)
