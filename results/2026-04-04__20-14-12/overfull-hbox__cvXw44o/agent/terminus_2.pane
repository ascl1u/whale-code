[?2004l[?2004h> import re
[?2004l[?2004h> 
[?2004l[?2004h> # Read synonyms
[?2004l[?2004h> synonyms = {}
[?2004l[?2004h> with open('synonyms.txt', 'r') as f:
[?2004l[?2004h>     for line in f:
[?2004l[?2004h>         line = line.strip()
[?2004l[?2004h>         if line:
[?2004l[?2004h>             words = [w.strip() for w in line.split(',')]
[?2004l[?2004h>             # Store all synonyms for each word in the group
[?2004l[?2004h>             for word in words:
[?2004l[?2004h>                 synonyms[word] = words
[?2004l[?2004h> 
[?2004l[?2004h> # Read input.tex
[?2004l[?2004h> with open('input.tex', 'r') as f:
[?2004l[?2004h>     content = f.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Function to find shorter synonym
[?2004l[?2004h> def find_shorter_synonym(word):
[?2004l[?2004h>     if word in synonyms:
[?2004l[?2004h>         candidates = synonyms[word]
[?2004l[?2004h>         # Find shortest synonym
[?2004l[?2004h>         shortest = min(candidates, key=len)
[?2004l[?2004h>         if len(shortest) < len(word):
[?2004l[?2004h>             return shortest
[?2004l[?2004h>     return word
[?2004l[?2004h> 
[?2004l[?2004h> # Make a backup
[?2004l[?2004h> with open('input.tex.bak', 'w') as f:
[?2004l[?2004h>     f.write(content)
[?2004l[?2004h> 
[?2004l[?2004h> # Strategy: Replace specific words that appear in overfull lines with shorter synonyms
[?2004l[?2004h> replacements = [
[?2004l[?2004h>     ('curious', 'curious'),  # Check for shorter
[?2004l[?2004h>     ('natures', 'natures'),  # Check for shorter
[?2004l[?2004h>     ('unsought', 'unsought'),  # Check for shorter
[?2004l[?2004h>     ('riotous', 'riotous'),  # Check for shorter
[?2004l[?2004h>     ('excursions', 'excursions'),  # Check for shorter
[?2004l[?2004h>     ('responsiveness', 'responsiveness'),  # Check for shorter
[?2004l[?2004h>     ('temperament', 'temperament'),  # Check for shorter
[?2004l[?2004h>     ('wisdom', 'wisdom'),  # Check for shorter
[?2004l[?2004h>     ('pathfinder', 'pathfinder'),  # Check for shorter
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> print("Available synonyms for problematic words:")
[?2004l[?2004h> for word, _ in replacements:
[?2004l[?2004h>     if word in synonyms:
[?2004l[?2004h>         print(f"{word}: {synonyms[word]}")
[?2004l[?2004h>         print(f"  Shortest: {min(synonyms[word], key=len)} (len={len(min(synonyms[word], key=len))})")
[?2004l[?2004h> 
