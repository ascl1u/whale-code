[?2004l[?2004h>             words = [w.strip() for w in line.split(',')]
[?2004l[?2004h>             synonym_groups.append(set(words))
[?2004l[?2004h> 
[?2004l[?2004h> # Check if two words are synonyms
[?2004l[?2004h> def are_synonyms(word1, word2):
[?2004l[?2004h>     for group in synonym_groups:
[?2004l[?2004h>         if word1.lower() in group and word2.lower() in group:
[?2004l[?2004h>             return True
[?2004l[?2004h>     return False
