[?2004l[?2004h> import re
[?2004l[?2004h> 
[?2004l[?2004h> # Read input.tex
[?2004l[?2004h> with open('input.tex', 'r') as f:
[?2004l[?2004h>     content = f.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Apply replacements using word boundaries to avoid partial matches
[?2004l[?2004h> replacements = [
[?2004l[?2004h>     (r'\bcurious\b', 'odd'),
[?2004l[?2004h>     (r'\briotous\b', 'wild'),
[?2004l[?2004h>     (r'\bexcursions\b', 'trips'),
[?2004l[?2004h>     (r'\bresponsiveness\b', 'reaction'),
[?2004l[?2004h>     (r'\btemperament\b', 'mood'),
[?2004l[?2004h>     (r'\bpathfinder\b', 'scout'),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> for pattern, replacement in replacements:
[?2004l[?2004h>     content = re.sub(pattern, replacement, content)
[?2004l[?2004h> 
[?2004l[?2004h> # Write updated content
[?2004l[?2004h> with open('input.tex', 'w') as f:
[?2004l[?2004h>     f.write(content)
