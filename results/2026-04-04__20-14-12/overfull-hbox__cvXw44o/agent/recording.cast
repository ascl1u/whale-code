[182.772311, "o", "All words in line 5 that can be shortened:\r\nabnormal (8) -> unusual (7) saves 1\r\ncollege (7) -> school (6) saves 1\r\ndecencies (9) -> manners (7) saves 2\r\n"]
[182.772694, "o", "infinite (8) -> endless (7) saves 1\r\njudgments (9) -> opinions (8) saves 1\r\nlevity (6) -> jest (4) saves 2\r\nobvious (7) -> clear (5) saves 2\r\nquality (7) -> trait (5) saves 2\r\nquick (5) -> fast (4) saves 1\r\nrevelation (10) -> exposure (8) saves 2\r\nrevelations (11) -> exposures (9) saves 2\r\nsleep (5) -> rest (4) saves 1\r\nsuppressions (12) -> censorings (10) saves 2\r\n"]
[182.773015, "o", "veteran (7) -> dated (5) saves 2\r\nvictim (6) -> prey (4) saves 2\r\nyoung (5) -> new (3) saves 2\r\n"]
