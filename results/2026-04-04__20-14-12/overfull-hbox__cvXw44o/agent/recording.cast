[182.735203, "i", "cat > check_all_line5.py << 'EOF'\nimport re\n\n# Read synonyms\nsynonyms = {}\nwith open('synonyms.txt', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line:\n            words = [w.strip() for w in line.split(',')]\n            for word in words:\n                synonyms[word] = words\n\n# Read input.tex and get line 5\nwith open('input.tex', 'r') as f:\n    lines = f.readlines()\n\nline5 = lines[4]\nwords_in_line = re.findall(r'\\b[a-zA-Z]+\\b', line5)\n\nprint(\"All words in line 5 that can be shortened:\")\nfor word in sorted(set(words_in_line)):\n    if word.lower() in synonyms:\n        syns = synonyms[word.lower()]\n        shortest = min(syns, key=len)\n        if len(shortest) < len(word):\n            print(f\"{word} ({len(word)}) -> {shortest} ({len(shortest)}) saves {len(word) - len(shortest)}\")\n\nEOF\npython3 check_all_line5.py\n"]
