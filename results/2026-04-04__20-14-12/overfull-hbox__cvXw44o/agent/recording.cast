[96.288482, "o", "import re\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[96.288989, "o", "> # Read synonyms\r\n\u001b[?2004l\r\u001b[?2004h> synonyms = {}\r\n\u001b[?2004l\r\u001b[?2004h"]
[96.289686, "o", "> with open('synonyms.txt', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     for line in f:\r\n\u001b[?2004l\r"]
[96.289873, "o", "\u001b[?2004h>         line = line.strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.289949, "o", "        if line:\r\n"]
[96.29024, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[96.290669, "o", "            words = [w.strip() for w in line.split(',')]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.291186, "o", "            # Store all synonyms for each word in the group\r\n\u001b[?2004l\r"]
[96.292306, "o", "\u001b[?2004h>             for word in words:\r\n\u001b[?2004l\r\u001b[?2004h>                 synonyms[word] = words\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Read input.tex\r\n\u001b[?2004l\r\u001b[?2004h> with open('input.tex', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[96.292602, "o", ">     content = f.read()\r\n\u001b[?2004l\r"]
[96.293035, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Function to find shorter synonym\r\n\u001b[?2004l\r\u001b[?2004h> def find_shorter_synonym(word):\r\n\u001b[?2004l\r"]
[96.293289, "o", "\u001b[?2004h> "]
[96.293593, "o", "    if word in synonyms:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.293785, "o", "        candidates = synonyms[word]\r\n\u001b[?2004l\r"]
[96.294168, "o", "\u001b[?2004h>         # Find shortest synonym\r\n\u001b[?2004l\r"]
[96.294538, "o", "\u001b[?2004h> "]
[96.294827, "o", "        shortest = min(candidates, key=len)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.295161, "o", "        if len(shortest) < len(word):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.295432, "o", "            return shortest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.295725, "o", "    return word\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[96.29602, "o", "> # Make a backup\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.296307, "o", "with open('input.tex.bak', 'w') as f:\r\n\u001b[?2004l\r"]
[96.296613, "o", "\u001b[?2004h> "]
[96.297008, "o", "    f.write(content)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[96.297439, "o", "\u001b[?2004h> "]
[96.29789, "o", "# Strategy: Replace specific words that appear in overfull lines with shorter synonyms\r\n\u001b[?2004l\r\u001b[?2004h> "]
[96.298199, "o", "replacements = [\r\n\u001b[?2004l\r"]
[96.298467, "o", "\u001b[?2004h> "]
