[246.545406, "i", "cat > apply_final_fixes.py << 'EOF'\nimport re\n\n# Read input.tex\nwith open('input.tex', 'r') as f:\n    content = f.read()\n\n# Apply final replacements using word boundaries\nreplacements = [\n    (r'\\bsuppressions\\b', 'censorings'),\n    (r'\\brevelations\\b', 'exposures'),\n    (r'\\brevelation\\b', 'exposure'),\n    (r'\\bjudgments\\b', 'opinions'),\n    (r'\\bdecencies\\b', 'manners'),\n    (r'\\babnormal\\b', 'unusual'),\n    (r'\\bobvious\\b', 'clear'),\n    (r'\\bquality\\b', 'trait'),\n    (r'\\bcollege\\b', 'school'),\n    (r'\\blevity\\b', 'jest'),\n    (r'\\bvictim\\b', 'prey'),\n    (r'\\byoung\\b', 'new'),\n    (r'\\bsleep\\b', 'rest'),\n    (r'\\bquick\\b', 'fast'),\n    (r'\\bveteran\\b', 'dated'),\n]\n\nfor pattern, replacement in replacements:\n    content = re.sub(pattern, replacement, content)\n\n# Write updated content\nwith open('input.tex', 'w') as f:\n    f.write(content)\n\nprint(\"Final replacements applied successfully\")\nEOF\npython3 apply_final_fixes.py\n"]
