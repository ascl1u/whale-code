[106.765315, "i", "cat > apply_fixes.py << 'EOF'\nimport re\n\n# Read input.tex\nwith open('input.tex', 'r') as f:\n    content = f.read()\n\n# Apply replacements using word boundaries to avoid partial matches\nreplacements = [\n    (r'\\bcurious\\b', 'odd'),\n    (r'\\briotous\\b', 'wild'),\n    (r'\\bexcursions\\b', 'trips'),\n    (r'\\bresponsiveness\\b', 'reaction'),\n    (r'\\btemperament\\b', 'mood'),\n    (r'\\bpathfinder\\b', 'scout'),\n]\n\nfor pattern, replacement in replacements:\n    content = re.sub(pattern, replacement, content)\n\n# Write updated content\nwith open('input.tex', 'w') as f:\n    f.write(content)\n\nprint(\"Replacements applied successfully\")\nEOF\npython3 apply_fixes.py\n"]
