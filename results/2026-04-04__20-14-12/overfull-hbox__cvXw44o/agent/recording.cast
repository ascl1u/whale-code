[147.495539, "i", "cat > find_replaceable.py << 'EOF'\nimport re\n\n# Read synonyms\nsynonyms = {}\nwith open('synonyms.txt', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line:\n            words = [w.strip() for w in line.split(',')]\n            for word in words:\n                synonyms[word] = words\n\n# Read input.tex\nwith open('input.tex', 'r') as f:\n    lines = f.readlines()\n\n# Check line 5 (index 4) for words with shorter synonyms\nprint(\"\\n=== Line 5 (problematic area with 'unsought') ===\")\nline5 = lines[4]\nwords_in_line = re.findall(r'\\b[a-zA-Z]+\\b', line5)\nfor word in set(words_in_line):\n    if word.lower() in synonyms:\n        syns = synonyms[word.lower()]\n        shortest = min(syns, key=len)\n        if len(shortest) < len(word):\n            print(f\"{word} -> {shortest} (saves {len(word) - len(shortest)} chars)\")\n\n# Check line 13 (index 12) for words with shorter synonyms  \nprint(\"\\n=== Line 13 (problematic area with 'wisdom') ===\")\nline13 = lines[12]\nwords_in_line = re.findall(r'\\b[a-zA-Z]+\\b', line13)\nfor word in set(words_in_line):\n    if word.lower() in synonyms:\n        syns = synonyms[word.lower()]\n        shortest = min(syns, key=len)\n        if len(shortest) < len(word):\n            print(f\"{word} -> {shortest} (saves {len(word) - len(shortest)} chars)\")\n\nEOF\npython3 find_replaceable.py\n"]
