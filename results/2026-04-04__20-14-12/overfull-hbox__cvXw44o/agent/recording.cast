[157.779701, "i", "cat > apply_more_fixes.py << 'EOF'\nimport re\n\n# Read input.tex\nwith open('input.tex', 'r') as f:\n    content = f.read()\n\n# Apply more replacements using word boundaries\nreplacements = [\n    (r'\\bcommunicative\\b', 'open'),\n    (r'\\bfundamental\\b', 'basic'),\n    (r'\\bplagiaristic\\b', 'copied'),\n    (r'\\bintimate\\b', 'close'),\n    (r'\\breserved\\b', 'quiet'),\n    (r'\\bweatherbeaten\\b', 'worn'),\n    (r'\\bfriendly\\b', 'kind'),\n    (r'\\bpractical\\b', 'useful'),\n    (r'\\bcountry\\b', 'land'),\n]\n\nfor pattern, replacement in replacements:\n    content = re.sub(pattern, replacement, content)\n\n# Write updated content\nwith open('input.tex', 'w') as f:\n    f.write(content)\n\nprint(\"Additional replacements applied successfully\")\nEOF\npython3 apply_more_fixes.py\n"]
