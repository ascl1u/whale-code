Sending keys: ['cat > final_fixes.py << \'EOF\'\nimport re\nimport subprocess\n\ndef parse_synonyms(filename):\n    synonym_map = {}\n    with open(filename, \'r\') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            words = [w.strip() for w in line.split(\',\')]\n            for word in words:\n                synonym_map[word] = words\n    return synonym_map\n\ndef replace_word(text, old_word, new_word):\n    pattern = r\'\\b\' + re.escape(old_word) + r\'\\b\'\n    return re.sub(pattern, new_word, text)\n\ndef check_overfull():\n    result = subprocess.run([\'pdflatex\', \'-interaction=nonstopmode\', \'main.tex\'],\n                          capture_output=True, text=True)\n    output = result.stdout + result.stderr\n    overfull_lines = [line for line in output.split(\'\\n\') if \'Overfull\' in line]\n    return overfull_lines\n\nsynonym_map = parse_synonyms(\'synonyms.txt\')\n\nwith open(\'input.tex\', \'r\') as f:\n    text = f.read()\n\n# Final set of replacements\nreplacements = [\n    (\'weatherbeaten\', \'worn\'),  # 13 -> 4, saves 9!\n    (\'successful\', \'winning\'),  # 10 -> 7, saves 3\n    (\'friendly\', \'kind\'),  # 8 -> 4, saves 4\n    (\'elations\', \'joys\'),  # 8 -> 4, saves 4\n    (\'abortive\', \'failed\'),  # 8 -> 6, saves 2\n    (\'forever\', \'always\'),  # 7 -> 6, saves 1\n]\n\nprint("Applying final fixes...")\nfor old, new in replacements:\n    if old in synonym_map and new in synonym_map[old]:\n        if len(new) <= len(old):\n            old_text = text\n            text = replace_word(text, old, new)\n            if text != old_text:\n                print(f"  {old} ({len(old)}) -> {new} ({len(new)}), saves {len(old)-len(new)}")\n\nwith open(\'input.tex\', \'w\') as f:\n    f.write(text)\n\nprint("\\nChecking compilation...")\noverfull = check_overfull()\nif overfull:\n    print(f"\\nStill have {len(overfull)} overfull warnings:")\n    for line in overfull:\n        print(line)\nelse:\n    print("\\n✓ SUCCESS! No overfull hbox warnings!")\nEOF\npython3 final_fixes.py\n'] min_timeout_sec: 3 max_timeout_sec: 180.0
