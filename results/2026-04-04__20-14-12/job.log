1\n    (\'original\', \'initial\'),  # 8 -> 7, saves 1\n    (\'quality\', \'trait\'),  # 7 -> 5, saves 2\n    (\'natures\', \'traits\'),  # 7 -> 6, saves 1\n    (\'victim\', \'prey\'),  # 6 -> 4, saves 2\n    (\'romantic\', \'dreamy\'),  # 8 -> 6, saves 2\n    (\'habit\', \'custom\'),  # 5 -> 6, WORSE - skip\n]\n\nprint("Applying strategic replacements (shorter words only)...")\nfor item in replacements:\n    if len(item) == 2:\n        old, new = item\n        if old in synonym_map and new in synonym_map[old]:\n            if len(new) < len(old):  # Only if shorter\n                old_text = text\n                text = replace_word(text, old, new)\n                if text != old_text:\n                    print(f"  {old} ({len(old)}) -> {new} ({len(new)}), saves {len(old)-len(new)}")\n\nwrite_file(\'input.tex\', text)\nprint("\\nChecking compilation...")\noverfull = check_overfull()\nif overfull:\n    print(f"\\nStill have {len(overfull)} overfull warnings:")\n    for line in overfull:\n        print(line)\nelse:\n    print("\\n✓ SUCCESS! No overfull hbox warnings!")\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
