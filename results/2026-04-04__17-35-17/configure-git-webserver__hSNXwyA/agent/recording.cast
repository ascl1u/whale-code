[125.258168, "o", "    # Check if this is the master branch\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.25854, "o", "    if [[ $refname == \"refs/heads/master\" ]]; then\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.258953, "o", "        echo \"Deploying to web server...\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.25933, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.259647, "o", "        # Create a temporary directory for checkout\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.25985, "o", "        TEMP_DIR=$(mktemp -d)\r\n\u001b[?2004l\r"]
[125.260155, "o", "\u001b[?2004h> "]
[125.260417, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.260765, "o", "        # Clone the repository to temp directory\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.260936, "o", "        git clone /git/server \"$TEMP_DIR\" 2>&1\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.261366, "o", "        # Copy files to web root (excluding .git directory)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[125.261824, "o", "        rsync -av --delete --exclude='.git' \"$TEMP_DIR/\" \"$WEB_ROOT/\"\r\n\u001b[?2004l\r"]
[125.261959, "o", "\u001b[?2004h> "]
