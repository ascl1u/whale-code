[173.196256, "i", "cat /git/server/hooks/post-receive; printf '%s\\n' '__CMDEND__40__'\n"]
[173.197112, "o", "cat /git/server/hooks/post-receive; printf '%s\\n' '__CMDEND__40__'\r\n\u001b[?2004l\r"]
[173.199346, "o", "#!/bin/bash\r\n\r\n# Post-receive hook to deploy to web server\r\nWEB_DIR=\"/var/www/html\"\r\nGIT_DIR=\"/git/server\"\r\nWORK_DIR=\"/tmp/git-work\"\r\n\r\n# Read the pushed branch\r\nwhile read oldrev newrev refname; do\r\n  # Check if this is the master branch\r\n  if [[ $refname == \"refs/heads/master\" ]]; then\r\n    echo \"Deploying to web server...\"\r\n    \r\n    # Create or clean the work directory\r\n    rm -rf \"$WORK_DIR\"\r\n    mkdir -p \"$WORK_DIR\"\r\n    \r\n    # Checkout the files to the work directory\r\n    git --work-tree=\"$WORK_DIR\" --git-dir=\"$GIT_DIR\" checkout -f master\r\n    \r\n    # Copy files to web directory\r\n    cp -r \"$WORK_DIR\"/* \"$WEB_DIR\"/\r\n    \r\n    echo \"Deployment complete!\"\r\n  fi\r\ndone\r\n"]
[173.19975, "o", "__CMDEND__40__\r\n"]
[173.200108, "o", "\u001b[?2004hroot@68af9fa3b59c:/app# "]
