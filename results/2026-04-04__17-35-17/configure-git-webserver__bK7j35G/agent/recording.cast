[78.665845, "o", "\u001b[?2004h> "]
[78.666049, "o", "WORK_DIR=\"/tmp/git-work\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[78.666148, "o", "> "]
