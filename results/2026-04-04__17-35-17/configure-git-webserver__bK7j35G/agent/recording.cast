[78.666617, "o", "while read oldrev newrev refname; do\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.666916, "o", "  # Check if this is the master branch\r\n\u001b[?2004l\r\u001b[?2004h"]
[78.667149, "o", ">   if [[ $refname == \"refs/heads/master\" ]]; then\r\n\u001b[?2004l\r"]
[78.667416, "o", "\u001b[?2004h> "]
[78.667692, "o", "    echo \"Deploying to web server...\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.667887, "o", "    # Create or clean the work directory\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.668124, "o", "    rm -rf \"$WORK_DIR\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.66835, "o", "    mkdir -p \"$WORK_DIR\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.668655, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.668841, "o", "    # Checkout the files to the work directory\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.669223, "o", "    git --work-tree=\"$WORK_DIR\" --git-dir=\"$GIT_DIR\" checkout -f master\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.669429, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.669607, "o", "    # Copy files to web directory\r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.669849, "o", "    cp -r \"$WORK_DIR\"/* \"$WEB_DIR\"/\r\n\u001b[?2004l\r\u001b[?2004h"]
[78.670007, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[78.670163, "o", "    echo \"Deployment complete!\"\r\n\u001b[?2004l\r"]
[78.670351, "o", "\u001b[?2004h>   fi\r\n\u001b[?2004l\r"]
[78.670536, "o", "\u001b[?2004h> done\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
