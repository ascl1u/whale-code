[190.711567, "o", "\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[190.711943, "o", "PORT = 8080\r\n\u001b[?2004l\r\u001b[?2004h> "]
[190.712173, "o", "DIRECTORY = \"/var/www/html\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[190.712505, "o", "class MyHTTPRequestHandler(http.server.SimpleHTTPRequestHandler):\r\n\u001b[?2004l\r\u001b[?2004h"]
[190.712616, "o", "> "]
[190.712986, "o", "    def __init__(self, *args, **kwargs):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[190.713422, "o", "        super().__init__(*args, directory=DIRECTORY, **kwargs)\r\n\u001b[?2004l\r\u001b[?2004h"]
[190.713703, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[190.713962, "o", "> "]
[190.714227, "o", "with socketserver.TCPServer((\"\", PORT), MyHTTPRequestHandler) as httpd:\r\n\u001b[?2004l\r\u001b[?2004h"]
[190.714514, "o", "> "]
