[79.544265, "o", "\u001b[?2004hroot@524fc0145fd8:/git/server# "]
[86.130144, "i", "cat > hooks/post-receive << 'EOF'\n#!/bin/bash\n# Post-receive hook to deploy pushed content to web directory\n\nWEB_DIR=\"/var/www/html\"\nGIT_DIR=\"/git/server\"\n\n# Clean the web directory\nrm -rf \"$WEB_DIR\"/*\n\n# Checkout the master branch to the web directory\nGIT_WORK_TREE=\"$WEB_DIR\" git checkout -f master\n\necho \"Deployed to $WEB_DIR\"\nEOF\n"]
[86.130614, "o", "cat > hooks/post-receive << 'EOF'\r\n\u001b[?2004l\r"]
[86.130838, "o", "\u001b[?2004h> #!/bin/bash\r\n\u001b[?2004l\r"]
[86.131072, "o", "\u001b[?2004h> "]
[86.131332, "o", "# Post-receive hook to deploy pushed content to web directory\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[86.13158, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[86.131768, "o", "WEB_DIR=\"/var/www/html\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.13199, "o", "GIT_DIR=\"/git/server\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[86.132101, "o", "> "]
[86.132214, "o", "# Clean the web directory\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.132816, "o", "rm -rf \"$WEB_DIR\"/*\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Checkout the master branch to the web directory\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.133084, "o", "GIT_WORK_TREE=\"$WEB_DIR\" git checkout -f master\r\n\u001b[?2004l\r"]
[86.133336, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.133615, "o", "echo \"Deployed to $WEB_DIR\"\r\n"]
