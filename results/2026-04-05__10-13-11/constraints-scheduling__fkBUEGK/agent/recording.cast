[41.991153, "i", "cat > find_slot.py << 'EOF'\nfrom datetime import datetime, timedelta\n\n# Define the week: Jan 15-19, 2024 (Monday-Friday)\ndays = [\n    datetime(2024, 1, 15),  # Monday\n    datetime(2024, 1, 16),  # Tuesday\n    datetime(2024, 1, 17),  # Wednesday\n    datetime(2024, 1, 18),  # Thursday\n    datetime(2024, 1, 19),  # Friday\n]\n\n# Alice's busy times (all times in UTC, same as local)\nalice_busy = [\n    (datetime(2024, 1, 15, 10, 0), datetime(2024, 1, 15, 11, 0)),\n    (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 14, 0)),\n    (datetime(2024, 1, 16, 10, 0), datetime(2024, 1, 16, 12, 0)),\n    (datetime(2024, 1, 17, 10, 0), datetime(2024, 1, 17, 11, 0)),\n    (datetime(2024, 1, 17, 13, 0), datetime(2024, 1, 17, 14, 0)),\n    (datetime(2024, 1, 18, 10, 0), datetime(2024, 1, 18, 11, 0)),\n    (datetime(2024, 1, 19, 10, 0), datetime(2024, 1, 19, 11, 0)),\n    (datetime(2024, 1, 19, 13, 0), datetime(2024, 1, 19, 14, 0)),\n]\n\n# Bob's busy times\nbob_busy = [\n    (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),\n    (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 15, 0)),\n    (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n    (datetime(2024, 1, 18, 13, 0), datetime(2024, 1, 18, 14, 0)),\n    (datetime(2024, 1, 19, 12, 0), datetime(2024, 1, 19, 13, 0)),\n]\n\n# Carol's busy times\ncarol_busy = [\n    (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),\n    (datetime(2024, 1, 16, 11, 0), datetime(2024, 1, 16, 12, 0)),\n    (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n    (datetime(2024, 1, 18, 12, 0), datetime(2024, 1, 18, 13, 0)),\n    (datetime(2024, 1, 19, 11, 0), datetime(2024, 1, 19, 12, 0)),\n]\n\ndef is_conflicting(start, end, busy_list):\n    \"\"\"Check if a time slot conflicts with any busy time\"\"\"\n    for busy_start, busy_end in busy_list:\n        # Conflict if there's any overlap\n        if start < busy_end and end > busy_start:\n            return True\n    return False\n\ndef check_constraints(start, end, day_of_week):\n    \"\"\"Check all hard constraints for a time slot\"\"\"\n    # Alice: 9 AM - 2 PM only\n    alice_start = start.replace(hour=9, minute=0, second=0)\n    alice_end = start.replace(hour=14, minute=0, second=0)\n    if start < alice_start or end > alice_end:\n        return False\n    if is_conflicting(start, end, alice_busy):\n        return False\n    \n    # Bob: No meetings before 10 AM, must leave by 4:30 PM on Tue/Thu\n    bob_start = start.replace(hour=10, minute=0, second=0)\n    if start < bob_start:\n        return False\n    if day_of_week in [1, 3]:  # Tuesday (1) and Thursday (3)\n        bob_end_limit = start.replace(hour=16, minute=30, second=0)\n        if end > bob_end_limit:\n            return False\n    if is_conflicting(start, end, bob_busy):\n        return False\n    \n    # Carol: 9 AM-5 PM, lunch 12:00-12:30 PM unavailable\n    carol_start = start.replace(hour=9, minute=0, second=0)\n    carol_end = start.replace(hour=17, minute=0, second=0)\n    if start < carol_start or end > carol_end:\n        return False\n    \n    # Check lunch conflict (12:00-12:30 PM)\n    lunch_start = start.replace(hour=12, minute=0, second=0)\n    lunch_end = start.replace(hour=12, minute=30, second=0)\n    if start < lunch_end and end > lunch_start:\n        return False\n    \n    if is_conflicting(start, end, carol_busy):\n        return False\n    \n    return True\n\n# Find earliest valid slot\nvalid_slots = []\n\nfor day_idx, day in enumerate(days):\n    # Check every minute from 9 AM to 5 PM (allowing 1 hour meeting to end by 6 PM)\n    # Business hours: 9 AM - 6 PM, so meeting can start up to 5 PM\n    start_hour = 9\n    end_hour = 17  # 5 PM is the latest start for a 1-hour meeting\n    \n    for hour in range(start_hour, end_hour + 1):\n        for minute in range(0, 60):\n            start = day.replace(hour=hour, minute=minute, second=0)\n            end = start + timedelta(hours=1)\n            \n            # Check if end time is within business hours (6 PM)\n            if end > d"]
[41.991373, "i", "ay.replace(hour=18, minute=0, second=0):\n                continue\n            \n            if check_constraints(start, end, day_idx):\n                is_monday = (day_idx == 0)\n                valid_slots.append((start, end, is_monday))\n\nif valid_slots:\n    # Sort by time (earliest first), then by not-Monday preference\n    valid_slots.sort(key=lambda x: (x[0], x[2]))  # Sort by start time, then by is_monday\n    \n    earliest = valid_slots[0]\n    print(f\"Earliest valid slot: {earliest[0]} to {earliest[1]}\")\n    print(f\"Is Monday: {earliest[2]}\")\n    print(f\"Start: {earliest[0].strftime('%Y%m%dT%H%M%SZ')}\")\n    print(f\"End: {earliest[1].strftime('%Y%m%dT%H%M%SZ')}\")\nelse:\n    print(\"No valid slot found!\")\nEOF\n"]
