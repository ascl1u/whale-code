[96.63803, "i", "cat > verify.py << 'EOF'\nfrom datetime import datetime\n\n# Scheduled meeting\nmeeting_start = datetime(2024, 1, 17, 11, 0)\nmeeting_end = datetime(2024, 1, 17, 12, 0)\n\nprint(\"Scheduled Meeting: Wednesday, January 17, 2024, 11:00 AM - 12:00 PM UTC\")\nprint()\n\n# Verify Alice's constraints\nprint(\"Alice's Constraints:\")\nprint(\"  - Available: 9 AM - 2 PM only\")\nprint(\"  - Busy: Mon 10-11 AM, Mon 1-2 PM, Tue 10 AM-12 PM, Wed 10-11 AM, Wed 1-2 PM, Thu 10-11 AM, Fri 10-11 AM, Fri 1-2 PM\")\nprint(f\"  - Meeting time 11 AM-12 PM: Within 9 AM-2 PM ✓\")\nprint(f\"  - No conflict with Wed 10-11 AM meeting ✓\")\nprint()\n\n# Verify Bob's constraints\nprint(\"Bob's Constraints:\")\nprint(\"  - No meetings before 10 AM\")\nprint(\"  - Must leave by 4:30 PM on Tue/Thu\")\nprint(\"  - Busy: Mon 11 AM-12 PM, Mon 1-3 PM, Tue 1-2 PM, Wed 12-1 PM, Thu 1-2 PM, Fri 12-1 PM\")\nprint(f\"  - Meeting time 11 AM-12 PM: After 10 AM ✓\")\nprint(f\"  - No conflict with Wed 12-1 PM meeting ✓\")\nprint()\n\n# Verify Carol's constraints\nprint(\"Carol's Constraints:\")\nprint(\"  - Available: 9 AM - 5 PM\")\nprint(\"  - Lunch break: 12:00-12:30 PM (unavailable)\")\nprint(\"  - Prefers not Monday\")\nprint(\"  - Busy: Mon 11 AM-12 PM, Tue 11 AM-12 PM, Tue 1-2 PM, Wed 12-1 PM, Thu 12-1 PM, Fri 11 AM-12 PM\")\nprint(f\"  - Meeting time 11 AM-12 PM: Within 9 AM-5 PM ✓\")\nprint(f\"  - No conflict with lunch (12:00-12:30 PM) ✓\")\nprint(f\"  - Not Monday ✓\")\nprint(f\"  - No conflict with Wed 12-1 PM meeting ✓\")\nprint()\n\n# Check if this is the earliest\nprint(\"Earliest Slot Analysis:\")\nprint(\"  Monday 1/15:\")\nprint(\"    - 9-10 AM: Alice free, Bob can't (before 10 AM), Carol free → INVALID\")\nprint(\"    - 10-11 AM: Alice busy, Bob busy (11 AM-12 PM overlaps), Carol busy → INVALID\")\nprint(\"    - 11 AM-12 PM: Alice free, Bob busy, Carol busy → INVALID\")\nprint(\"    - 12-1 PM: Alice free, Bob free, Carol lunch break (12:00-12:30) → INVALID\")\nprint(\"    - 1-2 PM: Alice busy, Bob busy, Carol free → INVALID\")\nprint(\"  Tuesday 1/16:\")\nprint(\"    - 10-11 AM: Alice busy (10 AM-12 PM), Bob free, Carol free → INVALID\")\nprint(\"    - 11 AM-12 PM: Alice busy (10 AM-12 PM), Bob free, Carol busy → INVALID\")\nprint(\"    - 12-1 PM: Alice free, Bob free, Carol lunch break (12:00-12:30) → INVALID\")\nprint(\"    - 1-2 PM: Alice free, Bob busy, Carol busy → INVALID\")\nprint(\"  Wednesday 1/17:\")\nprint(\"    - 10-11 AM: Alice busy, Bob free, Carol free → INVALID\")\nprint(\"    - 11 AM-12 PM: Alice free, Bob free, Carol free → VALID ✓✓✓\")\nprint()\nprint(\"Result: Wednesday, Jan 17, 11 AM-12 PM is the EARLIEST valid slot!\")\nEOF\n"]
