[42.014315, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.014734, "o", "    if day_of_week in [1, 3]:  # Tuesday (1) and Thursday (3)\r\n\u001b[?2004l\r"]
[42.014941, "o", "\u001b[?2004h> "]
[42.015181, "o", "        bob_end_limit = start.replace(hour=16, minute=30, second=0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.015405, "o", "        if end > bob_end_limit:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.015607, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.015822, "o", "    if is_conflicting(start, end, bob_busy):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.016112, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.016309, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.016532, "o", "    # Carol: 9 AM-5 PM, lunch 12:00-12:30 PM unavailable\r\n\u001b[?2004l\r"]
[42.016715, "o", "\u001b[?2004h> "]
[42.016914, "o", "    carol_start = start.replace(hour=9, minute=0, second=0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.01727, "o", "    carol_end = start.replace(hour=17, minute=0, second=0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.017453, "o", "> "]
[42.017671, "o", "    if start < carol_start or end > carol_end:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.017873, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.018103, "o", "    # Check lunch conflict (12:00-12:30 PM)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.018557, "o", "    lunch_start = start.replace(hour=12, minute=0, second=0)\r\n\u001b[?2004l\r"]
[42.039267, "o", "\u001b[?2004h> "]
[42.039659, "o", "    lunch_end = start.replace(hour=12, minute=30, second=0)\r\n\u001b[?2004l\r\u001b[?2004h>     if start < lunch_end and end > lunch_start:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     if is_conflicting(start, end, carol_busy):\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Find earliest valid slot\r\n\u001b[?2004l\r\u001b[?2004h> valid_slots = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for day_idx, day in enumerate(days):\r\n\u001b[?2004l\r\u001b[?2004h>     # Check every minute from 9 AM to 5 PM (allowing 1 hour meeting to end by 6 PM)\r\n\u001b[?2004l\r\u001b[?2004h>     # Business hours: 9 AM - 6 PM, so meeting can start up to 5 PM\r\n\u001b[?2004l\r\u001b[?2004h>     start_hour = 9\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.039803, "o", "    end_hour = 17  # 5 PM is the latest start for a 1-hour meeting\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.040101, "o", "    for hour in range(start_hour, end_hour + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.040299, "o", "        for minute in range(0, 60):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.040635, "o", "            start = day.replace(hour=hour, minute=minute, second=0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.040884, "o", "            end = start + timedelta(hours=1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.040989, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.041354, "o", "            # Check if end time is within business hours (6 PM)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.041657, "o", "            if end > day.replace(hour=18, minute=0, second=0):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.041825, "o", "                continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.042007, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.04224, "o", "            if check_constraints(start, end, day_idx):\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.042422, "o", "> "]
[42.042602, "o", "                is_monday = (day_idx == 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.042795, "o", "                valid_slots.append((start, end, is_monday))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[42.042881, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[42.043183, "o", "if valid_slots:\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.043381, "o", ">     # Sort by time (earliest first), then by not-Monday preference\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.043754, "o", "    valid_slots.sort(key=lambda x: (x[0], x[2]))  # Sort by start time, then by is_monday\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.043932, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.044101, "o", "    earliest = valid_slots[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.044307, "o", "    print(f\"Earliest valid slot: {earliest[0]} to {earliest[1]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.044402, "o", "> "]
[42.044563, "o", "    print(f\"Is Monday: {earliest[2]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.044861, "o", "    print(f\"Start: {earliest[0].strftime('%Y%m%dT%H%M%SZ')}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.045194, "o", "    print(f\"End: {earliest[1].strftime('%Y%m%dT%H%M%SZ')}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.045356, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.045532, "o", "    print(\"No valid slot found!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.045737, "o", "EOF\r\n\u001b[?2004l\r"]
[42.048748, "o", "\u001b[?2004hroot@c29f5ea064c8:/app# "]
