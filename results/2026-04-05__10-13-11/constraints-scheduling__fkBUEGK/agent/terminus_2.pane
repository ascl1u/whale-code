[?2004l[?2004h> 
[?2004l[?2004h> # Bob's busy times
[?2004l[?2004h> bob_busy = [
[?2004l[?2004h>     (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 15, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 18, 13, 0), datetime(2024, 1, 18, 14, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 19, 12, 0), datetime(2024, 1, 19, 13, 0)),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> # Carol's busy times
[?2004l[?2004h> carol_busy = [
[?2004l[?2004h>     (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 16, 11, 0), datetime(2024, 1, 16, 12, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 18, 12, 0), datetime(2024, 1, 18, 13, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 19, 11, 0), datetime(2024, 1, 19, 12, 0)),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> def is_conflicting(start, end, busy_list):
[?2004l[?2004h>     """Check if a time slot conflicts with any busy time"""
[?2004l[?2004h>     for busy_start, busy_end in busy_list:
[?2004l[?2004h>         # Conflict if there's any overlap
[?2004l[?2004h>         if start < busy_end and end > busy_start:
[?2004l[?2004h>             return True
[?2004l[?2004h>     return False
[?2004l[?2004h> 
[?2004l[?2004h> def check_constraints(start, end, day_of_week):
[?2004l[?2004h>     """Check all hard constraints for a time slot"""
[?2004l[?2004h>     # Alice: 9 AM - 2 PM only
[?2004l[?2004h>     alice_start = start.replace(hour=9, minute=0, second=0)
[?2004l[?2004h>     alice_end = start.replace(hour=14, minute=0, second=0)
[?2004l[?2004h>     if start < alice_start or end > alice_end:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if is_conflicting(start, end, alice_busy):
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Bob: No meetings before 10 AM, must leave by 4:30 PM on Tue/Thu
[?2004l[?2004h>     bob_start = start.replace(hour=10, minute=0, second=0)
[?2004l[?2004h>     if start < bob_start:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if day_of_week in [1, 3]:  # Tuesday (1) and Thursday (3)
[?2004l[?2004h>         bob_end_limit = start.replace(hour=16, minute=30, second=0)
[?2004l[?2004h>         if end > bob_end_limit:
[?2004l[?2004h>             return False
[?2004l[?2004h>     if is_conflicting(start, end, bob_busy):
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Carol: 9 AM-5 PM, lunch 12:00-12:30 PM unavailable
[?2004l[?2004h>     carol_start = start.replace(hour=9, minute=0, second=0)
[?2004l[?2004h>     carol_end = start.replace(hour=17, minute=0, second=0)
[?2004l[?2004h>     if start < carol_start or end > carol_end:
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Check lunch conflict (12:00-12:30 PM)
[?2004l[?2004h>     lunch_start = start.replace(hour=12, minute=0, second=0)
[?2004l[?2004h>     lunch_end = start.replace(hour=12, minute=30, second=0)
[?2004l[?2004h>     if start < lunch_end and end > lunch_start:
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     if is_conflicting(start, end, carol_busy):
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     return True
[?2004l[?2004h> 
[?2004l[?2004h> # Find earliest valid slot
[?2004l[?2004h> valid_slots = []
[?2004l[?2004h> 
[?2004l[?2004h> for day_idx, day in enumerate(days):
[?2004l[?2004h>     # Check every minute from 9 AM to 5 PM (allowing 1 hour meeting to end by 6 PM)
[?2004l[?2004h>     # Business hours: 9 AM - 6 PM, so meeting can start up to 5 PM
[?2004l[?2004h>     start_hour = 9
[?2004l[?2004h>     end_hour = 17  # 5 PM is the latest start for a 1-hour meeting
[?2004l[?2004h>     
[?2004l[?2004h>     for hour in range(start_hour, end_hour + 1):
[?2004l[?2004h>         for minute in range(0, 60):
[?2004l[?2004h>             start = day.replace(hour=hour, minute=minute, second=0)
[?2004l[?2004h>             end = start + timedelta(hours=1)
[?2004l[?2004h>             
[?2004l[?2004h>             # Check if end time is within business hours (6 PM)
[?2004l[?2004h>             if end > day.replace(hour=18, minute=0, second=0):
[?2004l[?2004h>                 continue
[?2004l[?2004h>             
[?2004l[?2004h>             if check_constraints(start, end, day_idx):
[?2004l[?2004h>                 is_monday = (day_idx == 0)
[?2004l[?2004h>                 valid_slots.append((start, end, is_monday))
[?2004l[?2004h> 
[?2004l[?2004h> if valid_slots:
[?2004l[?2004h>     # Sort by time (earliest first), then by not-Monday preference
[?2004l[?2004h>     valid_slots.sort(key=lambda x: (x[0], x[2]))  # Sort by start time, then by is_monday
[?2004l[?2004h>     
[?2004l[?2004h>     earliest = valid_slots[0]
[?2004l[?2004h>     print(f"Earliest valid slot: {earliest[0]} to {earliest[1]}")
[?2004l[?2004h>     print(f"Is Monday: {earliest[2]}")
[?2004l[?2004h>     print(f"Start: {earliest[0].strftime('%Y%m%dT%H%M%SZ')}")
[?2004l[?2004h>     print(f"End: {earliest[1].strftime('%Y%m%dT%H%M%SZ')}")
[?2004l[?2004h> else:
[?2004l[?2004h>     print("No valid slot found!")
