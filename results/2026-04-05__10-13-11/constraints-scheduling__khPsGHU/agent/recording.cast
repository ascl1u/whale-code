[82.147696, "i", "cat > verify.py << 'EOF'\nfrom datetime import datetime, timedelta\n\n# Meeting slot selected\nmeeting_start = datetime(2024, 1, 17, 11, 0)\nmeeting_end = datetime(2024, 1, 17, 12, 0)\n\nprint(\"=== VERIFICATION ===\")\nprint(f\"Meeting scheduled: {meeting_start.strftime('%A, %B %d, %Y %I:%M %p')} - {meeting_end.strftime('%I:%M %p')}\")\nprint()\n\n# Alice's constraints\nprint(\"Alice's constraints:\")\nprint(f\"  - Time: {meeting_start.strftime('%I:%M %p')} - {meeting_end.strftime('%I:%M %p')}\")\nprint(f\"  - Within 9 AM - 2 PM window: {9 <= meeting_start.hour and meeting_end.hour <= 14 and meeting_end.minute == 0}\")\nprint(f\"  - In preferred morning slot (9 AM-12 PM): {meeting_start.hour < 12}\")\n\nalice_meetings = [\n    (datetime(2024, 1, 17, 10, 0), datetime(2024, 1, 17, 11, 0)),\n    (datetime(2024, 1, 17, 13, 0), datetime(2024, 1, 17, 14, 0)),\n]\nconflicts = [m for m in alice_meetings if meeting_start < m[1] and meeting_end > m[0]]\nprint(f\"  - No calendar conflicts: {len(conflicts) == 0}\")\nprint()\n\n# Bob's constraints\nprint(\"Bob's constraints:\")\nprint(f\"  - After 10 AM: {meeting_start.hour >= 10}\")\nprint(f\"  - Day: {meeting_start.strftime('%A')}\")\nif meeting_start.weekday() in [1, 3]:  # Tue/Thu\n    print(f\"  - Ends by 4:30 PM (Tue/Thu): {meeting_end.hour < 16 or (meeting_end.hour == 16 and meeting_end.minute <= 30)}\")\n\nbob_meetings = [\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n]\nconflicts = [m for m in bob_meetings if meeting_start < m[1] and meeting_end > m[0]]\nprint(f\"  - No calendar conflicts: {len(conflicts) == 0}\")\nprint()\n\n# Carol's constraints\nprint(\"Carol's constraints:\")\nprint(f\"  - Within 9 AM - 5 PM: {9 <= meeting_start.hour and meeting_end.hour <= 17}\")\nlunch_start = meeting_start.replace(hour=12, minute=0)\nlunch_end = meeting_start.replace(hour=12, minute=30)\nprint(f\"  - Doesn't overlap lunch (12:00-12:30 PM): {not (meeting_start < lunch_end and meeting_end > lunch_start)}\")\nprint(f\"  - Not on Monday (preference): {meeting_start.weekday() != 0}\")\n\ncarol_meetings = [\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n]\nconflicts = [m for m in carol_meetings if meeting_start < m[1] and meeting_end > m[0]]\nprint(f\"  - No calendar conflicts: {len(conflicts) == 0}\")\nprint()\n\nprint(\"=== ALL CONSTRAINTS SATISFIED ===\")\nEOF\n"]
