[82.157608, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.157844, "o", "# Bob's constraints\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.158025, "o", "print(\"Bob's constraints:\")\r\n\u001b[?2004l\r"]
[82.15822, "o", "\u001b[?2004h> "]
[82.1585, "o", "print(f\"  - After 10 AM: {meeting_start.hour >= 10}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.158737, "o", "> "]
[82.159033, "o", "print(f\"  - Day: {meeting_start.strftime('%A')}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.159274, "o", "> "]
[82.159486, "o", "if meeting_start.weekday() in [1, 3]:  # Tue/Thu\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.160318, "o", "    print(f\"  - Ends by 4:30 PM (Tue/Thu): {meeting_end.hour < 16 or (meeting_end.hour == 16 and meeting_end.minute <= 30)}\")\r\n\u001b[?2004l\r"]
[82.160601, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.160945, "o", "bob_meetings = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.161324, "o", "    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\r\n\u001b[?2004l\r"]
[82.161535, "o", "\u001b[?2004h> ]\r\n\u001b[?2004l\r"]
[82.161768, "o", "\u001b[?2004h> "]
[82.162159, "o", "conflicts = [m for m in bob_meetings if meeting_start < m[1] and meeting_end > m[0]]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.162545, "o", "print(f\"  - No calendar conflicts: {len(conflicts) == 0}\")\r\n\u001b[?2004l\r"]
[82.162671, "o", "\u001b[?2004h> print()\r\n\u001b[?2004l\r"]
[82.162859, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.163012, "o", "# Carol's constraints\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.163357, "o", "print(\"Carol's constraints:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.163797, "o", "print(f\"  - Within 9 AM - 5 PM: {9 <= meeting_start.hour and meeting_end.hour <= 17}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.164158, "o", "lunch_start = meeting_start.replace(hour=12, minute=0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.16442, "o", "> "]
[82.164678, "o", "lunch_end = meeting_start.replace(hour=12, minute=30)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.165402, "o", "print(f\"  - Doesn't overlap lunch (12:00-12:30 PM): {not (meeting_start < lunch_end and meeting_end > lunch_start)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.165883, "o", "print(f\"  - Not on Monday (preference): {meeting_start.weekday() != 0}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[82.166124, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.166347, "o", "carol_meetings = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.166557, "o", "    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\r\n\u001b[?2004l\r\u001b[?2004h> ]"]
[82.166758, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.167224, "o", "conflicts = [m for m in carol_meetings if meeting_start < m[1] and meeting_end > m[0]]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.167734, "o", "print(f\"  - No calendar conflicts: {len(conflicts) == 0}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[82.167937, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
