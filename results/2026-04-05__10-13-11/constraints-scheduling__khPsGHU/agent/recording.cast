[47.661239, "i", "cat > find_slot.py << 'EOF'\nfrom datetime import datetime, timedelta\n\n# Define the date range: Jan 15-19, 2024\nstart_date = datetime(2024, 1, 15, 9, 0)  # Monday 9 AM\nend_date = datetime(2024, 1, 19, 18, 0)   # Friday 6 PM\n\n# Alice's existing meetings (all in UTC)\nalice_meetings = [\n    (datetime(2024, 1, 15, 10, 0), datetime(2024, 1, 15, 11, 0)),\n    (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 14, 0)),\n    (datetime(2024, 1, 16, 10, 0), datetime(2024, 1, 16, 12, 0)),\n    (datetime(2024, 1, 17, 10, 0), datetime(2024, 1, 17, 11, 0)),\n    (datetime(2024, 1, 17, 13, 0), datetime(2024, 1, 17, 14, 0)),\n    (datetime(2024, 1, 18, 10, 0), datetime(2024, 1, 18, 11, 0)),\n    (datetime(2024, 1, 19, 10, 0), datetime(2024, 1, 19, 11, 0)),\n    (datetime(2024, 1, 19, 13, 0), datetime(2024, 1, 19, 14, 0)),\n]\n\n# Bob's existing meetings\nbob_meetings = [\n    (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),\n    (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 15, 0)),\n    (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n    (datetime(2024, 1, 18, 13, 0), datetime(2024, 1, 18, 14, 0)),\n    (datetime(2024, 1, 19, 12, 0), datetime(2024, 1, 19, 13, 0)),\n]\n\n# Carol's existing meetings\ncarol_meetings = [\n    (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),\n    (datetime(2024, 1, 16, 11, 0), datetime(2024, 1, 16, 12, 0)),\n    (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n    (datetime(2024, 1, 18, 12, 0), datetime(2024, 1, 18, 13, 0)),\n    (datetime(2024, 1, 19, 11, 0), datetime(2024, 1, 19, 12, 0)),\n]\n\ndef has_conflict(start, end, meetings):\n    \"\"\"Check if a time slot conflicts with existing meetings\"\"\"\n    for meet_start, meet_end in meetings:\n        # Conflict if there's any overlap\n        if start < meet_end and end > meet_start:\n            return True\n    return False\n\ndef is_valid_slot(start, end):\n    \"\"\"Check if a time slot is valid for all three people\"\"\"\n    hour = start.hour\n    minute = start.minute\n    weekday = start.weekday()  # 0=Monday, 4=Friday\n    \n    # Alice constraints: 9 AM - 2 PM only\n    if start.hour < 9 or end.hour > 14:\n        return False\n    if end.hour == 14 and end.minute > 0:\n        return False\n    \n    # Bob constraints: No meetings before 10 AM\n    if start.hour < 10:\n        return False\n    \n    # Bob: Must leave by 4:30 PM on Tue/Thu (weekday 1, 3)\n    if weekday in [1, 3]:  # Tuesday or Thursday\n        if end.hour > 16 or (end.hour == 16 and end.minute > 30):\n            return False\n    \n    # Carol constraints: lunch break 12:00-12:30 PM (unavailable)\n    # Meeting conflicts if it overlaps with 12:00-12:30\n    lunch_start = start.replace(hour=12, minute=0)\n    lunch_end = start.replace(hour=12, minute=30)\n    if start < lunch_end and end > lunch_start:\n        return False\n    \n    # Carol: Needs 15-min buffer after meetings ending at 4:45 PM or later\n    # If meeting ends at 4:45 PM or later, need buffer until 5 PM\n    if end.hour > 16 or (end.hour == 16 and end.minute >= 45):\n        # Meeting can't end after 4:45 PM since Carol needs to leave by 5 PM\n        return False\n    \n    # Check calendar conflicts\n    if has_conflict(start, end, alice_meetings):\n        return False\n    if has_conflict(start, end, bob_meetings):\n        return False\n    if has_conflict(start, end, carol_meetings):\n        return False\n    \n    return True\n\ndef get_preference_score(start):\n    \"\"\"Lower score is better. Used for tie-breaking.\"\"\"\n    score = 0\n    weekday = start.weekday()\n    \n    # Carol prefers not Monday (higher score for Monday)\n    if weekday == 0:  # Monday\n        score += 1000\n    \n    # Alice prefers mornings (9 AM - 12 PM), can do early afternoons (12-2 PM)\n    # Lower score for morning slots\n    if start.hour < 12:\n        score += 0  # Best\n    else:\n        score += 100  # Less preferred\n    \n    return score\n\n# Find all valid slots (checking every minute)\nvalid_slots = []\ncurrent = start_date\n\n"]
[47.661365, "i", "while current <= end_date:\n    # Skip weekends\n    if current.weekday() < 5:  # Monday-Friday\n        # Check if this is within business hours\n        if 9 <= current.hour < 18:\n            meeting_end = current + timedelta(hours=1)\n            # Make sure meeting ends before 6 PM\n            if meeting_end.hour <= 18:\n                if is_valid_slot(current, meeting_end):\n                    valid_slots.append(current)\n    \n    # Move to next minute\n    current += timedelta(minutes=1)\n\nif valid_slots:\n    # Sort by time (earliest first), then by preference score\n    valid_slots.sort(key=lambda x: (x, get_preference_score(x)))\n    best_slot = valid_slots[0]\n    \n    print(f\"Found {len(valid_slots)} valid slots\")\n    print(f\"\\nEarliest valid slot:\")\n    print(f\"Start: {best_slot.strftime('%Y-%m-%d %H:%M')} ({best_slot.strftime('%A')})\") \n    print(f\"End: {(best_slot + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M')}\")\n    print(f\"\\nFormatted for ICS:\")\n    print(f\"DTSTART:{best_slot.strftime('%Y%m%dT%H%M%S')}Z\")\n    print(f\"DTEND:{(best_slot + timedelta(hours=1)).strftime('%Y%m%dT%H%M%S')}Z\")\nelse:\n    print(\"No valid slots found!\")\nEOF\n"]
