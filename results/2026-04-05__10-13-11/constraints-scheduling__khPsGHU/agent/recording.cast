[47.686438, "o", "    # Bob: Must leave by 4:30 PM on Tue/Thu (weekday 1, 3)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.686732, "o", "    if weekday in [1, 3]:  # Tuesday or Thursday\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.686922, "o", "> "]
[47.687174, "o", "        if end.hour > 16 or (end.hour == 16 and end.minute > 30):\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.687306, "o", ">             return False\r\n\u001b[?2004l\r"]
[47.687509, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.687702, "o", "> "]
[47.687921, "o", "    # Carol constraints: lunch break 12:00-12:30 PM (unavailable)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.688258, "o", "    # Meeting conflicts if it overlaps with 12:00-12:30\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.688545, "o", "    lunch_start = start.replace(hour=12, minute=0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.688753, "o", "> "]
[47.688971, "o", "    lunch_end = start.replace(hour=12, minute=30)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.689186, "o", "    if start < lunch_end and end > lunch_start:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.689384, "o", "        return False\r\n\u001b[?2004l\r"]
[47.68959, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.68986, "o", "    # Carol: Needs 15-min buffer after meetings ending at 4:45 PM or later\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.69005, "o", "> "]
[47.690236, "o", "    # If meeting ends at 4:45 PM or later, need buffer until 5 PM\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.690616, "o", "    if end.hour > 16 or (end.hour == 16 and end.minute >= 45):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.691108, "o", "        # Meeting can't end after 4:45 PM since Carol needs to leave by 5 PM\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.691376, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.691605, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.691803, "o", "> "]
[47.691991, "o", "    # Check calendar conflicts\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.692229, "o", "    if has_conflict(start, end, alice_meetings):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.692431, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.692682, "o", "    if has_conflict(start, end, bob_meetings):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.692905, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.693102, "o", "> "]
[47.693205, "o", "    if has_conflict(start, end, carol_meetings):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69348, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.693704, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69392, "o", "def get_preference_score(start):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.694251, "o", "    \"\"\"Lower score is better. Used for tie-breaking.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.694451, "o", ">     score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69469, "o", "    weekday = start.weekday()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.694906, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.695195, "o", "    # Carol prefers not Monday (higher score for Monday)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.695398, "o", "    if weekday == 0:  # Monday\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.695616, "o", "        score += 1000\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.695837, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.696181, "o", "    # Alice prefers mornings (9 AM - 12 PM), can do early afternoons (12-2 PM)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.696467, "o", "    # Lower score for morning slots\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.696767, "o", "    if start.hour < 12:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69703, "o", "        score += 0  # Best\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.697218, "o", "        score += 100  # Less preferred\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[47.697424, "o", "\u001b[?2004h>     return score\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.697624, "o", "\u001b[?2004h> "]
[47.697828, "o", "# Find all valid slots (checking every minute)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69808, "o", "valid_slots = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.698269, "o", "current = start_date\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.698445, "o", "while current <= end_date:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.698665, "o", "    # Skip weekends\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.698916, "o", "    if current.weekday() < 5:  # Monday-Friday\r\n\u001b[?2004l\r"]
[47.699163, "o", "\u001b[?2004h> "]
[47.69936, "o", "        # Check if this is within business hours\r\n\u001b[?2004l\r"]
[47.699551, "o", "\u001b[?2004h> "]
[47.699755, "o", "        if 9 <= current.hour < 18:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.700008, "o", "            meeting_end = current + timedelta(hours=1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.700333, "o", "            # Make sure meeting ends before 6 PM\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.7006, "o", "            if meeting_end.hour <= 18:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.700955, "o", "                if is_valid_slot(current, meeting_end):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.701283, "o", "                    valid_slots.append(current)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.701439, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.70174, "o", "    # Move to next minute\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.701952, "o", "    current += timedelta(minutes=1)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702183, "o", "if valid_slots:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702465, "o", "    # Sort by time (earliest first), then by preference score\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702853, "o", "    valid_slots.sort(key=lambda x: (x, get_preference_score(x)))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703122, "o", "    best_slot = valid_slots[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703352, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703548, "o", "    print(f\"Found {len(valid_slots)} valid slots\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.703753, "o", "> "]
[47.703961, "o", "    print(f\"\\nEarliest valid slot:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704355, "o", "    print(f\"Start: {best_slot.strftime('%Y-%m-%d %H:%M')} ({best_slot.strftime('%A')})\") \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704854, "o", "    print(f\"End: {(best_slot + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M')}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.705158, "o", "    print(f\"\\nFormatted for ICS:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.705411, "o", "> "]
[47.705636, "o", "    print(f\"DTSTART:{best_slot.strftime('%Y%m%dT%H%M%S')}Z\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.706143, "o", "    print(f\"DTEND:{(best_slot + timedelta(hours=1)).strftime('%Y%m%dT%H%M%S')}Z\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.706355, "o", "> else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.70655, "o", "    print(\"No valid slots found!\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.706846, "o", "> EOF\r\n\u001b[?2004l\r"]
[47.710343, "o", "\u001b[?2004hroot@64f9508e74b2:/app# "]
[52.186706, "i", "python3 find_slot.py; printf '%s\\n' '__CMDEND__4__'\n"]
