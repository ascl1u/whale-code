[?2004l[?2004h>     (datetime(2024, 1, 18, 10, 0), datetime(2024, 1, 18, 11, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 19, 10, 0), datetime(2024, 1, 19, 11, 0)),
[?2004l [?2004h>     (datetime(2024, 1, 19, 13, 0), datetime(2024, 1, 19, 14, 0)),
[?2004l[?2004h> ]
[?2004l%M[?2004h> 
[?2004l'[?2004h> # Bob's existing meetings
[?2004l[?2004h> bob_meetings = [
[?2004l[?2004h>     (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 15, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),
[?2004li[?2004h>     (datetime(2024, 1, 18, 13, 0), datetime(2024, 1, 18, 14, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 19, 12, 0), datetime(2024, 1, 19, 13, 0)),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> # Carol's existing meetings
[?2004l[?2004h> carol_meetings = [
[?2004l[?2004h>     (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 16, 11, 0), datetime(2024, 1, 16, 12, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 18, 12, 0), datetime(2024, 1, 18, 13, 0)),
[?2004l[?2004h>     (datetime(2024, 1, 19, 11, 0), datetime(2024, 1, 19, 12, 0)),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> def has_conflict(start, end, meetings):
[?2004l[?2004h>     """Check if a time slot conflicts with existing meetings"""
[?2004l[?2004h>     for meet_start, meet_end in meetings:
[?2004l[?2004h>         # Conflict if there's any overlap
[?2004l[?2004h>         if start < meet_end and end > meet_start:
[?2004l[?2004h>             return True
[?2004l[?2004h>     return False
[?2004l[?2004h> 
[?2004l[?2004h> def is_valid_slot(start, end):
[?2004l[?2004h>     """Check if a time slot is valid for all three people"""
[?2004l[?2004h>     hour = start.hour
[?2004l[?2004h>     minute = start.minute
[?2004l[?2004h>     weekday = start.weekday()  # 0=Monday, 4=Friday
[?2004l[?2004h>     
[?2004l[?2004h>     # Alice constraints: 9 AM - 2 PM only
[?2004l[?2004h>     if start.hour < 9 or end.hour > 14:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if end.hour == 14 and end.minute > 0:
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Bob constraints: No meetings before 10 AM
[?2004l[?2004h>     if start.hour < 10:
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Bob: Must leave by 4:30 PM on Tue/Thu (weekday 1, 3)
[?2004l[?2004h>     if weekday in [1, 3]:  # Tuesday or Thursday
[?2004l[?2004h>         if end.hour > 16 or (end.hour == 16 and end.minute > 30):
[?2004l[?2004h>             return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Carol constraints: lunch break 12:00-12:30 PM (unavailable)
[?2004l[?2004h>     # Meeting conflicts if it overlaps with 12:00-12:30
[?2004l[?2004h>     lunch_start = start.replace(hour=12, minute=0)
[?2004l[?2004h>     lunch_end = start.replace(hour=12, minute=30)
[?2004l[?2004h>     if start < lunch_end and end > lunch_start:
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Carol: Needs 15-min buffer after meetings ending at 4:45 PM or later
[?2004l[?2004h>     # If meeting ends at 4:45 PM or later, need buffer until 5 PM
[?2004l[?2004h>     if end.hour > 16 or (end.hour == 16 and end.minute >= 45):
[?2004l[?2004h>         # Meeting can't end after 4:45 PM since Carol needs to leave by 5 PM
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     # Check calendar conflicts
[?2004l[?2004h>     if has_conflict(start, end, alice_meetings):
[?2004l[?2004h>         return False
[?2004l[?2004h>     if has_conflict(start, end, bob_meetings):
[?2004l[?2004h>         return False
[?2004l[?2004h>     if has_conflict(start, end, carol_meetings):
[?2004l[?2004h>         return False
[?2004l[?2004h>     
[?2004l[?2004h>     return True
[?2004l[?2004h> 
[?2004l[?2004h> def get_preference_score(start):
[?2004l[?2004h>     """Lower score is better. Used for tie-breaking."""
[?2004l[?2004h>     score = 0
[?2004l[?2004h>     weekday = start.weekday()
[?2004l[?2004h>     
[?2004l[?2004h>     # Carol prefers not Monday (higher score for Monday)
[?2004l[?2004h>     if weekday == 0:  # Monday
[?2004l[?2004h>         score += 1000
[?2004l[?2004h>     
[?2004l[?2004h>     # Alice prefers mornings (9 AM - 12 PM), can do early afternoons (12-2 PM)
[?2004l[?2004h>     # Lower score for morning slots
[?2004l[?2004h>     if start.hour < 12:
[?2004l[?2004h>         score += 0  # Best
[?2004l[?2004h>     else:
[?2004l[?2004h>         score += 100  # Less preferred
[?2004l[?2004h>     
[?2004l[?2004h>     return score
[?2004l[?2004h> 
[?2004l[?2004h> # Find all valid slots (checking every minute)
[?2004l[?2004h> valid_slots = []
[?2004l[?2004h> current = start_date
[?2004l[?2004h> 
[?2004l[?2004h> while current <= end_date:
[?2004l[?2004h>     # Skip weekends
[?2004l[?2004h>     if current.weekday() < 5:  # Monday-Friday
[?2004l[?2004h>         # Check if this is within business hours
[?2004l[?2004h>         if 9 <= current.hour < 18:
[?2004l[?2004h>             meeting_end = current + timedelta(hours=1)
[?2004l[?2004h>             # Make sure meeting ends before 6 PM
[?2004l[?2004h>             if meeting_end.hour <= 18:
[?2004l[?2004h>                 if is_valid_slot(current, meeting_end):
[?2004l[?2004h>                     valid_slots.append(current)
[?2004l[?2004h>     
[?2004l[?2004h>     # Move to next minute
[?2004l[?2004h>     current += timedelta(minutes=1)
[?2004l[?2004h> 
[?2004l[?2004h> if valid_slots:
[?2004l[?2004h>     # Sort by time (earliest first), then by preference score
[?2004l[?2004h>     valid_slots.sort(key=lambda x: (x, get_preference_score(x)))
[?2004l[?2004h>     best_slot = valid_slots[0]
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Found {len(valid_slots)} valid slots")
[?2004l[?2004h>     print(f"\nEarliest valid slot:")
[?2004l[?2004h>     print(f"Start: {best_slot.strftime('%Y-%m-%d %H:%M')} ({best_slot.strftime('%A')})") 
[?2004l[?2004h>     print(f"End: {(best_slot + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M')}")
[?2004l[?2004h>     print(f"\nFormatted for ICS:")
[?2004l[?2004h>     print(f"DTSTART:{best_slot.strftime('%Y%m%dT%H%M%S')}Z")
[?2004l[?2004h>     print(f"DTEND:{(best_slot + timedelta(hours=1)).strftime('%Y%m%dT%H%M%S')}Z")
[?2004l[?2004h> else:
[?2004l[?2004h>     print("No valid slots found!")
[?2004l[?2004h> EOF
