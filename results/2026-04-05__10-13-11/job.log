Sending keys: ['cat > find_meeting_slot.py << \'EOF\'\nimport datetime\nfrom datetime import datetime as dt, timedelta\n\n# Parse ICS file to extract meetings\ndef parse_ics(filename):\n    meetings = []\n    with open(filename, \'r\') as f:\n        content = f.read()\n        events = content.split(\'BEGIN:VEVENT\')[1:]  # Skip first split\n        for event in events:\n            lines = event.split(\'\\n\')\n            start = None\n            end = None\n            for line in lines:\n                if line.startswith(\'DTSTART:\'):\n                    start_str = line.split(\':\', 1)[1].strip()\n                    start = dt.strptime(start_str, \'%Y%m%dT%H%M%SZ\')\n                elif line.startswith(\'DTEND:\'):\n                    end_str = line.split(\':\', 1)[1].strip()\n                    end = dt.strptime(end_str, \'%Y%m%dT%H%M%SZ\')\n            if start and end:\n                meetings.append((start, end))\n    return meetings\n\n# Check if a time slot conflicts with existing meetings\ndef has_conflict(start, end, meetings):\n    for m_start, m_end in meetings:\n        # Check for overlap\n        if start < m_end and end > m_start:\n            return True\n    return False\n\n# Check if slot is valid for Alice\ndef valid_for_alice(start, end):\n    # Alice: 9 AM - 2 PM only (no meetings after 2 PM or before 9 AM)\n    hour = start.hour\n    minute = start.minute\n    end_hour = end.hour\n    end_minute = end.minute\n    \n    # Must start at or after 9 AM\n    if hour < 9:\n        return False\n    # Must end by 2 PM (14:00)\n    if end_hour > 14 or (end_hour == 14 and end_minute > 0):\n        return False\n    return True\n\n# Check if slot is valid for Bob\ndef valid_for_bob(start, end):\n    # Bob: No meetings before 10 AM\n    if start.hour < 10:\n        return False\n    \n    # Must leave by 4:30 PM on Tue/Thu (weekday 1=Tue, 3=Thu)\n    weekday = start.weekday()\n    if weekday in [1, 3]:  # Tuesday or Thursday\n        # Must end by 4:30 PM (16:30)\n        if end.hour > 16 or (end.hour == 16 and end.minute > 30):\n            return False\n    \n    return True\n\n# Check if slot is valid for Carol\ndef valid_for_carol(start, end):\n    # Carol: Available 9 AM - 5 PM\n    if start.hour < 9:\n        return False\n    if end.hour > 17 or (end.hour == 17 and end.minute > 0):\n        return False\n    \n    # Lunch break 12:00-12:30 PM unavailable\n    lunch_start = start.replace(hour=12, minute=0, second=0)\n    lunch_end = start.replace(hour=12, minute=30, second=0)\n    if start < lunch_end and end > lunch_start:\n        return False\n    \n    return True\n\n# Check if Carol needs buffer after this meeting\ndef carol_needs_buffer(end, carol_meetings):\n    # If meeting ends at 4:45 PM or later, needs 15-min buffer\n    if end.hour > 16 or (end.hour == 16 and end.minute >= 45):\n        # Check if there\'s a meeting within 15 minutes after this slot\n        buffer_end = end + timedelta(minutes=15)\n        for m_start, m_end in carol_meetings:\n            if m_start < buffer_end and m_start >= end:\n                return True  # Conflict with buffer\n    return False\n\n# Main logic\nalice_meetings = parse_ics(\'/app/alice_calendar.ics\')\nbob_meetings = parse_ics(\'/app/bob_calendar.ics\')\ncarol_meetings = parse_ics(\'/app/carol_calendar.ics\')\n\nprint("Alice meetings:", alice_meetings)\nprint("Bob meetings:", bob_meetings)\nprint("Carol meetings:", carol_meetings)\n\n# Date range: January 15-19, 2024 (Monday to Friday)\nstart_date = dt(2024, 1, 15, 9, 0, 0)  # Monday 9 AM\nend_date = dt(2024, 1, 19, 18, 0, 0)   # Friday 6 PM\n\n# Try all possible 1-hour slots at minute granularity\ncurrent = start_date\nvalid_slots = []\n\nwhile current < end_date:\n    slot_end = current + timedelta(hours=1)\n    \n    # Check if within same day and business hours (9 AM - 6 PM)\n    if current.date() == slot_end.date() and slot_end.hour <= 18:\n        # Check all constraints\n        if (valid_for_alice(current, slot_end) and\n            valid_for_bob(current, slot_end) and\n            valid_for_carol(current, slot_end) and\n            not has_conflict(current, slot_end, alice_meetings) and\n            not has_conflict(current, slot_end, bob_meetings) and\n            not has_conflict(current, slot_end, carol_meetings) and\n            not carol_needs_buffer(slot_end, carol_meetings)):\n            \n            # Valid slot found\n            is_monday = current.weekday() == 0\n            valid_slots.append((current, slot_end, is_monday))\n    \n    # Move to next minute\n    current += timedelta(minutes=1)\n    \n    # Skip to next day at 9 AM if we\'ve passed 6 PM\n    if current.hour >= 18:\n        next_day = current.date() + timedelta(days=1)\n        current = dt.combine(next_day, dt.min.time()) + timedelta(hours=9)\n\nprint(f"\\nFound {len(valid_slots)} valid slots")\n\nif valid_slots:\n    # Find earliest slot\n    # Among slots at same time, prefer non-Monday (Carol\'s preference)\n    earliest = valid_slots[0]\n    print(f"\\nEarliest valid slot: {earliest[0]} to {earliest[1]}")\n    print(f"Is Monday: {earliest[2]}")\n    \n    # Generate ICS file\n    meeting_start = earliest[0]\n    meeting_end = earliest[1]\n    \n    # Generate UID based on timestamp\n    uid = f"team-planning-{meeting_start.strftime(\'%Y%m%dT%H%M%S\')}@example.com"\n    \n    ics_content = f"""BEGIN:VCALENDAR\nVERSION:2.0\nPRODID:-//Terminal-Bench//Team Meeting Scheduler//EN\nCALSCALE:GREGORIAN\nMETHOD:PUBLISH\n\nBEGIN:VEVENT\nUID:{uid}\nDTSTART:{meeting_start.strftime(\'%Y%m%dT%H%M%SZ\')}\nDTEND:{meeting_end.strftime(\'%Y%m%dT%H%M%SZ\')}\nSUMMARY:Team Planning Meeting\nDESCRIPTION:Team Planning Meeting with Alice, Bob, and Carol\nATTENDEE:alice@example.com\nATTENDEE:bob@example.com\nATTENDEE:carol@example.com\nEND:VEVENT\n\nEND:VCALENDAR\n"""\n    \n    with open(\'/app/meeting_scheduled.ics\', \'w\') as f:\n        f.write(ics_content)\n    \n    print(f"\\nMeeting scheduled: {meeting_start} to {meeting_end}")\n    print(f"ICS file created: /app/meeting_scheduled.ics")\nelse:\n    print("No valid slot found!")\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
