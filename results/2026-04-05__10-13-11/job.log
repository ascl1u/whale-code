Sending keys: ['cat > find_slot.py << \'EOF\'\nfrom datetime import datetime, timedelta\n\n# Define the date range: Jan 15-19, 2024\ndays = [\n    datetime(2024, 1, 15),  # Monday\n    datetime(2024, 1, 16),  # Tuesday\n    datetime(2024, 1, 17),  # Wednesday\n    datetime(2024, 1, 18),  # Thursday\n    datetime(2024, 1, 19),  # Friday\n]\n\n# Alice\'s existing meetings\nalice_meetings = [\n    (datetime(2024, 1, 15, 10, 0), datetime(2024, 1, 15, 11, 0)),\n    (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 14, 0)),\n    (datetime(2024, 1, 16, 10, 0), datetime(2024, 1, 16, 12, 0)),\n    (datetime(2024, 1, 17, 10, 0), datetime(2024, 1, 17, 11, 0)),\n    (datetime(2024, 1, 17, 13, 0), datetime(2024, 1, 17, 14, 0)),\n    (datetime(2024, 1, 18, 10, 0), datetime(2024, 1, 18, 11, 0)),\n    (datetime(2024, 1, 19, 10, 0), datetime(2024, 1, 19, 11, 0)),\n    (datetime(2024, 1, 19, 13, 0), datetime(2024, 1, 19, 14, 0)),\n]\n\n# Bob\'s existing meetings\nbob_meetings = [\n    (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),\n    (datetime(2024, 1, 15, 13, 0), datetime(2024, 1, 15, 15, 0)),\n    (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n    (datetime(2024, 1, 18, 13, 0), datetime(2024, 1, 18, 14, 0)),\n    (datetime(2024, 1, 19, 12, 0), datetime(2024, 1, 19, 13, 0)),\n]\n\n# Carol\'s existing meetings\ncarol_meetings = [\n    (datetime(2024, 1, 15, 11, 0), datetime(2024, 1, 15, 12, 0)),\n    (datetime(2024, 1, 16, 11, 0), datetime(2024, 1, 16, 12, 0)),\n    (datetime(2024, 1, 16, 13, 0), datetime(2024, 1, 16, 14, 0)),\n    (datetime(2024, 1, 17, 12, 0), datetime(2024, 1, 17, 13, 0)),\n    (datetime(2024, 1, 18, 12, 0), datetime(2024, 1, 18, 13, 0)),\n    (datetime(2024, 1, 19, 11, 0), datetime(2024, 1, 19, 12, 0)),\n]\n\ndef has_conflict(start, end, meetings):\n    """Check if a time slot conflicts with existing meetings"""\n    for m_start, m_end in meetings:\n        # Conflicts if: new start < existing end AND new end > existing start\n        if start < m_end and end > m_start:\n            return True\n    return False\n\ndef check_alice_constraints(start, end):\n    """Alice: 9 AM - 2 PM only"""\n    hour_start = start.hour + start.minute / 60.0\n    hour_end = end.hour + end.minute / 60.0\n    \n    if hour_start < 9 or hour_end > 14:\n        return False\n    if has_conflict(start, end, alice_meetings):\n        return False\n    return True\n\ndef check_bob_constraints(start, end):\n    """Bob: No meetings before 10 AM, must leave by 4:30 PM on Tue/Thu"""\n    hour_start = start.hour + start.minute / 60.0\n    hour_end = end.hour + end.minute / 60.0\n    \n    if hour_start < 10:\n        return False\n    \n    # Tuesday (1/16) or Thursday (1/18)\n    if start.day in [16, 18] and hour_end > 16.5:  # 4:30 PM = 16.5\n        return False\n    \n    if has_conflict(start, end, bob_meetings):\n        return False\n    return True\n\ndef check_carol_constraints(start, end):\n    """Carol: 9 AM-5 PM, lunch 12:00-12:30 PM unavailable"""\n    hour_start = start.hour + start.minute / 60.0\n    hour_end = end.hour + end.minute / 60.0\n    \n    if hour_start < 9 or hour_end > 17:\n        return False\n    \n    # Check lunch conflict (12:00-12:30 PM)\n    lunch_start = start.replace(hour=12, minute=0, second=0)\n    lunch_end = start.replace(hour=12, minute=30, second=0)\n    if start < lunch_end and end > lunch_start:\n        return False\n    \n    if has_conflict(start, end, carol_meetings):\n        return False\n    return True\n\ndef is_valid_slot(start, end):\n    """Check if a slot satisfies all constraints"""\n    return (check_alice_constraints(start, end) and\n            check_bob_constraints(start, end) and\n            check_carol_constraints(start, end))\n\ndef is_monday(dt):\n    return dt.weekday() == 0\n\n# Find the earliest valid slot\nvalid_slots = []\n\nfor day in days:\n    # Check every minute from 9 AM to 6 PM\n    for hour in range(9, 18):\n        for minute in range(0, 60):\n            start = day.replace(hour=hour, minute=minute, second=0)\n            end = start + timedelta(hours=1)\n            \n            # Don\'t go past 6 PM\n            if end.hour > 18 or (end.hour == 18 and end.minute > 0):\n                continue\n            \n            if is_valid_slot(start, end):\n                valid_slots.append(start)\n\nif valid_slots:\n    # Sort by time (earliest first)\n    valid_slots.sort()\n    \n    # Among earliest slots, prefer non-Monday (Carol\'s preference)\n    earliest_time = valid_slots[0]\n    \n    # Find all slots at the same earliest time\n    earliest_slots = [s for s in valid_slots if s == earliest_time]\n    \n    # If earliest is Monday, check if there\'s a non-Monday slot very soon after\n    # But the requirement is to find the EARLIEST valid slot first\n    chosen_slot = earliest_time\n    \n    print(f"Earliest valid slot: {chosen_slot}")\n    print(f"Day: {chosen_slot.strftime(\'%A, %B %d, %Y\')}")\n    print(f"Time: {chosen_slot.strftime(\'%I:%M %p\')} - {(chosen_slot + timedelta(hours=1)).strftime(\'%I:%M %p\')}")\n    print(f"Is Monday: {is_monday(chosen_slot)}")\n    \n    # Generate ICS file\n    start_str = chosen_slot.strftime(\'%Y%m%dT%H%M%SZ\')\n    end_str = (chosen_slot + timedelta(hours=1)).strftime(\'%Y%m%dT%H%M%SZ\')\n    \n    ics_content = f"""BEGIN:VCALENDAR\nVERSION:2.0\nPRODID:-//Terminal-Bench//Team Meeting Scheduler//EN\nCALSCALE:GREGORIAN\nMETHOD:PUBLISH\n\nBEGIN:VEVENT\nUID:team-planning-meeting@example.com\nDTSTART:{start_str}\nDTEND:{end_str}\nSUMMARY:Team Planning Meeting\nDESCRIPTION:Team Planning Meeting with Alice, Bob, and Carol\nATTENDEE:mailto:alice@example.com\nATTENDEE:mailto:bob@example.com\nATTENDEE:mailto:carol@example.com\nEND:VEVENT\n\nEND:VCALENDAR"""\n    \n    with open(\'/app/meeting_scheduled.ics\', \'w\') as f:\n        f.write(ics_content)\n    \n    print("\\nICS file created: /app/meeting_scheduled.ics")\nelse:\n    print("No valid slot found!")\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
