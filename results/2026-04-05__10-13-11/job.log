Sending keys: ['cat > find_meeting.py << \'EOF\'\nimport re\nfrom datetime import datetime, timedelta\n\n# Parse ICS files\ndef parse_ics(filename):\n    events = []\n    with open(filename, \'r\') as f:\n        content = f.read()\n        # Find all VEVENT blocks\n        vevent_pattern = r\'BEGIN:VEVENT.*?END:VEVENT\'\n        vevents = re.findall(vevent_pattern, content, re.DOTALL)\n        \n        for vevent in vevents:\n            # Extract DTSTART and DTEND\n            start_match = re.search(r\'DTSTART:(\\d{8}T\\d{6}Z)\', vevent)\n            end_match = re.search(r\'DTEND:(\\d{8}T\\d{6}Z)\', vevent)\n            \n            if start_match and end_match:\n                start = datetime.strptime(start_match.group(1), \'%Y%m%dT%H%M%SZ\')\n                end = datetime.strptime(end_match.group(1), \'%Y%m%dT%H%M%SZ\')\n                events.append((start, end))\n    \n    return events\n\n# Parse all calendars\nalice_events = parse_ics(\'/app/alice_calendar.ics\')\nbob_events = parse_ics(\'/app/bob_calendar.ics\')\ncarol_events = parse_ics(\'/app/carol_calendar.ics\')\n\nprint("Alice\'s busy times:")\nfor start, end in alice_events:\n    print(f"  {start} - {end}")\n\nprint("\\nBob\'s busy times:")\nfor start, end in bob_events:\n    print(f"  {start} - {end}")\n\nprint("\\nCarol\'s busy times:")\nfor start, end in carol_events:\n    print(f"  {start} - {end}")\n\n# Generate all possible 1-hour slots for Jan 15-19, 2024\n# Business hours: 9 AM - 6 PM, but we need to check individual constraints\ndef generate_slots():\n    slots = []\n    # Jan 15-19, 2024 (Monday to Friday)\n    for day in range(15, 20):\n        date = datetime(2024, 1, day, 0, 0, 0)\n        # Generate slots at minute granularity from 9 AM to 5 PM (last slot starts at 5 PM, ends at 6 PM)\n        for hour in range(9, 18):\n            for minute in range(0, 60):\n                start = datetime(2024, 1, day, hour, minute, 0)\n                end = start + timedelta(hours=1)\n                # Only consider slots that end by 6 PM\n                if end.hour <= 18:\n                    slots.append((start, end))\n    return slots\n\ndef check_conflict(start, end, events):\n    """Check if a time slot conflicts with existing events"""\n    for event_start, event_end in events:\n        # Conflict if there\'s any overlap\n        if start < event_end and end > event_start:\n            return True\n    return False\n\ndef check_alice_constraints(start, end):\n    """Alice: 9 AM - 2 PM only"""\n    if start.hour < 9:\n        return False\n    if end.hour > 14:\n        return False\n    if end.hour == 14 and end.minute > 0:\n        return False\n    return True\n\ndef check_bob_constraints(start, end):\n    """Bob: No meetings before 10 AM, must leave by 4:30 PM on Tue/Thu"""\n    if start.hour < 10:\n        return False\n    \n    # Check if it\'s Tuesday (16th) or Thursday (18th)\n    if start.day in [16, 18]:\n        # Must leave by 4:30 PM, so meeting must end by 4:30 PM\n        if end.hour > 16 or (end.hour == 16 and end.minute > 30):\n            return False\n    return True\n\ndef check_carol_constraints(start, end):\n    """Carol: 9 AM - 5 PM, lunch 12:00-12:30 PM unavailable"""\n    if start.hour < 9:\n        return False\n    if end.hour > 17:\n        return False\n    \n    # Check lunch conflict (12:00-12:30 PM)\n    lunch_start = datetime(start.year, start.month, start.day, 12, 0, 0)\n    lunch_end = datetime(start.year, start.month, start.day, 12, 30, 0)\n    if start < lunch_end and end > lunch_start:\n        return False\n    \n    return True\n\ndef is_monday(dt):\n    return dt.weekday() == 0\n\n# Find valid slots\nvalid_slots = []\nfor start, end in generate_slots():\n    # Check all hard constraints\n    if not check_alice_constraints(start, end):\n        continue\n    if not check_bob_constraints(start, end):\n        continue\n    if not check_carol_constraints(start, end):\n        continue\n    \n    # Check conflicts with existing calendars\n    if check_conflict(start, end, alice_events):\n        continue\n    if check_conflict(start, end, bob_events):\n        continue\n    if check_conflict(start, end, carol_events):\n        continue\n    \n    valid_slots.append((start, end))\n\nif not valid_slots:\n    print("\\nNo valid slots found!")\nelse:\n    # Sort by time (earliest first), then prefer non-Monday\n    valid_slots.sort(key=lambda x: (x[0], is_monday(x[0])))\n    \n    print(f"\\nFound {len(valid_slots)} valid slots")\n    print("\\nFirst 10 valid slots:")\n    for i, (start, end) in enumerate(valid_slots[:10]):\n        day_name = start.strftime(\'%A\')\n        print(f"  {i+1}. {start} - {end} ({day_name})")\n    \n    # Select the earliest slot\n    selected_start, selected_end = valid_slots[0]\n    print(f"\\nSelected slot: {selected_start} - {selected_end}")\n    \n    # Generate ICS file\n    ics_content = f"""BEGIN:VCALENDAR\nVERSION:2.0\nPRODID:-//Terminal-Bench//Team Planning Meeting//EN\nCALSCALE:GREGORIAN\nMETHOD:PUBLISH\n\nBEGIN:VEVENT\nUID:team-planning-{selected_start.strftime(\'%Y%m%dT%H%M%S\')}@example.com\nDTSTART:{selected_start.strftime(\'%Y%m%dT%H%M%SZ\')}\nDTEND:{selected_end.strftime(\'%Y%m%dT%H%M%SZ\')}\nSUMMARY:Team Planning Meeting\nDESCRIPTION:Team planning meeting with Alice, Bob, and Carol\nATTENDEE:alice@example.com\nATTENDEE:bob@example.com\nATTENDEE:carol@example.com\nEND:VEVENT\n\nEND:VCALENDAR"""\n    \n    with open(\'/app/meeting_scheduled.ics\', \'w\') as f:\n        f.write(ics_content)\n    \n    print("\\nICS file created at /app/meeting_scheduled.ics")\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
