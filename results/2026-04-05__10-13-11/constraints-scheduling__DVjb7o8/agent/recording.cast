[51.378303, "o", "cat meeting_scheduled.ics; printf '%s\\n' '__CMDEND__6__'\r\n\u001b[?2004l\r"]
[51.380609, "o", "BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//Terminal-Bench//Team Meeting Scheduler//EN\r\nCALSCALE:GREGORIAN\r\nMETHOD:PUBLISH\r\n\r\nBEGIN:VEVENT\r\nUID:team-planning-20240117T110000@example.com\r\nDTSTART:20240117T110000Z\r\nDTEND:20240117T120000Z\r\nSUMMARY:Team Planning Meeting\r\nDESCRIPTION:Team Planning Meeting with Alice, Bob, and Carol\r\nATTENDEE:alice@example.com\r\nATTENDEE:bob@example.com\r\nATTENDEE:carol@example.com\r\nEND:VEVENT\r\n\r\nEND:VCALENDAR\r\n"]
