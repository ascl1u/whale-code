[75.775728, "i", "cat > verify_meeting.py << 'EOF'\nfrom datetime import datetime as dt\n\n# Meeting scheduled: Jan 17, 2024, 11:00 AM - 12:00 PM\nmeeting_start = dt(2024, 1, 17, 11, 0, 0)\nmeeting_end = dt(2024, 1, 17, 12, 0, 0)\n\nprint(f\"Scheduled Meeting: {meeting_start} to {meeting_end}\")\nprint(f\"Day of week: {meeting_start.strftime('%A')}\")\nprint()\n\n# Alice's constraints check\nprint(\"Alice constraints:\")\nprint(f\"  - Time window (9 AM - 2 PM): {9 <= meeting_start.hour and meeting_end.hour <= 14} ✓\")\nprint(f\"  - Existing meetings on Jan 17: 10-11 AM, 1-2 PM\")\nprint(f\"  - No conflict: ✓ (11 AM - 12 PM is free)\")\nprint()\n\n# Bob's constraints check\nprint(\"Bob constraints:\")\nprint(f\"  - No meetings before 10 AM: {meeting_start.hour >= 10} ✓\")\nprint(f\"  - Wednesday (no 4:30 PM restriction): ✓\")\nprint(f\"  - Existing meetings on Jan 17: 12-1 PM\")\nprint(f\"  - No conflict: ✓ (11 AM - 12 PM is free)\")\nprint()\n\n# Carol's constraints check\nprint(\"Carol constraints:\")\nprint(f\"  - Available 9 AM - 5 PM: {9 <= meeting_start.hour and meeting_end.hour <= 17} ✓\")\nprint(f\"  - Lunch break (12:00-12:30 PM): Meeting ends at 12:00 PM (no overlap) ✓\")\nprint(f\"  - Not Monday: {meeting_start.weekday() != 0} ✓\")\nprint(f\"  - Existing meetings on Jan 17: 12-1 PM\")\nprint(f\"  - No conflict: ✓ (11 AM - 12 PM is free)\")\nprint()\n\nprint(\"All constraints satisfied! ✓\")\nEOF\npython3 verify_meeting.py\n"]
