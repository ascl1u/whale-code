[60.786145, "o", "drwxr-xr-x 1 root root 4096 Apr  5 17:15 \u001b[0m\u001b[01;34m.\u001b[0m\r\ndrwxr-xr-x 1 root root 4096 Apr  5 17:14 \u001b[01;34m..\u001b[0m\r\n-rw-r--r-- 1 root root 1660 Oct 24 05:18 alice_calendar.ics\r\n-rw-r--r-- 1 root root 1209 Oct 24 05:18 bob_calendar.ics\r\n-rw-r--r-- 1 root root 1263 Oct 24 05:18 carol_calendar.ics\r\n-rw-r--r-- 1 root root  419 Apr  5 17:14 meeting_scheduled.ics\r\n"]
