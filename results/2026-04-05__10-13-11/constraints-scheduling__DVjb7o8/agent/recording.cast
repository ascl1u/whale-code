[40.956717, "o", "    \r\n\u001b[?2004l\re\u001b[?2004h> "]
[40.95743, "o", "    # Must leave by 4:30 PM on Tue/Thu (weekday 1=Tue, 3=Thu)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.957758, "o", "    weekday = start.weekday()\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.957901, "o", "> "]
[40.958214, "o", "    if weekday in [1, 3]:  # Tuesday or Thursday\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.958509, "o", "        # Must end by 4:30 PM (16:30)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.958888, "o", "        if end.hour > 16 or (end.hour == 16 and end.minute > 30):\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.959077, "o", "> "]
[40.959309, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.959489, "o", ">     return True\r\n\u001b[?2004l\r"]
[40.959681, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.959868, "o", "# Check if slot is valid for Carol\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.960051, "o", "def valid_for_carol(start, end):\r\n\u001b[?2004l\r"]
[40.960233, "o", "\u001b[?2004h> "]
[40.960405, "o", "    # Carol: Available 9 AM - 5 PM\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.960659, "o", "    if start.hour < 9:\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.960806, "o", ">         return False\r\n\u001b[?2004l\r"]
[40.961064, "o", "\u001b[?2004h> "]
[40.961288, "o", "    if end.hour > 17 or (end.hour == 17 and end.minute > 0):\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.961528, "o", "> "]
[40.961719, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.961987, "o", "    # Lunch break 12:00-12:30 PM unavailable\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.962423, "o", "    lunch_start = start.replace(hour=12, minute=0, second=0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.962609, "o", "> "]
[40.962865, "o", "    lunch_end = start.replace(hour=12, minute=30, second=0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.963069, "o", "> "]
[40.963236, "o", "    if start < lunch_end and end > lunch_start:\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.963428, "o", "> "]
[40.963626, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[40.963727, "o", "\u001b[?2004h>     return True\r\n\u001b[?2004l\r"]
[40.963958, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.964253, "o", "# Check if Carol needs buffer after this meeting\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.964585, "o", "def carol_needs_buffer(end, carol_meetings):\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.96475, "o", "> "]
[40.96507, "o", "    # If meeting ends at 4:45 PM or later, needs 15-min buffer\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.965493, "o", "    if end.hour > 16 or (end.hour == 16 and end.minute >= 45):\r\n\u001b[?2004l\r"]
[40.965679, "o", "\u001b[?2004h> "]
[40.965887, "o", "        # Check if there's a meeting within 15 minutes after this slot\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.966173, "o", "        buffer_end = end + timedelta(minutes=15)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.966348, "o", "> "]
[40.966502, "o", "        for m_start, m_end in carol_meetings:\r\n\u001b[?2004l\r"]
[40.966689, "o", "\u001b[?2004h> "]
[40.966894, "o", "            if m_start < buffer_end and m_start >= end:\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.967083, "o", "> "]
[40.967244, "o", "                return True  # Conflict with buffer\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.967414, "o", "    return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.96763, "o", "> # Main logic\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.967825, "o", "alice_meetings = parse_ics('/app/alice_calendar.ics')\r\n\u001b[?2004l\r"]
[40.967998, "o", "\u001b[?2004h> "]
[40.968219, "o", "bob_meetings = parse_ics('/app/bob_calendar.ics')\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.968407, "o", "> "]
[40.968572, "o", "carol_meetings = parse_ics('/app/carol_calendar.ics')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.968754, "o", "\u001b[?2004h> "]
[40.968934, "o", "print(\"Alice meetings:\", alice_meetings)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.969122, "o", "print(\"Bob meetings:\", bob_meetings)\r\n\u001b[?2004l\r"]
[40.96938, "o", "\u001b[?2004h> "]
[40.969591, "o", "print(\"Carol meetings:\", carol_meetings)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.969807, "o", "# Date range: January 15-19, 2024 (Monday to Friday)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.970104, "o", "start_date = dt(2024, 1, 15, 9, 0, 0)  # Monday 9 AM\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.970408, "o", "end_date = dt(2024, 1, 19, 18, 0, 0)   # Friday 6 PM\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.970583, "o", "\u001b[?2004h> "]
[40.970802, "o", "# Try all possible 1-hour slots at minute granularity\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.970986, "o", "current = start_date\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.971201, "o", "valid_slots = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.971378, "o", "while current < end_date:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.971541, "o", "    slot_end = current + timedelta(hours=1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.971715, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.972013, "o", "    # Check if within same day and business hours (9 AM - 6 PM)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.972328, "o", "    if current.date() == slot_end.date() and slot_end.hour <= 18:\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.972496, "o", "> "]
[40.972686, "o", "        # Check all constraints\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.972896, "o", "        if (valid_for_alice(current, slot_end) and\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.973105, "o", "            valid_for_bob(current, slot_end) and\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.973297, "o", "> "]
[40.973689, "o", "            valid_for_carol(current, slot_end) and\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.973819, "o", "            not has_conflict(current, slot_end, alice_meetings) and\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.974182, "o", "            not has_conflict(current, slot_end, bob_meetings) and\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.974653, "o", "            not has_conflict(current, slot_end, carol_meetings) and\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.974855, "o", "> "]
[40.975066, "o", "            not carol_needs_buffer(slot_end, carol_meetings)):\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.975294, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.975475, "o", "> "]
[40.975668, "o", "            # Valid slot found\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.975834, "o", "            is_monday = current.weekday() == 0\r\n\u001b[?2004l\r"]
[40.976021, "o", "\u001b[?2004h> "]
[40.976246, "o", "            valid_slots.append((current, slot_end, is_monday))\r\n\u001b[?2004l\r"]
[40.976431, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.976641, "o", "    # Move to next minute\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.976877, "o", "    current += timedelta(minutes=1)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.977096, "o", "    # Skip to next day at 9 AM if we've passed 6 PM\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.977267, "o", "    if current.hour >= 18:\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.977504, "o", "> "]
[40.977692, "o", "        next_day = current.date() + timedelta(days=1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.977897, "o", "> "]
[40.978175, "o", "        current = dt.combine(next_day, dt.min.time()) + timedelta(hours=9)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.978357, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.97856, "o", "print(f\"\\nFound {len(valid_slots)} valid slots\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.978754, "o", "\u001b[?2004h> "]
[40.978985, "o", "if valid_slots:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.979157, "o", "    # Find earliest slot\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.97947, "o", "    # Among slots at same time, prefer non-Monday (Carol's preference)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.979572, "o", "> "]
[40.979833, "o", "    earliest = valid_slots[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.98018, "o", "    print(f\"\\nEarliest valid slot: {earliest[0]} to {earliest[1]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.98037, "o", "> "]
[40.980595, "o", "    print(f\"Is Monday: {earliest[2]}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.98072, "o", ">     # Generate ICS file\r\n\u001b[?2004l\r"]
[40.980902, "o", "\u001b[?2004h> "]
[40.981119, "o", "    meeting_start = earliest[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.98135, "o", "    meeting_end = earliest[1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.98157, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.981867, "o", "    # Generate UID based on timestamp\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.982147, "o", "    uid = f\"team-planning-{meeting_start.strftime('%Y%m%dT%H%M%S')}@example.com\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.982332, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.982606, "o", "    ics_content = f\"\"\"BEGIN:VCALENDAR\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.982855, "o", "> VERSION:2.0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.983148, "o", "PRODID:-//Terminal-Bench//Team Meeting Scheduler//EN\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.983432, "o", "> CALSCALE:GREGORIAN\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.983654, "o", "METHOD:PUBLISH\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.983891, "o", "BEGIN:VEVENT\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.984149, "o", "UID:{uid}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.984414, "o", "DTSTART:{meeting_start.strftime('%Y%m%dT%H%M%SZ')}\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.984714, "o", "> "]
[40.98494, "o", "DTEND:{meeting_end.strftime('%Y%m%dT%H%M%SZ')}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.985176, "o", "SUMMARY:Team Planning Meeting\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.985573, "o", "DESCRIPTION:Team Planning Meeting with Alice, Bob, and Carol\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.048899, "o", "> "]
[41.049429, "o", "ATTENDEE:alice@example.com\r\n\u001b[?2004l\r\u001b[?2004h> ATTENDEE:bob@example.com\r\n\u001b[?2004l\r\u001b[?2004h> ATTENDEE:carol@example.com\r\n\u001b[?2004l\r\u001b[?2004h> END:VEVENT\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> END:VCALENDAR\r\n\u001b[?2004l\r\u001b[?2004h> \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     with open('/app/meeting_scheduled.ics', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(ics_content)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"\\nMeeting scheduled: {meeting_start} to {meeting_end}\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"ICS file created: /app/meeting_scheduled.ics\")\r\n\u001b[?2004l\r\u001b[?2004h> else:\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"No valid slot found!\")\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r\u001b[?2004hroot@b99d382ae3d4:/app# "]
[45.202321, "i", "python3 find_meeting_slot.py; printf '%s\\n' '__CMDEND__5__'\n"]
[45.202925, "o", "python3 find_meeting_slot.py; printf '%s\\n' '__CMDEND__5__'\r\n\u001b[?2004l\r"]
[45.231996, "o", "Alice meetings: [(datetime.datetime(2024, 1, 15, 10, 0), datetime.datetime(2024, 1, 15, 11, 0)), (datetime.datetime(2024, 1, 15, 13, 0), datetime.datetime(2024, 1, 15, 14, 0)), (datetime.datetime(2024, 1, 16, 10, 0), datetime.datetime(2024, 1, 16, 12, 0)), (datetime.datetime(2024, 1, 17, 10, 0), datetime.datetime(2024, 1, 17, 11, 0)), (datetime.datetime(2024, 1, 17, 13, 0), datetime.datetime(2024, 1, 17, 14, 0)), (datetime.datetime(2024, 1, 18, 10, 0), datetime.datetime(2024, 1, 18, 11, 0)), (datetime.datetime(2024, 1, 19, 10, 0), datetime.datetime(2024, 1, 19, 11, 0)), (datetime.datetime(2024, 1, 19, 13, 0), datetime.datetime(2024, 1, 19, 14, 0))]\r\nBob meetings: [(datetime.datetime(2024, 1, 15, 11, 0), datetime.datetime(2024, 1, 15, 12, 0)), (datetime.datetime(2024, 1, 15, 13, 0), datetime.datetime(2024, 1, 15, 15, 0)), (datetime.datetime(2024, 1, 16, 13, 0), datetime.datetime(2024, 1, 16, 14, 0)), (datetime.datetime(2024, 1, 17, 12, 0), datetime.datetime(2024, 1, 17, 13, 0)), (datetime.datetime(2024, 1, 18, 13, 0), datetime.datetime(2024, 1, 18, 14, 0)), (datetime.datetime(2024, 1, 19, 12, 0), datetime.datetime(2024, 1, 19, 13, 0))]\r\nCarol meetings: [(datetime.datetime(2024, 1, 15, 11, 0), datetime.datetime(2024, 1, 15, 12, 0)), (datetime.datetime(2024, 1, 16, 11, 0), datetime.datetime(2024, 1, 16, 12, 0)), (datetime.datetime(2024, 1, 16, 13, 0), datetime.datetime(2024, 1, 16, 14, 0)), (datetime.datetime(2024, 1, 17, 12, 0), datetime.datetime(2024, 1, 17, 13, 0)), (datetime.datetime(2024, 1, 18, 12, 0), datetime.datetime(2024, 1, 18, 13, 0)), (datetime.datetime(2024, 1, 19, 11, 0), datetime.datetime(2024, 1, 19, 12, 0))]\r\n"]
[45.239807, "o", "\r\nFound 2 valid slots\r\n\r\nEarliest valid slot: 2024-01-17 11:00:00 to 2024-01-17 12:00:00\r\nIs Monday: False\r\n"]
[45.240129, "o", "\r\nMeeting scheduled: 2024-01-17 11:00:00 to 2024-01-17 12:00:00\r\nICS file created: /app/meeting_scheduled.ics\r\n"]
[45.246118, "o", "__CMDEND__5__\r\n\u001b[?2004h"]
