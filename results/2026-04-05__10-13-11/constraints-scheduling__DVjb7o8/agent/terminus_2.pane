[?2004l[?2004h>         return False
[?2004l[?2004h>     return True
[?2004l[?2004h> 
[?2004l[?2004h> # Check if slot is valid for Bob
[?2004l[?2004h> def valid_for_bob(start, end):
[?2004l[?2004h>     # Bob: No meetings before 10 AM
[?2004l[?2004h>     if start.hour < 10:
[?2004l[?2004h>         return False
[?2004lc[?2004h>     
[?2004le[?2004h>     # Must leave by 4:30 PM on Tue/Thu (weekday 1=Tue, 3=Thu)
[?2004l[?2004h>     weekday = start.weekday()
[?2004l[?2004h>     if weekday in [1, 3]:  # Tuesday or Thursday
[?2004l[?2004h>         # Must end by 4:30 PM (16:30)
