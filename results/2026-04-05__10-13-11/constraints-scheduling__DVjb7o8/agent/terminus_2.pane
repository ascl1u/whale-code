[?2004l[?2004h>     # Alice: 9 AM - 2 PM only (no meetings after 2 PM or before 9 AM)
[?2004l[?2004h>     hour = start.hour
[?2004l[?2004h>     minute = start.minute
[?2004le[?2004h>     end_hour = end.hour
[?2004l[?2004h>     end_minute = end.minute
