[?2004l[?2004h>                     start_str = line.split(':', 1)[1].strip()
[?2004l[?2004h>                     start = dt.strptime(start_str, '%Y%m%dT%H%M%SZ')
[?2004l[?2004h>                 elif line.startswith('DTEND:'):
[?2004l[?2004h>                     end_str = line.split(':', 1)[1].strip()
[?2004l[?2004h>                     end = dt.strptime(end_str, '%Y%m%dT%H%M%SZ')
[?2004l[?2004h>             if start and end:
