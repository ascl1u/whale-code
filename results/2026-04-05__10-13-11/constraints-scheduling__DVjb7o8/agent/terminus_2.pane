[?2004l[?2004h>     return meetings
[?2004l[?2004h> 
[?2004l[?2004h> # Check if a time slot conflicts with existing meetings
[?2004l[?2004h> def has_conflict(start, end, meetings):
[?2004ln[?2004h>     for m_start, m_end in meetings:
[?2004l[?2004h>         # Check for overlap
[?2004l[?2004h>         if start < m_end and end > m_start:
[?2004ln[?2004h>             return True
[?2004l[?2004h>     return False
