[?2004l[?2004h>             return False
[?2004l[?2004h>     
[?2004l[?2004h>     return True
[?2004l[?2004h> 
[?2004l[?2004h> # Check if slot is valid for Carol
[?2004l[?2004h> def valid_for_carol(start, end):
[?2004l[?2004h>     # Carol: Available 9 AM - 5 PM
[?2004l[?2004h>     if start.hour < 9:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if end.hour > 17 or (end.hour == 17 and end.minute > 0):
