[39.221002, "o", "> def check_alice_constraints(start, end):\r\n\u001b[?2004l\r"]
[39.22123, "o", "\u001b[?2004h>     \"\"\"Alice: 9 AM - 2 PM only\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.221438, "o", "    if start.hour < 9:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.221669, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     if end.hour > 14:\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.221899, "o", ">         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.22211, "o", "    if end.hour == 14 and end.minute > 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.22231, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.222503, "o", "    return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.222653, "o", "def check_bob_constraints(start, end):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.223072, "o", "    \"\"\"Bob: No meetings before 10 AM, must leave by 4:30 PM on Tue/Thu\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.223254, "o", "    if start.hour < 10:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.223413, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[39.223609, "o", "\u001b[?2004h> "]
[39.223856, "o", "    # Check if it's Tuesday (16th) or Thursday (18th)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.224049, "o", "    if start.day in [16, 18]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.233881, "o", "        # Must leave by 4:30 PM, so meeting must end by 4:30 PM\r\n\u001b[?2004l\r\u001b[?2004h>         if end.hour > 16 or (end.hour == 16 and end.minute > 30):\r\n\u001b[?2004l\r\u001b[?2004h>             return False\r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def check_carol_constraints(start, end):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Carol: 9 AM - 5 PM, lunch 12:00-12:30 PM unavailable\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     if start.hour < 9:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     if end.hour > 17:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Check lunch conflict (12:00-12:30 PM)\r\n\u001b[?2004l\r\u001b[?2004h>     lunch_start = datetime(start.year, start.month, start.day, 12, 0, 0)\r\n\u001b[?2004l\r\u001b[?2004h>     lunch_end = datetime(start.year, start.month, start.day, 12, 30, 0)\r\n\u001b[?2004l\r\u001b[?2004h>     if start < lunch_end and end > lunch_start:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n\u001b[?2004l\r"]
[39.234139, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.234376, "o", "def is_monday(dt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.234519, "o", "    return dt.weekday() == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.234723, "o", "# Find valid slots\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.234834, "o", "valid_slots = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.235091, "o", "for start, end in generate_slots():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.235277, "o", "    # Check all hard constraints\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.235462, "o", "    if not check_alice_constraints(start, end):\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.235694, "o", ">         continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.235903, "o", "    if not check_bob_constraints(start, end):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.236112, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.236472, "o", "    if not check_carol_constraints(start, end):\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.236562, "o", "> "]
[39.23685, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.23702, "o", "    # Check conflicts with existing calendars\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.237316, "o", "    if check_conflict(start, end, alice_events):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.237504, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.237722, "o", "    if check_conflict(start, end, bob_events):\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.237818, "o", ">         continue\r\n\u001b[?2004l\r"]
[39.237997, "o", "\u001b[?2004h> "]
[39.238179, "o", "    if check_conflict(start, end, carol_events):\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.238286, "o", "> "]
[39.238458, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.2387, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.238822, "o", "    valid_slots.append((start, end))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.239014, "o", "if not valid_slots:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.239318, "o", "    print(\"\\nNo valid slots found!\")\r\n\u001b[?2004l\r\u001b[?2004h> else:\r\n\u001b[?2004l\r"]
[39.239531, "o", "\u001b[?2004h> "]
[39.239725, "o", "    # Sort by time (earliest first), then prefer non-Monday\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.239967, "o", "    valid_slots.sort(key=lambda x: (x[0], is_monday(x[0])))\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.240191, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.240493, "o", "    print(f\"\\nFound {len(valid_slots)} valid slots\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.240704, "o", "> "]
[39.240901, "o", "    print(\"\\nFirst 10 valid slots:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.241078, "o", "    for i, (start, end) in enumerate(valid_slots[:10]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.241335, "o", "        day_name = start.strftime('%A')\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.241522, "o", "> "]
[39.241663, "o", "        print(f\"  {i+1}. {start} - {end} ({day_name})\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.241835, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.24207, "o", "    # Select the earliest slot\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.242331, "o", "    selected_start, selected_end = valid_slots[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.242687, "o", "    print(f\"\\nSelected slot: {selected_start} - {selected_end}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.242876, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.243116, "o", "    # Generate ICS file\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.243325, "o", "    ics_content = f\"\"\"BEGIN:VCALENDAR\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.243523, "o", "> VERSION:2.0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.243703, "o", "PRODID:-//Terminal-Bench//Team Planning Meeting//EN\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.243919, "o", "CALSCALE:GREGORIAN\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.244206, "o", "> METHOD:PUBLISH\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.244398, "o", "BEGIN:VEVENT\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.244604, "o", "> "]
[39.24485, "o", "UID:team-planning-{selected_start.strftime('%Y%m%dT%H%M%S')}@example.com\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.245111, "o", "DTSTART:{selected_start.strftime('%Y%m%dT%H%M%SZ')}\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.245228, "o", "> "]
[39.245463, "o", "DTEND:{selected_end.strftime('%Y%m%dT%H%M%SZ')}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.245659, "o", "SUMMARY:Team Planning Meeting\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.246207, "o", "DESCRIPTION:Team planning meeting with Alice, Bob, and Carol\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.246538, "o", "ATTENDEE:alice@example.com\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.246757, "o", "> "]
[39.246972, "o", "ATTENDEE:bob@example.com\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.247268, "o", "ATTENDEE:carol@example.com\r\n\u001b[?2004l\r\u001b[?2004h> END:VEVENT\r\n\u001b[?2004l\r"]
[39.247504, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.247742, "o", "END:VCALENDAR\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.248259, "o", "    with open('/app/meeting_scheduled.ics', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.248438, "o", "        f.write(ics_content)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.248756, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.249087, "o", "    print(\"\\nICS file created at /app/meeting_scheduled.ics\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.249308, "o", "EOF\r\n\u001b[?2004l\r"]
[39.252742, "o", "\u001b[?2004hroot@12ed0c16d4a4:/app# "]
[44.269778, "i", "python3 find_meeting.py; printf '%s\\n' '__CMDEND__4__'\n"]
[44.270405, "o", "python3 find_meeting.py; printf '%s\\n' '__CMDEND__4__'\r\n\u001b[?2004l\r"]
[44.29943, "o", "Alice's busy times:\r\n  2024-01-15 10:00:00 - 2024-01-15 11:00:00\r\n  2024-01-15 13:00:00 - 2024-01-15 14:00:00\r\n  2024-01-16 10:00:00 - 2024-01-16 12:00:00\r\n  2024-01-17 10:00:00 - 2024-01-17 11:00:00\r\n  2024-01-17 13:00:00 - 2024-01-17 14:00:00\r\n  2024-01-18 10:00:00 - 2024-01-18 11:00:00\r\n  2024-01-19 10:00:00 - 2024-01-19 11:00:00\r\n  2024-01-19 13:00:00 - 2024-01-19 14:00:00\r\n\r\nBob's busy times:\r\n  2024-01-15 11:00:00 - 2024-01-15 12:00:00\r\n"]
[44.299782, "o", "  2024-01-15 13:00:00 - 2024-01-15 15:00:00\r\n  2024-01-16 13:00:00 - 2024-01-16 14:00:00\r\n  2024-01-17 12:00:00 - 2024-01-17 13:00:00\r\n  2024-01-18 13:00:00 - 2024-01-18 14:00:00\r\n  2024-01-19 12:00:00 - 2024-01-19 13:00:00\r\n\r\nCarol's busy times:\r\n  2024-01-15 11:00:00 - 2024-01-15 12:00:00\r\n  2024-01-16 11:00:00 - 2024-01-16 12:00:00\r\n  2024-01-16 13:00:00 - 2024-01-16 14:00:00\r\n  2024-01-17 12:00:00 - 2024-01-17 13:00:00\r\n  2024-01-18 12:00:00 - 2024-01-18 13:00:00\r\n  2024-01-19 11:00:00 - 2024-01-19 12:00:00\r\n"]
[44.306217, "o", "\r\nFound 2 valid slots\r\n\r\nFirst 10 valid slots:\r\n  1. 2024-01-17 11:00:00 - 2024-01-17 12:00:00 (Wednesday)\r\n"]
[44.306485, "o", "  2. 2024-01-18 11:00:00 - 2024-01-18 12:00:00 (Thursday)\r\n\r\nSelected slot: 2024-01-17 11:00:00 - 2024-01-17 12:00:00\r\n"]
[44.306738, "o", "\r\nICS file created at /app/meeting_scheduled.ics\r\n"]
[44.311853, "o", "__CMDEND__4__\r\n\u001b[?2004h"]
[44.312207, "o", "root@12ed0c16d4a4:/app# "]
