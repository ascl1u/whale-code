[?2004l[?2004h>                 if end.hour <= 18:
[?2004l[?2004h>                     slots.append((start, end))
[?2004l[?2004h>     return slots
[?2004l[?2004h> 
[?2004l[?2004h> def check_conflict(start, end, events):
[?2004l[?2004h>     """Check if a time slot conflicts with existing events"""
[?2004l[?2004h>     for event_start, event_end in events:
[?2004l[?2004h>         # Conflict if there's any overlap
[?2004l[?2004h>         if start < event_end and end > event_start:
[?2004l[?2004h>             return True
[?2004l[?2004h>     return False
[?2004l[?2004h> 
[?2004l[?2004h> def check_alice_constraints(start, end):
[?2004l[?2004h>     """Alice: 9 AM - 2 PM only"""
[?2004l[?2004h>     if start.hour < 9:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if end.hour > 14:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if end.hour == 14 and end.minute > 0:
[?2004l[?2004h>         return False
[?2004l[?2004h>     return True
[?2004l[?2004h> 
[?2004l[?2004h> def check_bob_constraints(start, end):
[?2004l[?2004h>     """Bob: No meetings before 10 AM, must leave by 4:30 PM on Tue/Thu"""
[?2004l[?2004h>     if start.hour < 10:
[?2004l[?2004h>         return False
