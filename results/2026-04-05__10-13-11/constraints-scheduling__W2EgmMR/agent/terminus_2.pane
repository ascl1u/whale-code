[?2004l[?2004h>             
[?2004l[?2004h>             if start_match and end_match:
[?2004l[?2004h>                 start = datetime.strptime(start_match.group(1), '%Y%m%dT%H%M%SZ')
[?2004l[?2004h>                 end = datetime.strptime(end_match.group(1), '%Y%m%dT%H%M%SZ')
[?2004le[?2004h>                 events.append((start, end))
[?2004lm[?2004h>     
[?2004l[?2004h>     return events
[?2004lt[?2004h> 
[?2004l[?2004h> # Parse all calendars
