[?2004l[?2004h>             return False
[?2004l[?2004h>     return True
[?2004l[?2004h> 
[?2004l[?2004h> def check_carol_constraints(start, end):
[?2004l[?2004h>     """Carol: 9 AM - 5 PM, lunch 12:00-12:30 PM unavailable"""
[?2004l[?2004h>     if start.hour < 9:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if end.hour > 17:
