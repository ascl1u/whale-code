[?2004l[?2004h>         # Generate slots at minute granularity from 9 AM to 5 PM (last slot starts at 5 PM, ends at 6 PM)
[?2004l[?2004h>         for hour in range(9, 18):
[?2004l[?2004h>             for minute in range(0, 60):
[?2004l[?2004h>                 start = datetime(2024, 1, day, hour, minute, 0)
[?2004l[?2004h>                 end = start + timedelta(hours=1)
