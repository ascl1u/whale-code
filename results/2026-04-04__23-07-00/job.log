Sending keys: ['cat > /app/convert_masks.py << \'EOF\'\nimport argparse\nimport pandas as pd\nimport numpy as np\nimport cv2\nfrom mobile_sam import sam_model_registry, SamPredictor\nimport torch\nfrom tqdm import tqdm\n\ndef parse_coords(coords_str):\n    """Parse comma-separated coordinate string to list of integers."""\n    if pd.isna(coords_str) or coords_str == \'\':\n        return []\n    return [int(x) for x in str(coords_str).split(\',\')]\n\ndef coords_to_string(coords_list):\n    """Convert list of coordinates to comma-separated string."""\n    return \',\'.join(map(str, coords_list))\n\ndef get_largest_contour(mask):\n    """Get the largest contiguous region from a binary mask."""\n    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    if len(contours) == 0:\n        return None\n    # Find largest contour by area\n    largest_contour = max(contours, key=cv2.contourArea)\n    return largest_contour\n\ndef mask_to_polyline(mask):\n    """Convert binary mask to polyline coordinates."""\n    contour = get_largest_contour(mask)\n    if contour is None or len(contour) < 3:\n        return None, None, None, None\n    \n    # Simplify contour to reduce number of points\n    epsilon = 1.0  # Adjust this for more/less simplification\n    contour = cv2.approxPolyDP(contour, epsilon, True)\n    \n    # Extract coordinates\n    coords_x = [int(point[0][0]) for point in contour]\n    coords_y = [int(point[0][1]) for point in contour]\n    \n    # Calculate bounding box\n    xmin = min(coords_x)\n    xmax = max(coords_x)\n    ymin = min(coords_y)\n    ymax = max(coords_y)\n    \n    return xmin, ymin, xmax, ymax, coords_x, coords_y\n\ndef refine_mask_with_sam(predictor, box):\n    """Use SAM to refine a mask given a bounding box."""\n    # box should be in format [xmin, ymin, xmax, ymax]\n    masks, scores, _ = predictor.predict(\n        box=box,\n        multimask_output=True\n    )\n    \n    # Select the mask with highest score\n    best_idx = np.argmax(scores)\n    best_mask = masks[best_idx]\n    \n    return best_mask\n\ndef remove_overlap(masks_list, current_mask, current_idx):\n    """Remove overlap between current mask and previously processed masks."""\n    # Create a combined mask of all previous masks\n    combined_previous = np.zeros_like(current_mask, dtype=np.uint8)\n    for i in range(current_idx):\n        if masks_list[i] is not None:\n            combined_previous = np.logical_or(combined_previous, masks_list[i])\n    \n    # Remove overlap from current mask\n    current_mask = np.logical_and(current_mask, ~combined_previous)\n    return current_mask.astype(np.uint8)\n\ndef main():\n    parser = argparse.ArgumentParser(description=\'Convert rectangle masks to polylines using MobileSAM\')\n    parser.add_argument(\'weights_path\', type=str, help=\'Path to MobileSAM weights\')\n    parser.add_argument(\'output_path\', type=str, help=\'Path to output CSV file\')\n    parser.add_argument(\'rgb_path\', type=str, help=\'Path to RGB image\')\n    parser.add_argument(\'csv_path\', type=str, help=\'Path to metadata CSV\')\n    \n    args = parser.parse_args()\n    \n    # Load the image\n    print("Loading image...")\n    image = cv2.imread(args.rgb_path)\n    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n    \n    # Load MobileSAM model\n    print("Loading MobileSAM model...")\n    device = \'cpu\'\n    model_type = \'vit_t\'\n    sam = sam_model_registry[model_type](checkpoint=args.weights_path)\n    sam.to(device=device)\n    sam.eval()\n    \n    predictor = SamPredictor(sam)\n    predictor.set_image(image)\n    \n    # Load CSV\n    print("Loading CSV...")\n    df = pd.read_csv(args.csv_path)\n    \n    # Store all masks for overlap removal\n    all_masks = [None] * len(df)\n    \n    # Process each mask\n    print("Processing masks...")\n    for idx in tqdm(range(len(df))):\n        row = df.iloc[idx]\n        \n        # Get bounding box\n        xmin, ymin, xmax, ymax = row[\'xmin\'], row[\'ymin\'], row[\'xmax\'], row[\'ymax\']\n        box = np.array([xmin, ymin, xmax, ymax])\n        \n        # Refine mask with SAM\n        refined_mask = refine_mask_with_sam(predictor, box)\n        \n        # Remove overlap with previous masks\n        refined_mask = remove_overlap(all_masks, refined_mask, idx)\n        \n        # Store mask\n        all_masks[idx] = refined_mask\n        \n        # Convert to polyline\n        result = mask_to_polyline(refined_mask)\n        if result[0] is not None:\n            new_xmin, new_ymin, new_xmax, new_ymax, coords_x, coords_y = result\n            \n            # Update dataframe\n            df.at[idx, \'xmin\'] = new_xmin\n            df.at[idx, \'ymin\'] = new_ymin\n            df.at[idx, \'xmax\'] = new_xmax\n            df.at[idx, \'ymax\'] = new_ymax\n            df.at[idx, \'coords_x\'] = coords_to_string(coords_x)\n            df.at[idx, \'coords_y\'] = coords_to_string(coords_y)\n            df.at[idx, \'type\'] = \'polyline\'\n        else:\n            print(f"Warning: Could not extract contour for mask {idx}")\n    \n    # Save updated CSV\n    print(f"Saving to {args.output_path}...")\n    df.to_csv(args.output_path, index=False)\n    print("Done!")\n\nif __name__ == \'__main__\':\n    main()\nEOF\n'] min_timeout_sec: 1 max_timeout_sec: 180.0
