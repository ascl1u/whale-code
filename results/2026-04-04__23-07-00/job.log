Sending keys: ['cat > /app/convert_masks.py << \'EOF\'\nimport argparse\nimport pandas as pd\nimport numpy as np\nimport cv2\nimport torch\nfrom mobile_sam import sam_model_registry, SamPredictor\n\n\ndef parse_coords(coords_str):\n    """Parse coordinate string to list of integers."""\n    if pd.isna(coords_str) or coords_str == \'\':\n        return []\n    return [int(x) for x in str(coords_str).split(\',\')]\n\n\ndef coords_to_string(coords_list):\n    """Convert list of coordinates to comma-separated string."""\n    return \',\'.join(map(str, coords_list))\n\n\ndef get_largest_contour(mask):\n    """Get the largest contiguous contour from a binary mask."""\n    # Find contours\n    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    \n    if len(contours) == 0:\n        return None\n    \n    # Get the largest contour by area\n    largest_contour = max(contours, key=cv2.contourArea)\n    \n    return largest_contour\n\n\ndef contour_to_coords(contour):\n    """Convert OpenCV contour to separate x and y coordinate lists."""\n    if contour is None or len(contour) == 0:\n        return [], []\n    \n    # Flatten the contour array\n    points = contour.squeeze()\n    \n    # Handle single point case\n    if len(points.shape) == 1:\n        points = points.reshape(1, -1)\n    \n    coords_x = points[:, 0].tolist()\n    coords_y = points[:, 1].tolist()\n    \n    return coords_x, coords_y\n\n\ndef get_bbox_from_coords(coords_x, coords_y):\n    """Get bounding box from coordinates."""\n    if len(coords_x) == 0 or len(coords_y) == 0:\n        return None\n    \n    xmin = min(coords_x)\n    xmax = max(coords_x)\n    ymin = min(coords_y)\n    ymax = max(coords_y)\n    \n    return np.array([xmin, ymin, xmax, ymax])\n\n\ndef remove_overlaps(masks_dict, img_shape):\n    """Remove overlaps between masks by assigning each pixel to the closest mask center."""\n    h, w = img_shape[:2]\n    pixel_assignment = np.full((h, w), -1, dtype=np.int32)\n    \n    # Create a full mask image for each cell\n    mask_images = {}\n    centers = {}\n    \n    for idx, mask_data in masks_dict.items():\n        mask = mask_data[\'mask\']\n        mask_images[idx] = mask\n        \n        # Calculate mask center\n        y_coords, x_coords = np.where(mask > 0)\n        if len(x_coords) > 0:\n            centers[idx] = (np.mean(x_coords), np.mean(y_coords))\n        else:\n            centers[idx] = (0, 0)\n    \n    # For each pixel, assign to closest mask\n    for idx, mask in mask_images.items():\n        y_coords, x_coords = np.where(mask > 0)\n        for x, y in zip(x_coords, y_coords):\n            if pixel_assignment[y, x] == -1:\n                pixel_assignment[y, x] = idx\n            else:\n                # Check which mask center is closer\n                current_idx = pixel_assignment[y, x]\n                current_dist = np.sqrt((x - centers[current_idx][0])**2 + (y - centers[current_idx][1])**2)\n                new_dist = np.sqrt((x - centers[idx][0])**2 + (y - centers[idx][1])**2)\n                \n                if new_dist < current_dist:\n                    pixel_assignment[y, x] = idx\n    \n    # Create new non-overlapping masks\n    new_masks = {}\n    for idx in masks_dict.keys():\n        new_mask = (pixel_assignment == idx).astype(np.uint8)\n        new_masks[idx] = new_mask\n    \n    return new_masks\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\'Convert cell masks to polylines using MobileSAM\')\n    parser.add_argument(\'weights_path\', type=str, help=\'Path to MobileSAM weights\')\n    parser.add_argument(\'output_path\', type=str, help=\'Path to output CSV file\')\n    parser.add_argument(\'rgb_path\', type=str, help=\'Path to RGB image\')\n    parser.add_argument(\'csv_path\', type=str, help=\'Path to input CSV file\')\n    \n    args = parser.parse_args()\n    \n    # Load the image\n    print(f"Loading image from {args.rgb_path}...")\n    image = cv2.imread(args.rgb_path)\n    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n    \n    # Load MobileSAM model\n    print(f"Loading MobileSAM model from {args.weights_path}...")\n    device = \'cpu\'\n    model_type = \'vit_t\'\n    mobile_sam = sam_model_registry[model_type](checkpoint=args.weights_path)\n    mobile_sam.to(device=device)\n    mobile_sam.eval()\n    \n    predictor = SamPredictor(mobile_sam)\n    predictor.set_image(image_rgb)\n    \n    # Load the CSV\n    print(f"Loading CSV from {args.csv_path}...")\n    df = pd.read_csv(args.csv_path)\n    \n    # Store all masks first\n    masks_dict = {}\n    \n    print("Processing masks...")\n    for idx, row in df.iterrows():\n        # Get bounding box\n        xmin = row[\'xmin\']\n        ymin = row[\'ymin\']\n        xmax = row[\'xmax\']\n        ymax = row[\'ymax\']\n        \n        # Create box prompt in XYXY format\n        box = np.array([xmin, ymin, xmax, ymax])\n        \n        # Predict mask using MobileSAM\n        masks, scores, _ = predictor.predict(\n            point_coords=None,\n            point_labels=None,\n            box=box,\n            multimask_output=True,\n        )\n        \n        # Select the mask with highest score\n        best_mask_idx = np.argmax(scores)\n        mask = masks[best_mask_idx]\n        \n        masks_dict[idx] = {\n            \'mask\': mask.astype(np.uint8),\n            \'score\': scores[best_mask_idx]\n        }\n    \n    # Remove overlaps between masks\n    print("Removing overlaps...")\n    non_overlapping_masks = remove_overlaps(masks_dict, image_rgb.shape)\n    \n    # Convert masks to polylines and update dataframe\n    print("Converting masks to polylines...")\n    for idx, row in df.iterrows():\n        mask = non_overlapping_masks[idx]\n        \n        # Get largest contour\n        contour = get_largest_contour(mask)\n        \n        if contour is not None:\n            # Convert contour to coordinates\n            coords_x, coords_y = contour_to_coords(contour)\n            \n            if len(coords_x) > 0 and len(coords_y) > 0:\n                # Update bounding box\n                df.at[idx, \'xmin\'] = min(coords_x)\n                df.at[idx, \'xmax\'] = max(coords_x)\n                df.at[idx, \'ymin\'] = min(coords_y)\n                df.at[idx, \'ymax\'] = max(coords_y)\n                \n                # Update coordinates\n                df.at[idx, \'coords_x\'] = coords_to_string(coords_x)\n                df.at[idx, \'coords_y\'] = coords_to_string(coords_y)\n            else:\n                # Keep original if no contour found\n                print(f"Warning: No contour found for mask {idx}, keeping original")\n        else:\n            print(f"Warning: No contour found for mask {idx}, keeping original")\n    \n    # Save the updated CSV\n    print(f"Saving results to {args.output_path}...")\n    df.to_csv(args.output_path, index=False)\n    print("Done!")\n\n\nif __name__ == \'__main__\':\n    main()\nEOF\n'] min_timeout_sec: 1 max_timeout_sec: 180.0
