Sending keys: ['cat > /app/convert_masks.py << \'EOF\'\nimport argparse\nimport pandas as pd\nimport numpy as np\nimport cv2\nimport torch\nfrom mobile_sam import sam_model_registry, SamPredictor\nimport os\n\ndef parse_coords(coords_str):\n    """Parse comma-separated coordinate string to list of integers."""\n    if pd.isna(coords_str) or coords_str == \'\':\n        return []\n    return [int(x) for x in str(coords_str).split(\',\')]\n\ndef coords_to_string(coords_list):\n    """Convert list of coordinates to comma-separated string."""\n    return \',\'.join([str(int(x)) for x in coords_list])\n\ndef get_largest_contour(mask):\n    """Extract the largest contiguous contour from a binary mask."""\n    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    if len(contours) == 0:\n        return None\n    # Get the largest contour\n    largest_contour = max(contours, key=cv2.contourArea)\n    return largest_contour\n\ndef contour_to_coords(contour):\n    """Convert contour to separate x and y coordinate lists."""\n    if contour is None or len(contour) == 0:\n        return [], []\n    \n    # Flatten contour and extract x, y coordinates\n    contour = contour.squeeze()\n    if len(contour.shape) == 1:  # Single point\n        contour = contour.reshape(1, -1)\n    \n    coords_x = contour[:, 0].tolist()\n    coords_y = contour[:, 1].tolist()\n    \n    return coords_x, coords_y\n\ndef get_bbox_from_coords(xmin, ymin, xmax, ymax):\n    """Get bounding box in format expected by SAM."""\n    return np.array([xmin, ymin, xmax, ymax])\n\ndef main():\n    parser = argparse.ArgumentParser(description=\'Convert masks to polylines using MobileSAM\')\n    parser.add_argument(\'weights_path\', type=str, help=\'Path to MobileSAM weights\')\n    parser.add_argument(\'output_path\', type=str, help=\'Path to output CSV file\')\n    parser.add_argument(\'rgb_path\', type=str, help=\'Path to RGB image\')\n    parser.add_argument(\'csv_path\', type=str, help=\'Path to metadata CSV\')\n    \n    args = parser.parse_args()\n    \n    # Load the image\n    image = cv2.imread(args.rgb_path)\n    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n    \n    # Load the CSV\n    df = pd.read_csv(args.csv_path)\n    \n    # Initialize MobileSAM\n    device = \'cpu\'\n    model_type = \'vit_t\'\n    sam = sam_model_registry[model_type](checkpoint=args.weights_path)\n    sam.to(device=device)\n    sam.eval()\n    \n    predictor = SamPredictor(sam)\n    predictor.set_image(image_rgb)\n    \n    # Create a mask to track occupied pixels (to avoid overlaps)\n    occupied_mask = np.zeros(image.shape[:2], dtype=np.uint8)\n    mask_assignments = np.zeros(image.shape[:2], dtype=np.int32) - 1  # -1 means unassigned\n    \n    # Process each mask\n    refined_masks = []\n    \n    for idx, row in df.iterrows():\n        xmin, ymin, xmax, ymax = int(row[\'xmin\']), int(row[\'ymin\']), int(row[\'xmax\']), int(row[\'ymax\'])\n        \n        # Use bounding box as prompt for SAM\n        bbox = get_bbox_from_coords(xmin, ymin, xmax, ymax)\n        \n        # Predict mask using SAM\n        with torch.no_grad():\n            masks, scores, logits = predictor.predict(\n                box=bbox,\n                multimask_output=False\n            )\n        \n        # Get the predicted mask (first one since multimask_output=False)\n        predicted_mask = masks[0].astype(np.uint8)\n        \n        # Remove overlaps with previously assigned masks\n        # Only keep pixels that haven\'t been assigned to other masks\n        predicted_mask = predicted_mask * (mask_assignments == -1).astype(np.uint8)\n        \n        # Get the largest contiguous contour\n        contour = get_largest_contour(predicted_mask)\n        \n        if contour is not None and len(contour) > 0:\n            # Create a clean mask from the contour\n            clean_mask = np.zeros_like(predicted_mask)\n            cv2.drawContours(clean_mask, [contour], -1, 1, thickness=cv2.FILLED)\n            \n            # Mark these pixels as assigned to this mask\n            mask_assignments[clean_mask == 1] = idx\n            \n            # Convert contour to coordinates\n            coords_x, coords_y = contour_to_coords(contour)\n            \n            # Calculate new bounding box from contour\n            if len(coords_x) > 0:\n                new_xmin = min(coords_x)\n                new_xmax = max(coords_x)\n                new_ymin = min(coords_y)\n                new_ymax = max(coords_y)\n            else:\n                new_xmin, new_xmax = xmin, xmax\n                new_ymin, new_ymax = ymin, ymax\n                coords_x, coords_y = [xmin, xmax, xmax, xmin, xmin], [ymin, ymin, ymax, ymax, ymin]\n        else:\n            # If no contour found, keep original bounding box as polyline\n            coords_x = [xmin, xmax, xmax, xmin, xmin]\n            coords_y = [ymin, ymin, ymax, ymax, ymin]\n            new_xmin, new_xmax = xmin, xmax\n            new_ymin, new_ymax = ymin, ymax\n        \n        refined_masks.append({\n            \'coords_x\': coords_to_string(coords_x),\n            \'coords_y\': coords_to_string(coords_y),\n            \'xmin\': new_xmin,\n            \'xmax\': new_xmax,\n            \'ymin\': new_ymin,\n            \'ymax\': new_ymax\n        })\n    \n    # Update the dataframe\n    for idx, refined in enumerate(refined_masks):\n        df.at[idx, \'coords_x\'] = refined[\'coords_x\']\n        df.at[idx, \'coords_y\'] = refined[\'coords_y\']\n        df.at[idx, \'xmin\'] = refined[\'xmin\']\n        df.at[idx, \'xmax\'] = refined[\'xmax\']\n        df.at[idx, \'ymin\'] = refined[\'ymin\']\n        df.at[idx, \'ymax\'] = refined[\'ymax\']\n        df.at[idx, \'type\'] = \'polyline\'  # All masks are now polylines\n    \n    # Save the updated CSV\n    df.to_csv(args.output_path, index=False)\n    print(f"Refined masks saved to {args.output_path}")\n\nif __name__ == \'__