[1145.187165, "o", "cat /app/convert_masks.py; printf '%s\\n' '__CMDEND__34__'\r\n\u001b[?2004l\r"]
[1145.189763, "o", "import argparse\r\nimport pandas as pd\r\nimport numpy as np\r\nimport cv2\r\nimport torch\r\nfrom mobile_sam import sam_model_registry, SamPredictor\r\n\r\n\r\ndef parse_coords(coords_str):\r\n    \"\"\"Parse coordinate string to list of integers.\"\"\"\r\n    if pd.isna(coords_str) or coords_str == '':\r\n        return []\r\n    return [int(x) for x in str(coords_str).split(',')]\r\n\r\n\r\ndef coords_to_string(coords_list):\r\n    \"\"\"Convert list of coordinates to comma-separated string.\"\"\"\r\n    return ','.join(map(str, coords_list))\r\n\r\n\r\ndef get_largest_contour(mask):\r\n    \"\"\"Get the largest contiguous contour from a binary mask.\"\"\"\r\n    # Find contours\r\n    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\r\n    \r\n    if len(contours) == 0:\r\n        return None\r\n    \r\n    # Get the largest contour by area\r\n    largest_contour = max(contours, key=cv2.contourArea)\r\n    \r\n    return largest_contour\r\n\r\n\r\ndef contour_to_coords(contour):\r\n    \"\"\"Convert OpenCV contour to separate x and y coordinate lists.\"\"\"\r\n    if contour is None or len(contour) == 0:\r\n        return [], []\r\n    \r\n    # Flatten the contour array\r\n    points = contour.squeeze()\r\n    \r\n    # Handle single point case\r\n    if len(points.shape) == 1:\r\n        points = points.reshape(1, -1)\r\n    \r\n    coords_x = points[:, 0].tolist()\r\n    coords_y = points[:, 1].tolist()\r\n    \r\n    return coords_x, coords_y\r\n\r\n\r\ndef get_bbox_from_coords(coords_x, coords_y):\r\n    \"\"\"Get bounding box from coordinates.\"\"\"\r\n    if len(coords_x) == 0 or len(coords_y) == 0:\r\n        return None\r\n    \r\n    xmin = min(coords_x)\r\n    xmax = max(coords_x)\r\n    ymin = min(coords_y)\r\n    ymax = max(coords_y)\r\n    \r\n    return np.array([xmin, ymin, xmax, ymax])\r\n\r\n\r\ndef remove_overlaps(masks_dict, img_shape):\r\n    \"\"\"Remove overlaps between masks by assigning each pixel to the closest mask center.\"\"\"\r\n    h, w = img_shape[:2]\r\n    pixel_assignment = np.full((h, w), -1, dtype=np.int32)\r\n    \r\n    # Create a full mask image for each cell\r\n    mask_images = {}\r\n    centers = {}\r\n    \r\n    for idx, mask_data in masks_dict.items():\r\n        mask = mask_data['mask']\r\n        mask_images[idx] = mask\r\n        \r\n        # Calculate mask center\r\n        y_coords, x_coords = np.where(mask > 0)\r\n        if len(x_coords) > 0:\r\n            centers[idx] = (np.mean(x_coords), np.mean(y_coords))\r\n        else:\r\n            centers[idx] = (0, 0)\r\n    \r\n    # For each pixel, assign to closest mask\r\n    for idx, mask in mask_images.items():\r\n        y_coords, x_coords = np.where(mask > 0)\r\n        for x, y in zip(x_coords, y_coords):\r\n            if pixel_assignment[y, x] == -1:\r\n                pixel_assignment[y, x] = idx\r\n            else:\r\n                # Check which mask center is closer\r\n                current_idx = pixel_assignment[y, x]\r\n                current_dist = np.sqrt((x - centers[current_idx][0])**2 + (y - centers[current_idx][1])**2)\r\n                new_dist = np.sqrt((x - centers[idx][0])**2 + (y - centers[idx][1])**2)\r\n                \r\n                if new_dist < current_dist:\r\n                    pixel_assignment[y, x] = idx\r\n    \r\n    # Create new non-overlapping masks\r\n    new_masks = {}\r\n    for idx in masks_dict.keys():\r\n        new_mask = (pixel_assignment == idx).astype(np.uint8)\r\n        new_masks[idx] = new_mask\r\n    \r\n    return new_masks\r\n\r\n\r\ndef main():\r\n    parser = argparse.ArgumentParser(description='Convert cell masks to polylines using MobileSAM')\r\n    parser.add_argument('weights_path', type=str, help='Path to MobileSAM weights')"]
[1145.189941, "o", "\r\n    parser.add_argument('output_path', type=str, help='Path to output CSV file')\r\n    parser.add_argument('rgb_path', type=str, help='Path to RGB image')\r\n    parser.add_argument('csv_path', type=str, help='Path to input CSV file')\r\n    \r\n    args = parser.parse_args()\r\n    \r\n    # Load the image\r\n    print(f\"Loading image from {args.rgb_path}...\")\r\n    image = cv2.imread(args.rgb_path)\r\n    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\r\n    \r\n    # Load MobileSAM model\r\n    print(f\"Loading MobileSAM model from {args.weights_path}...\")\r\n    device = 'cpu'\r\n    model_type = 'vit_t'\r\n    mobile_sam = sam_model_registry[model_type](checkpoint=args.weights_path)\r\n    mobile_sam.to(device=device)\r\n    mobile_sam.eval()\r\n    \r\n    predictor = SamPredictor(mobile_sam)\r\n    predictor.set_image(image_rgb)\r\n    \r\n    # Load the CSV\r\n    print(f\"Loading CSV from {args.csv_path}...\")\r\n    df = pd.read_csv(args.csv_path)\r\n    \r\n    # Store all masks first\r\n    masks_dict = {}\r\n    \r\n    print(\"Processing masks...\")\r\n    for idx, row in df.iterrows():\r\n        # Get bounding box\r\n        xmin = row['xmin']\r\n        ymin = row['ymin']\r\n        xmax = row['xmax']\r\n        ymax = row['ymax']\r\n        \r\n        # Create box prompt in XYXY format\r\n        box = np.array([xmin, ymin, xmax, ymax])\r\n        \r\n        # Predict mask using MobileSAM\r\n        masks, scores, _ = predictor.predict(\r\n            point_coords=None,\r\n            point_labels=None,\r\n            box=box,\r\n            multimask_output=True,\r\n        )\r\n        \r\n        # Select the mask with highest score\r\n        best_mask_idx = np.argmax(scores)\r\n        mask = masks[best_mask_idx]\r\n        \r\n        masks_dict[idx] = {\r\n            'mask': mask.astype(np.uint8),\r\n            'score': scores[best_mask_idx]\r\n        }\r\n    \r\n    # Remove overlaps between masks\r\n    print(\"Removing overlaps...\")\r\n    non_overlapping_masks = remove_overlaps(masks_dict, image_rgb.shape)\r\n    \r\n    # Convert masks to polylines and update dataframe\r\n    print(\"Converting masks to polylines...\")\r\n    for idx, row in df.iterrows():\r\n        mask = non_overlapping_masks[idx]\r\n        \r\n        # Get largest contour\r\n        contour = get_largest_contour(mask)\r\n        \r\n        if contour is not None:\r\n            # Convert contour to coordinates\r\n            coords_x, coords_y = contour_to_coords(contour)\r\n            \r\n            if len(coords_x) > 0 and len(coords_y) > 0:\r\n                # Update bounding box\r\n                df.at[idx, 'xmin'] = min(coords_x)\r\n                df.at[idx, 'xmax'] = max(coords_x)\r\n                df.at[idx, 'ymin'] = min(coords_y)\r\n                df.at[idx, 'ymax'] = max(coords_y)\r\n                \r\n                # Update coordinates\r\n                df.at[idx, 'coords_x'] = coords_to_string(coords_x)\r\n                df.at[idx, 'coords_y'] = coords_to_string(coords_y)\r\n            else:\r\n                # Keep original if no contour found\r\n                print(f\"Warning: No contour found for mask {idx}, keeping original\")\r\n        else:\r\n            print(f\"Warning: No contour found for mask {idx}, keeping original\")\r\n    \r\n    # Save the updated CSV\r\n    print(f\"Saving results to {args.output_path}...\")\r\n    df.to_csv(args.output_path, index=False)\r\n    print(\"Done!\")\r\n\r\n\r\nif __name__ == '__main__':\r\n    main()\r\n"]
