[214.920084, "o", "\u001b[?2004h> "]
[214.920452, "o", "    parser.add_argument('rgb_path', type=str, help='Path to RGB image')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.920908, "o", "    parser.add_argument('csv_path', type=str, help='Path to input CSV file')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.921173, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.921375, "o", "    args = parser.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[214.921595, "o", "\u001b[?2004h>     # Load the image\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.921852, "o", "    print(f\"Loading image from {args.rgb_path}...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[214.922138, "o", "> "]
[214.922485, "o", "    image = cv2.imread(args.rgb_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.922844, "o", "    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\r\n\u001b[?2004l\r"]
[214.923, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[214.923322, "o", "\u001b[?2004h> "]
[214.923561, "o", "    # Load MobileSAM model\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.923885, "o", "    print(f\"Loading MobileSAM model from {args.weights_path}...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[214.924199, "o", ">     device = 'cpu'\r\n\u001b[?2004l\r"]
[214.924475, "o", "\u001b[?2004h>     model_type = 'vit_t'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.924931, "o", "    mobile_sam = sam_model_registry[model_type](checkpoint=args.weights_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[214.925074, "o", "> "]
[214.92531, "o", "    mobile_sam.to(device=device)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.925551, "o", "    mobile_sam.eval()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.92585, "o", "    predictor = SamPredictor(mobile_sam)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.926247, "o", "    predictor.set_image(image_rgb)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[214.926554, "o", "\u001b[?2004h> "]
[214.92685, "o", "    # Load the CSV\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.927166, "o", "    print(f\"Loading CSV from {args.csv_path}...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[214.927461, "o", "> "]
[214.927714, "o", "    df = pd.read_csv(args.csv_path)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[214.927838, "o", "\u001b[?2004h>     # Store all masks first\r\n\u001b[?2004l\r"]
[214.928228, "o", "\u001b[?2004h>     masks_dict = {}\r\n\u001b[?2004l\r"]
[214.928464, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.928708, "o", "    print(\"Processing masks...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.928936, "o", "    for idx, row in df.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.929171, "o", "        # Get bounding box\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.929401, "o", "        xmin = row['xmin']\r\n\u001b[?2004l\r"]
[214.929615, "o", "\u001b[?2004h>         ymin = row['ymin']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.929864, "o", "        xmax = row['xmax']\r\n\u001b[?2004l\r"]
[214.930075, "o", "\u001b[?2004h> "]
[214.930301, "o", "        ymax = row['ymax']\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[214.930576, "o", "\u001b[?2004h> "]
[214.930835, "o", "        # Create box prompt in XYXY format\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.931022, "o", "        box = np.array([xmin, ymin, xmax, ymax])\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[214.931518, "o", "\u001b[?2004h> "]
[214.932035, "o", "        # Predict mask using MobileSAM\r\n"]
[214.932289, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[214.932881, "o", "        masks, scores, _ = predictor.predict(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.933247, "o", "            point_coords=None,\r\n"]
[214.996283, "o", "\u001b[?2004l\r\u001b[?2004h"]
[214.996474, "o", ">             point_labels=None,\r\n\u001b[?2004l\r\u001b[?2004h>             box=box,\r\n\u001b[?2004l\r\u001b[?2004h>             multimask_output=True,\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         # Select the mask with highest score\r\n\u001b[?2004l\r\u001b[?2004h>         best_mask_idx = np.argmax(scores)\r\n\u001b[?2004l\r\u001b[?2004h>         mask = masks[best_mask_idx]\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         masks_dict[idx] = {\r\n\u001b[?2004l\r\u001b[?2004h>             'mask': mask.astype(np.uint8),\r\n\u001b[?2004l\r\u001b[?2004h>             'score': scores[best_mask_idx]\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Remove overlaps between masks\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"Removing overlaps...\")\r\n\u001b[?2004l\r\u001b[?2004h>     non_overlapping_masks = remove_overlaps(masks_dict, image_rgb.shape)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Convert masks to polylines and update dataframe\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"Converting masks to polylines...\")\r\n\u001b[?2004l\r\u001b[?2004h>     for idx, row in df.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h>         mask = non_overlapping_masks[idx]\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[214.996784, "o", "\u001b[?2004h> "]
[214.996939, "o", "        # Get largest contour\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.99713, "o", "        contour = get_largest_contour(mask)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[214.997225, "o", "\u001b[?2004h> "]
[214.997379, "o", "        if contour is not None:\r\n\u001b[?2004l\r"]
[214.997575, "o", "\u001b[?2004h> "]
[214.997734, "o", "            # Convert contour to coordinates\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.998111, "o", "            coords_x, coords_y = contour_to_coords(contour)\r\n\u001b[?2004l\r"]
[214.998384, "o", "\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.998649, "o", "            if len(coords_x) > 0 and len(coords_y) > 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[214.998876, "o", "> "]
[214.999185, "o", "                # Update bounding box\r\n\u001b[?2004l\r\u001b[?2004h> "]
[214.999404, "o", "                df.at[idx, 'xmin'] = min(coords_x)\r\n\u001b[?2004l\r"]
[214.999601, "o", "\u001b[?2004h> "]
[214.999853, "o", "                df.at[idx, 'xmax'] = max(coords_x)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.000075, "o", "                df.at[idx, 'ymin'] = min(coords_y)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.000322, "o", "                df.at[idx, 'ymax'] = max(coords_y)\r\n\u001b[?2004l\r\u001b[?2004h"]
[215.000529, "o", ">                 \r\n\u001b[?2004l\r"]
[215.000719, "o", "\u001b[?2004h> "]
[215.00084, "o", "                # Update coordinates\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.0012, "o", "                df.at[idx, 'coords_x'] = coords_to_string(coords_x)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.00168, "o", "                df.at[idx, 'coords_y'] = coords_to_string(coords_y)\r\n\u001b[?2004l\r\u001b[?2004h"]
[215.001947, "o", ">             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.002229, "o", "                # Keep original if no contour found\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.002691, "o", "                print(f\"Warning: No contour found for mask {idx}, keeping original\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.00289, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.003327, "o", "            print(f\"Warning: No contour found for mask {idx}, keeping original\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.003512, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.003701, "o", "    # Save the updated CSV\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.003905, "o", "    print(f\"Saving results to {args.output_path}...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.004189, "o", "    df.to_csv(args.output_path, index=False)\r\n\u001b[?2004l\r"]
[215.004382, "o", "\u001b[?2004h> "]
[215.004597, "o", "    print(\"Done!\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.00485, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[215.005134, "o", "    main()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[215.009337, "o", "\u001b[?2004hroot@f26d45314cff:/app# "]
