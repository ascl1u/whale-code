[733.116938, "i", "python3 << 'EOF'\nimport pandas as pd\ndf = pd.read_csv('/tmp/final_test.csv')\nprint(f\"Output shape: {df.shape}\")\nprint(f\"All types are polyline: {(df['type'] == 'polyline').all()}\")\nprint(f\"Type counts: {df['type'].value_counts().to_dict()}\")\nprint(f\"Columns: {df.columns.tolist()}\")\nprint(f\"\\nSample row (originally rectangle):\")\nrow = df.iloc[0]\nprint(f\"  xmin={row['xmin']}, ymin={row['ymin']}, xmax={row['xmax']}, ymax={row['ymax']}\")\nprint(f\"  type={row['type']}\")\nprint(f\"  coords_x length: {len(str(row['coords_x']).split(','))}\")\nprint(f\"  coords_y length: {len(str(row['coords_y']).split(','))}\")\nEOF\n"]
