[745.3056, "o", "\r\n-rw-r--r-- 1 root root   5266 Apr  5 06:13 convert_masks.py\r\n-rw-r--r-- 1 root root   7072 Oct 24 05:18 demo_metadata.csv\r\n-rw-r--r-- 1 root root 187898 Oct 24 05:18 demo_rgb.png\r\n"]
