[299.364258, "o", "        return []\r\n\u001b[?2004l\r"]
[299.364541, "o", "\u001b[?2004h> "]
[299.365462, "o", "    return [int(x) for x in str(coords_str).split(',')]\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.365621, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.365977, "o", "> "]
[299.366291, "o", "def coords_to_string(coords_list):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.367493, "o", "    \"\"\"Convert list of coordinates to comma-separated string.\"\"\"\r\n\u001b[?2004l\r"]
[299.36801, "o", "\u001b[?2004h> "]
[299.368355, "o", "    return ','.join(map(str, coords_list))\r\n\u001b[?2004l\r"]
[299.368573, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.369217, "o", "def get_largest_contour(mask):\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.369536, "o", "> "]
[299.370602, "o", "    \"\"\"Extract the largest contour from a binary mask.\"\"\"\r\n\u001b[?2004l\r"]
[299.370848, "o", "\u001b[?2004h> "]
[299.372657, "o", "    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.372822, "o", "> "]
[299.373112, "o", "    if len(contours) == 0:\r\n\u001b[?2004l\r"]
[299.373274, "o", "\u001b[?2004h> "]
[299.373754, "o", "        return None\r\n\u001b[?2004l\ri\u001b[?2004h> "]
[299.374121, "o", "    # Get the largest contour by area\r\n\u001b[?2004l\r "]
[299.374667, "o", "\u001b[?2004h> "]
[299.37528, "o", "    largest_contour = max(contours, key=cv2.contourArea)\r\n\u001b[?2004l\r"]
[299.375877, "o", "\u001b[?2004h>     return largest_contour\r\n\u001b[?2004l\r \u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.376295, "o", "> "]
[299.376827, "o", "def contour_to_coords(contour):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.377232, "o", "    \"\"\"Convert OpenCV contour to separate x and y coordinate lists.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.37801, "o", "    if contour is None or len(contour) == 0:\r\n\u001b[?2004l\r"]
[299.394132, "o", "\u001b[?2004h> "]
[299.394713, "o", "        return [], []\r\n\u001b[?2004l\r\u001b[?2004h>     # Squeeze to remove extra dimension and extract x, y coordinates\r\n\u001b[?2004l\r\u001b[?2004h>     points = contour.squeeze()\r\n\u001b[?2004l\r\u001b[?2004h>     if len(points.shape) == 1:  # Single point\r\n\u001b[?2004l\r\u001b[?2004h>         points = points.reshape(1, -1)\r\n\u001b[?2004l\r\u001b[?2004h>     coords_x = points[:, 0].tolist()\r\n\u001b[?2004l\r\u001b[?2004h>     coords_y = points[:, 1].tolist()\r\n\u001b[?2004l\r\u001b[?2004h>     return coords_x, coords_y\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def refine_mask_with_sam(predictor, bbox):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Use SAM to refine a mask given a bounding box prompt.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     # bbox format: [xmin, ymin, xmax, ymax]\r\n\u001b[?2004l\r\u001b[?2004h>     box_prompt = np.array(bbox)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.395237, "o", "    # Predict mask using bounding box prompt\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.395581, "o", "    masks, scores, _ = predictor.predict(\r\n\u001b[?2004l\r\u001b[?2004h>         point_coords=None,\r\n\u001b[?2004l\r"]
[299.395754, "o", "\u001b[?2004h> "]
[299.395871, "o", "        point_labels=None,\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.39632, "o", "> "]
[299.396688, "o", "        box=box_prompt,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.397011, "o", "        multimask_output=False  # Single mask output\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.397178, "o", "    )\r\n\u001b[?2004l\r"]
[299.397583, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.397896, "o", "> "]
[299.39815, "o", "    # Return the mask (first one since multimask_output=False)\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.398428, "o", "> "]
[299.398674, "o", "    return masks[0]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.398968, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.399367, "o", "    parser = argparse.ArgumentParser(\r\n\u001b[?2004l\r"]
[299.399679, "o", "\u001b[?2004h> "]
[299.400033, "o", "        description='Convert cell masks to polylines using MobileSAM'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.400511, "o", "    )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.400942, "o", "    parser.add_argument('weights_path', type=str, help='Path to MobileSAM weights')\r\n\u001b[?2004l\r"]
[299.401194, "o", "\u001b[?2004h> "]
[299.401748, "o", "    parser.add_argument('output_path', type=str, help='Path to output CSV file')\r\n\u001b[?2004l\r"]
[299.401979, "o", "\u001b[?2004h> "]
[299.40244, "o", "    parser.add_argument('rgb_path', type=str, help='Path to RGB image')\r\n\u001b[?2004l\r"]
[299.402692, "o", "\u001b[?2004h> "]
[299.402977, "o", "    parser.add_argument('csv_path', type=str, help='Path to metadata CSV')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.403227, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.403439, "o", "    args = parser.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.403715, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.403993, "o", "    # Load the image\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.404306, "o", "    print(\"Loading image...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.404883, "o", "    image = cv2.imread(args.rgb_path)\r\n\u001b[?2004l\r\u001b[?2004h>     if image is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.405349, "o", "> "]
[299.405713, "o", "        raise ValueError(f\"Could not load image from {args.rgb_path}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.40612, "o", "    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.406409, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.406664, "o", "    # Load the CSV\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.406959, "o", "    print(\"Loading CSV...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.407199, "o", "    df = pd.read_csv(args.csv_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.407458, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.407735, "o", ">     # Initialize MobileSAM\r\n\u001b[?2004l\r"]
[299.407915, "o", "\u001b[?2004h> "]
[299.408128, "o", "    print(\"Loading MobileSAM model...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.408723, "o", "    device = 'cpu'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.409099, "o", "    sam = sam_model_registry['vit_t'](checkpoint=args.weights_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.409443, "o", "    sam.to(device=device)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.409794, "o", "    sam.eval()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.410163, "o", "    predictor = SamPredictor(sam)\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.410446, "o", "> "]
[299.410929, "o", "    predictor.set_image(image_rgb)\r\n\u001b[?2004l\r"]
[299.411222, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[299.411526, "o", "\u001b[?2004h> "]
[299.411846, "o", "    # Create a mask to track which pixels are already assigned\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.412109, "o", "> "]
[299.412384, "o", "    assigned_mask = np.zeros(image.shape[:2], dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[299.412524, "o", "\u001b[?2004h> "]
[299.412855, "o", "    # Process each mask\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.413199, "o", "    print(f\"Processing {len(df)} masks...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.413467, "o", "    for idx in range(len(df)):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.413736, "o", "        row = df.iloc[idx]\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.414048, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.414374, "o", "        # Get bounding box\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.415152, "o", "        xmin, ymin, xmax, ymax = int(row['xmin']), int(row['ymin']), int(row['xmax']), int(row['ymax'])\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.415498, "o", "> "]
[299.415834, "o", "        bbox = [xmin, ymin, xmax, ymax]\r\n\u001b[?2004l\r"]
[299.416002, "o", "\u001b[?2004h> "]
[299.416455, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.417184, "o", "        # Refine mask with SAM\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.417604, "o", "        refined_mask = refine_mask_with_sam(predictor, bbox)\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.417919, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.418314, "o", "        # Remove any overlap with previously assigned masks\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.41871, "o", "        refined_mask = refined_mask & (~assigned_mask)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.418979, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.419224, "o", "        # Extract the largest contour\r\n\u001b[?2004l\r"]
[299.419363, "o", "\u001b[?2004h> "]
[299.419605, "o", "        contour = get_largest_contour(refined_mask)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[299.419808, "o", "\u001b[?2004h> "]
[299.420085, "o", "        if contour is not None and len(contour) > 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.420438, "o", "            # Convert contour to coordinates\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.42064, "o", "> "]
[299.420949, "o", "            coords_x, coords_y = contour_to_coords(contour)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.421233, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.421523, "o", "            # Update bounding box based on actual contour\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.421825, "o", "            if len(coords_x) > 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.422169, "o", "                new_xmin = min(coords_x)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.42248, "o", "                new_xmax = max(coords_x)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.422842, "o", "                new_ymin = min(coords_y)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.423172, "o", "                new_ymax = max(coords_y)\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.423379, "o", ">                 \r\n\u001b[?2004l\r"]
[299.424023, "o", "\u001b[?2004h>                 # Update dataframe\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.424412, "o", "> "]
[299.424783, "o", "                df.at[idx, 'xmin'] = new_xmin\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.425136, "o", "                df.at[idx, 'xmax'] = new_xmax\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.425465, "o", "                df.at[idx, 'ymin'] = new_ymin\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.425934, "o", "                df.at[idx, 'ymax'] = new_ymax\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.426234, "o", "> "]
[299.426648, "o", "                df.at[idx, 'coords_x'] = coords_to_string(coords_x)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.427477, "o", "                df.at[idx, 'coords_y'] = coords_to_string(coords_y)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.428071, "o", "                df.at[idx, 'type'] = 'polyline'\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.428257, "o", "> "]
[299.428657, "o", "                \r\n\u001b[?2004l\r"]
[299.494106, "o", "\u001b[?2004h"]
[299.494496, "o", ">                 # Mark these pixels as assigned\r\n\u001b[?2004l\r\u001b[?2004h>                 mask_filled = np.zeros(image.shape[:2], dtype=np.uint8)\r\n\u001b[?2004l\r\u001b[?2004h>                 cv2.drawContours(mask_filled, [contour], -1, 1, -1)\r\n\u001b[?2004l\r\u001b[?2004h>                 assigned_mask = assigned_mask | (mask_filled > 0)\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.494691, "o", "                # Keep original if no valid contour found\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.495142, "o", "                print(f\"Warning: No valid contour for mask {idx}, keeping original\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.495431, "o", ">         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.495762, "o", "            # Keep original if no contour found\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.496505, "o", "            print(f\"Warning: No contour found for mask {idx}, keeping original\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.49686, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[299.497127, "o", "    # Save the updated CSV\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.497421, "o", "> "]
[299.497708, "o", "    print(f\"Saving results to {args.output_path}...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[299.497988, "o", "> "]
[299.498328, "o", "    df.to_csv(args.output_path, index=False)\r\n\u001b[?2004l\r"]
[299.49866, "o", "\u001b[?2004h>     print(\"Done!\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[299.498946, "o", "> "]
[299.49925, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h>     main()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[299.503655, "o", "\u001b[?2004hroot@75e0c428ae4c:/app# "]
[305.664869, "i", "python3 /app/convert_masks.py /tmp/MobileSAM/weights/mobile_sam.pt /app/test_output.csv /app/demo_rgb.png /app/demo_metadata.csv; printf '%s\\n' '__CMDEND__17__'\n"]
[305.665953, "o", "python3 /app/convert_masks.py /tmp/MobileSAM/weights/mobile_sam.pt /app/test_output.csv /app/demo_rgb.png /app/demo_metadata.csv; printf '%s\\n' '__CMDEND__17__'\r\n\u001b[?2004l\r"]
