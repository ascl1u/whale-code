[600.207982, "i", "python3 << 'EOF'\nimport pandas as pd\n\n# Load original and output CSVs\ndf_orig = pd.read_csv('/app/demo_metadata.csv')\ndf_out = pd.read_csv('/app/test_output.csv')\n\nprint(f\"Original CSV shape: {df_orig.shape}\")\nprint(f\"Output CSV shape: {df_out.shape}\")\nprint(f\"\\nOriginal types: {df_orig['type'].value_counts().to_dict()}\")\nprint(f\"Output types: {df_out['type'].value_counts().to_dict()}\")\n\n# Check a few examples\nprint(\"\\n=== Example 1: Originally rectangle (row 0) ===\")\nprint(f\"Original coords_x: {df_orig.iloc[0]['coords_x']}\")\nprint(f\"Output coords_x: {df_out.iloc[0]['coords_x'][:100]}...\")\nprint(f\"Original type: {df_orig.iloc[0]['type']}\")\nprint(f\"Output type: {df_out.iloc[0]['type']}\")\n\nprint(\"\\n=== Example 2: Originally polyline (row 1) ===\")\nprint(f\"Original coords_x: {df_orig.iloc[1]['coords_x'][:100]}...\")\nprint(f\"Output coords_x: {df_out.iloc[1]['coords_x'][:100]}...\")\nprint(f\"Original type: {df_orig.iloc[1]['type']}\")\nprint(f\"Output type: {df_out.iloc[1]['type']}\")\n\nprint(\"\\nAll columns in output:\")\nprint(df_out.columns.tolist())\nEOF\n"]
