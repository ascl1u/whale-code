[?2004hroot@75e0c428ae4c:/app# cat > /app/convert_masks.py << 'EOF'
[?2004l[?2004h> import argparse
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import torch
[?2004l[?2004h> from mobile_sam import sam_model_registry, SamPredictor
[?2004l[?2004h> 
[?2004l[?2004h> def parse_coords(coords_str):
[?2004l [?2004h>     """Parse comma-separated coordinate string to list of integers."""
[?2004l[?2004h>     if pd.isna(coords_str):
[?2004l[?2004h>         return []
[?2004l[?2004h>     return [int(x) for x in str(coords_str).split(',')]
[?2004l[?2004h> 
[?2004l[?2004h> def coords_to_string(coords_list):
[?2004l[?2004h>     """Convert list of coordinates to comma-separated string."""
[?2004l[?2004h>     return ','.join(map(str, coords_list))
[?2004l[?2004h> 
[?2004l[?2004h> def get_largest_contour(mask):
[?2004l[?2004h>     """Extract the largest contour from a binary mask."""
[?2004l[?2004h>     contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
[?2004l[?2004h>     if len(contours) == 0:
[?2004l[?2004h>         return None
[?2004li[?2004h>     # Get the largest contour by area
[?2004l [?2004h>     largest_contour = max(contours, key=cv2.contourArea)
[?2004l[?2004h>     return largest_contour
[?2004l [?2004h> 
[?2004l[?2004h> def contour_to_coords(contour):
[?2004l[?2004h>     """Convert OpenCV contour to separate x and y coordinate lists."""
[?2004l[?2004h>     if contour is None or len(contour) == 0:
[?2004l[?2004h>         return [], []
[?2004l[?2004h>     # Squeeze to remove extra dimension and extract x, y coordinates
[?2004l[?2004h>     points = contour.squeeze()
[?2004l[?2004h>     if len(points.shape) == 1:  # Single point
[?2004l[?2004h>         points = points.reshape(1, -1)
[?2004l[?2004h>     coords_x = points[:, 0].tolist()
[?2004l[?2004h>     coords_y = points[:, 1].tolist()
[?2004l[?2004h>     return coords_x, coords_y
[?2004l[?2004h> 
[?2004l[?2004h> def refine_mask_with_sam(predictor, bbox):
[?2004l[?2004h>     """Use SAM to refine a mask given a bounding box prompt."""
[?2004l[?2004h>     # bbox format: [xmin, ymin, xmax, ymax]
[?2004l[?2004h>     box_prompt = np.array(bbox)
[?2004l[?2004h>     
[?2004l[?2004h>     # Predict mask using bounding box prompt
[?2004l[?2004h>     masks, scores, _ = predictor.predict(
[?2004l[?2004h>         point_coords=None,
[?2004l[?2004h>         point_labels=None,
[?2004l[?2004h>         box=box_prompt,
[?2004l[?2004h>         multimask_output=False  # Single mask output
[?2004l[?2004h>     )
[?2004l[?2004h>     
[?2004l[?2004h>     # Return the mask (first one since multimask_output=False)
[?2004l[?2004h>     return masks[0]
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     parser = argparse.ArgumentParser(
[?2004l[?2004h>         description='Convert cell masks to polylines using MobileSAM'
[?2004l[?2004h>     )
[?2004l[?2004h>     parser.add_argument('weights_path', type=str, help='Path to MobileSAM weights')
[?2004l[?2004h>     parser.add_argument('output_path', type=str, help='Path to output CSV file')
[?2004l[?2004h>     parser.add_argument('rgb_path', type=str, help='Path to RGB image')
[?2004l[?2004h>     parser.add_argument('csv_path', type=str, help='Path to metadata CSV')
[?2004l[?2004h>     
[?2004l[?2004h>     args = parser.parse_args()
[?2004l[?2004h>     
[?2004l[?2004h>     # Load the image
[?2004l[?2004h>     print("Loading image...")
[?2004l[?2004h>     image = cv2.imread(args.rgb_path)
[?2004l[?2004h>     if image is None:
[?2004l[?2004h>         raise ValueError(f"Could not load image from {args.rgb_path}")
[?2004l[?2004h>     image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
[?2004l[?2004h>     
[?2004l[?2004h>     # Load the CSV
[?2004l[?2004h>     print("Loading CSV...")
[?2004l[?2004h>     df = pd.read_csv(args.csv_path)
[?2004l[?2004h>     
[?2004l[?2004h>     # Initialize MobileSAM
[?2004l[?2004h>     print("Loading MobileSAM model...")
[?2004l[?2004h>     device = 'cpu'
[?2004l[?2004h>     sam = sam_model_registry['vit_t'](checkpoint=args.weights_path)
[?2004l[?2004h>     sam.to(device=device)
[?2004l[?2004h>     sam.eval()
[?2004l[?2004h>     
[?2004l[?2004h>     predictor = SamPredictor(sam)
[?2004l[?2004h>     predictor.set_image(image_rgb)
[?2004l[?2004h>     
[?2004l[?2004h>     # Create a mask to track which pixels are already assigned
[?2004l[?2004h>     assigned_mask = np.zeros(image.shape[:2], dtype=bool)
[?2004l[?2004h>     
[?2004l[?2004h>     # Process each mask
[?2004l[?2004h>     print(f"Processing {len(df)} masks...")
[?2004l[?2004h>     for idx in range(len(df)):
[?2004l[?2004h>         row = df.iloc[idx]
[?2004l[?2004h>         
[?2004l[?2004h>         # Get bounding box
[?2004l[?2004h>         xmin, ymin, xmax, ymax = int(row['xmin']), int(row['ymin']), int(row['xmax']), int(row['ymax'])
[?2004l[?2004h>         bbox = [xmin, ymin, xmax, ymax]
[?2004l[?2004h>         
[?2004l[?2004h>         # Refine mask with SAM
[?2004l[?2004h>         refined_mask = refine_mask_with_sam(predictor, bbox)
[?2004l[?2004h>         
[?2004l[?2004h>         # Remove any overlap with previously assigned masks
[?2004l[?2004h>         refined_mask = refined_mask & (~assigned_mask)
[?2004l[?2004h>         
[?2004l[?2004h>         # Extract the largest contour
[?2004l[?2004h>         contour = get_largest_contour(refined_mask)
[?2004l[?2004h>         
[?2004l[?2004h>         if contour is not None and len(contour) > 0:
[?2004l[?2004h>             # Convert contour to coordinates
[?2004l[?2004h>             coords_x, coords_y = contour_to_coords(contour)
[?2004l[?2004h>             
[?2004l[?2004h>             # Update bounding box based on actual contour
[?2004l[?2004h>             if len(coords_x) > 0:
[?2004l[?2004h>                 new_xmin = min(coords_x)
[?2004l[?2004h>                 new_xmax = max(coords_x)
[?2004l[?2004h>                 new_ymin = min(coords_y)
[?2004l[?2004h>                 new_ymax = max(coords_y)
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Update dataframe
[?2004l[?2004h>                 df.at[idx, 'xmin'] = new_xmin
[?2004l[?2004h>                 df.at[idx, 'xmax'] = new_xmax
[?2004l[?2004h>                 df.at[idx, 'ymin'] = new_ymin
[?2004l[?2004h>                 df.at[idx, 'ymax'] = new_ymax
[?2004l[?2004h>                 df.at[idx, 'coords_x'] = coords_to_string(coords_x)
[?2004l[?2004h>                 df.at[idx, 'coords_y'] = coords_to_string(coords_y)
[?2004l[?2004h>                 df.at[idx, 'type'] = 'polyline'
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Mark these pixels as assigned
[?2004l[?2004h>                 mask_filled = np.zeros(image.shape[:2], dtype=np.uint8)
[?2004l[?2004h>                 cv2.drawContours(mask_filled, [contour], -1, 1, -1)
[?2004l[?2004h>                 assigned_mask = assigned_mask | (mask_filled > 0)
[?2004l[?2004h>             else:
[?2004l[?2004h>                 # Keep original if no valid contour found
[?2004l[?2004h>                 print(f"Warning: No valid contour for mask {idx}, keeping original")
[?2004l[?2004h>         else:
[?2004l[?2004h>             # Keep original if no contour found
[?2004l[?2004h>             print(f"Warning: No contour found for mask {idx}, keeping original")
[?2004l[?2004h>     
[?2004l[?2004h>     # Save the updated CSV
[?2004l[?2004h>     print(f"Saving results to {args.output_path}...")
[?2004l[?2004h>     df.to_csv(args.output_path, index=False)
[?2004l[?2004h>     print("Done!")
