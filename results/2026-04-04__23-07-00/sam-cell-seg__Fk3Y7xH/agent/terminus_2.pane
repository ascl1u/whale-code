[?2004l[?2004h>     return parser.parse_args()
[?2004l[?2004h> 
[?2004l[?2004h> def mask_to_polyline(mask):
[?2004l[?2004h>     """Convert binary mask to polyline coordinates."""
[?2004l[?2004h>     # Find contours
[?2004l[?2004h>     contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(contours) == 0:
[?2004l[?2004h>         return None, None, None, None, None, None
[?2004l[?2004h>     
[?2004l[?2004h>     # Get the largest contour (most contiguous mask)
[?2004l[?2004h>     contour = max(contours, key=cv2.contourArea)
[?2004l[?2004h>     
[?2004l[?2004h>     # Simplify contour slightly to reduce points
[?2004l[?2004h>     epsilon = 0.5
[?2004l[?2004h>     contour = cv2.approxPolyDP(contour, epsilon, True)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract coordinates
[?2004l[?2004h>     contour = contour.squeeze()
[?2004l[?2004h>     if len(contour.shape) == 1:  # Single point
[?2004l[?2004h>         contour = contour.reshape(1, -1)
[?2004l[?2004h>     
[?2004l[?2004h>     coords_x = contour[:, 0]
[?2004l[?2004h>     coords_y = contour[:, 1]
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate bounding box
[?2004l[?2004h>     xmin = int(coords_x.min())
[?2004l[?2004h>     xmax = int(coords_x.max())
[?2004l[?2004h>     ymin = int(coords_y.min())
[?2004l[?2004h>     ymax = int(coords_y.max())
[?2004l[?2004h>     
[?2004l[?2004h>     # Convert to comma-separated strings
[?2004l[?2004h>     coords_x_str = ','.join(map(str, coords_x))
[?2004l[?2004h>     coords_y_str = ','.join(map(str, coords_y))
[?2004l[?2004h>     
[?2004l[?2004h>     return xmin, ymin, xmax, ymax, coords_x_str, coords_y_str
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     args = parse_args()
[?2004l[?2004h>     
[?2004l[?2004h>     # Load image
[?2004l[?2004h>     image = cv2.imread(args.rgb_path)
[?2004l[?2004h>     image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
[?2004l[?2004h>     
[?2004l[?2004h>     # Load CSV
[?2004l[?2004h>     df = pd.read_csv(args.csv_path)
[?2004l[?2004h>     
[?2004l[?2004h>     # Initialize MobileSAM
[?2004l[?2004h>     device = 'cpu'
[?2004l[?2004h>     model_type = 'vit_t'
[?2004l[?2004h>     mobile_sam = sam_model_registry[model_type](checkpoint=args.weights_path)
[?2004l[?2004h>     mobile_sam.to(device=device)
[?2004l[?2004h>     mobile_sam.eval()
[?2004l[?2004h>     
[?2004l[?2004h>     predictor = SamPredictor(mobile_sam)
[?2004l[?2004h>     predictor.set_image(image)
[?2004l[?2004h>     
[?2004l[?2004h>     # Create a mask to track occupied pixels (to handle overlaps)
[?2004l[?2004h>     h, w = image.shape[:2]
[?2004l[?2004h>     occupied_mask = np.zeros((h, w), dtype=np.int32)
[?2004l[?2004h>     
[?2004l[?2004h>     # Process each mask
[?2004l[?2004h>     for idx in range(len(df)):
[?2004l[?2004h>         row = df.iloc[idx]
[?2004l[?2004h>         
[?2004l[?2004h>         # Get bounding box
[?2004l[?2004h>         xmin, ymin, xmax, ymax = row['xmin'], row['ymin'], row['xmax'], row['ymax']
[?2004l[?2004h>         box = np.array([xmin, ymin, xmax, ymax])
[?2004l[?2004h>         
[?2004l[?2004h>         # Predict mask using MobileSAM
[?2004l[?2004h>         masks, scores, _ = predictor.predict(
[?2004l[?2004h>             point_coords=None,
[?2004l[?2004h>             point_labels=None,
[?2004l[?2004h>             box=box[None, :],
[?2004l[?2004h>             multimask_output=False,
[?2004l[?2004h>         )
[?2004l[?2004h>         
[?2004l[?2004h>         # Get the mask (first mask, as multimask_output=False)
[?2004l[?2004h>         mask = masks[0]
[?2004l[?2004h>         
[?2004l[?2004h>         # Remove overlap with previously processed masks
[?2004l[?2004h>         mask = mask & (occupied_mask == 0)
[?2004l[?2004h>         
[?2004l[?2004h>         # Update occupied mask
[?2004l[?2004h>         occupied_mask[mask] = idx + 1
[?2004l[?2004h>         
[?2004l[?2004h>         # Convert mask to polyline
[?2004l[?2004h>         new_xmin, new_ymin, new_xmax, new_ymax, coords_x_str, coords_y_str = mask_to_polyline(mask)
[?2004l[?2004h>         
[?2004l[?2004h>         if coords_x_str is not None:
[?2004l[?2004h>             # Update dataframe
[?2004l[?2004h>             df.at[idx, 'xmin'] = new_xmin
[?2004l[?2004h>             df.at[idx, 'ymin'] = new_ymin
[?2004l[?2004h>             df.at[idx, 'xmax'] = new_xmax
[?2004l[?2004h>             df.at[idx, 'ymax'] = new_ymax
[?2004l[?2004h>             df.at[idx, 'coords_x'] = coords_x_str
[?2004l[?2004h>             df.at[idx, 'coords_y'] = coords_y_str
[?2004l[?2004h>             df.at[idx, 'type'] = 'polyline'
[?2004l[?2004h>     
[?2004l[?2004h>     # Save updated CSV
[?2004l[?2004h>     df.to_csv(args.output_path, index=False)
[?2004l[?2004h>     print(f"Converted {len(df)} masks and saved to {args.output_path}")
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     main()
