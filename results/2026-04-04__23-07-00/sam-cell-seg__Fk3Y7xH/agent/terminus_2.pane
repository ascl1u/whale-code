[?2004limport argparse
import pandas as pd
import numpy as np
import cv2
import torch
from mobile_sam import sam_model_registry, SamPredictor

def parse_args():
    parser = argparse.ArgumentParser(description='Convert mask annotations using MobileSAM')
    parser.add_argument('weights_path', type=str, help='Path to MobileSAM weights')
    parser.add_argument('output_path', type=str, help='Path to output CSV')
    parser.add_argument('rgb_path', type=str, help='Path to RGB image')
    parser.add_argument('csv_path', type=str, help='Path to input CSV')
    return parser.parse_args()

def mask_to_polyline(mask):
    """Convert binary mask to polyline coordinates."""
    # Find contours
    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    
    if len(contours) == 0:
        return None, None, None, None, None, None
    
    # Get the largest contour (most contiguous mask)
    contour = max(contours, key=cv2.contourArea)
    
    # Simplify contour slightly to reduce points
    epsilon = 0.5
    contour = cv2.approxPolyDP(contour, epsilon, True)
    
    # Extract coordinates
    contour = contour.squeeze()
    if len(contour.shape) == 1:  # Single point
        contour = contour.reshape(1, -1)
    
    coords_x = contour[:, 0]
    coords_y = contour[:, 1]
    
    # Calculate bounding box
    xmin = int(coords_x.min())
    xmax = int(coords_x.max())
    ymin = int(coords_y.min())
    ymax = int(coords_y.max())
    
    # Convert to comma-separated strings
    coords_x_str = ','.join(map(str, coords_x))
    coords_y_str = ','.join(map(str, coords_y))
    
    return xmin, ymin, xmax, ymax, coords_x_str, coords_y_str

def main():
    args = parse_args()
    
    # Load image
    image = cv2.imread(args.rgb_path)
    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
    
    # Load CSV
    df = pd.read_csv(args.csv_path)
    
    # Initialize MobileSAM
    device = 'cpu'
    model_type = 'vit_t'
    mobile_sam = sam_model_registry[model_type](checkpoint=args.weights_path)
    mobile_sam.to(device=device)
    mobile_sam.eval()
    
    predictor = SamPredictor(mobile_sam)
    predictor.set_image(image)
    
    # Create a mask to track occupied pixels (to handle overlaps)
    h, w = image.shape[:2]
    occupied_mask = np.zeros((h, w), dtype=np.int32)
    
    # Process each mask
    for idx in range(len(df)):
        row = df.iloc[idx]
        
        # Get bounding box
        xmin, ymin, xmax, ymax = row['xmin'], row['ymin'], row['xmax'], row['ymax']
        box = np.array([xmin, ymin, xmax, ymax])
        
        # Predict mask using MobileSAM
        masks, scores, _ = predictor.predict(
            point_coords=None,
            point_labels=None,
            box=box[None, :],
            multimask_output=False,
        )
        
        # Get the mask (first mask, as multimask_output=False)
        mask = masks[0]
        
        # Remove overlap with previously processed masks
        mask = mask & (occupied_mask == 0)
        
        # Update occupied mask
        occupied_mask[mask] = idx + 1
        
        # Convert mask to polyline
        new_xmin, new_ymin, new_xmax, new_ymax, coords_x_str, coords_y_str = mask_to_polyline(mask)
        
        if coords_x_str is not None:
            # Update dataframe
            df.at[idx, 'xmin'] = new_xmin
            df.at[idx, 'ymin'] = new_ymin
            df.at[idx, 'xmax'] = new_xmax
            df.at[idx, 'ymax'] = new_ymax
            df.at[idx, 'coords_x'] = coords_x_str
            df.at[idx, 'coords_y'] = coords_y_str
            df.at[idx, 'type'] = 'polyline'
    
    # Save updated CSV
    df.to_csv(args.output_path, index=False)
    print(f"Converted {len(df)} masks and saved to {args.output_path}")

if __name__ == '__main__':
    main()
