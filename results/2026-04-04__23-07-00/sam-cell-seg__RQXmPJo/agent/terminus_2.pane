[?2004lr[?2004h> 
[?2004l[?2004h> def contour_to_coords(contour):
[?2004l[?2004h>     """Convert contour to separate x and y coordinate lists."""
[?2004l[?2004h>     if contour is None or len(contour) == 0:
[?2004l[?2004h>         return [], []
[?2004l[?2004h>     
[?2004l[?2004h>     # Flatten contour and extract x, y coordinates
[?2004l [?2004h>     contour = contour.squeeze()
[?2004l[?2004h>     if len(contour.shape) == 1:  # Single point
[?2004l[?2004h>         contour = contour.reshape(1, -1)
