[549.711264, "i", "cat > /app/polyglot/main.py.c << 'ENDOFFILE'\n#if 0\n''' \n#endif\n#include <stdio.h>\n#include <stdlib.h>\n\nlong long fibonacci(int n) {\n    if (n <= 1) return n;\n    long long a = 0, b = 1, c;\n    for (int i = 2; i <= n; i++) {\n        c = a + b;\n        a = b;\n        b = c;\n    }\n    return b;\n}\n\nint main(int argc, char *argv[]) {\n    if (argc != 2) {\n        return 1;\n    }\n    int n = atoi(argv[1]);\n    printf(\"%lld\\\\n\", fibonacci(n));\n    return 0;\n}\n#if 0\n''' \n#endif\n\nimport sys\n\ndef fibonacci(n):\n    if n <= 1:\n        return n\n    a, b = 0, 1\n    for _ in range(2, n + 1):\n        a, b = b, a + b\n    return b\n\nif __name__ == \"__main__\":\n    if len(sys.argv) != 2:\n        sys.exit(1)\n    n = int(sys.argv[1])\n    print(fibonacci(n))\nENDOFFILE\n"]
