'''
#endif
#include <stdio.h>
#include <stdlib.h>

long long fib(int n) {
    if (n <= 1) return n;
    long long a = 0, b = 1, temp;
    for (int i = 2; i <= n; i++) {
        temp = a + b;
        a = b;
        b = temp;
    }
    return b;
}

int main(int argc, char *argv[]) {
    if (argc != 2) {
        fprintf(stderr, "Usage: %s N\n", argv[0]);
        return 1;
    }
    int n = atoi(argv[1]);
    printf("%lld\n", fib(n));
    return 0;
}

