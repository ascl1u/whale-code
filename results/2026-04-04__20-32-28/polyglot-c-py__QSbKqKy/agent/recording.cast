[179.490921, "o", "#if 0\r\n\"\"\"\r\n#endif\r\n#include <stdio.h>\r\n#include <stdlib.h>\r\n\r\nlong long fibonacci(int n) {\r\n    if (n <= 0) return 0;\r\n    if (n == 1) return 1;\r\n    \r\n    long long a = 0, b = 1, temp;\r\n    for (int i = 2; i <= n; i++) {\r\n        temp = a + b;\r\n        a = b;\r\n        b = temp;\r\n    }\r\n    return b;\r\n}\r\n\r\nint main(int argc, char *argv[]) {\r\n    if (argc < 2) {\r\n        fprintf(stderr, \"Usage: %s N\\n\", argv[0]);\r\n        return 1;\r\n    }\r\n    \r\n    int n = atoi(argv[1]);\r\n    printf(\"%lld\\n\", fibonacci(n));\r\n    return 0;\r\n}\r\n\r\n#if 0\r\n\"\"\"\r\n\r\nimport sys\r\n\r\ndef fibonacci(n):\r\n    if n <= 0:\r\n        return 0\r\n    elif n == 1:\r\n        return 1\r\n    else:\r\n        a, b = 0, 1\r\n        for _ in range(2, n + 1):\r\n            a, b = b, a + b\r\n        return b\r\n\r\nif __name__ == \"__main__\":\r\n    n = int(sys.argv[1])\r\n    print(fibonacci(n))\r\n\r\n#endif\r\n"]
