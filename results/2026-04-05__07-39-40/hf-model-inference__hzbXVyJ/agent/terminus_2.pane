[?2004l[?2004h> def analyze_sentiment():
[?2004l[?2004h>     try:
[?2004l[?2004h>         # Get JSON data from request
[?2004l[?2004h>         data = request.get_json()
[?2004l[?2004h>         
[?2004l[?2004h>         # Validate input
[?2004l[?2004h>         if not data:
[?2004l[?2004h>             return jsonify({"error": "No JSON data provided"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         if 'text' not in data:
[?2004l[?2004h>             return jsonify({"error": "Missing 'text' field in request body"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         text = data['text']
[?2004l[?2004h>         
[?2004l[?2004h>         if not isinstance(text, str):
[?2004l[?2004h>             return jsonify({"error": "'text' field must be a string"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         if not text.strip():
[?2004l[?2004h>             return jsonify({"error": "'text' field cannot be empty"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         # Tokenize and run inference
[?2004l[?2004h>         inputs = tokenizer(text, return_tensors="pt", truncation=True, max_length=512)
[?2004l[?2004h>         
[?2004l[?2004h>         with torch.no_grad():
[?2004l[?2004h>             outputs = model(**inputs)
[?2004l[?2004h>             logits = outputs.logits
[?2004l[?2004h>             probabilities = F.softmax(logits, dim=1)
[?2004l[?2004h>         
[?2004l[?2004h>         # Extract confidence scores
[?2004l[?2004h>         # Model outputs: [negative, positive]
[?2004l[?2004h>         negative_score = float(probabilities[0][0])
[?2004l[?2004h>         positive_score = float(probabilities[0][1])
[?2004l[?2004h>         
[?2004l[?2004h>         # Determine sentiment
[?2004l[?2004h>         sentiment = "positive" if positive_score > negative_score else "negative"
[?2004l[?2004h>         
[?2004l[?2004h>         # Return response
