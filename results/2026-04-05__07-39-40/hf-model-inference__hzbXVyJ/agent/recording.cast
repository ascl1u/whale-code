[253.85058, "i", "python3 << 'EOF'\nimport requests\nimport json\n\n# Test positive sentiment\nresponse = requests.post(\n    'http://localhost:5000/sentiment',\n    json={'text': 'I love this product! It is amazing!'}\n)\nprint(\"Test 1 - Positive sentiment:\")\nprint(f\"Status Code: {response.status_code}\")\nprint(f\"Response: {json.dumps(response.json(), indent=2)}\")\nprint()\n\n# Test negative sentiment\nresponse = requests.post(\n    'http://localhost:5000/sentiment',\n    json={'text': 'This is terrible and I hate it.'}\n)\nprint(\"Test 2 - Negative sentiment:\")\nprint(f\"Status Code: {response.status_code}\")\nprint(f\"Response: {json.dumps(response.json(), indent=2)}\")\nprint()\n\n# Test error case - missing text field\nresponse = requests.post(\n    'http://localhost:5000/sentiment',\n    json={}\n)\nprint(\"Test 3 - Error case (missing text):\")\nprint(f\"Status Code: {response.status_code}\")\nprint(f\"Response: {json.dumps(response.json(), indent=2)}\")\nEOF\n"]
