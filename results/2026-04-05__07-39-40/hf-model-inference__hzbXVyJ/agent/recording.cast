[320.182321, "i", "python3 << 'EOF'\nimport requests\nimport json\n\nprint(\"=\" * 60)\nprint(\"FINAL COMPREHENSIVE API TEST\")\nprint(\"=\" * 60)\n\n# Test 1: Valid positive sentiment\nprint(\"\\n1. Testing valid positive sentiment:\")\nresponse = requests.post('http://0.0.0.0:5000/sentiment', json={'text': 'I love this!'})\nprint(f\"   Status: {response.status_code}\")\ndata = response.json()\nprint(f\"   Sentiment: {data['sentiment']}\")\nprint(f\"   Confidence: positive={data['confidence']['positive']:.4f}, negative={data['confidence']['negative']:.4f}\")\nassert response.status_code == 200\nassert 'sentiment' in data\nassert 'confidence' in data\nassert 'positive' in data['confidence']\nassert 'negative' in data['confidence']\nprint(\"   ✓ PASSED\")\n\n# Test 2: Valid negative sentiment\nprint(\"\\n2. Testing valid negative sentiment:\")\nresponse = requests.post('http://0.0.0.0:5000/sentiment', json={'text': 'This is awful!'})\nprint(f\"   Status: {response.status_code}\")\ndata = response.json()\nprint(f\"   Sentiment: {data['sentiment']}\")\nprint(f\"   Confidence: posi"]
