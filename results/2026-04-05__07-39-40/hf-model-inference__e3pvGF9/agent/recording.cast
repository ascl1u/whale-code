[254.793722, "i", "python3 << 'EOF'\nimport requests\nimport json\n\nprint(\"=\" * 60)\nprint(\"FINAL COMPREHENSIVE API TEST\")\nprint(\"=\" * 60)\n\n# Test 1: Positive sentiment\nprint(\"\\n1. Testing positive sentiment:\")\nresponse = requests.post('http://localhost:5000/sentiment', \n                         json={'text': 'I love this product! It works perfectly.'})\nprint(f\"   Status: {response.status_code}\")\nresult = response.json()\nprint(f\"   Sentiment: {result['sentiment']}\")\nprint(f\"   Confidence - Positive: {result['confidence']['positive']:.4f}\")\nprint(f\"   Confidence - Negative: {result['confidence']['negative']:.4f}\")\nassert result['sentiment'] == 'positive', \"Expected positive sentiment\"\nassert 'confidence' in result, \"Missing confidence field\"\nassert 'positive' in result['confidence'], \"Missing positive confidence\"\nassert 'negative' in result['confidence'], \"Missing negative confidence\"\nprint(\"   ✓ PASSED\")\n\n# Test 2: Negative sentiment\nprint(\"\\n2. Testing negative sentiment:\")\nresponse = requests.post('http://localhost:5000/sentime"]
[254.793876, "i", "nt',\n                         json={'text': 'This is awful and disappointing.'})\nprint(f\"   Status: {response.status_code}\")\nresult = response.json()\nprint(f\"   Sentiment: {result['sentiment']}\")\nprint(f\"   Confidence - Positive: {result['confidence']['positive']:.4f}\")\nprint(f\"   Confidence - Negative: {result['confidence']['negative']:.4f}\")\nassert result['sentiment'] == 'negative', \"Expected negative sentiment\"\nprint(\"   ✓ PASSED\")\n\n# Test 3: Error handling\nprint(\"\\n3. Testing error handling (missing text field):\")\nresponse = requests.post('http://localhost:5000/sentiment', json={})\nprint(f\"   Status: {response.status_code}\")\nresult = response.json()\nprint(f\"   Error: {result['error']}\")\nassert response.status_code == 400, \"Expected 400 status code\"\nassert 'error' in result, \"Missing error field\"\nprint(\"   ✓ PASSED\")\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"ALL TESTS PASSED - SERVICE IS WORKING CORRECTLY\")\nprint(\"=\" * 60)\nEOF\n"]
