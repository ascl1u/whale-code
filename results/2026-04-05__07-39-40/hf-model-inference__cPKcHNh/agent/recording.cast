[138.243005, "o", ">         \r\n\u001b[?2004l\r"]
[138.243176, "o", "\u001b[?2004h> "]
[138.243289, "o", "        if not text.strip():\r\n\u001b[?2004l\r"]
[138.243438, "o", "\u001b[?2004h> "]
[138.243877, "o", "            return jsonify({\"error\": \"'text' field cannot be empty\"}), 400\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.244043, "o", "> "]
[138.244166, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[138.244304, "o", "> "]
[138.244666, "o", "        # Tokenize input\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.244841, "o", "> "]
[138.245159, "o", "        inputs = tokenizer(text, return_tensors=\"pt\", truncation=True, max_length=512)\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.245297, "o", "> "]
[138.245423, "o", "        \r\n\u001b[?2004l\r"]
[138.245562, "o", "\u001b[?2004h> "]
[138.24569, "o", "        # Get model predictions\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.245806, "o", "> "]
[138.245991, "o", "        with torch.no_grad():\r\n\u001b[?2004l\r"]
[138.24603, "o", "\u001b[?2004h> "]
[138.246316, "o", "            outputs = model(**inputs)\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.24642, "o", "> "]
[138.246641, "o", "            logits = outputs.logits\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.246761, "o", "> "]
[138.246921, "o", "        \r\n\u001b[?2004l\r"]
[138.246991, "o", "\u001b[?2004h> "]
[138.247253, "o", "        # Apply softmax to get probabilities\r\n\u001b[?2004l\r"]
[138.247375, "o", "\u001b[?2004h> "]
[138.24783, "o", "        probabilities = torch.nn.functional.softmax(logits, dim=-1)\r\n"]
[138.247975, "o", "\u001b[?2004l\r"]
[138.248093, "o", "\u001b[?2004h> "]
[138.248349, "o", "        probs = probabilities[0].tolist()\r\n\u001b[?2004l\r"]
[138.248506, "o", "\u001b[?2004h> "]
[138.248628, "o", "        \r\n\u001b[?2004l\r"]
[138.248691, "o", "\u001b[?2004h> "]
[138.24916, "o", "        # The model outputs [negative, positive] probabilities\r\n\u001b[?2004l\r"]
[138.249458, "o", "\u001b[?2004h> "]
[138.249582, "o", "        negative_score = probs[0]\r\n\u001b[?2004l\r"]
[138.249758, "o", "\u001b[?2004h> "]
[138.249893, "o", "        positive_score = probs[1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.250123, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.250353, "o", "        # Determine sentiment\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.250948, "o", "        sentiment = \"positive\" if positive_score > negative_score else \"negative\"\r\n\u001b[?2004l\r"]
[138.251096, "o", "\u001b[?2004h> "]
[138.251138, "o", "        \r\n\u001b[?2004l\r"]
[138.251309, "o", "\u001b[?2004h> "]
[138.251491, "o", "        # Return response\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.251569, "o", "> "]
[138.251786, "o", "        return jsonify({\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.251838, "o", "> "]
[138.252145, "o", "            \"sentiment\": sentiment,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.252355, "o", "            \"confidence\": {\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.25248, "o", "> "]
[138.252678, "o", "                \"positive\": positive_score,\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.252827, "o", "> "]
[138.252996, "o", "                \"negative\": negative_score\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.253132, "o", "> "]
[138.253434, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.253671, "o", "        }), 200\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[138.253826, "o", "\u001b[?2004h> "]
[138.254081, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.255341, "o", "        return jsonify({\"error\": str(e)}), 400\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h>     app.run(host='0.0.0.0', port=5000, debug=False)\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
