[170.50767, "i", "e - empty text\")\nresponse = requests.post(\n    'http://localhost:5000/sentiment',\n    json={'text': ''}\n)\nprint(f\"Status Code: {response.status_code}\")\nprint(f\"Response: {json.dumps(response.json(), indent=2)}\")\nEOF\n"]
