[?2004hroot@1ce96f2cee11:/app# cat > app.py << 'EOF'
[?2004l[?2004h> from flask import Flask, request, jsonify
[?2004l[?2004h> from transformers import AutoTokenizer, AutoModelForSequenceClassification
[?2004l[?2004h> import torch
[?2004l[?2004h> import os
[?2004l[?2004h> 
[?2004l[?2004h> app = Flask(__name__)
[?2004l[?2004h> 
[?2004l[?2004h> # Load model and tokenizer from local directory
[?2004l[?2004h> model_path = "/app/model_cache/sentiment_model"
[?2004l[?2004h> print(f"Loading model from {model_path}...")
[?2004l[?2004h> tokenizer = AutoTokenizer.from_pretrained(model_path)
[?2004l[?2004h> model = AutoModelForSequenceClassification.from_pretrained(model_path)
[?2004l[?2004h> print("Model loaded successfully!")
[?2004l[?2004h> 
[?2004l[?2004h> @app.route('/sentiment', methods=['POST'])
[?2004l[?2004h> def analyze_sentiment():
[?2004l[?2004h>     try:
[?2004l[?2004h>         # Get JSON data from request
[?2004l[?2004h>         data = request.get_json()
[?2004l[?2004h>         
[?2004l[?2004h>         # Validate input
[?2004l[?2004h>         if not data:
[?2004l[?2004h>             return jsonify({"error": "No JSON data provided"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         if 'text' not in data:
[?2004l[?2004h>             return jsonify({"error": "Missing 'text' field in request"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         text = data['text']
[?2004l[?2004h>         
[?2004l[?2004h>         if not isinstance(text, str):
[?2004l[?2004h>             return jsonify({"error": "'text' field must be a string"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         if not text.strip():
[?2004l[?2004h>             return jsonify({"error": "'text' field cannot be empty"}), 400
[?2004l[?2004h>         
[?2004l[?2004h>         # Tokenize input
[?2004l[?2004h>         inputs = tokenizer(text, return_tensors="pt", truncation=True, max_length=512)
[?2004l[?2004h>         
[?2004l[?2004h>         # Get model predictions
[?2004l[?2004h>         with torch.no_grad():
[?2004l[?2004h>             outputs = model(**inputs)
[?2004l[?2004h>             logits = outputs.logits
[?2004l[?2004h>         
[?2004l[?2004h>         # Apply softmax to get probabilities
[?2004l[?2004h>         probabilities = torch.nn.functional.softmax(logits, dim=-1)
[?2004l[?2004h>         probs = probabilities[0].tolist()
[?2004l[?2004h>         
[?2004l[?2004h>         # The model outputs [negative, positive] probabilities
[?2004l[?2004h>         negative_score = probs[0]
[?2004l[?2004h>         positive_score = probs[1]
[?2004l[?2004h>         
[?2004l[?2004h>         # Determine sentiment
[?2004l[?2004h>         sentiment = "positive" if positive_score > negative_score else "negative"
[?2004l[?2004h>         
[?2004l[?2004h>         # Return response
[?2004l[?2004h>         return jsonify({
[?2004l[?2004h>             "sentiment": sentiment,
[?2004l[?2004h>             "confidence": {
[?2004l[?2004h>                 "positive": positive_score,
[?2004l[?2004h>                 "negative": negative_score
[?2004l[?2004h>             }
[?2004l[?2004h>         }), 200
[?2004l[?2004h>     
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         return jsonify({"error": str(e)}), 400
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     app.run(host='0.0.0.0', port=5000, debug=False)
