[352.829431, "i", "python3 << 'EOFPY'\nimport struct\nimport sys\n\n# Try to find and list files in the ISO\nwith open('/app/alpine.iso', 'rb') as f:\n    # Skip to primary volume descriptor (sector 16)\n    f.seek(16 * 2048)\n    pvd = f.read(2048)\n    \n    # Check if it's a valid ISO\n    if pvd[1:6] != b'CD001':\n        print('Not a valid ISO')\n        sys.exit(1)\n    \n    print('Valid ISO 9660 filesystem')\n    print('Looking for boot directory...')\n    \n    # Try to find boot files by searching for common patterns\n    f.seek(0)\n    data = f.read(100000)  # Read first 100KB\n    \n    if b'vmlinuz' in data:\n        print('Found vmlinuz reference')\n    if b'initramfs' in data or b'initrd' in data:\n        print('Found initramfs/initrd reference')\nEOFPY\n"]
[352.829797, "o", "python3 << 'EOFPY'\r\n\u001b[?2004l\r"]
