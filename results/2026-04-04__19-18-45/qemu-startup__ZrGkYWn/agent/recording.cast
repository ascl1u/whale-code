[219.570551, "i", "cat > /tmp/qemu_telnet.sh << 'EOFSCRIPT'\n#!/bin/bash\n\n# Create FIFOs for bidirectional communication\nFIFO_IN=/tmp/qemu_in\nFIFO_OUT=/tmp/qemu_out\n\nrm -f $FIFO_IN $FIFO_OUT\nmkfifo $FIFO_IN $FIFO_OUT\n\n# Start QEMU in background with stdio\nqemu-system-x86_64 -m 512 -cdrom /app/alpine.iso -boot d -nographic < $FIFO_IN > $FIFO_OUT 2>&1 &\nQEMU_PID=$!\n\n# Wait a bit for QEMU to start\nsleep 2\n\n# Start nc listener that forwards to/from FIFOs\nwhile true; do\n  nc -l -p 6665 < $FIFO_OUT > $FIFO_IN\ndone\nEOFSCRIPT\n"]
