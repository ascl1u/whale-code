[44.136058, "i", "cat > /tmp/wait_for_boot.sh << 'EOF'\n#!/bin/bash\necho \"Waiting for Alpine to boot...\"\nfor i in {1..60}; do\n  # Try to connect and get some output\n  output=$(timeout 2 telnet 127.0.0.1 6665 2>&1 <<< $'\\n' | head -20)\n  if echo \"$output\" | grep -qiE '(login:|alpine|localhost|Welcome)'; then\n    echo \"System is ready!\"\n    exit 0\n  fi\n  echo \"Attempt $i: Not ready yet, waiting...\"\n  sleep 2\ndone\necho \"Timeout waiting for boot\"\nexit 1\nEOF\n"]
