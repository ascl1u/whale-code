[233.995183, "i", "cat > /tmp/qemu_bridge.py << 'EOFPYTHON'\n#!/usr/bin/env python3\nimport socket\nimport subprocess\nimport threading\nimport sys\n\ndef handle_client(client_sock, qemu_proc):\n    def read_from_qemu():\n        while True:\n            data = qemu_proc.stdout.read(1)\n            if not data:\n                break\n            try:\n                client_sock.send(data)\n            except:\n                break\n    \n    def write_to_qemu():\n        while True:\n            try:\n                data = client_sock.recv(1024)\n                if not data:\n                    break\n                qemu_proc.stdin.write(data)\n                qemu_proc.stdin.flush()\n            except:\n                break\n    \n    t1 = threading.Thread(target=read_from_qemu, daemon=True)\n    t2 = threading.Thread(target=write_to_qemu, daemon=True)\n    t1.start()\n    t2.start()\n    t1.join()\n    t2.join()\n\n# Start QEMU\nqemu_proc = subprocess.Popen(\n    ['qemu-system-x86_64', '-m', '512', '-cdrom', '/app/alpine.iso', '-boot', 'd', '-nographic'],"]
[233.995622, "i", "\n    stdin=subprocess.PIPE,\n    stdout=subprocess.PIPE,\n    stderr=subprocess.STDOUT,\n    bufsize=0\n)\n\n# Create telnet server\nserver = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\nserver.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)\nserver.bind(('127.0.0.1', 6665))\nserver.listen(1)\n\nprint('Waiting for telnet connection on port 6665...')\n\nwhile True:\n    client, addr = server.accept()\n    print(f'Client connected from {addr}')\n    handle_client(client, qemu_proc)\n    client.close()\nEOFPYTHON\n"]
