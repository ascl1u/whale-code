ract the file\n                f.seek(file_lba * 2048)\n                file_data = f.read(file_size)\n                with open(\'/tmp/vmlinuz-lts-new\', \'wb\') as out:\n                    out.write(file_data)\n                print(f"Extracted to /tmp/vmlinuz-lts-new")\n                print(f"First 20 bytes: {file_data[:20].hex()}")\n                break\n            offset += length\n\nEOF\n'] min_timeout_sec: 1 max_timeout_sec: 180.0
