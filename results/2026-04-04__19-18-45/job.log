Sending keys: ['cat > /tmp/extract_iso.py << \'PYEOF\'\nimport struct\nimport sys\n\ndef read_iso_directory(iso_file, extent, size):\n    """Read directory records from ISO"""\n    iso_file.seek(extent * 2048)\n    data = iso_file.read(size)\n    \n    entries = []\n    offset = 0\n    while offset < len(data):\n        record_len = data[offset]\n        if record_len == 0:\n            offset = ((offset // 2048) + 1) * 2048\n            if offset >= len(data):\n                break\n            continue\n        \n        if offset + record_len > len(data):\n            break\n            \n        record = data[offset:offset + record_len]\n        \n        # Parse directory record\n        if len(record) >= 33:\n            extent_loc = struct.unpack(\'<I\', record[2:6])[0]\n            data_len = struct.unpack(\'<I\', record[10:14])[0]\n            name_len = record[32]\n            \n            if name_len > 0 and offset + 33 + name_len <= len(data):\n                name = record[33:33 + name_len].decode(\'ascii\', errors=\'ignore\')\n                entries.append((name, extent_loc, data_len))\n        \n        offset += record_len\n    \n    return entries\n\ndef find_and_extract_file(iso_path, target_names, output_path):\n    """Find and extract files from ISO"""\n    with open(iso_path, \'rb\') as f:\n        # Read primary volume descriptor\n        f.seek(16 * 2048)\n        pvd = f.read(2048)\n        \n        # Get root directory location\n        root_extent = struct.unpack(\'<I\', pvd[158:162])[0]\n        root_size = struct.unpack(\'<I\', pvd[166:170])[0]\n        \n        # Read root directory\n        root_entries = read_iso_directory(f, root_extent, root_size)\n        \n        # Look for boot directory\n        boot_extent = None\n        boot_size = None\n        for name, extent, size in root_entries:\n            if \'BOOT\' in name.upper():\n                boot_extent = extent\n                boot_size = size\n                break\n        \n        if boot_extent:\n            boot_entries = read_iso_directory(f, boot_extent, boot_size)\n            \n            # Find kernel and initrd\n            for name, extent, size in boot_entries:\n                for target in target_names:\n                    if target.upper() in name.upper():\n                        # Extract file\n                        f.seek(extent * 2048)\n                        file_data = f.read(size)\n                        out_file = f"{output_path}/{target}"\n                        with open(out_file, \'wb\') as out:\n                            out.write(file_data)\n                        print(f"Extracted {name} ({size} bytes) to {out_file}")\n                        return out_file\n    return None\n\n# Extract kernel\nkernel = find_and_extract_file(\'/app/alpine.iso\', [\'vmlinuz\', \'VMLINUZ\'], \'/tmp\')\nif kernel:\n    print(f"Kernel found: {kernel}")\nelse:\n    print("Kernel not found")\n\n# Extract initrd\ninitrd = find_and_extract_file(\'/app/alpine.iso\', [\'initramfs\', \'INITRAMFS\', \'initrd\'], \'/tmp\')\nif initrd:\n    print(f"Initrd found: {initrd}")\nelse:\n    print("Initrd not found")\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
