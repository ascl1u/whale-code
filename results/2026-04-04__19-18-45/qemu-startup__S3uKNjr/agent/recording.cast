[519.51271, "i", "python3 << 'EOF'\nimport struct\nimport os\n\ndef read_iso_directory(iso_path):\n    with open(iso_path, 'rb') as f:\n        # Read primary volume descriptor at sector 16\n        f.seek(16 * 2048)\n        pvd = f.read(2048)\n        \n        if pvd[0:6] != b'\\x01CD001':\n            return None\n            \n        # Root directory record starts at offset 156\n        root_dir_record = pvd[156:156+34]\n        root_lba = struct.unpack('<I', root_dir_record[2:6])[0]\n        root_size = struct.unpack('<I', root_dir_record[10:14])[0]\n        \n        # Read root directory\n        f.seek(root_lba * 2048)\n        root_data = f.read(root_size)\n        \n        return f, root_data, root_lba\n\nresult = read_iso_directory('/app/alpine.iso')\nif result:\n    print(\"Successfully parsed ISO structure\")\nelse:\n    print(\"Failed to parse ISO\")\n    \nEOF\n"]
