[675.01581, "i", "python3 << 'EOF'\nwith open('/app/alpine.iso', 'rb') as f:\n    # Extract vmlinuz\n    f.seek(290 * 2048)\n    kernel = f.read(7219200)\n    with open('/tmp/vmlinuz-lts', 'wb') as out:\n        out.write(kernel)\n    print(f\"Extracted vmlinuz-lts: {len(kernel)} bytes\")\n    \n    # Extract initramfs\n    f.seek(3816 * 2048)\n    initramfs = f.read(39165952)\n    with open('/tmp/initramfs-lts', 'wb') as out:\n        out.write(initramfs)\n    print(f\"Extracted initramfs-lts: {len(initramfs)} bytes\")\nEOF\n"]
