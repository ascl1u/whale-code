[507.178369, "i", "python3 << 'EOF'\nimport os\n\n# Search for kernel in ISO\niso_path = '/app/alpine.iso'\nchunk_size = 1024 * 1024  # 1MB chunks\n\nwith open(iso_path, 'rb') as f:\n    data = f.read()\n    \n# Look for common Alpine kernel paths\nif b'boot/vmlinuz' in data:\n    print(\"Found boot/vmlinuz reference\")\nif b'vmlinuz-lts' in data:\n    print(\"Found vmlinuz-lts reference\")\nif b'vmlinuz-virt' in data:\n    print(\"Found vmlinuz-virt reference\")  \nif b'initramfs' in data:\n    print(\"Found initramfs reference\")\n    \nEOF\n"]
