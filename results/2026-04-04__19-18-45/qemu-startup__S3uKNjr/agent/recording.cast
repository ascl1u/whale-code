[468.853584, "i", "python3 << 'EOF'\nimport os\nimport struct\n\n# Try to find and extract kernel and initrd from ISO\niso_path = '/app/alpine.iso'\n\n# ISO 9660 basic parsing to find files\nwith open(iso_path, 'rb') as f:\n    # Skip to volume descriptor at sector 16\n    f.seek(16 * 2048)\n    vd = f.read(2048)\n    \n    # Check if it's a primary volume descriptor\n    if vd[0:6] == b'\\x01CD001':\n        print(\"ISO 9660 format detected\")\n        # Root directory is at a specific location\n        # This is complex, let's try a simpler approach\n        \nprint(\"Trying simpler approach...\")\nEOF\n"]
