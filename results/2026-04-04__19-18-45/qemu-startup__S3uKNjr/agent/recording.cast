[534.960386, "i", "cat > /tmp/extract_iso.py << 'EOF'\nimport struct\nimport os\n\ndef parse_directory_record(data, offset):\n    if offset >= len(data) or data[offset] == 0:\n        return None\n    \n    length = data[offset]\n    if length == 0:\n        return None\n        \n    lba = struct.unpack('<I', data[offset+2:offset+6])[0]\n    size = struct.unpack('<I', data[offset+10:offset+14])[0]\n    flags = data[offset+25]\n    name_len = data[offset+32]\n    name = data[offset+33:offset+33+name_len].decode('ascii', errors='ignore')\n    \n    return {\n        'length': length,\n        'lba': lba,\n        'size': size,\n        'flags': flags,\n        'name': name,\n        'is_dir': (flags & 2) != 0\n    }\n\ndef extract_file(iso_path, lba, size, output_path):\n    with open(iso_path, 'rb') as f:\n        f.seek(lba * 2048)\n        data = f.read(size)\n        with open(output_path, 'wb') as out:\n            out.write(data)\n\ndef find_and_extract_files(iso_path, target_files):\n    with open(iso_path, 'rb') as f:\n        # Read primary volume descrip"]
[534.96064, "i", "tor\n        f.seek(16 * 2048)\n        pvd = f.read(2048)\n        \n        # Get root directory\n        root_dir_record = pvd[156:156+34]\n        root_lba = struct.unpack('<I', root_dir_record[2:6])[0]\n        root_size = struct.unpack('<I', root_dir_record[10:14])[0]\n        \n        # Search directories\n        dirs_to_search = [(root_lba, root_size, '')]\n        found_files = {}\n        \n        while dirs_to_search:\n            dir_lba, dir_size, path = dirs_to_search.pop(0)\n            f.seek(dir_lba * 2048)\n            dir_data = f.read(dir_size)\n            \n            offset = 0\n            while offset < len(dir_data):\n                record = parse_directory_record(dir_data, offset)\n                if not record:\n                    offset += 1\n                    continue\n                    \n                if record['name'] not in ['.', '..', '\\x00']:\n                    full_path = (path + '/' + record['name']).lower().strip('/')\n                    \n                    if record['is_dir']:\n    "]
[534.960704, "i", "                    dirs_to_search.append((record['lba'], record['size'], path + '/' + record['name']))\n                    else:\n                        for target in target_files:\n                            if target.lower() in full_path:\n                                found_files[target] = (record['lba'], record['size'])\n                                print(f\"Found {target} at {full_path}\")\n                \n                offset += record['length']\n        \n        return found_files\n\n# Find and extract kernel and initramfs\ntarget_files = ['vmlinuz-lts', 'initramfs-lts']\nfound = find_and_extract_files('/app/alpine.iso', target_files)\n\nfor name, (lba, size) in found.items():\n    output = f'/tmp/{name}'\n    extract_file('/app/alpine.iso', lba, size, output)\n    print(f\"Extracted {name} to {output} ({size} bytes)\")\n\nEOF\n"]
[534.96088, "o", "cat > /tmp/extract_iso.py << 'EOF'\r\n\u001b[?2004l\r                    dirs_to_search.append((record['lba'], record['size'], path + '/' + record['name']))\r\n    "]
[534.961068, "o", "                else:\r\n                        for target in target_files:\r\n                            if target.lower() in full_path:\r\n                                found_files[target] = (record['lba'], record['size'])\r\n                                print(f\"Found {target} at {full_path}\")\r\n"]
[534.961281, "o", "                \r\n                offset += record['length']\r\n        \r\n        return found_files\r\n\r\n# Find and extract kernel and initramfs\r\ntarget_files = ['vmlinuz-lts', 'initramfs-lts']\r\nfound = find_and_extract_files('/app/alpine.iso', target_files)\r\n\r\nfor name, (lba, size) in found.items():\r\n    output = f'/tmp/{name}'\r\n    extract_file('/app/alpine.iso', lba, size, output)\r\n    print(f\"Extracted {name} to {"]
[534.961498, "o", "output} ({size} bytes)\")\r\n\r\nEOF\r\n\u001b[?2004h> "]
