[801.426814, "i", "cat > /tmp/start_qemu.py << 'PYEOF'\nimport socket\nimport time\nimport subprocess\nimport sys\n\ndef is_port_free(port):\n    try:\n        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)\n        s.bind(('127.0.0.1', port))\n        s.close()\n        return True\n    except:\n        return False\n\n# Wait for port to be free\nprint(\"Checking if port 6665 is free...\")\nwhile not is_port_free(6665):\n    print(\"Port 6665 is in use, waiting...\")\n    time.sleep(2)\n\nprint(\"Port 6665 is free! Starting QEMU...\")\n\n# Start QEMU\ncmd = [\n    'qemu-system-x86_64',\n    '-kernel', '/tmp/vmlinuz',\n    '-initrd', '/tmp/initramfs',\n    '-cdrom', '/app/alpine.iso',\n    '-append', 'console=ttyS0',\n    '-display', 'none',\n    '-serial', 'telnet:127.0.0.1:6665,server,nowait',\n    '-m', '512'\n]\n\nproc = subprocess.Popen(cmd, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)\ntime.sleep(2)\n\n# Check if it started successfully\nif proc.poll() is not None:"]
[801.427054, "i", "\n    stderr = proc.stderr.read().decode()\n    print(f\"QEMU failed to start: {stderr}\")\n    sys.exit(1)\n\nprint(f\"QEMU started successfully with PID {proc.pid}\")\nprint(\"Waiting 30 seconds for boot...\")\ntime.sleep(30)\n\n# Test connection\nprint(\"Testing telnet connection...\")\ntry:\n    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n    s.settimeout(3)\n    s.connect(('127.0.0.1', 6665))\n    time.sleep(1)\n    data = s.recv(4096)\n    s.close()\n    if data:\n        print(f\"Received data ({len(data)} bytes)\")\n        print(data.decode('ascii', errors='ignore')[:500])\n    else:\n        print(\"Connected but no data received yet\")\nexcept Exception as e:\n    print(f\"Connection test failed: {e}\")\n\nprint(f\"\\nQEMU is running with PID {proc.pid}\")\nprint(\"You can now connect with: telnet 127.0.0.1 6665\")\nPYEOF\n"]
