[47.465168, "i", "cat > /tmp/wait_for_boot.sh << 'EOF'\n#!/bin/bash\necho \"Waiting for Alpine to boot and show login prompt...\"\nfor i in {1..60}; do\n  output=$(timeout 2 telnet 127.0.0.1 6665 2>&1 <<< \"\" | head -20)\n  if echo \"$output\" | grep -qi \"login\"; then\n    echo \"Login prompt detected! System is ready.\"\n    exit 0\n  fi\n  echo \"Attempt $i: Not ready yet, waiting...\"\n  sleep 2\ndone\necho \"Timeout waiting for boot\"\nexit 1\nEOF\n"]
