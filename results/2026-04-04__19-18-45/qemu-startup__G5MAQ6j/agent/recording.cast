[227.099729, "i", "python3 << 'PYEOF'\nimport os\nimport struct\n\n# Try to find and extract kernel and initrd from ISO\niso_path = '/app/alpine.iso'\n\n# ISO 9660 format - let's try to read it\nwith open(iso_path, 'rb') as f:\n    # Skip to primary volume descriptor at sector 16\n    f.seek(16 * 2048)\n    pvd = f.read(2048)\n    \n    # Check if it's a valid ISO\n    if pvd[1:6] == b'CD001':\n        print(\"Valid ISO 9660 format detected\")\n        print(\"Attempting to extract boot files...\")\n    else:\n        print(\"Not a standard ISO format\")\n\nPYEOF\n"]
[227.13004, "o", "python3 << 'PYEOF'\r\n\u001b[?2004l\r"]
