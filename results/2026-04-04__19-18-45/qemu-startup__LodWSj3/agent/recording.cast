[370.593185, "i", "python3 << 'EOFPY'\nimport os\nimport signal\nimport glob\n\nfor cmdline_file in glob.glob('/proc/*/cmdline'):\n    try:\n        with open(cmdline_file, 'rb') as f:\n            cmdline = f.read().decode('utf-8', errors='ignore')\n            if 'qemu' in cmdline:\n                pid = int(cmdline_file.split('/')[2])\n                print(f\"Killing QEMU PID: {pid}\")\n                os.kill(pid, signal.SIGKILL)\n    except:\n        pass\nEOFPY\n"]
