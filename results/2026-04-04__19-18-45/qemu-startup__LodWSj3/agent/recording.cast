[221.300159, "i", "cat > /tmp/start_alpine.py << 'EOF'\nimport subprocess\nimport time\nimport socket\nimport telnetlib\n\n# Start QEMU with monitor on Unix socket and serial on telnet\nqemu_cmd = [\n    'qemu-system-x86_64',\n    '-m', '512',\n    '-cdrom', '/app/alpine.iso',\n    '-boot', 'd',\n    '-serial', 'telnet:127.0.0.1:6665,server,nowait',\n    '-monitor', 'unix:/tmp/qemu-monitor.sock,server,nowait',\n    '-display', 'none',\n    '-nographic'\n]\n\nprint(\"Starting QEMU...\")\nproc = subprocess.Popen(qemu_cmd)\n\nprint(f\"QEMU started with PID {proc.pid}\")\n\n# Wait for monitor socket to be ready\ntime.sleep(2)\n\n# Connect to monitor\nprint(\"Connecting to QEMU monitor...\")\nmonitor = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)\ntry:\n    monitor.connect('/tmp/qemu-monitor.sock')\n    monitor.recv(1024)  # Read welcome message\n    \n    # Send keystrokes to boot menu\n    # At boot prompt, press Tab to edit, then add console parameter\n    time.sleep(3)  # Wait for boot menu\n    \n    # Send Tab key to edit boot options\n    monitor.send(b'sendkey ta"]
[221.3007, "i", "b\\n')\n    time.sleep(0.5)\n    \n    # Type console=ttyS0,115200\n    keys = ' console=ttyS0,115200'\n    for char in keys:\n        if char == ' ':\n            monitor.send(b'sendkey spc\\n')\n        elif char == '=':\n            monitor.send(b'sendkey equal\\n')\n        elif char == ',':\n            monitor.send(b'sendkey comma\\n')\n        else:\n            monitor.send(f'sendkey {char}\\n'.encode())\n        time.sleep(0.1)\n    \n    # Press Enter\n    monitor.send(b'sendkey ret\\n')\n    \n    monitor.close()\n    \nexcept Exception as e:\n    print(f\"Error: {e}\")\n\nprint(\"Waiting for system to boot...\")\ntime.sleep(15)\n\n# Test telnet connection\nprint(\"Testing telnet connection...\")\ntry:\n    tn = telnetlib.Telnet('127.0.0.1', 6665, timeout=5)\n    data = tn.read_very_eager()\n    print(f\"Telnet connected. Data: {data}\")\n    tn.close()\nexcept Exception as e:\n    print(f\"Telnet test failed: {e}\")\n\nprint(f\"\\nQEMU is running in background with PID {proc.pid}\")\nprint(\"Connect with: telnet 127.0.0.1 6665\")\nEOF\n"]
