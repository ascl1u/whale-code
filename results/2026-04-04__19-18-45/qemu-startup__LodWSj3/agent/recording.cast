[791.860251, "i", "cat > /tmp/boot_alpine_final.exp << 'EOFEXP'\n#!/usr/bin/expect -f\n\nset timeout 120\nlog_user 1\n\n# Start QEMU with two serial ports\nspawn qemu-system-x86_64 -m 512 -cdrom /app/alpine.iso -boot d \\\n  -serial stdio \\\n  -serial telnet:127.0.0.1:6665,server,nowait \\\n  -monitor none \\\n  -nographic\n\n# Wait for boot prompt\nexpect {\n    \"boot:\" {\n        send \" console=ttyS1,115200\\r\"\n    }\n    timeout {\n        puts \"Timeout waiting for boot prompt\"\n        exit 1\n    }\n}\n\n# Wait for system to boot - we won't see much here since output goes to ttyS1\nputs \"\\nBoot command sent. Waiting for system to boot (30 seconds)...\\n\"\nsleep 30\n\nputs \"\\n=== Alpine should now be accessible via telnet 127.0.0.1 6665 ===\\n\"\nputs \"QEMU is running. Press Ctrl+C to stop, or the process will continue.\\n\"\n\n# Keep running\ninteract\nEOFEXP\n"]
