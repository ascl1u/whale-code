[417.283332, "i", "python3 << 'EOFPY'\nimport os, signal, glob\nfor f in glob.glob('/proc/*/cmdline'):\n    try:\n        with open(f, 'rb') as cf:\n            if b'qemu' in cf.read():\n                os.kill(int(f.split('/')[2]), signal.SIGKILL)\n    except: pass\nEOFPY\n"]
