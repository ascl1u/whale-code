[281.395556, "i", "cat > /tmp/boot_qemu.exp << 'EOFEXP'\n#!/usr/bin/expect -f\n\nset timeout 120\n\n# Start QEMU with serial console\nspawn qemu-system-x86_64 -m 512 -cdrom /app/alpine.iso -boot d -serial telnet:127.0.0.1:6665,server,nowait -nographic\n\n# The -nographic option makes QEMU redirect VGA to stdio\n# Syslinux should appear here\n\nexpect {\n    -re \"boot:.*\" {\n        send \"\\r\"\n        exp_continue\n    }\n    -re \"login:\" {\n        puts \"\\n=== Login prompt detected ===\"\n        puts \"System is ready. Keeping QEMU running...\\n\"\n        # Detach from expect but keep process running\n        interact\n    }\n    timeout {\n        puts \"\\nTimeout - but QEMU should still be running\"\n        interact\n    }\n}\nEOFEXP\n"]
