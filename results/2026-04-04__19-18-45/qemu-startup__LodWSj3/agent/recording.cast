[531.473144, "i", "cat > /tmp/start_qemu2.sh << 'EOFSCRIPT'\n#!/bin/bash\n\n# Start QEMU in tmux with proper serial configuration\n# -serial stdio: for bootloader interaction (in tmux)\n# -serial telnet: for user access\ntmux new-session -d -s qemu_alpine 'qemu-system-x86_64 -m 512 -cdrom /app/alpine.iso -boot d -serial stdio -serial telnet:127.0.0.1:6665,server,nowait -monitor none -nographic'\n\necho \"QEMU started in tmux session\"\necho \"Waiting for boot menu...\"\nsleep 5\n\n# At the boot prompt, press Tab to edit\ntmux send-keys -t qemu_alpine Tab\nsleep 1\n\n# Add serial console parameter for the second serial port (ttyS1)\ntmux send-keys -t qemu_alpine ' console=ttyS1,115200'\nsleep 1\n\n# Press Enter to boot  \ntmux send-keys -t qemu_alpine Enter\n\necho \"Boot command sent. Waiting for system to boot...\"\nsleep 25\n\necho \"\"\necho \"QEMU is running. Connect with: telnet 127.0.0.1 6665\"\nEOFSCRIPT\n"]
