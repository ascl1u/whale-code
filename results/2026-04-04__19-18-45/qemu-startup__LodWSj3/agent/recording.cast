[232.604338, "i", "cat > /tmp/start_alpine_simple.sh << 'EOF'\n#!/bin/bash\n\n# Start QEMU with serial console\nqemu-system-x86_64 \\\n  -m 512 \\\n  -cdrom /app/alpine.iso \\\n  -boot d \\\n  -serial telnet:127.0.0.1:6665,server,nowait \\\n  -nographic \\\n  -no-reboot &\n\nQEMU_PID=$!\necho \"QEMU started with PID $QEMU_PID\"\n\n# Wait for QEMU to start\nsleep 2\n\n# The -nographic option should redirect VGA to stdio, but Alpine needs console=ttyS0\n# We'll wait for the system to boot and see what happens\necho \"Waiting for boot (30 seconds)...\"\nsleep 30\n\necho \"Testing telnet connection...\"\ntimeout 3 telnet 127.0.0.1 6665 << TELNET_EOF\n\nTELNET_EOF\n\necho \"\"\necho \"QEMU is running. Connect with: telnet 127.0.0.1 6665\"\necho \"QEMU PID: $QEMU_PID\"\nEOF\n"]
