[166.513619, "o", "\u001b[?2004hroot@2d580899b4cf:/app# "]
[177.611056, "i", "cat > /tmp/boot_alpine.exp << 'EOF'\n#!/usr/bin/expect -f\n\nset timeout 60\n\n# Start QEMU in background\nspawn qemu-system-x86_64 -m 512 -cdrom /app/alpine.iso -boot d -serial telnet:127.0.0.1:6665,server,nowait -nographic\n\n# Wait for boot loader prompt\nexpect {\n    \"boot:\" {\n        # Send boot command with serial console\n        send \"console=ttyS0,115200\\r\"\n    }\n    timeout {\n        puts \"Timeout waiting for boot prompt\"\n        exit 1\n    }\n}\n\n# Wait for login prompt\nexpect {\n    \"login:\" {\n        puts \"\\nLogin prompt detected. Alpine is ready.\\n\"\n        interact\n    }\n    timeout {\n        puts \"Timeout waiting for login prompt\"\n        interact\n    }\n}\nEOF\n"]
