[439.894204, "i", "cat > /tmp/start_qemu.sh << 'EOFSCRIPT'\n#!/bin/bash\n\n# Start QEMU in a detached tmux session\ntmux new-session -d -s qemu_alpine 'qemu-system-x86_64 -m 512 -cdrom /app/alpine.iso -boot d -serial telnet:127.0.0.1:6665,server,nowait -nographic'\n\necho \"QEMU started in tmux session 'qemu_alpine'\"\necho \"Waiting for boot menu...\"\nsleep 5\n\n# Send Tab key to edit boot options at the syslinux prompt\ntmux send-keys -t qemu_alpine Tab\nsleep 1\n\n# Add console parameter\ntmux send-keys -t qemu_alpine ' console=ttyS0,115200'\nsleep 1\n\n# Press Enter to boot\ntmux send-keys -t qemu_alpine Enter\n\necho \"Boot command sent. Waiting for system to boot...\"\nsleep 20\n\necho \"Testing telnet connection...\"\ntimeout 3 telnet 127.0.0.1 6665 << EOF\n\nEOF\n\necho \"\"\necho \"QEMU is running in tmux session 'qemu_alpine'\"\necho \"Connect with: telnet 127.0.0.1 6665\"\necho \"To view tmux session: tmux attach -t qemu_alpine\"\nEOFSCRIPT\n"]
