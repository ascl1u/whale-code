[432.112335, "o", "  output=$( (sleep 3; echo) | telnet 127.0.0.1 6665 2>&1 )\r\n\u001b[?2004l\r"]
[432.112538, "o", "\u001b[?2004h> "]
[432.112756, "o", "  if echo \"$output\" | grep -qi \"login:\"; then\r\n\u001b[?2004l\r"]
[432.112933, "o", "\u001b[?2004h> "]
[432.113114, "o", "    echo \"Login prompt detected!\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[432.113401, "o", "    echo \"---Output---\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[432.113621, "o", "> "]
[432.113759, "o", "    echo \"$output\" | tail -20\r\n\u001b[?2004l\r"]
[432.113929, "o", "\u001b[?2004h>     exit 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[432.114055, "o", "  fi\r\n\u001b[?2004l\r\u001b[?2004h> "]
[432.114161, "o", "  sleep 2\r\n\u001b[?2004l\r"]
[432.114322, "o", "\u001b[?2004h> done\r\n\u001b[?2004l\r\u001b[?2004h> "]
[432.114583, "o", "echo \"Timeout waiting for login\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[432.114729, "o", "> exit 1\r\n\u001b[?2004l\r"]
[432.114849, "o", "\u001b[?2004h"]
[432.114962, "o", "> EOF\r\n\u001b[?2004l\r"]
