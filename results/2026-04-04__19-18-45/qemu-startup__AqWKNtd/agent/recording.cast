[432.110737, "i", "cat > /tmp/wait_login.sh << 'EOF'\n#!/bin/bash\nfor i in {1..30}; do\n  echo \"Attempt $i: Checking for login prompt...\"\n  output=$( (sleep 3; echo) | telnet 127.0.0.1 6665 2>&1 )\n  if echo \"$output\" | grep -qi \"login:\"; then\n    echo \"Login prompt detected!\"\n    echo \"---Output---\"\n    echo \"$output\" | tail -20\n    exit 0\n  fi\n  sleep 2\ndone\necho \"Timeout waiting for login\"\nexit 1\nEOF\n"]
[432.11114, "o", "cat > /tmp/wait_login.sh << 'EOF'\r\n"]
