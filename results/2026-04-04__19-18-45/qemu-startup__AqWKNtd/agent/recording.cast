[352.613409, "i", "python3 << 'PYEOF'\nimport struct\nimport os\n\n# Simple ISO9660 reader to extract files\niso_path = '/app/alpine.iso'\n\ndef read_iso_directory(iso_file, extent_location, extent_length):\n    iso_file.seek(extent_location * 2048)\n    data = iso_file.read(extent_length * 2048)\n    entries = []\n    pos = 0\n    while pos < len(data):\n        if data[pos] == 0:\n            break\n        length = data[pos]\n        if length == 0:\n            break\n        entry = data[pos:pos+length]\n        name_len = entry[32]\n        name = entry[33:33+name_len].decode('ascii', errors='ignore')\n        extent_loc = struct.unpack('<I', entry[2:6])[0]\n        extent_len = struct.unpack('<I', entry[10:14])[0]\n        is_dir = entry[25] & 2\n        entries.append((name, extent_loc, extent_len, is_dir))\n        pos += length\n    return entries\n\nwith open(iso_path, 'rb') as f:\n    # Read primary volume descriptor\n    f.seek(16 * 2048)\n    pvd = f.read(2048)\n    \n    # Get root directory location\n    root_extent = struct.unpack('<I', pvd[158"]
[352.614018, "i", ":162])[0]\n    root_length = struct.unpack('<I', pvd[166:170])[0]\n    \n    # Read root directory\n    root_entries = read_iso_directory(f, root_extent, root_length)\n    \n    # Find boot directory\n    boot_extent = None\n    for name, extent, length, is_dir in root_entries:\n        if 'BOOT' in name.upper() and is_dir:\n            boot_extent = extent\n            boot_length = length\n            break\n    \n    if boot_extent:\n        boot_entries = read_iso_directory(f, boot_extent, boot_length)\n        print(\"Boot directory contents:\")\n        for name, extent, length, is_dir in boot_entries:\n            print(f\"  {name} - extent: {extent}, length: {length}, is_dir: {is_dir}\")\n            \n            # Extract vmlinuz and initramfs\n            if 'VMLINUZ' in name.upper() or 'INITRAMFS' in name.upper() or name.endswith('.GZ'):\n                f.seek(extent * 2048)\n                data = f.read(length)\n                outname = name.split(';')[0].lower()\n                outpath = f'/tmp/{outname}'\n              "]
[352.614333, "o", "python3 << 'PYEOF'\r\n\u001b[?2004l\r:162])[0]\r\n    root_length = struct.unpack('<I', pvd[166:170])[0]\r\n    \r\n    # Read root directory\r\n    root_entries = read_iso_directory(f, root_extent, root_length)\r\n    \r\n    # Find boot directory\r\n    boot_extent = None\r\n    for name, extent, length, is_dir in root_entries:\r\n        if 'BOOT' in name.upper() and is_dir:\r\n            boot_extent = extent\r\n            boot_length = length\r\n            break\r\n    \r\n    if boot_extent:\r\n        boot_entries = read_iso_directory(f, boot_exte"]
