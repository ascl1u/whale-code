[73.848343, "i", "cat > /tmp/check_login.sh << 'EOF'\n#!/bin/bash\nfor i in {1..60}; do\n  output=$(timeout 2 nc 127.0.0.1 6665 < /dev/null 2>&1)\n  if echo \"$output\" | grep -qi \"login\"; then\n    echo \"Login prompt detected!\"\n    exit 0\n  fi\n  echo \"Waiting for boot... attempt $i\"\n  sleep 2\ndone\necho \"Timeout waiting for login prompt\"\nexit 1\nEOF\n"]
