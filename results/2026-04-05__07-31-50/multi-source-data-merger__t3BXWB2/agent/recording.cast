[56.610548, "i", "cat > merge_users.py << 'EOF'\nimport pandas as pd\nimport json\nfrom datetime import datetime\n\n# Read source_a (JSON)\nwith open('/data/source_a/users.json', 'r') as f:\n    source_a_data = json.load(f)\n\n# Convert to DataFrame and map fields\ndf_a = pd.DataFrame(source_a_data)\ndf_a = df_a.rename(columns={\n    'id': 'user_id',\n    'full_name': 'name',\n    'email': 'email',\n    'registration_date': 'created_date'\n})\ndf_a['source'] = 'source_a'\n\n# Read source_b (CSV)\ndf_b = pd.read_csv('/data/source_b/users.csv')\ndf_b = df_b.rename(columns={\n    'user_id': 'user_id',\n    'name': 'name',\n    'email_address': 'email',\n    'created_at': 'created_date'\n})\n# Map is_active to status\nif 'is_active' in df_b.columns:\n    df_b['status'] = df_b['is_active'].map({True: 'active', False: 'inactive'})\n    df_b = df_b.drop(columns=['is_active'])\ndf_b['source'] = 'source_b'\n\n# Read source_c (Parquet)\ndf_c = pd.read_parquet('/data/source_c/users.parquet')\ndf_c = df_c.rename(columns={\n    'userId': 'user_id',\n    'userName': 'name',\n    'email': 'email',\n    'joined': 'created_date'\n})\n# Map active to status\nif 'active' in df_c.columns:\n    df_c['status'] = df_c['active'].map({True: 'active', False: 'inactive'})\n    df_c = df_c.drop(columns=['active'])\ndf_c['source'] = 'source_c'\n\nprint(\"Source A:\")\nprint(df_a)\nprint(\"\\nSource B:\")\nprint(df_b)\nprint(\"\\nSource C:\")\nprint(df_c)\n\n# Combine all sources\nall_data = pd.concat([df_a, df_b, df_c], ignore_index=True)\n\n# Ensure user_id is integer\nall_data['user_id'] = all_data['user_id'].astype(int)\n\n# Get all unique user_ids\nunique_users = all_data['user_id'].unique()\n\n# Track conflicts\nconflicts = []\n\n# Merge logic with priority\nmerged_records = []\n\nfor user_id in unique_users:\n    user_records = all_data[all_data['user_id'] == user_id]\n    \n    # Get records from each source\n    record_a = user_records[user_records['source'] == 'source_a']\n    record_b = user_records[user_records['source'] == 'source_b']\n    record_c = user_records[user_records['source'] == 'source_c']\n    \n    # Start with empty merged record\n    merged = {'user_id': user_id}\n    \n    # Fields to merge\n    fields = ['name', 'email', 'created_date', 'status']\n    \n    for field in fields:\n        values = {}\n        \n        # Collect values from each source\n        if not record_a.empty and field in record_a.columns and pd.notna(record_a[field].iloc[0]):\n            values['source_a'] = record_a[field].iloc[0]\n        if not record_b.empty and field in record_b.columns and pd.notna(record_b[field].iloc[0]):\n            values['source_b'] = record_b[field].iloc[0]\n        if not record_c.empty and field in record_c.columns and pd.notna(record_c[field].iloc[0]):\n            values['source_c'] = record_c[field].iloc[0]\n        \n        # Select value by priority\n        selected = None\n        if 'source_a' in values:\n            selected = values['source_a']\n        elif 'source_b' in values:\n            selected = values['source_b']\n        elif 'source_c' in values:\n            selected = values['source_c']\n        \n        merged[field] = selected\n        \n        # Check for conflicts (multiple sources with different values)\n        unique_values = set(str(v) for v in values.values())\n        if len(values) > 1 and len(unique_values) > 1:\n            conflict = {\n                'user_id': int(user_id),\n                'field': field,\n                'values': values,\n                'selected': selected\n            }\n            conflicts.append(conflict)\n    \n    merged_records.append(merged)\n\n# Create merged DataFrame\nmerged_df = pd.DataFrame(merged_records)\n\n# Ensure proper column order\ncolumn_order = ['user_id', 'name', 'email', 'created_date', 'status']\nfor col in column_order:\n    if col not in merged_df.columns:\n        merged_df[col] = None\n\nmerged_df = merged_df[column_order]\n\n# Ensure user_id is integer\nmerged_df['user_id'] = merged_df['user_id'].astype(int)\n\n# Sort by user_id\nmerged_df = merged_df.sort_values('user_id').reset_index(drop=True)\n\nprint(\"\\n\\nMerged DataFrame:\")\nprint(merged_df)\nprint(\"\\nData types:\")\nprint(mer"]
[56.610667, "i", "ged_df.dtypes)\n\n# Save to Parquet\nmerged_df.to_parquet('/app/merged_users.parquet', index=False)\nprint(\"\\nSaved merged_users.parquet\")\n\n# Create conflict report\nconflict_report = {\n    'total_conflicts': len(conflicts),\n    'conflicts': conflicts\n}\n\nwith open('/app/conflicts.json', 'w') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint(f\"\\nSaved conflicts.json with {len(conflicts)} conflicts\")\nprint(\"\\nConflict report:\")\nprint(json.dumps(conflict_report, indent=2))\nEOF\n"]
