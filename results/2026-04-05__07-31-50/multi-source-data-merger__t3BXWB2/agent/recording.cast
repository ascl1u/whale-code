[56.672809, "o", "\u001b[?2004h>     record_b = user_records[user_records['source'] == 'source_b']\r\n\u001b[?2004l\r\u001b[?2004h>     record_c = user_records[user_records['source'] == 'source_c']\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Start with empty merged record\r\n\u001b[?2004l\r\u001b[?2004h>     merged = {'user_id': user_id}\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Fields to merge\r\n\u001b[?2004l\r\u001b[?2004h>     fields = ['name', 'email', 'created_date', 'status']\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for field in fields:\r\n\u001b[?2004l\r\u001b[?2004h>         values = {}\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h"]
[56.673079, "o", "> "]
[56.67355, "o", "        # Collect values from each source\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.674123, "o", "        if not record_a.empty and field in record_a.columns and pd.notna(record_a[field].iloc[0]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.674636, "o", "            values['source_a'] = record_a[field].iloc[0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.674943, "o", "> "]
[56.675353, "o", "        if not record_b.empty and field in record_b.columns and pd.notna(record_b[field].iloc[0]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.675749, "o", "            values['source_b'] = record_b[field].iloc[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.676521, "o", "        if not record_c.empty and field in record_c.columns and pd.notna(record_c[field].iloc[0]):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.676976, "o", "            values['source_c'] = record_c[field].iloc[0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.677277, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.677543, "o", "        # Select value by priority\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.677844, "o", "        selected = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.678181, "o", "        if 'source_a' in values:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.678487, "o", "            selected = values['source_a']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.678733, "o", "        elif 'source_b' in values:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.679127, "o", "            selected = values['source_b']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.679469, "o", "        elif 'source_c' in values:\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.679776, "o", "> "]
[56.680026, "o", "            selected = values['source_c']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.680293, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.680495, "o", "        merged[field] = selected\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.680869, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.681248, "o", "        # Check for conflicts (multiple sources with different values)\r\n\u001b[?2004l\r"]
[56.681568, "o", "\u001b[?2004h> "]
[56.681874, "o", "        unique_values = set(str(v) for v in values.values())\r\n\u001b[?2004l\r"]
[56.682225, "o", "\u001b[?2004h> "]
[56.682523, "o", "        if len(values) > 1 and len(unique_values) > 1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.682843, "o", "            conflict = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.683095, "o", "                'user_id': int(user_id),\r\n\u001b[?2004l\r"]
[56.683258, "o", "\u001b[?2004h> "]
[56.683643, "o", "                'field': field,\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.683969, "o", ">                 'values': values,\r\n\u001b[?2004l\r"]
[56.684282, "o", "\u001b[?2004h> "]
[56.684739, "o", "                'selected': selected\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.685103, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.685365, "o", "> "]
[56.685682, "o", "            conflicts.append(conflict)\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.686022, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.686446, "o", "    merged_records.append(merged)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.686922, "o", "# Create merged DataFrame\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.687329, "o", "merged_df = pd.DataFrame(merged_records)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[56.687604, "o", "> # Ensure proper column order\r\n\u001b[?2004l\r"]
[56.687776, "o", "\u001b[?2004h> "]
[56.688487, "o", "column_order = ['user_id', 'name', 'email', 'created_date', 'status']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.688784, "o", "for col in column_order:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.689118, "o", "    if col not in merged_df.columns:\r\n\u001b[?2004l\r"]
[56.689483, "o", "\u001b[?2004h>         merged_df[col] = None\r\n\u001b[?2004l\r"]
[56.689777, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.690044, "o", "merged_df = merged_df[column_order]\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.690401, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.69066, "o", "# Ensure user_id is integer\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.690975, "o", "merged_df['user_id'] = merged_df['user_id'].astype(int)\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.691147, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.691622, "o", "# Sort by user_id\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.69188, "o", "merged_df = merged_df.sort_values('user_id').reset_index(drop=True)\r\n\u001b[?2004l\r"]
[56.692211, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.692542, "o", "print(\"\\n\\nMerged DataFrame:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.692713, "o", "print(merged_df)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.692868, "o", "print(\"\\nData types:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.693271, "o", "print(merged_df.dtypes)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[56.693609, "o", "> "]
[56.693886, "o", "# Save to Parquet\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.694634, "o", "merged_df.to_parquet('/app/merged_users.parquet', index=False)\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.694993, "o", "> "]
[56.695166, "o", "print(\"\\nSaved merged_users.parquet\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[56.695447, "o", "\u001b[?2004h> "]
[56.695782, "o", "# Create conflict report\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.696223, "o", "conflict_report = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.696388, "o", "    'total_conflicts': len(conflicts),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.69664, "o", "    'conflicts': conflicts\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[56.696911, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[56.697258, "o", "> "]
[56.697684, "o", "with open('/app/conflicts.json', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.698085, "o", "    json.dump(conflict_report, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.698531, "o", "print(f\"\\nSaved conflicts.json with {len(conflicts)} conflicts\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.698845, "o", "> "]
[56.69914, "o", "print(\"\\nConflict report:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[56.69939, "o", "print(json.dumps(conflict_report, indent=2))\r\n\u001b[?2004l\r\u001b[?2004h"]
[56.699517, "o", "> EOF\r\n\u001b[?2004l\r"]
