[122.360128, "o", "print(\"   - User 103: ✓ (from source_b only)\")\r\n\u001b[?2004l\r"]
[122.360292, "o", "\u001b[?2004h> "]
[122.360522, "o", "print(\"   - User 104: ✓ (from source_c only)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[122.360693, "o", "> print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[122.360792, "o", "> "]
[122.361033, "o", "print(\"5. Field mappings applied:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[122.361299, "o", "print(\"   - id/user_id/userId -> user_id ✓\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[122.361524, "o", "> "]
[122.361699, "o", "print(\"   - full_name/name/userName -> name ✓\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[122.361919, "o", "print(\"   - email/email_address -> email ✓\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[122.362209, "o", "print(\"   - registration_date/created_at/joined -> created_date ✓\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[122.36239, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[122.362583, "o", "\u001b[?2004h> "]
