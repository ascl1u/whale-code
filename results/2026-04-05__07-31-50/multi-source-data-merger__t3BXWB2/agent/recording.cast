[85.42492, "i", "python3 << 'EOF'\nimport pandas as pd\n\n# Read the merged parquet file\ndf = pd.read_parquet('/app/merged_users.parquet')\n\nprint(\"Columns:\", df.columns.tolist())\nprint(\"\\nShape:\", df.shape)\nprint(\"\\nData types:\")\nprint(df.dtypes)\nprint(\"\\nFull data:\")\nprint(df.to_string())\nprint(\"\\nUser IDs:\", sorted(df['user_id'].tolist()))\nEOF\n"]
