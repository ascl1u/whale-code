[?2004l[?2004h> # Read source_c (Parquet)
[?2004l[?2004h> df_c = pd.read_parquet('/data/source_c/users.parquet')
[?2004l[?2004h> df_c = df_c.rename(columns={
[?2004l[?2004h>     'userId': 'user_id',
[?2004l[?2004h>     'userName': 'name',
[?2004l[?2004h>     'email': 'email',
[?2004l[?2004h>     'joined': 'created_date'
[?2004l[?2004h> })
[?2004l[?2004h> # Map active to status
[?2004l[?2004h> if 'active' in df_c.columns:
[?2004l[?2004h>     df_c['status'] = df_c['active'].map({True: 'active', False: 'inactive'})
[?2004l[?2004h>     df_c = df_c.drop(columns=['active'])
