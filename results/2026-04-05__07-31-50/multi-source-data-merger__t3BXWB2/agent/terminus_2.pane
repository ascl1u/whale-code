[?2004l[?2004h> 
[?2004l[?2004h> # Combine all sources
[?2004l[?2004h> all_data = pd.concat([df_a, df_b, df_c], ignore_index=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure user_id is integer
[?2004l[?2004h> all_data['user_id'] = all_data['user_id'].astype(int)
[?2004l[?2004h> 
[?2004l[?2004h> # Get all unique user_ids
[?2004l[?2004h> unique_users = all_data['user_id'].unique()
[?2004l[?2004h> 
[?2004l[?2004h> # Track conflicts
[?2004l[?2004h> conflicts = []
[?2004l[?2004h> 
[?2004l[?2004h> # Merge logic with priority
[?2004l[?2004h> merged_records = []
[?2004l[?2004h> 
[?2004l[?2004h> for user_id in unique_users:
[?2004l[?2004h>     user_records = all_data[all_data['user_id'] == user_id]
[?2004l[?2004h>     
[?2004l[?2004h>     # Get records from each source
[?2004l[?2004h>     record_a = user_records[user_records['source'] == 'source_a']
[?2004l[?2004h>     record_b = user_records[user_records['source'] == 'source_b']
[?2004l[?2004h>     record_c = user_records[user_records['source'] == 'source_c']
[?2004l[?2004h>     
[?2004l[?2004h>     # Start with empty merged record
[?2004l[?2004h>     merged = {'user_id': user_id}
[?2004l[?2004h>     
[?2004l[?2004h>     # Fields to merge
