[?2004l[?2004h>     
[?2004l[?2004h>     for field in fields:
[?2004l[?2004h>         values = {}
[?2004l[?2004h>         
[?2004l[?2004h>         # Collect values from each source
[?2004l[?2004h>         if not record_a.empty and field in record_a.columns and pd.notna(record_a[field].iloc[0]):
[?2004l[?2004h>             values['source_a'] = record_a[field].iloc[0]
[?2004l[?2004h>         if not record_b.empty and field in record_b.columns and pd.notna(record_b[field].iloc[0]):
[?2004l[?2004h>             values['source_b'] = record_b[field].iloc[0]
[?2004l[?2004h>         if not record_c.empty and field in record_c.columns and pd.notna(record_c[field].iloc[0]):
[?2004l[?2004h>             values['source_c'] = record_c[field].iloc[0]
[?2004l[?2004h>         
[?2004l[?2004h>         # Select value by priority
[?2004l[?2004h>         selected = None
[?2004l[?2004h>         if 'source_a' in values:
[?2004l[?2004h>             selected = values['source_a']
[?2004l[?2004h>         elif 'source_b' in values:
[?2004l[?2004h>             selected = values['source_b']
[?2004l[?2004h>         elif 'source_c' in values:
[?2004l[?2004h>             selected = values['source_c']
[?2004l[?2004h>         
[?2004l[?2004h>         merged[field] = selected
[?2004l[?2004h>         
[?2004l[?2004h>         # Check for conflicts (multiple sources with different values)
[?2004l[?2004h>         unique_values = set(str(v) for v in values.values())
[?2004l[?2004h>         if len(values) > 1 and len(unique_values) > 1:
[?2004l[?2004h>             conflict = {
[?2004l[?2004h>                 'user_id': int(user_id),
[?2004l[?2004h>                 'field': field,
[?2004l[?2004h>                 'values': values,
[?2004l[?2004h>                 'selected': selected
[?2004l[?2004h>             }
[?2004l[?2004h>             conflicts.append(conflict)
[?2004l[?2004h>     
[?2004l[?2004h>     merged_records.append(merged)
[?2004l[?2004h> 
[?2004l[?2004h> # Create merged DataFrame
[?2004l[?2004h> merged_df = pd.DataFrame(merged_records)
[?2004l[?2004h> 
