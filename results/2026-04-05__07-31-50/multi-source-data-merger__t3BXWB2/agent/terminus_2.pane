[?2004l[?2004h> 
[?2004l[?2004h> merged_df = merged_df[column_order]
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure user_id is integer
[?2004l[?2004h> merged_df['user_id'] = merged_df['user_id'].astype(int)
[?2004l[?2004h> 
