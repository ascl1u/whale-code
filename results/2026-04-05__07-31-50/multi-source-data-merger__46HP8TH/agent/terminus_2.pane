[?2004l[?2004h> })
[?2004l[?2004h> df_a['source'] = 'source_a'
[?2004l[?2004h> 
[?2004l[?2004h> # Read source B (CSV)
[?2004l[?2004h> df_b = pd.read_csv('/data/source_b/users.csv')
[?2004l[?2004h> df_b = df_b.rename(columns={
[?2004l[?2004h>     'email_address': 'email',
[?2004l[?2004h>     'created_at': 'created_date'
[?2004l[?2004h> })
[?2004l[?2004h> # Map is_active to status
[?2004l[?2004h> if 'is_active' in df_b.columns:
[?2004l[?2004h>     df_b['status'] = df_b['is_active'].apply(lambda x: 'active' if x else 'inactive')
[?2004l[?2004h>     df_b = df_b.drop('is_active', axis=1)
[?2004l[?2004h> df_b['source'] = 'source_b'
[?2004l[?2004h> 
[?2004l[?2004h> # Read source C (Parquet)
[?2004l[?2004h> df_c = pd.read_parquet('/data/source_c/users.parquet')
[?2004l[?2004h> df_c = df_c.rename(columns={
[?2004l[?2004h>     'userId': 'user_id',
[?2004l[?2004h>     'userName': 'name',
[?2004l[?2004h>     'joined': 'created_date'
[?2004l[?2004h> })
[?2004l[?2004h> # Map active to status
[?2004l[?2004h> if 'active' in df_c.columns:
[?2004l[?2004h>     df_c['status'] = df_c['active'].apply(lambda x: 'active' if x else 'inactive')
[?2004l[?2004h>     df_c = df_c.drop('active', axis=1)
[?2004l[?2004h> df_c['source'] = 'source_c'
[?2004l[?2004h> 
[?2004l[?2004h> print("Source A:")
[?2004l[?2004h> print(df_a)
[?2004l[?2004h> print("\nSource B:")
[?2004l[?2004h> print(df_b)
[?2004l[?2004h> print("\nSource C:")
[?2004l[?2004h> print(df_c)
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure all DataFrames have the same columns
[?2004l[?2004h> all_columns = ['user_id', 'name', 'email', 'created_date', 'status', 'source']
[?2004l[?2004h> 
[?2004l[?2004h> for df in [df_a, df_b, df_c]:
[?2004l[?2004h>     for col in all_columns:
[?2004l[?2004h>         if col not in df.columns:
[?2004l[?2004h>             df[col] = None
[?2004l[?2004h> 
[?2004l[?2004h> # Combine all sources
[?2004l[?2004h> all_data = pd.concat([df_a, df_b, df_c], ignore_index=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Track conflicts
[?2004l[?2004h> conflicts = []
[?2004l[?2004h> merged_records = {}
[?2004l[?2004h> 
[?2004l[?2004h> # Get unique user_ids
[?2004l[?2004h> unique_users = all_data['user_id'].unique()
[?2004l[?2004h> 
[?2004l[?2004h> for user_id in unique_users:
[?2004l[?2004h>     user_records = all_data[all_data['user_id'] == user_id]
[?2004l[?2004h>     
[?2004l[?2004h>     # Initialize merged record
[?2004l[?2004h>     merged_record = {'user_id': int(user_id)}
[?2004l[?2004h>     
[?2004l[?2004h>     # Track which sources have this user
[?2004l[?2004h>     sources_with_user = user_records['source'].tolist()
[?2004l[?2004h>     
[?2004l[?2004h>     # For each field, check for conflicts
[?2004l[?2004h>     for field in ['name', 'email', 'created_date', 'status']:
[?2004l[?2004h>         values_by_source = {}
[?2004l[?2004h>         
[?2004l[?2004h>         for _, row in user_records.iterrows():
[?2004l[?2004h>             source = row['source']
[?2004l[?2004h>             value = row[field]
[?2004l[?2004h>             if pd.notna(value):
[?2004l[?2004h>                 values_by_source[source] = value
[?2004l[?2004h>         
[?2004l[?2004h>         # Determine selected value by priority
[?2004l[?2004h>         selected_value = None
[?2004l[?2004h>         for source in ['source_a', 'source_b', 'source_c']:
[?2004l[?2004h>             if source in values_by_source:
[?2004l[?2004h>                 selected_value = values_by_source[source]
[?2004l[?2004h>                 break
[?2004l[?2004h>         
[?2004l[?2004h>         merged_record[field] = selected_value
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if there's a conflict (multiple different values)
[?2004l[?2004h>         unique_values = set(v for v in values_by_source.values() if v is not None)
[?2004l[?2004h>         if len(unique_values) > 1:
[?2004l[?2004h>             conflict = {
[?2004l[?2004h>                 'user_id': int(user_id),
[?2004l[?2004h>                 'field': field,
[?2004l[?2004h>                 'values': values_by_source,
[?2004l[?2004h>                 'selected': selected_value
[?2004l[?2004h>             }
[?2004l[?2004h>             conflicts.append(conflict)
[?2004l[?2004h>     
[?2004l[?2004h>     merged_records[user_id] = merged_record
[?2004l[?2004h> 
[?2004l[?2004h> # Create merged DataFrame
[?2004l[?2004h> merged_df = pd.DataFrame(list(merged_records.values()))
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure proper data types
[?2004l[?2004h> merged_df['user_id'] = merged_df['user_id'].astype('int64')
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure date format is YYYY-MM-DD
[?2004l[?2004h> for idx, row in merged_df.iterrows():
[?2004l[?2004h>     if pd.notna(row['created_date']):
[?2004l[?2004h>         date_str = str(row['created_date'])
[?2004l[?2004h>         # Already in correct format, but validate
[?2004l[?2004h>         if len(date_str) == 10 and date_str[4] == '-' and date_str[7] == '-':
[?2004l[?2004h>             merged_df.at[idx, 'created_date'] = date_str
[?2004l[?2004h> 
[?2004l[?2004h> # Select and order columns
[?2004l[?2004h> output_columns = ['user_id', 'name', 'email', 'created_date', 'status']
[?2004l[?2004h> merged_df = merged_df[output_columns]
[?2004l[?2004h> 
[?2004l[?2004h> print("\nMerged DataFrame:")
[?2004l[?2004h> print(merged_df)
[?2004l[?2004h> print("\nData types:")
[?2004l[?2004h> print(merged_df.dtypes)
[?2004l[?2004h> 
[?2004l[?2004h> # Save to Parquet
[?2004l[?2004h> merged_df.to_parquet('/app/merged_users.parquet', index=False)
