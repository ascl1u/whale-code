[23.217954, "i", "python3 << 'EOF'\nimport pandas as pd\nimport pyarrow.parquet as pq\n\n# Read and display parquet file\ndf = pd.read_parquet('/data/source_c/users.parquet')\nprint(\"Source C (Parquet) columns:\", df.columns.tolist())\nprint(\"\\nSource C data:\")\nprint(df.to_string())\nprint(\"\\nData types:\")\nprint(df.dtypes)\nEOF\n"]
