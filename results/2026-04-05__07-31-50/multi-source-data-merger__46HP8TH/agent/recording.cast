[52.715981, "o", "\u001b[?2004h> "]
[52.716106, "o", "            if pd.notna(value):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.716399, "o", "                values_by_source[source] = value\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.716652, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.716959, "o", "        # Determine selected value by priority\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.717207, "o", "        selected_value = None\r\n\u001b[?2004l\r"]
[52.717492, "o", "\u001b[?2004h> "]
[52.71771, "o", "        for source in ['source_a', 'source_b', 'source_c']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.717875, "o", "> "]
[52.718143, "o", "            if source in values_by_source:\r\n\u001b[?2004l\r"]
[52.71827, "o", "\u001b[?2004h> "]
[52.718543, "o", "                selected_value = values_by_source[source]\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.718748, "o", "> "]
[52.718915, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.719244, "o", "        merged_record[field] = selected_value\r\n\u001b[?2004l\r"]
[52.719498, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.719836, "o", "        # Check if there's a conflict (multiple different values)\r\n\u001b[?2004l\r"]
[52.720028, "o", "\u001b[?2004h> "]
[52.720409, "o", "        unique_values = set(v for v in values_by_source.values() if v is not None)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.72066, "o", "        if len(unique_values) > 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.720903, "o", "> "]
[52.721153, "o", "            conflict = {\r\n\u001b[?2004l\r\u001b[?2004h>                 'user_id': int(user_id),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.721336, "o", "                'field': field,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.721685, "o", "                'values': values_by_source,\r\n\u001b[?2004l\r"]
[52.721875, "o", "\u001b[?2004h> "]
[52.72212, "o", "                'selected': selected_value\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.722356, "o", ">             }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.722632, "o", "            conflicts.append(conflict)\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.72292, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.723166, "o", "    merged_records[user_id] = merged_record\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.723368, "o", "# Create merged DataFrame\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.723835, "o", "merged_df = pd.DataFrame(list(merged_records.values()))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.78412, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.784441, "o", "# Ensure proper data types\r\n\u001b[?2004l\r\u001b[?2004h> merged_df['user_id'] = merged_df['user_id'].astype('int64')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Ensure date format is YYYY-MM-DD\r\n\u001b[?2004l\r\u001b[?2004h> for idx, row in merged_df.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h>     if pd.notna(row['created_date']):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.784638, "o", "        date_str = str(row['created_date'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.784966, "o", "        # Already in correct format, but validate\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.785236, "o", "        if len(date_str) == 10 and date_str[4] == '-' and date_str[7] == '-':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.785524, "o", "            merged_df.at[idx, 'created_date'] = date_str\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[52.785759, "o", "\u001b[?2004h> "]
[52.785911, "o", "# Select and order columns\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.786224, "o", "output_columns = ['user_id', 'name', 'email', 'created_date', 'status']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.786472, "o", "merged_df = merged_df[output_columns]\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.786642, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.786816, "o", "print(\"\\nMerged DataFrame:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.787027, "o", "> print(merged_df)\r\n\u001b[?2004l\r"]
[52.787211, "o", "\u001b[?2004h> print(\"\\nData types:\")\r\n\u001b[?2004l\r"]
[52.787395, "o", "\u001b[?2004h> print(merged_df.dtypes)\r\n\u001b[?2004l\r"]
[52.7875, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.787705, "o", "# Save to Parquet\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.788026, "o", "merged_df.to_parquet('/app/merged_users.parquet', index=False)\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.788199, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.788428, "o", "# Generate conflict report\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.788561, "o", "> conflict_report = {\r\n\u001b[?2004l\r"]
[52.788755, "o", "\u001b[?2004h> "]
[52.789026, "o", "    'total_conflicts': len(conflicts),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.789211, "o", "    'conflicts': conflicts\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.789435, "o", "with open('/app/conflicts.json', 'w') as f:\r\n\u001b[?2004l\r"]
[52.789613, "o", "\u001b[?2004h> "]
[52.78981, "o", "    json.dump(conflict_report, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.790043, "o", "print(f\"\\nTotal conflicts: {len(conflicts)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.790372, "o", "print(f\"\\nConflict report saved to /app/conflicts.json\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.790682, "o", "print(f\"Merged data saved to /app/merged_users.parquet\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.790873, "o", "EOF\r\n\u001b[?2004l\r"]
