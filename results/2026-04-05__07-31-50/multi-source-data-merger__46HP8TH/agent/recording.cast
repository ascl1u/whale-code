[52.690329, "i", "cat > merge_users.py << 'EOF'\nimport pandas as pd\nimport json\nfrom datetime import datetime\n\n# Read source A (JSON)\nwith open('/data/source_a/users.json', 'r') as f:\n    source_a_data = json.load(f)\n\n# Convert to DataFrame and map fields\ndf_a = pd.DataFrame(source_a_data)\ndf_a = df_a.rename(columns={\n    'id': 'user_id',\n    'full_name': 'name',\n    'registration_date': 'created_date'\n})\ndf_a['source'] = 'source_a'\n\n# Read source B (CSV)\ndf_b = pd.read_csv('/data/source_b/users.csv')\ndf_b = df_b.rename(columns={\n    'email_address': 'email',\n    'created_at': 'created_date'\n})\n# Map is_active to status\nif 'is_active' in df_b.columns:\n    df_b['status'] = df_b['is_active'].apply(lambda x: 'active' if x else 'inactive')\n    df_b = df_b.drop('is_active', axis=1)\ndf_b['source'] = 'source_b'\n\n# Read source C (Parquet)\ndf_c = pd.read_parquet('/data/source_c/users.parquet')\ndf_c = df_c.rename(columns={\n    'userId': 'user_id',\n    'userName': 'name',\n    'joined': 'created_date'\n})\n# Map active to status\nif 'active' in df_c.columns:\n    df_c['status'] = df_c['active'].apply(lambda x: 'active' if x else 'inactive')\n    df_c = df_c.drop('active', axis=1)\ndf_c['source'] = 'source_c'\n\nprint(\"Source A:\")\nprint(df_a)\nprint(\"\\nSource B:\")\nprint(df_b)\nprint(\"\\nSource C:\")\nprint(df_c)\n\n# Ensure all DataFrames have the same columns\nall_columns = ['user_id', 'name', 'email', 'created_date', 'status', 'source']\n\nfor df in [df_a, df_b, df_c]:\n    for col in all_columns:\n        if col not in df.columns:\n            df[col] = None\n\n# Combine all sources\nall_data = pd.concat([df_a, df_b, df_c], ignore_index=True)\n\n# Track conflicts\nconflicts = []\nmerged_records = {}\n\n# Get unique user_ids\nunique_users = all_data['user_id'].unique()\n\nfor user_id in unique_users:\n    user_records = all_data[all_data['user_id'] == user_id]\n    \n    # Initialize merged record\n    merged_record = {'user_id': int(user_id)}\n    \n    # Track which sources have this user\n    sources_with_user = user_records['source'].tolist()\n    \n    # For each field, check for conflicts\n    for field in ['name', 'email', 'created_date', 'status']:\n        values_by_source = {}\n        \n        for _, row in user_records.iterrows():\n            source = row['source']\n            value = row[field]\n            if pd.notna(value):\n                values_by_source[source] = value\n        \n        # Determine selected value by priority\n        selected_value = None\n        for source in ['source_a', 'source_b', 'source_c']:\n            if source in values_by_source:\n                selected_value = values_by_source[source]\n                break\n        \n        merged_record[field] = selected_value\n        \n        # Check if there's a conflict (multiple different values)\n        unique_values = set(v for v in values_by_source.values() if v is not None)\n        if len(unique_values) > 1:\n            conflict = {\n                'user_id': int(user_id),\n                'field': field,\n                'values': values_by_source,\n                'selected': selected_value\n            }\n            conflicts.append(conflict)\n    \n    merged_records[user_id] = merged_record\n\n# Create merged DataFrame\nmerged_df = pd.DataFrame(list(merged_records.values()))\n\n# Ensure proper data types\nmerged_df['user_id'] = merged_df['user_id'].astype('int64')\n\n# Ensure date format is YYYY-MM-DD\nfor idx, row in merged_df.iterrows():\n    if pd.notna(row['created_date']):\n        date_str = str(row['created_date'])\n        # Already in correct format, but validate\n        if len(date_str) == 10 and date_str[4] == '-' and date_str[7] == '-':\n            merged_df.at[idx, 'created_date'] = date_str\n\n# Select and order columns\noutput_columns = ['user_id', 'name', 'email', 'created_date', 'status']\nmerged_df = merged_df[output_columns]\n\nprint(\"\\nMerged DataFrame:\")\nprint(merged_df)\nprint(\"\\nData types:\")\nprint(merged_df.dtypes)\n\n# Save to Parquet\nmerged_df.to_parquet('/app/merged_users.parquet', index=False)\n\n# Generate conflict report\nconflict_report = {\n    'total_conflicts': len(conflicts),\n    'conflicts': confl"]
[52.690452, "i", "icts\n}\n\nwith open('/app/conflicts.json', 'w') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint(f\"\\nTotal conflicts: {len(conflicts)}\")\nprint(f\"\\nConflict report saved to /app/conflicts.json\")\nprint(f\"Merged data saved to /app/merged_users.parquet\")\nEOF\n"]
