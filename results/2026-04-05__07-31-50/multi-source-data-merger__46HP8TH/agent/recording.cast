[79.934891, "i", "python3 << 'EOF'\nimport pandas as pd\nimport pyarrow.parquet as pq\n\n# Read the merged parquet file\ndf = pd.read_parquet('/app/merged_users.parquet')\n\nprint(\"Merged Users Parquet File:\")\nprint(\"=\"*50)\nprint(\"\\nColumns:\", df.columns.tolist())\nprint(\"\\nData types:\")\nprint(df.dtypes)\nprint(\"\\nNumber of records:\", len(df))\nprint(\"\\nData:\")\nprint(df.to_string())\n\n# Verify data types\nprint(\"\\n\" + \"=\"*50)\nprint(\"Verification:\")\nprint(f\"user_id is integer: {df['user_id'].dtype == 'int64'}\")\nprint(f\"All user_ids unique: {df['user_id'].nunique() == len(df)}\")\nprint(f\"Date format check:\")\nfor idx, date in df['created_date'].items():\n    print(f\"  User {df.loc[idx, 'user_id']}: {date} (length: {len(str(date))})\")\n\nEOF\n"]
