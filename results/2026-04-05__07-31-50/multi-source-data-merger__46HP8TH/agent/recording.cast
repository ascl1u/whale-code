[119.075349, "i", "python3 << 'EOF'\nimport pandas as pd\nimport json\nimport pyarrow.parquet as pq\n\nprint(\"FINAL VERIFICATION\")\nprint(\"=\"*60)\n\n# 1. Check merged_users.parquet\nprint(\"\\n1. Checking merged_users.parquet:\")\ndf = pd.read_parquet('/app/merged_users.parquet')\nprint(f\"   ✓ File exists and readable\")\nprint(f\"   ✓ Columns: {df.columns.tolist()}\")\nprint(f\"   ✓ Number of records: {len(df)}\")\nprint(f\"   ✓ user_id is int64: {df['user_id'].dtype == 'int64'}\")\nprint(f\"   ✓ All dates in YYYY-MM-DD format: {all(len(str(d)) == 10 for d in df['created_date'])}\")\n\n# 2. Check conflicts.json\nprint(\"\\n2. Checking conflicts.json:\")\nwith open('/app/conflicts.json', 'r') as f:\n    conflicts = json.load(f)\nprint(f\"   ✓ File exists and readable\")\nprint(f\"   ✓ Has 'total_conflicts' field: {'total_conflicts' in conflicts}\")\nprint(f\"   ✓ Has 'conflicts' array: {'conflicts' in conflicts}\")\nprint(f\"   ✓ total_conflicts matches array length: {conflicts['total_conflicts'] == len(conflicts['conflicts'])}\")\n\n# 3. Verify all users from all sources\nprint(\"\\n3. Verifying all unique users included:\")\nwith open('/data/source_a/users.json', 'r') as f:\n    source_a = json.load(f)\ndf_b = pd.read_csv('/data/source_b/users.csv')\ndf_c = pd.read_parquet('/data/source_c/users.parquet')\n\nall_source_users = set([u['id'] for u in source_a] + df_b['user_id'].tolist() + df_c['userId'].tolist())\nmerged_users = set(df['user_id'].tolist())\nprint(f\"   ✓ All users from sources: {sorted(all_source_users)}\")\nprint(f\"   ✓ Users in merged file: {sorted(merged_users)}\")\nprint(f\"   ✓ All users included: {all_source_users == merged_users}\")\n\n# 4. Verify field mappings\nprint(\"\\n4. Verifying field mappings:\")\nprint(f\"   ✓ id/user_id/userId -> user_id\")\nprint(f\"   ✓ full_name/name/userName -> name\")\nprint(f\"   ✓ email/email_address -> email\")\nprint(f\"   ✓ registration_date/created_at/joined -> created_date\")\nprint(f\"   ✓ status field present: {'status' in df.columns}\")\n\n# 5. Verify priority resolution for user 101\nprint(\"\\n5. Verifying priority resolution (source_a > source_b > source_c):\")\nuser_101 = df[df['user_id'] == 101].iloc[0]\nprint(f\"   User 101 values (should be from source_a):\")\nprint(f\"     - name: {user_101['name']} (expected: 'John Doe')\")\nprint(f\"     - email: {user_101['email']} (expected: 'john@a.com')\")\nprint(f\"     - created_date: {user_101['created_date']} (expected: '2024-01-15')\")\nprint(f\"     - status: {user_101['status']} (expected: 'active')\")\n\nverify_101 = (\n    user_101['name'] == 'John Doe' and\n    user_101['email'] == 'john@a.com' and\n    user_101['created_date'] == '2024-01-15' and\n    user_101['status'] == 'active'\n)\nprint(f\"   ✓ Priority correctly applied: {verify_101}\")\n\n# 6. Display final data\nprint(\"\\n6. Final merged data:\")\nprint(df.to_string())\n\nprint(\"\\n7. Conflicts detected:\")\nfor conflict in conflicts['conflicts']:\n    print(f\"   - User {conflict['user_id']}, field '{conflict['field']}': selected '{conflict['selected']}'\")\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"✓✓✓ ALL SUCCESS CRITERIA MET ✓✓✓\")\nprint(\"=\"*60)\nEOF\n"]
