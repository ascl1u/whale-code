[?2004l[?2004h>         values = {}
[?2004l[?2004h>         
[?2004l[?2004h>         # Collect values from each source
[?2004l[?2004h>         for _, row in user_records.iterrows():
[?2004l[?2004h>             source = row['source']
[?2004l[?2004h>             value = row[field]
[?2004l[?2004h>             if pd.notna(value):
[?2004l[?2004h>                 values[source] = value
[?2004l[?2004h>         
[?2004l[?2004h>         # Select value based on priority
[?2004l[?2004h>         selected_value = None
[?2004l[?2004h>         if 'source_a' in values:
[?2004l[?2004h>             selected_value = values['source_a']
[?2004l[?2004h>         elif 'source_b' in values:
[?2004l[?2004h>             selected_value = values['source_b']
[?2004l[?2004h>         elif 'source_c' in values:
[?2004l[?2004h>             selected_value = values['source_c']
[?2004l[?2004h>         
[?2004l[?2004h>         merged[field] = selected_value
[?2004l[?2004h>         
[?2004l[?2004h>         # Check for conflicts (different values across sources)
