[?2004l[?2004h>                 'values': values,
[?2004l[?2004h>                 'selected': selected_value
[?2004l[?2004h>             })
[?2004l[?2004h>     
[?2004l[?2004h>     merged_records.append(merged)
[?2004l[?2004h> 
[?2004l[?2004h> # Create merged DataFrame
