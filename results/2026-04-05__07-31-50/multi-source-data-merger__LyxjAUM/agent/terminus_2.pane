[?2004l[?2004h> df_b['status'] = df_b['is_active'].apply(lambda x: 'active' if x else 'inactive')
[?2004l[?2004h> df_b = df_b.drop(columns=['is_active'])
[?2004l[?2004h> df_b['source'] = 'source_b'
[?2004l[?2004h> 
[?2004l[?2004h> # Read source C (Parquet - lowest priority)
[?2004l[?2004h> df_c = pd.read_parquet('/data/source_c/users.parquet')
[?2004l[?2004h> df_c = df_c.rename(columns={
[?2004l[?2004h>     'userId': 'user_id',
[?2004l[?2004h>     'userName': 'name',
[?2004l[?2004h>     'joined': 'created_date'
[?2004l[?2004h> })
[?2004l[?2004h> # Map active to status
[?2004l[?2004h> df_c['status'] = df_c['active'].apply(lambda x: 'active' if x else 'inactive')
[?2004l[?2004h> df_c = df_c.drop(columns=['active'])
[?2004l[?2004h> df_c['source'] = 'source_c'
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure all DataFrames have the same columns
[?2004l[?2004h> all_columns = ['user_id', 'name', 'email', 'created_date', 'status', 'source']
[?2004l[?2004h> for col in all_columns:
[?2004l[?2004h>     if col not in df_a.columns:
[?2004l[?2004h>         df_a[col] = None
[?2004l[?2004h>     if col not in df_b.columns:
[?2004l[?2004h>         df_b[col] = None
[?2004l[?2004h>     if col not in df_c.columns:
[?2004l[?2004h>         df_c[col] = None
[?2004l[?2004h> 
[?2004l[?2004h> df_a = df_a[all_columns]
[?2004l[?2004h> df_b = df_b[all_columns]
[?2004l[?2004h> df_c = df_c[all_columns]
[?2004l[?2004h> 
[?2004l[?2004h> # Combine all sources
[?2004l[?2004h> all_data = pd.concat([df_a, df_b, df_c], ignore_index=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Convert user_id to integer
[?2004l[?2004h> all_data['user_id'] = all_data['user_id'].astype(int)
[?2004l[?2004h> 
[?2004l[?2004h> # Get unique user_ids
[?2004l[?2004h> unique_users = all_data['user_id'].unique()
[?2004l[?2004h> 
[?2004l[?2004h> # Initialize conflict tracking
[?2004l[?2004h> conflicts = []
[?2004l[?2004h> merged_records = []
[?2004l[?2004h> 
