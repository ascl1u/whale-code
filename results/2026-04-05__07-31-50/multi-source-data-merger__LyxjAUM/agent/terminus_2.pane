[?2004l[?2004h> for user_id in sorted(unique_users):
[?2004l[?2004h>     user_records = all_data[all_data['user_id'] == user_id]
[?2004l[?2004h>     
[?2004l[?2004h>     # Initialize merged record
[?2004l[?2004h>     merged = {'user_id': int(user_id)}
[?2004l[?2004h>     
