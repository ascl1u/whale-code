[27.155474, "o", "\u001b[?2004hroot@8db1ad3c0d5d:/app# "]
[47.743171, "i", "cat > merge_users.py << 'EOF'\nimport pandas as pd\nimport json\nfrom datetime import datetime\n\n# Read source A (JSON - highest priority)\nwith open('/data/source_a/users.json', 'r') as f:\n    source_a_data = json.load(f)\n\n# Convert to DataFrame and map fields\ndf_a = pd.DataFrame(source_a_data)\ndf_a = df_a.rename(columns={\n    'id': 'user_id',\n    'full_name': 'name',\n    'registration_date': 'created_date'\n})\ndf_a['source'] = 'source_a'\n\n# Read source B (CSV - medium priority)\ndf_b = pd.read_csv('/data/source_b/users.csv')\ndf_b = df_b.rename(columns={\n    'name': 'name',\n    'email_address': 'email',\n    'created_at': 'created_date'\n})\n# Map is_active to status\ndf_b['status'] = df_b['is_active'].apply(lambda x: 'active' if x else 'inactive')\ndf_b = df_b.drop(columns=['is_active'])\ndf_b['source'] = 'source_b'\n\n# Read source C (Parquet - lowest priority)\ndf_c = pd.read_parquet('/data/source_c/users.parquet')\ndf_c = df_c.rename(columns={\n    'userId': 'user_id',\n    'userName': 'name',\n    'joined': 'created_date'\n})\n# Map active to status\ndf_c['status'] = df_c['active'].apply(lambda x: 'active' if x else 'inactive')\ndf_c = df_c.drop(columns=['active'])\ndf_c['source'] = 'source_c'\n\n# Ensure all DataFrames have the same columns\nall_columns = ['user_id', 'name', 'email', 'created_date', 'status', 'source']\nfor col in all_columns:\n    if col not in df_a.columns:\n        df_a[col] = None\n    if col not in df_b.columns:\n        df_b[col] = None\n    if col not in df_c.columns:\n        df_c[col] = None\n\ndf_a = df_a[all_columns]\ndf_b = df_b[all_columns]\ndf_c = df_c[all_columns]\n\n# Combine all sources\nall_data = pd.concat([df_a, df_b, df_c], ignore_index=True)\n\n# Convert user_id to integer\nall_data['user_id'] = all_data['user_id'].astype(int)\n\n# Get unique user_ids\nunique_users = all_data['user_id'].unique()\n\n# Initialize conflict tracking\nconflicts = []\nmerged_records = []\n\n# Process each user\nfor user_id in sorted(unique_users):\n    user_records = all_data[all_data['user_id'] == user_id]\n    \n    # Initialize merged record\n    merged = {'user_id': int(user_id)}\n    \n    # Track which sources have this user\n    sources_present = user_records['source'].tolist()\n    \n    # For each field, merge with priority\n    for field in ['name', 'email', 'created_date', 'status']:\n        values = {}\n        \n        # Collect values from each source\n        for _, row in user_records.iterrows():\n            source = row['source']\n            value = row[field]\n            if pd.notna(value):\n                values[source] = value\n        \n        # Select value based on priority\n        selected_value = None\n        if 'source_a' in values:\n            selected_value = values['source_a']\n        elif 'source_b' in values:\n            selected_value = values['source_b']\n        elif 'source_c' in values:\n            selected_value = values['source_c']\n        \n        merged[field] = selected_value\n        \n        # Check for conflicts (different values across sources)\n        unique_values = set(v for v in values.values() if pd.notna(v))\n        if len(unique_values) > 1:\n            conflicts.append({\n                'user_id': int(user_id),\n                'field': field,\n                'values': values,\n                'selected': selected_value\n            })\n    \n    merged_records.append(merged)\n\n# Create merged DataFrame\nmerged_df = pd.DataFrame(merged_records)\n\n# Ensure correct column order and types\nmerged_df = merged_df[['user_id', 'name', 'email', 'created_date', 'status']]\nmerged_df['user_id'] = merged_df['user_id'].astype('int64')\n\n# Convert date format to YYYY-MM-DD if needed\ndef normalize_date(date_str):\n    if pd.isna(date_str):\n        return None\n    # Already in YYYY-MM-DD format in our sources\n    return str(date_str)\n\nmerged_df['created_date'] = merged_df['created_date'].apply(normalize_date)\n\n# Save merged data as Parquet\nmerged_df.to_parquet('/app/merged_users.parquet', index=False)\n\n# Create conflict report\nconflict_report = {\n    'total_conflicts': len(conflicts),\n    'conflicts': conflicts\n}\n\n# Save conflict report as "]
[47.743296, "i", "JSON\nwith open('/app/conflicts.json', 'w') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint(f\"Merged {len(merged_df)} unique users\")\nprint(f\"Found {len(conflicts)} conflicts\")\nprint(\"\\nMerged data preview:\")\nprint(merged_df.to_string())\nprint(\"\\nConflict report:\")\nprint(json.dumps(conflict_report, indent=2))\nEOF\n"]
