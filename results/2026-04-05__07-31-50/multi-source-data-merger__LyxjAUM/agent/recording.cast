[47.764018, "o", "        # Collect values from each source\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.764308, "o", "        for _, row in user_records.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.764524, "o", "            source = row['source']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.764727, "o", "            value = row[field]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.764921, "o", "            if pd.notna(value):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.765203, "o", "                values[source] = value\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.765398, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.765559, "o", "        # Select value based on priority\r\n\u001b[?2004l\r"]
[47.765723, "o", "\u001b[?2004h> "]
[47.765857, "o", "        selected_value = None\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.766025, "o", "> "]
[47.766233, "o", "        if 'source_a' in values:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.766522, "o", "            selected_value = values['source_a']\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.766695, "o", "> "]
[47.766889, "o", "        elif 'source_b' in values:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.767145, "o", "            selected_value = values['source_b']\r\n\u001b[?2004l\r"]
[47.767324, "o", "\u001b[?2004h> "]
[47.767496, "o", "        elif 'source_c' in values:\r\n\u001b[?2004l\r"]
[47.767679, "o", "\u001b[?2004h> "]
[47.767863, "o", "            selected_value = values['source_c']\r\n\u001b[?2004l\r"]
[47.76797, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[47.768126, "o", "\u001b[?2004h> "]
[47.768288, "o", "        merged[field] = selected_value\r\n\u001b[?2004l\r"]
[47.768462, "o", "\u001b[?2004h> "]
[47.76864, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.768909, "o", "        # Check for conflicts (different values across sources)\r\n\u001b[?2004l\r"]
[47.769128, "o", "\u001b[?2004h> "]
[47.76941, "o", "        unique_values = set(v for v in values.values() if pd.notna(v))\r\n\u001b[?2004l\r"]
[47.769608, "o", "\u001b[?2004h> "]
[47.769788, "o", "        if len(unique_values) > 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.769903, "o", "> "]
[47.770204, "o", "            conflicts.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.770393, "o", "                'user_id': int(user_id),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.770586, "o", "                'field': field,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.77082, "o", "                'values': values,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.771103, "o", "                'selected': selected_value\r\n\u001b[?2004l\r"]
[47.7713, "o", "\u001b[?2004h> "]
[47.771503, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.77168, "o", "    merged_records.append(merged)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[47.771925, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[47.772123, "o", "# Create merged DataFrame\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.772304, "o", "merged_df = pd.DataFrame(merged_records)\r\n\u001b[?2004l\r"]
[47.772456, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.772692, "o", "# Ensure correct column order and types\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.773159, "o", "merged_df = merged_df[['user_id', 'name', 'email', 'created_date', 'status']]\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.773338, "o", "> "]
[47.773567, "o", "merged_df['user_id'] = merged_df['user_id'].astype('int64')\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.773759, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.77401, "o", "# Convert date format to YYYY-MM-DD if needed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.774238, "o", "def normalize_date(date_str):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.774361, "o", "    if pd.isna(date_str):\r\n\u001b[?2004l\r"]
[47.774452, "o", "\u001b[?2004h> "]
[47.83014, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h>     # Already in YYYY-MM-DD format in our sources\r\n\u001b[?2004l\r\u001b[?2004h>     return str(date_str)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> merged_df['created_date'] = merged_df['created_date'].apply(normalize_date)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Save merged data as Parquet\r\n\u001b[?2004l\r\u001b[?2004h> merged_df.to_parquet('/app/merged_users.parquet', index=False)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Create conflict report\r\n\u001b[?2004l\r\u001b[?2004h> conflict_report = {\r\n\u001b[?2004l\r\u001b[?2004h>     'total_conflicts': len(conflicts),\r\n\u001b[?2004l\r\u001b[?2004h>     'conflicts': conflicts\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.830386, "o", "\u001b[?2004h> # Save conflict report as JSON\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.830611, "o", "with open('/app/conflicts.json', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.830804, "o", "    json.dump(conflict_report, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.83098, "o", "> "]
[47.831179, "o", "print(f\"Merged {len(merged_df)} unique users\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.831404, "o", "print(f\"Found {len(conflicts)} conflicts\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.831572, "o", "print(\"\\nMerged data preview:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.831709, "o", "print(merged_df.to_string())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.83182, "o", "print(\"\\nConflict report:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.832027, "o", "print(json.dumps(conflict_report, indent=2))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.83221, "o", "EOF\r\n\u001b[?2004l\r"]
