[91.052579, "i", "python3 << 'EOF'\nimport pandas as pd\nimport json\n\nprint(\"=== VERIFICATION ===\")\nprint()\n\n# Read all source files\nwith open('/data/source_a/users.json', 'r') as f:\n    source_a = json.load(f)\nsource_b = pd.read_csv('/data/source_b/users.csv')\nsource_c = pd.read_parquet('/data/source_c/users.parquet')\n\n# Get unique user IDs from each source\nids_a = set([u['id'] for u in source_a])\nids_b = set(source_b['user_id'].tolist())\nids_c = set(source_c['userId'].tolist())\n\nall_source_ids = ids_a | ids_b | ids_c\nprint(f\"Source A user IDs: {sorted(ids_a)}\")\nprint(f\"Source B user IDs: {sorted(ids_b)}\")\nprint(f\"Source C user IDs: {sorted(ids_c)}\")\nprint(f\"All unique user IDs from sources: {sorted(all_source_ids)}\")\nprint()\n\n# Read merged file\nmerged = pd.read_parquet('/app/merged_users.parquet')\nmerged_ids = set(merged['user_id'].tolist())\nprint(f\"Merged file user IDs: {sorted(merged_ids)}\")\nprint()\n\n# Check if all users are included\nif all_source_ids == merged_ids:\n    print(\"✓ All unique users from all sources are included\")\nelse:\n    print(\"✗ Missing users:\", all_source_ids - merged_ids)\nprint()\n\n# Check data types\nprint(\"Data types:\")\nprint(merged.dtypes)\nprint()\nif merged['user_id'].dtype == 'int64':\n    print(\"✓ user_id is integer type\")\nelse:\n    print(\"✗ user_id is not integer type\")\nprint()\n\n# Check date format\nimport re\ndate_pattern = r'^\\d{4}-\\d{2}-\\d{2}$'\nall_dates_valid = all(re.match(date_pattern, str(d)) if pd.notna(d) else True for d in merged['created_date'])\nif all_dates_valid:\n    print(\"✓ All dates are in YYYY-MM-DD format\")\nelse:\n    print(\"✗ Some dates are not in YYYY-MM-DD format\")\nprint()\n\n# Read conflicts\nwith open('/app/conflicts.json', 'r') as f:\n    conflicts = json.load(f)\n\nprint(f\"Total conflicts: {conflicts['total_conflicts']}\")\nprint(f\"Conflicts in list: {len(conflicts['conflicts'])}\")\nif conflicts['total_conflicts'] == len(conflicts['conflicts']):\n    print(\"✓ Conflict count matches\")\nelse:\n    print(\"✗ Conflict count mismatch\")\nprint()\n\n# Verify priority-based resolution for user 101\nprint(\"Verifying priority-based conflict resolution for user 101:\")\nuser_101 = merged[merged['user_id'] == 101].iloc[0]\nprint(f\"  name: {user_101['name']} (should be 'John Doe' from source_a)\")\nprint(f\"  email: {user_101['email']} (should be 'john@a.com' from source_a)\")\nprint(f\"  created_date: {user_101['created_date']} (should be '2024-01-15' from source_a)\")\nprint(f\"  status: {user_101['status']} (should be 'active' from source_a)\")\nprint()\n\nif (user_101['name'] == 'John Doe' and \n    user_101['email'] == 'john@a.com' and \n    user_101['created_date'] == '2024-01-15' and\n    user_101['status'] == 'active'):\n    print(\"✓ Priority-based conflict resolution working correctly\")\nelse:\n    print(\"✗ Priority-based conflict resolution has issues\")\n\nprint()\nprint(\"=== VERIFICATION COMPLETE ===\")\nEOF\n"]
