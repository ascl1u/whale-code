[26.045927, "i", "python3 << 'EOF'\nimport pandas as pd\nimport pyarrow.parquet as pq\n\n# Read and display the parquet file schema and content\ndf = pd.read_parquet('/data/source_c/users.parquet')\nprint(\"Schema:\")\nprint(df.dtypes)\nprint(\"\\nData:\")\nprint(df.to_string())\nEOF\n"]
