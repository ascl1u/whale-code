[50.343601, "o", "# Merge with priority and track conflicts\r\n\u001b[?2004l\r\u001b[?2004h> merged_records = []\r\n\u001b[?2004l\r\u001b[?2004h> conflicts = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> for user_id in sorted(unique_users):\r\n\u001b[?2004l\r\u001b[?2004h>     user_records = all_data[all_data['user_id'] == user_id]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Get records from each source\r\n\u001b[?2004l\r\u001b[?2004h>     records_by_source = {}\r\n\u001b[?2004l\r\u001b[?2004h>     for _, record in user_records.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h>         source = record['source']\r\n\u001b[?2004l\r\u001b[?2004h>         records_by_source[source] = record\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Priority order\r\n\u001b[?2004l\r\u001b[?2004h>     priority = ['source_a', 'source_b', 'source_c']\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Build merged record\r\n\u001b[?2004l\r"]
[50.343808, "o", "\u001b[?2004h> "]
[50.344018, "o", "    merged = {'user_id': int(user_id)}\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[50.344219, "o", "\u001b[?2004h> "]
[50.344394, "o", "    # For each field, check for conflicts and apply priority\r\n\u001b[?2004l\r"]
[50.344556, "o", "\u001b[?2004h> "]
[50.344736, "o", "    fields = ['name', 'email', 'created_date', 'status']\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[50.344842, "o", "\u001b[?2004h>     for field in fields:\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.345095, "o", "> "]
[50.345269, "o", "        values_by_source = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.345449, "o", "        for source in ['source_a', 'source_b', 'source_c']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.345629, "o", "> "]
[50.345815, "o", "            if source in records_by_source:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.346036, "o", "                val = records_by_source[source][field]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.346213, "o", "                if pd.notna(val):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.346465, "o", "                    values_by_source[source] = val\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.346697, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.346883, "o", "        # Select value by priority\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.347046, "o", "        selected_value = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.347204, "o", "        for source in priority:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.347381, "o", "            if source in values_by_source:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.347616, "o", "                selected_value = values_by_source[source]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.347824, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.348005, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.348188, "o", "        merged[field] = selected_value\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.348476, "o", "        # Check for conflicts (different non-null values)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.348896, "o", "        unique_values = set(v for v in values_by_source.values() if pd.notna(v))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.349273, "o", "        if len(unique_values) > 1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.349452, "o", "            conflict = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.349628, "o", "                'user_id': int(user_id),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.349788, "o", "                'field': field,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.350011, "o", "                'values': values_by_source,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.35024, "o", "                'selected': selected_value\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.350452, "o", ">             }\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.350554, "o", ">             conflicts.append(conflict)\r\n\u001b[?2004l\r"]
[50.350826, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.351016, "o", "    merged_records.append(merged)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.351197, "o", "print(f\"Total conflicts detected: {len(conflicts)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[50.35139, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[50.351564, "o", "# Create merged dataframe\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.351655, "o", "merged_df = pd.DataFrame(merged_records)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.35189, "o", "\u001b[?2004h> "]
[50.35206, "o", "# Ensure correct data types\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.352213, "o", "merged_df['user_id'] = merged_df['user_id'].astype(int)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.352467, "o", "merged_df['name'] = merged_df['name'].astype(str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.352762, "o", "merged_df['email'] = merged_df['email'].astype(str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.353126, "o", "merged_df['created_date'] = merged_df['created_date'].astype(str)\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.353299, "o", "> "]
[50.353409, "o", "# status can be None/null\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.353563, "o", "# Sort by user_id\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.353863, "o", "merged_df = merged_df.sort_values('user_id').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.354084, "o", "\u001b[?2004h> "]
[50.354255, "o", "print(\"\\nMerged data preview:\")\r\n\u001b[?2004l\r\u001b[?2004h> print(merged_df.to_string())\r\n\u001b[?2004l\r"]
[50.354542, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Save merged data to parquet\r\n\u001b[?2004l\r"]
[50.354748, "o", "\u001b[?2004h> "]
[50.354963, "o", "print(\"\\nSaving merged data to /app/merged_users.parquet...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.355198, "o", "merged_df.to_parquet('/app/merged_users.parquet', index=False)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.355385, "o", "\u001b[?2004h> "]
[50.355599, "o", "# Create conflict report\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.355697, "o", "conflict_report = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.355855, "o", "    'total_conflicts': len(conflicts),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.355954, "o", "    'conflicts': conflicts\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.356183, "o", "> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.356445, "o", "print(f\"Saving conflict report to /app/conflicts.json...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.356685, "o", "with open('/app/conflicts.json', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.356919, "o", "    json.dump(conflict_report, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.357127, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.357304, "o", "print(\"\\nMerge complete!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.357482, "o", "print(f\"Total users: {len(merged_df)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.357658, "o", "print(f\"Total conflicts: {len(conflicts)}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.357836, "o", "> EOF\r\n\u001b[?2004l\r"]
