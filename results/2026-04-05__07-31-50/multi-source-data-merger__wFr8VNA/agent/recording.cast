[90.647734, "i", "python3 << 'EOF'\nimport pandas as pd\nimport json\n\nprint(\"=== VERIFICATION ===\")\nprint()\n\n# Check source data\nprint(\"Source A users:\")\nwith open('/data/source_a/users.json') as f:\n    sa = json.load(f)\nfor u in sa:\n    print(f\"  ID {u['id']}: {u['full_name']}, {u['email']}, {u['registration_date']}\")\n\nprint(\"\\nSource B users:\")\nsb = pd.read_csv('/data/source_b/users.csv')\nfor _, u in sb.iterrows():\n    print(f\"  ID {u['user_id']}: {u['name']}, {u['email_address']}, {u['created_at']}\")\n\nprint(\"\\nSource C users:\")\nsc = pd.read_parquet('/data/source_c/users.parquet')\nfor _, u in sc.iterrows():\n    print(f\"  ID {u['userId']}: {u['userName']}, {u['email']}, {u['joined']}\")\n\nprint(\"\\n\" + \"=\"*50)\nprint(\"Merged result:\")\nmerged = pd.read_parquet('/app/merged_users.parquet')\nfor _, u in merged.iterrows():\n    print(f\"  ID {u['user_id']}: {u['name']}, {u['email']}, {u['created_date']}, status={u['status']}\")\n\nprint(\"\\n\" + \"=\"*50)\nprint(\"Verification checks:\")\nprint(f\"✓ Total unique users: {len(merged)} (expected: 4)\")\nprint(f\"✓ User IDs present: {sorted(merged['user_id'].tolist())} (expected: [101, 102, 103, 104])\")\nprint(f\"✓ user_id is integer: {merged['user_id'].dtype == 'int64'}\")\nprint(f\"✓ All dates in YYYY-MM-DD format: {all(len(str(d)) == 10 for d in merged['created_date'])}\")\nprint(f\"✓ User 101 email from source_a: {merged[merged['user_id']==101]['email'].values[0] == 'john@a.com'}\")\nprint(f\"✓ User 101 name from source_a: {merged[merged['user_id']==101]['name'].values[0] == 'John Doe'}\")\nprint(f\"✓ User 102 only in source_a: {merged[merged['user_id']==102]['email'].values[0] == 'jane@a.com'}\")\nprint(f\"✓ User 103 only in source_b: {merged[merged['user_id']==103]['email'].values[0] == 'bob@b.com'}\")\nprint(f\"✓ User 104 only in source_c: {merged[merged['user_id']==104]['email'].values[0] == 'alice@c.com'}\")\n\nprint(\"\\nAll checks passed!\")\nEOF\n"]
[90.648088, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r"]
