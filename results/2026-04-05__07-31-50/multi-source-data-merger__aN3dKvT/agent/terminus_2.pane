[?2004l[?2004h>     source_a_data = json.load(f)
[?2004l[?2004h> 
[?2004lg[?2004h> # Convert to DataFrame and normalize
[?2004l[?2004h> df_a = pd.DataFrame(source_a_data)
[?2004l[?2004h> df_a = df_a.rename(columns={
[?2004l[?2004h>     'id': 'user_id',
[?2004l[?2004h>     'full_name': 'name',
[?2004l[?2004h>     'email': 'email',
[?2004l[?2004h>     'registration_date': 'created_date'
[?2004l[?2004h> })
[?2004l[?2004h> df_a['source'] = 'source_a'
[?2004l)[?2004h> df_a['priority'] = 1
[?2004l[?2004h> 
[?2004l[?2004h> # Read source_b (CSV)
[?2004l[?2004h> df_b = pd.read_csv('/data/source_b/users.csv')
[?2004l[?2004h> df_b = df_b.rename(columns={
[?2004l[?2004h>     'user_id': 'user_id',
[?2004l[?2004h>     'name': 'name',
[?2004l[?2004h>     'email_address': 'email',
[?2004l[?2004h>     'created_at': 'created_date'
[?2004l = m[?2004h> })
[?2004l[?2004h> # Map is_active to status
[?2004l[?2004h> if 'is_active' in df_b.columns:
[?2004l[?2004h>     df_b['status'] = df_b['is_active'].apply(lambda x: 'active' if x else 'inactive')
[?2004l[?2004h>     df_b = df_b.drop('is_active', axis=1)
[?2004l[?2004h> df_b['source'] = 'source_b'
[?2004l[?2004h> df_b['priority'] = 2
[?2004l[?2004h> 
[?2004l:[?2004h> # Read source_c (Parquet)
[?2004l[?2004h> df_c = pd.read_parquet('/data/source_c/users.parquet')
[?2004l[?2004h> df_c = df_c.rename(columns={
[?2004l[?2004h>     'userId': 'user_id',
[?2004l[?2004h>     'userName': 'name',
[?2004l[?2004h>     'email': 'email',
[?2004le[?2004h>     'joined': 'created_date'
[?2004l[?2004h> })
[?2004l[?2004h> # Map active to status
[?2004l[?2004h> if 'active' in df_c.columns:
[?2004l[?2004h>     df_c['status'] = df_c['active'].apply(lambda x: 'active' if x else 'inactive')
[?2004l[?2004h>     df_c = df_c.drop('active', axis=1)
[?2004l[?2004h> df_c['source'] = 'source_c'
[?2004l[?2004h> df_c['priority'] = 3
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure all DataFrames have the same columns
[?2004l[?2004h> all_columns = ['user_id', 'name', 'email', 'created_date', 'status', 'source', 'priority']
[?2004l[?2004h> for df in [df_a, df_b, df_c]:
[?2004l[?2004h>     for col in all_columns:
[?2004l[?2004h>         if col not in df.columns:
[?2004l[?2004h>             df[col] = None
[?2004l[?2004h> 
[?2004l[?2004h> # Combine all sources
[?2004l[?2004h> df_all = pd.concat([df_a[all_columns], df_b[all_columns], df_c[all_columns]], ignore_index=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Convert user_id to integer
[?2004l[?2004h> df_all['user_id'] = df_all['user_id'].astype(int)
[?2004l[?2004h> 
[?2004l[?2004h> # Normalize dates to YYYY-MM-DD format
[?2004l[?2004h> def normalize_date(date_str):
[?2004l[?2004h>     if pd.isna(date_str) or date_str is None:
[?2004l[?2004h>         return None
[?2004l[?2004h>     date_str = str(date_str)
[?2004l[?2004h>     # Try to parse and format as YYYY-MM-DD
[?2004l[?2004h>     try:
[?2004l[?2004h>         # Handle various date formats
[?2004l[?2004h>         for fmt in ['%Y-%m-%d', '%Y/%m/%d', '%m/%d/%Y', '%d/%m/%Y']:
[?2004l[?2004h>             try:
[?2004l[?2004h>                 dt = datetime.strptime(date_str, fmt)
[?2004l[?2004h>                 return dt.strftime('%Y-%m-%d')
[?2004l[?2004h>             except:
[?2004l[?2004h>                 continue
[?2004l[?2004h>         # If already in correct format, return as is
[?2004l[?2004h>         if len(date_str) == 10 and date_str[4] == '-' and date_str[7] == '-':
[?2004l[?2004h>             return date_str
[?2004l[?2004h>         return date_str
[?2004l[?2004h>     except:
[?2004l[?2004h>         return date_str
[?2004l[?2004h> 
[?2004l[?2004h> df_all['created_date'] = df_all['created_date'].apply(normalize_date)
[?2004l[?2004h> 
[?2004l[?2004h> # Track conflicts
[?2004l[?2004h> conflicts = []
[?2004l[?2004h> merged_records = {}
[?2004l[?2004h> 
[?2004l[?2004h> # Group by user_id
[?2004l[?2004h> for user_id, group in df_all.groupby('user_id'):
[?2004l[?2004h>     # Sort by priority (lower is higher priority)
[?2004l[?2004h>     group = group.sort_values('priority')
[?2004l[?2004h>     
[?2004l[?2004h>     # Check for conflicts
[?2004l[?2004h>     fields_to_check = ['name', 'email', 'created_date', 'status']
[?2004l[?2004h>     
[?2004l[?2004h>     for field in fields_to_check:
[?2004l[?2004h>         # Get non-null values for this field
[?2004l[?2004h>         values = group[group[field].notna()][['source', field]]
[?2004l[?2004h>         
[?2004l[?2004h>         if len(values) > 1:
[?2004l[?2004h>             # Check if values are different
[?2004l[?2004h>             unique_values = values[field].unique()
[?2004l[?2004h>             if len(unique_values) > 1:
[?2004l[?2004h>                 # There's a conflict
[?2004l[?2004h>                 conflict_entry = {
[?2004l[?2004h>                     'user_id': int(user_id),
[?2004l[?2004h>                     'field': field,
[?2004l[?2004h>                     'values': {},
[?2004l[?2004h>                     'selected': None
[?2004l[?2004h>                 }
[?2004l[?2004h>                 
[?2004l[?2004h>                 for _, row in values.iterrows():
[?2004l[?2004h>                     conflict_entry['values'][row['source']] = row[field]
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Selected value is from highest priority source with non-null value
[?2004l[?2004h>                 selected_value = group[group[field].notna()].iloc[0][field]
[?2004l[?2004h>                 conflict_entry['selected'] = selected_value
[?2004l[?2004h>                 
[?2004l[?2004h>                 conflicts.append(conflict_entry)
[?2004l[?2004h>     
[?2004l[?2004h>     # Merge: take values from highest priority source (lowest priority number)
[?2004l[?2004h>     merged_record = {
[?2004l[?2004h>         'user_id': int(user_id),
[?2004l[?2004h>         'name': None,
[?2004l[?2004h>         'email': None,
[?2004l[?2004h>         'created_date': None,
[?2004l[?2004h>         'status': None
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     for field in ['name', 'email', 'created_date', 'status']:
[?2004l[?2004h>         # Get first non-null value (already sorted by priority)
[?2004l[?2004h>         non_null = group[group[field].notna()]
[?2004l[?2004h>         if len(non_null) > 0:
[?2004l[?2004h>             merged_record[field] = non_null.iloc[0][field]
[?2004l[?2004h>     
[?2004l[?2004h>     merged_records[user_id] = merged_record
[?2004l[?2004h> 
[?2004l[?2004h> # Create merged DataFrame
[?2004l[?2004h> merged_df = pd.DataFrame(list(merged_records.values()))
[?2004l[?2004h> 
[?2004l[?2004h> # Ensure correct column order and types
[?2004l[?2004h> merged_df = merged_df[['user_id', 'name', 'email', 'created_date', 'status']]
[?2004l[?2004h> merged_df['user_id'] = merged_df['user_id'].astype('int64')
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by user_id for consistency
[?2004l[?2004h> merged_df = merged_df.sort_values('user_id').reset_index(drop=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Write to Parquet
[?2004l[?2004h> merged_df.to_parquet('/app/merged_users.parquet', index=False)
[?2004l[?2004h> 
[?2004l[?2004h> # Create conflict report
[?2004l[?2004h> conflict_report = {
[?2004l[?2004h>     'total_conflicts': len(conflicts),
[?2004l[?2004h>     'conflicts': conflicts
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # Write conflict report
[?2004l[?2004h> with open('/app/conflicts.json', 'w') as f:
[?2004l[?2004h>     json.dump(conflict_report, f, indent=2)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Merge complete!")
[?2004l[?2004h> print(f"Total users: {len(merged_df)}")
[?2004l[?2004h> print(f"Total conflicts: {len(conflicts)}")
