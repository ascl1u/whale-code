[77.228209, "o", "print(f\"user_id is integer: {df['user_id'].dtype in ['int64', 'int32']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[77.228588, "o", "print(f\"name is string: {df['name'].dtype == 'object'}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
