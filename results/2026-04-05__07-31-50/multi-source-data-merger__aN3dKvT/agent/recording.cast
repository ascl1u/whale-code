[77.223807, "i", "python3 << 'EOF'\nimport pandas as pd\nimport pyarrow.parquet as pq\n\n# Read the merged parquet file\ndf = pd.read_parquet('/app/merged_users.parquet')\n\nprint(\"Schema:\")\nprint(df.dtypes)\nprint(\"\\nData:\")\nprint(df)\nprint(\"\\nColumn names:\", df.columns.tolist())\nprint(\"\\nNumber of records:\", len(df))\nprint(\"\\nUser IDs:\", sorted(df['user_id'].tolist()))\n\n# Verify data types\nprint(\"\\nData type checks:\")\nprint(f\"user_id is integer: {df['user_id'].dtype in ['int64', 'int32']}\")\nprint(f\"name is string: {df['name'].dtype == 'object'}\")\nprint(f\"email is string: {df['email'].dtype == 'object'}\")\nprint(f\"created_date is string: {df['created_date'].dtype == 'object'}\")\n\n# Verify date format\nprint(\"\\nDate format check (should be YYYY-MM-DD):\")\nfor idx, date in enumerate(df['created_date']):\n    print(f\"  Row {idx}: {date}\")\nEOF\n"]
