[77.225941, "o", "\u001b[?2004h> print(\"\\nData:\")\r\n\u001b[?2004l\r"]
[77.226154, "o", "\u001b[?2004h> print(df)\r\n\u001b[?2004l\r\u001b[?2004h"]
[77.226386, "o", "> "]
[77.226567, "o", "print(\"\\nColumn names:\", df.columns.tolist())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[77.226777, "o", "print(\"\\nNumber of records:\", len(df))\r\n\u001b[?2004l\r\u001b[?2004h"]
[77.226995, "o", "> print(\"\\nUser IDs:\", sorted(df['user_id'].tolist()))\r\n\u001b[?2004l\r"]
[77.227194, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[77.227418, "o", "\u001b[?2004h> # Verify data types\r\n\u001b[?2004l\r\u001b[?2004h"]
[77.227655, "o", "> "]
