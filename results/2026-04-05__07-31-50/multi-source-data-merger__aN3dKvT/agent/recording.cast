[77.229384, "o", "print(f\"created_date is string: {df['created_date'].dtype == 'object'}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[77.229585, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
