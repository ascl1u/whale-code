[77.224387, "o", "\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r"]
[77.224685, "o", "\u001b[?2004h> import pyarrow.parquet as pq\r\n\u001b[?2004l\r"]
[77.224923, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
