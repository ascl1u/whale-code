[51.021344, "o", "        if len(date_str) == 10 and date_str[4] == '-' and date_str[7] == '-':\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.021605, "o", "> "]
[51.021787, "o", "            return date_str\r\n\u001b[?2004l\r\u001b[?2004h>         return date_str\r\n\u001b[?2004l\r"]
[51.022139, "o", "\u001b[?2004h>     except:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.02231, "o", "        return date_str\r\n\u001b[?2004l\r"]
[51.022712, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.023081, "o", "df_all['created_date'] = df_all['created_date'].apply(normalize_date)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[51.023237, "o", "\u001b[?2004h> "]
[51.023657, "o", "# Track conflicts\r\n\u001b[?2004l\r\u001b[?2004h> conflicts = []\r\n\u001b[?2004l\r"]
[51.02391, "o", "\u001b[?2004h> merged_records = {}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.024201, "o", "# Group by user_id\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.024463, "o", "> "]
[51.024718, "o", "for user_id, group in df_all.groupby('user_id'):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.025199, "o", "    # Sort by priority (lower is higher priority)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.025536, "o", "    group = group.sort_values('priority')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.025815, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.026111, "o", ">     # Check for conflicts\r\n\u001b[?2004l\r"]
[51.026365, "o", "\u001b[?2004h> "]
[51.02681, "o", "    fields_to_check = ['name', 'email', 'created_date', 'status']\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.027069, "o", ">     \r\n\u001b[?2004l\r"]
[51.027354, "o", "\u001b[?2004h> "]
[51.027496, "o", "    for field in fields_to_check:\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.027876, "o", "> "]
[51.028047, "o", "        # Get non-null values for this field\r\n\u001b[?2004l\r"]
[51.028329, "o", "\u001b[?2004h> "]
[51.02868, "o", "        values = group[group[field].notna()][['source', field]]\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.028973, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.029129, "o", "> "]
[51.029502, "o", "        if len(values) > 1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.029791, "o", "            # Check if values are different\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.029958, "o", "> "]
[51.030294, "o", "            unique_values = values[field].unique()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.030502, "o", "            if len(unique_values) > 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.030757, "o", "> "]
[51.030949, "o", "                # There's a conflict\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.031214, "o", "> "]
[51.031514, "o", "                conflict_entry = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.031737, "o", "                    'user_id': int(user_id),\r\n\u001b[?2004l\r"]
[51.032084, "o", "\u001b[?2004h> "]
[51.03237, "o", "                    'field': field,\r\n\u001b[?2004l\r"]
[51.032581, "o", "\u001b[?2004h> "]
[51.033248, "o", "                    'values': {},\r\n\u001b[?2004l\r\u001b[?2004h>                     'selected': None\r\n\u001b[?2004l\r"]
[51.033513, "o", "\u001b[?2004h>                 }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.033783, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.034213, "o", "                for _, row in values.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.034763, "o", "                    conflict_entry['values'][row['source']] = row[field]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.03515, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.03611, "o", "                # Selected value is from highest priority source with non-null value\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.036352, "o", "                selected_value = group[group[field].notna()].iloc[0][field]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.037267, "o", "                conflict_entry['selected'] = selected_value\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.037666, "o", "                conflicts.append(conflict_entry)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[51.037945, "o", "\u001b[?2004h> "]
[51.038361, "o", "    # Merge: take values from highest priority source (lowest priority number)\r\n\u001b[?2004l\r"]
[51.038621, "o", "\u001b[?2004h> "]
[51.038955, "o", "    merged_record = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.039265, "o", "        'user_id': int(user_id),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.03946, "o", "        'name': None,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.039909, "o", "        'email': None,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.040301, "o", "        'created_date': None,\r\n\u001b[?2004l\r\u001b[?2004h>         'status': None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.040549, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.041037, "o", "    for field in ['name', 'email', 'created_date', 'status']:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.041526, "o", "        # Get first non-null value (already sorted by priority)\r\n\u001b[?2004l\r"]
[51.041866, "o", "\u001b[?2004h> "]
[51.042183, "o", "        non_null = group[group[field].notna()]\r\n\u001b[?2004l\r"]
[51.042484, "o", "\u001b[?2004h>         if len(non_null) > 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.042819, "o", "> "]
[51.043007, "o", "            merged_record[field] = non_null.iloc[0][field]\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.043263, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.0436, "o", "    merged_records[user_id] = merged_record\r\n\u001b[?2004l\r"]
[51.043769, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.044016, "o", "# Create merged DataFrame\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.044409, "o", "merged_df = pd.DataFrame(list(merged_records.values()))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[51.044706, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[51.045069, "o", "# Ensure correct column order and types\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.045335, "o", "> "]
[51.045692, "o", "merged_df = merged_df[['user_id', 'name', 'email', 'created_date', 'status']]\r\n\u001b[?2004l\r"]
[51.045809, "o", "\u001b[?2004h> "]
[51.046296, "o", "merged_df['user_id'] = merged_df['user_id'].astype('int64')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.046427, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.046738, "o", "# Sort by user_id for consistency\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.04684, "o", "> "]
[51.112087, "o", "merged_df = merged_df.sort_values('user_id').reset_index(drop=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Write to Parquet\r\n\u001b[?2004l\r\u001b[?2004h> merged_df.to_parquet('/app/merged_users.parquet', index=False)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Create conflict report\r\n\u001b[?2004l\r\u001b[?2004h> conflict_report = {\r\n\u001b[?2004l\r\u001b[?2004h>     'total_conflicts': len(conflicts),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.112448, "o", "    'conflicts': conflicts\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[51.112803, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.113017, "o", "# Write conflict report\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.113443, "o", "with open('/app/conflicts.json', 'w') as f:\r\n\u001b[?2004l\r"]
[51.113618, "o", "\u001b[?2004h> "]
[51.113908, "o", "    json.dump(conflict_report, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.114162, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.114407, "o", "print(f\"Merge complete!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.114745, "o", "print(f\"Total users: {len(merged_df)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.115246, "o", "print(f\"Total conflicts: {len(conflicts)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.115585, "o", "print(f\"\\nMerged data preview:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.115783, "o", "> print(merged_df)\r\n\u001b[?2004l\r"]
[51.11623, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[51.122205, "o", "\u001b[?2004hroot@a57fbfbd74e9:/app# "]
