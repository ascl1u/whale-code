Sending keys: ['cat > merge_users.py << \'EOF\'\nimport pandas as pd\nimport json\nfrom datetime import datetime\nimport pyarrow as pa\nimport pyarrow.parquet as pq\n\n# Read source_a (JSON)\nwith open(\'/data/source_a/users.json\', \'r\') as f:\n    source_a_data = json.load(f)\n\n# Convert to DataFrame and normalize\ndf_a = pd.DataFrame(source_a_data)\ndf_a = df_a.rename(columns={\n    \'id\': \'user_id\',\n    \'full_name\': \'name\',\n    \'email\': \'email\',\n    \'registration_date\': \'created_date\'\n})\ndf_a[\'source\'] = \'source_a\'\ndf_a[\'priority\'] = 1\n\n# Read source_b (CSV)\ndf_b = pd.read_csv(\'/data/source_b/users.csv\')\ndf_b = df_b.rename(columns={\n    \'user_id\': \'user_id\',\n    \'name\': \'name\',\n    \'email_address\': \'email\',\n    \'created_at\': \'created_date\'\n})\n# Map is_active to status\nif \'is_active\' in df_b.columns:\n    df_b[\'status\'] = df_b[\'is_active\'].apply(lambda x: \'active\' if x else \'inactive\')\n    df_b = df_b.drop(\'is_active\', axis=1)\ndf_b[\'source\'] = \'source_b\'\ndf_b[\'priority\'] = 2\n\n# Read source_c (Parquet)\ndf_c = pd.read_parquet(\'/data/source_c/users.parquet\')\ndf_c = df_c.rename(columns={\n    \'userId\': \'user_id\',\n    \'userName\': \'name\',\n    \'email\': \'email\',\n    \'joined\': \'created_date\'\n})\n# Map active to status\nif \'active\' in df_c.columns:\n    df_c[\'status\'] = df_c[\'active\'].apply(lambda x: \'active\' if x else \'inactive\')\n    df_c = df_c.drop(\'active\', axis=1)\ndf_c[\'source\'] = \'source_c\'\ndf_c[\'priority\'] = 3\n\n# Ensure all DataFrames have the same columns\nall_columns = [\'user_id\', \'name\', \'email\', \'created_date\', \'status\', \'source\', \'priority\']\nfor df in [df_a, df_b, df_c]:\n    for col in all_columns:\n        if col not in df.columns:\n            df[col] = None\n\n# Combine all sources\ndf_all = pd.concat([df_a[all_columns], df_b[all_columns], df_c[all_columns]], ignore_index=True)\n\n# Convert user_id to integer\ndf_all[\'user_id\'] = df_all[\'user_id\'].astype(int)\n\n# Normalize dates to YYYY-MM-DD format\ndef normalize_date(date_str):\n    if pd.isna(date_str) or date_str is None:\n        return None\n    date_str = str(date_str)\n    # Try to parse and format as YYYY-MM-DD\n    try:\n        # Handle various date formats\n        for fmt in [\'%Y-%m-%d\', \'%Y/%m/%d\', \'%m/%d/%Y\', \'%d/%m/%Y\']:\n            try:\n                dt = datetime.strptime(date_str, fmt)\n                return dt.strftime(\'%Y-%m-%d\')\n            except:\n                continue\n        # If already in correct format, return as is\n        if len(date_str) == 10 and date_str[4] == \'-\' and date_str[7] == \'-\':\n            return date_str\n        return date_str\n    except:\n        return date_str\n\ndf_all[\'created_date\'] = df_all[\'created_date\'].apply(normalize_date)\n\n# Track conflicts\nconflicts = []\nmerged_records = {}\n\n# Group by user_id\nfor user_id, group in df_all.groupby(\'user_id\'):\n    # Sort by priority (lower is higher priority)\n    group = group.sort_values(\'priority\')\n    \n    # Check for conflicts\n    fields_to_check = [\'name\', \'email\', \'created_date\', \'status\']\n    \n    for field in fields_to_check:\n        # Get non-null values for this field\n        values = group[group[field].notna()][[\'source\', field]]\n        \n        if len(values) > 1:\n            # Check if values are different\n            unique_values = values[field].unique()\n            if len(unique_values) > 1:\n                # There\'s a conflict\n                conflict_entry = {\n                    \'user_id\': int(user_id),\n                    \'field\': field,\n                    \'values\': {},\n                    \'selected\': None\n                }\n                \n                for _, row in values.iterrows():\n                    conflict_entry[\'values\'][row[\'source\']] = row[field]\n                \n                # Selected value is from highest priority source with non-null value\n                selected_value = group[group[field].notna()].iloc[0][field]\n                conflict_entry[\'selected\'] = selected_value\n                \n                conflicts.append(conflict_entry)\n    \n    # Merge: take values from highest priority source (lowest priority number)\n    merged_record = {\n        \'user_id\': int(user_id),\n        \'name\': None,\n        \'email\': None,\n        \'created_date\': None,\n        \'status\': None\n    }\n    \n    for field in [\'name\', \'email\', \'created_date\', \'status\']:\n        # Get first non-null value (already sorted by priority)\n        non_null = group[group[field].notna()]\n        if len(non_null) > 0:\n            merged_record[field] = non_null.iloc[0][field]\n    \n    merged_records[user_id] = merged_record\n\n# Create merged DataFrame\nmerged_df = pd.DataFrame(list(merged_records.values()))\n\n# Ensure correct column order and types\nmerged_df = merged_df[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\nmerged_df[\'user_id\'] = merged_df[\'user_id\'].astype(\'int64\')\n\n# Sort by user_id for consistency\nmerged_df = merged_df.sort_values(\'user_id\').reset_index(drop=True)\n\n# Write to Parquet\nmerged_df.to_parquet(\'/app/merged_users.parquet\', index=False)\n\n# Create conflict report\nconflict_report = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\n\n# Write conflict report\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint(f"Merge complete!")\nprint(f"Total users: {len(merged_df)}")\nprint(f"Total conflicts: {len(conflicts)}")\nprint(f"\\nMerged data preview:")\nprint(merged_df)\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
