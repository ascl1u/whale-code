n\n# Initialize conflict tracking\nconflicts = []\nmerged_records = []\n\n# Process each user\nfor user_id in sorted(unique_users):\n    user_records = all_data[all_data[\'user_id\'] == user_id]\n    \n    # Initialize merged record\n    merged = {\'user_id\': int(user_id)}\n    \n    # Track which sources have this user\n    sources_present = user_records[\'source\'].tolist()\n    \n    # For each field, merge with priority\n    for field in [\'name\', \'email\', \'created_date\', \'status\']:\n        values = {}\n        \n        # Collect values from each source\n        for _, row in user_records.iterrows():\n            source = row[\'source\']\n            value = row[field]\n            if pd.notna(value):\n                values[source] = value\n        \n        # Select value based on priority\n        selected_value = None\n        if \'source_a\' in values:\n            selected_value = values[\'source_a\']\n        elif \'source_b\' in values:\n            selected_value = values[\'source_b\']\n        elif \'source_c\' in values:\n            selected_value = values[\'source_c\']\n        \n        merged[field] = selected_value\n        \n        # Check for conflicts (different values across sources)\n        unique_values = set(v for v in values.values() if pd.notna(v))\n        if len(unique_values) > 1:\n            conflicts.append({\n                \'user_id\': int(user_id),\n                \'field\': field,\n                \'values\': values,\n                \'selected\': selected_value\n            })\n    \n    merged_records.append(merged)\n\n# Create merged DataFrame\nmerged_df = pd.DataFrame(merged_records)\n\n# Ensure correct column order and types\nmerged_df = merged_df[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\nmerged_df[\'user_id\'] = merged_df[\'user_id\'].astype(\'int64\')\n\n# Convert date format to YYYY-MM-DD if needed\ndef normalize_date(date_str):\n    if pd.isna(date_str):\n        return None\n    # Already in YYYY-MM-DD format in our sources\n    return str(date_str)\n\nmerged_df[\'created_date\'] = merged_df[\'created_date\'].apply(normalize_date)\n\n# Save merged data as Parquet\nmerged_df.to_parquet(\'/app/merged_users.parquet\', index=False)\n\n# Create conflict report\nconflict_report = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\n\n# Save conflict report as JSON\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint(f"Merged {len(merged_df)} unique users")\nprint(f"Found {len(conflicts)} conflicts")\nprint("\\nMerged data preview:")\nprint(merged_df.to_string())\nprint("\\nConflict report:")\nprint(json.dumps(conflict_report, indent=2))\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
