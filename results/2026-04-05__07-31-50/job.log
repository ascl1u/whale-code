Sending keys: ['cat > merge_users.py << \'EOF\'\nimport pandas as pd\nimport json\nfrom datetime import datetime\n\n# Read source files\nprint("Reading source files...")\n\n# Source A - JSON (highest priority)\nwith open(\'/data/source_a/users.json\', \'r\') as f:\n    source_a_data = json.load(f)\nsource_a = pd.DataFrame(source_a_data)\n\n# Source B - CSV\nsource_b = pd.read_csv(\'/data/source_b/users.csv\')\n\n# Source C - Parquet (lowest priority)\nsource_c = pd.read_parquet(\'/data/source_c/users.parquet\')\n\nprint(f"Source A: {len(source_a)} records")\nprint(f"Source B: {len(source_b)} records")\nprint(f"Source C: {len(source_c)} records")\n\n# Normalize field names for each source\ndef normalize_source_a(df):\n    normalized = pd.DataFrame()\n    normalized[\'user_id\'] = df[\'id\'].astype(int)\n    normalized[\'name\'] = df[\'full_name\']\n    normalized[\'email\'] = df[\'email\']\n    normalized[\'created_date\'] = df[\'registration_date\']\n    normalized[\'status\'] = df.get(\'status\', None)\n    normalized[\'source\'] = \'source_a\'\n    return normalized\n\ndef normalize_source_b(df):\n    normalized = pd.DataFrame()\n    normalized[\'user_id\'] = df[\'user_id\'].astype(int)\n    normalized[\'name\'] = df[\'name\']\n    normalized[\'email\'] = df[\'email_address\']\n    normalized[\'created_date\'] = df[\'created_at\']\n    # Map is_active to status if present\n    if \'is_active\' in df.columns:\n        normalized[\'status\'] = df[\'is_active\'].apply(lambda x: \'active\' if x else \'inactive\')\n    else:\n        normalized[\'status\'] = None\n    normalized[\'source\'] = \'source_b\'\n    return normalized\n\ndef normalize_source_c(df):\n    normalized = pd.DataFrame()\n    normalized[\'user_id\'] = df[\'userId\'].astype(int)\n    normalized[\'name\'] = df[\'userName\']\n    normalized[\'email\'] = df[\'email\']\n    normalized[\'created_date\'] = df[\'joined\']\n    # Map active to status if present\n    if \'active\' in df.columns:\n        normalized[\'status\'] = df[\'active\'].apply(lambda x: \'active\' if x else \'inactive\')\n    else:\n        normalized[\'status\'] = None\n    normalized[\'source\'] = \'source_c\'\n    return normalized\n\n# Normalize all sources\nprint("\\nNormalizing sources...")\nnorm_a = normalize_source_a(source_a)\nnorm_b = normalize_source_b(source_b)\nnorm_c = normalize_source_c(source_c)\n\n# Ensure dates are in YYYY-MM-DD format\ndef normalize_date(date_str):\n    if pd.isna(date_str):\n        return None\n    # Try to parse and format\n    try:\n        # Handle various date formats\n        date_str = str(date_str)\n        if \'T\' in date_str:\n            date_str = date_str.split(\'T\')[0]\n        return date_str[:10]  # YYYY-MM-DD\n    except:\n        return date_str\n\nfor df in [norm_a, norm_b, norm_c]:\n    df[\'created_date\'] = df[\'created_date\'].apply(normalize_date)\n\n# Combine all sources\nall_data = pd.concat([norm_a, norm_b, norm_c], ignore_index=True)\n\n# Get all unique user_ids\nunique_users = all_data[\'user_id\'].unique()\n\nprint(f"\\nTotal unique users: {len(unique_users)}")\n\n# Merge with priority and track conflicts\nmerged_records = []\nconflicts = []\n\nfor user_id in sorted(unique_users):\n    user_records = all_data[all_data[\'user_id\'] == user_id]\n    \n    # Get records from each source\n    records_by_source = {}\n    for _, record in user_records.iterrows():\n        source = record[\'source\']\n        records_by_source[source] = record\n    \n    # Priority order\n    priority = [\'source_a\', \'source_b\', \'source_c\']\n    \n    # Build merged record\n    merged = {\'user_id\': int(user_id)}\n    \n    # For each field, check for conflicts and apply priority\n    fields = [\'name\', \'email\', \'created_date\', \'status\']\n    \n    for field in fields:\n        values_by_source = {}\n        for source in [\'source_a\', \'source_b\', \'source_c\']:\n            if source in records_by_source:\n                val = records_by_source[source][field]\n                if pd.notna(val):\n                    values_by_source[source] = val\n        \n        # Select value by priority\n        selected_value = None\n        for source in priority:\n            if source in values_by_source:\n                selected_value = values_by_source[source]\n                break\n        \n        merged[field] = selected_value\n        \n        # Check for conflicts (different non-null values)\n        unique_values = set(v for v in values_by_source.values() if pd.notna(v))\n        if len(unique_values) > 1:\n            conflict = {\n                \'user_id\': int(user_id),\n                \'field\': field,\n                \'values\': values_by_source,\n                \'selected\': selected_value\n            }\n            conflicts.append(conflict)\n    \n    merged_records.append(merged)\n\nprint(f"Total conflicts detected: {len(conflicts)}")\n\n# Create merged dataframe\nmerged_df = pd.DataFrame(merged_records)\n\n# Ensure correct data types\nmerged_df[\'user_id\'] = merged_df[\'user_id\'].astype(int)\nmerged_df[\'name\'] = merged_df[\'name\'].astype(str)\nmerged_df[\'email\'] = merged_df[\'email\'].astype(str)\nmerged_df[\'created_date\'] = merged_df[\'created_date\'].astype(str)\n# status can be None/null\n\n# Sort by user_id\nmerged_df = merged_df.sort_values(\'user_id\').reset_index(drop=True)\n\nprint("\\nMerged data preview:")\nprint(merged_df.to_string())\n\n# Save merged data to parquet\nprint("\\nSaving merged data to /app/merged_users.parquet...")\nmerged_df.to_parquet(\'/app/merged_users.parquet\', index=False)\n\n# Create conflict report\nconflict_report = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\n\nprint(f"Saving conflict report to /app/conflicts.json...")\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint("\\nMerge complete!")\nprint(f"Total users: {len(merged_df)}")\nprint(f"Total conflicts: {len(conflicts)}")\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
