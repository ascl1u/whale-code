m each source\n    record_a = user_records[user_records[\'source\'] == \'source_a\']\n    record_b = user_records[user_records[\'source\'] == \'source_b\']\n    record_c = user_records[user_records[\'source\'] == \'source_c\']\n    \n    # Start with empty merged record\n    merged = {\'user_id\': user_id}\n    \n    # Fields to merge\n    fields = [\'name\', \'email\', \'created_date\', \'status\']\n    \n    for field in fields:\n        values = {}\n        \n        # Collect values from each source\n        if not record_a.empty and field in record_a.columns and pd.notna(record_a[field].iloc[0]):\n            values[\'source_a\'] = record_a[field].iloc[0]\n        if not record_b.empty and field in record_b.columns and pd.notna(record_b[field].iloc[0]):\n            values[\'source_b\'] = record_b[field].iloc[0]\n        if not record_c.empty and field in record_c.columns and pd.notna(record_c[field].iloc[0]):\n            values[\'source_c\'] = record_c[field].iloc[0]\n        \n        # Select value by priority\n        selected = None\n        if \'source_a\' in values:\n            selected = values[\'source_a\']\n        elif \'source_b\' in values:\n            selected = values[\'source_b\']\n        elif \'source_c\' in values:\n            selected = values[\'source_c\']\n        \n        merged[field] = selected\n        \n        # Check for conflicts (multiple sources with different values)\n        unique_values = set(str(v) for v in values.values())\n        if len(values) > 1 and len(unique_values) > 1:\n            conflict = {\n                \'user_id\': int(user_id),\n                \'field\': field,\n                \'values\': values,\n                \'selected\': selected\n            }\n            conflicts.append(conflict)\n    \n    merged_records.append(merged)\n\n# Create merged DataFrame\nmerged_df = pd.DataFrame(merged_records)\n\n# Ensure proper column order\ncolumn_order = [\'user_id\', \'name\', \'email\', \'created_date\', \'status\']\nfor col in column_order:\n    if col not in merged_df.columns:\n        merged_df[col] = None\n\nmerged_df = merged_df[column_order]\n\n# Ensure user_id is integer\nmerged_df[\'user_id\'] = merged_df[\'user_id\'].astype(int)\n\n# Sort by user_id\nmerged_df = merged_df.sort_values(\'user_id\').reset_index(drop=True)\n\nprint("\\n\\nMerged DataFrame:")\nprint(merged_df)\nprint("\\nData types:")\nprint(merged_df.dtypes)\n\n# Save to Parquet\nmerged_df.to_parquet(\'/app/merged_users.parquet\', index=False)\nprint("\\nSaved merged_users.parquet")\n\n# Create conflict report\nconflict_report = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\n\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint(f"\\nSaved conflicts.json with {len(conflicts)} conflicts")\nprint("\\nConflict report:")\nprint(json.dumps(conflict_report, indent=2))\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
