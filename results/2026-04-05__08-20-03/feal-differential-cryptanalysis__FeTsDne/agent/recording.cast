[479.652873, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef decrypt_two_rounds(ciphertext, key4, key5):\n    c_left = getleft(ciphertext)\n    c_right = getright(ciphertext)\n    R4 = c_left\n    L4 = c_right ^ R4\n    R3 = L4\n    L3 = R4 ^ f_function(R3 ^ key5)\n    R2 = L3\n    L2 = R3 ^ f_function(R2 ^ key4)\n    return L2, R2\n\ndef attack(encrypt_fn):\n    # Use plaintext 0 for simplicity\n    p0 = 0\n    c0 = encrypt_fn(p0)\n  "]
[479.652952, "i", "  \n    p1 = 1\n    c1 = encrypt_fn(p1)\n    \n    # For p0=0: after whitening L=key[0], R=key[1]\n    # After pre-round: L=key[0], R=key[0]^key[1]\n    # Let K01 = key[0]^key[1]\n    # After round 1: L=K01, R=key[0]^f(K01^key[2])\n    # Let F2 = f(K01^key[2]), so R1=key[0]^F2\n    # After round 2: L=key[0]^F2, R=K01^f((key[0]^F2)^key[3])\n    # So: L2_0 = key[0]^F2, R2_0 = K01^f((key[0]^F2)^key[3])\n    \n    # For p1=1: after whitening L=key[0], R=key[1]^1\n    # After pre-round: L=key[0], R=key[0]^key[1]^1 = K01^1\n    # After round 1: L=K01^1, R=key[0]^f((K01^1)^key[2])\n    # Let F2' = f((K01^1)^key[2]), so R1=key[0]^F2'\n    # After round 2: L=key[0]^F2', R=(K01^1)^f((key[0]^F2')^key[3])\n    # So: L2_1 = key[0]^F2', R2_1 = (K01^1)^f((key[0]^F2')^key[3])\n    \n    # Key observation: L2_0 ^ L2_1 = F2 ^ F2' = f(K01^key[2]) ^ f((K01^1)^key[2])\n    # This depends only on K01 and key[2], not on key[0] individually!\n    \n    # Similarly: R2_0 ^ R2_1 = [K01^f((key[0]^F2)^key[3])] ^ [(K01^1)^f((key[0]^F2')^key[3])]\n    #        "]
[479.65325, "i", "                = 1 ^ f((key[0]^F2)^key[3]) ^ f((key[0]^F2')^key[3])\n    \n    # Brute force key[4] and key[5]\n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        for seed4 in range(0x10000):\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            L2_0, R2_0 = decrypt_two_rounds(c0, key4, key5)\n            L2_1, R2_1 = decrypt_two_rounds(c1, key4, key5)\n            \n            # Check the differential property\n            diff_L = L2_0 ^ L2_1\n            diff_R = R2_0 ^ R2_1\n            \n            # diff_L = f(K01^key[2]) ^ f((K01^1)^key[2])\n            # For some value of K01 and key[2], this should be achievable\n            # We need to check if there exists K01 and key[2] such that this holds\n            \n            # Try all possible K01 values (32-bit, too many)\n            # But we can sample or use a different check\n            \n            # Actually, let's use a different observation:\n            # For p0 and p1, the input difference t"]
[479.653417, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r                ="]
[479.653569, "i", "o f in round 1 is 1\n            # The output difference is diff_L\n            # We can check if this is a valid differential for f\n            \n            # Try all possible inputs to f\n            found_valid = False\n            for test_input in range(0x10000):  # Sample 16-bit inputs\n                out1 = f_function(test_input)\n                out2 = f_function(test_input ^ 1)\n                if (out1 ^ out2) == diff_L:\n                    # Found a valid input! This means diff_L is achievable\n                    found_valid = True\n                    break\n            \n            if found_valid:\n                # Additional check with diff_R\n                # This is more complex, so let's skip for now and just return\n                return key5\n    \n    return 0\n\nEOF\n"]
[479.653768, "o", " 1 ^ f((key[0]^F2)^key[3]) ^ f((key[0]^F2')^key[3])\r\n    \r\n    # Brute force key[4] and key[5]\r\n    for seed5 in range(0x10000):\r\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n        \r\n        for seed4 in range(0x10000):\r\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n            \r\n            L2_0, R2_0 = decrypt_two_rounds(c0, key4, key5)\r\n            L2_1, R2_1 = decrypt_two_rounds(c1, key4, key5)\r\n            \r\n            # Check the differential property\r\n            diff_L = L2_0 ^ L2_1\r\n            diff_R = R2_0 ^ R2_1\r\n            \r\n            # diff_L = f(K01^key[2]) ^ f((K01^1)^key[2])\r\n            # For some value of K01 and key[2], this should be achieva"]
[479.654084, "o", "ble\r\n            # We need to check if there exists K01 and key[2] such that this holds\r\n            \r\n            # Try all possible K01 values (32-bit, too many)\r\n            # But we can sample or use a different check\r\n            \r\n            # Actually, let's use a different observation:\r\n            # For p0 and p1, the input difference to f in round 1 is 1\r\n            # The output difference is diff_L\r\n            # We can check if this is a valid differential for f\r\n            \r\n            # Try all possible inputs to f\r\n            found_valid = False\r\n            for test_inpu"]
[479.654243, "o", "t in range(0x10000):  # Sample 16-bit inputs\r\n                out1 = f_function(test_input)\r\n                out2 = f_function(test_input ^ 1)\r\n                if (out1 ^ out2) == diff_L:\r\n                    # Found a valid input! This means diff_L is achievable\r\n                    found_valid = True\r\n                    break\r\n            \r\n            if found_valid:\r\n                # Additional check with"]
[479.654618, "o", " diff_R\r\n                # This is more complex, so let's skip for now and just return\r\n                return key5\r\n    \r\n    return 0\r\n\r\nEOF\r\n"]
