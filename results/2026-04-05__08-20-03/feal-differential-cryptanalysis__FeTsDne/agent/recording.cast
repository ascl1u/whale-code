[1038.659378, "o", "> "]
[1038.690647, "o", "            # Check pairs 0 and 1\r\n\u001b[?2004l\r\u001b[?2004h>             L2_0 = states[0][1] ^ f_function(states[0][0] ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h>             L2_1 = states[1][1] ^ f_function(states[1][0] ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if (L2_0 ^ L2_1) in valid_diffs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1038.690955, "o", "                matches += 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[1038.69103, "o", "> "]
