[1023.221591, "o", "  File \u001b[35m\"/app/test_attack.py\"\u001b[0m, line \u001b[35m15\u001b[0m, in \u001b[35m<module>\u001b[0m\r\n    recovered_key5 = attack(encrypt)\r\n  File \u001b[35m\"/app/attack.py\"\u001b[0m, line \u001b[35m61\u001b[0m, in \u001b[35mattack\u001b[0m\r\n    f_diff = f_function(L3_0 ^ test_key4) ^ \u001b[31mf_function\u001b[0m\u001b[1;31m(L3_1 ^ test_key4)\u001b[0m\r\n                                            \u001b[31m~~~~~~~~~~\u001b[0m\u001b[1;31m^^^^^^^^^^^^^^^^^^\u001b[0m\r\n  File \u001b[35m\"/app/attack.py\"\u001b[0m, line \u001b[35m18\u001b[0m, in \u001b[35mf_function\u001b[0m\r\n"]
