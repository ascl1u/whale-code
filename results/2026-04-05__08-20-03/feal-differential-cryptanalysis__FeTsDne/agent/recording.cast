[108.776244, "o", "    right ^= key1\r\n\u001b[?2004l\r"]
[108.776299, "o", "\u001b[?2004h"]
[108.776416, "o", "> "]
[108.776571, "o", "    # Pre-round\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.776759, "o", ">     right ^= left\r\n\u001b[?2004l\r"]
[108.776926, "o", "\u001b[?2004h> "]
[108.77705, "o", "    # Round 1\r\n\u001b[?2004l\r"]
[108.7772, "o", "\u001b[?2004h> "]
[108.7774, "o", "    temp = f_function(right ^ key2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.777665, "o", "    left, right = right, left ^ temp\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.777801, "o", "> "]
[108.777964, "o", "    # Round 2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.778173, "o", "    temp = f_function(right ^ key3)\r\n\u001b[?2004l\r"]
[108.778337, "o", "\u001b[?2004h> "]
[108.77855, "o", "    left, right = right, left ^ temp\r\n\u001b[?2004l\r"]
[108.778701, "o", "\u001b[?2004h> "]
[108.778855, "o", "    # Round 3\r\n\u001b[?2004l\r"]
[108.779101, "o", "\u001b[?2004h> "]
[108.779258, "o", "    temp = f_function(right ^ key4)\r\n\u001b[?2004l\r"]
[108.779374, "o", "\u001b[?2004h> "]
[108.779654, "o", "    left, right = right, left ^ temp\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.779722, "o", "> "]
[108.779932, "o", "    return left, right\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.779979, "o", "> \r\n\u001b[?2004l\r"]
[108.780016, "o", "\u001b[?2004h"]
[108.780217, "o", "> "]
[108.780428, "o", "def partial_decrypt(ciphertext, key5):\r\n\u001b[?2004l\r"]
[108.780539, "o", "\u001b[?2004h"]
[108.780636, "o", "> "]
[108.780821, "o", "    \"\"\"Decrypt only the last round\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.780987, "o", "> "]
[108.78119, "o", "    c_left = getleft(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.781483, "o", "    c_right = getright(ciphertext)\r\n\u001b[?2004l\r"]
[108.781573, "o", "\u001b[?2004h> "]
[108.781754, "o", "    # Undo swap\r\n\u001b[?2004l\r"]
[108.781879, "o", "\u001b[?2004h> "]
[108.782043, "o", "    R4 = c_left\r\n\u001b[?2004l\r"]
[108.78212, "o", "\u001b[?2004h> "]
[108.782331, "o", "    L4_xored = c_right\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.782455, "o", "> "]
[108.782593, "o", "    # Undo post-round XOR\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.78274, "o", "> "]
[108.782915, "o", "    L4 = L4_xored ^ R4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.783374, "o", "    # Undo round 4: R4 = L3 XOR f(R3 XOR key5), L4 = R3\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.783493, "o", "> "]
[108.783609, "o", "    R3 = L4\r\n\u001b[?2004l\r"]
[108.783784, "o", "\u001b[?2004h> "]
[108.783913, "o", "    L3 = R4 ^ f_function(R3 ^ key5)"]
[108.784032, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.784139, "o", "    return L3, R3\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.784229, "o", "> \r\n\u001b[?2004l\r"]
[108.784365, "o", "\u001b[?2004h"]
[108.784455, "o", "> "]
[108.784551, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.784674, "o", "> "]
[108.784991, "o", "    \"\"\"Recover key[5] using meet-in-the-middle attack\"\"\"\r\n\u001b[?2004l\r"]
[108.785106, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[108.785199, "o", "\u001b[?2004h> "]
[108.785429, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.785557, "o", "> "]
[108.785676, "o", "    plaintext = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.78594, "o", "    ciphertext = encrypt_fn(plaintext)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.786104, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.786216, "o", "    plaintext2 = 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.786453, "o", "    ciphertext2 = encrypt_fn(plaintext2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.78661, "o", ">     \r\n\u001b[?2004l\r"]
[108.786745, "o", "\u001b[?2004h> "]
[108.787086, "o", "    # Build a table of possible states after round 3 by encrypting forward\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.787214, "o", "> "]
[108.787468, "o", "    # with all possible key combinations for first 5 keys\r\n\u001b[?2004l\r"]
[108.787565, "o", "\u001b[?2004h> "]
[108.787694, "o", "    forward_table = {}\r\n\u001b[?2004l\r"]
[108.787798, "o", "\u001b[?2004h"]
[108.787886, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.788119, "o", "    # This is too many: 2^80 combinations\r\n\u001b[?2004l\r"]
[108.788222, "o", "\u001b[?2004h> "]
[108.788512, "o", "    # Let's try a different approach: sample the space\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.788651, "o", ">     \r\n\u001b[?2004l\r"]
[108.788772, "o", "\u001b[?2004h> "]
[108.788977, "o", "    # Sample approach: try random key combinations\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.789086, "o", "> "]
[108.789171, "o", "    import random\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.789292, "o", "> "]
[108.789402, "o", "    random.seed(42)\r\n\u001b[?2004l\r"]
[108.789523, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[108.789667, "o", "\u001b[?2004h> "]
[108.789847, "o", "    for _ in range(100000):  # Sample 100k combinations\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.790022, "o", "> "]
[108.790231, "o", "        seed0 = random.randint(0, 0xFFFF)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.790321, "o", "> "]
[108.790482, "o", "        seed1 = random.randint(0, 0xFFFF)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.790632, "o", "> "]
[108.790797, "o", "        seed2 = random.randint(0, 0xFFFF)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.791, "o", "> "]
[108.791212, "o", "        seed3 = random.randint(0, 0xFFFF)\r\n\u001b[?2004l\r"]
[108.791354, "o", "\u001b[?2004h> "]
[108.7916, "o", "        seed4 = random.randint(0, 0xFFFF)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.791727, "o", "> "]
[108.791854, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.792126, "o", "        key0 = (seed0 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[108.792221, "o", "\u001b[?2004h> "]
[108.79249, "o", "        key1 = (seed1 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.792518, "o", "> "]
[108.79283, "o", "        key2 = (seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[108.792859, "o", "\u001b[?2004h"]
[108.792904, "o", "> "]
[108.793211, "o", "        key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.840533, "o", "        key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         p_left = getleft(plaintext)\r\n\u001b[?2004l\r\u001b[?2004h>         p_right = getright(plaintext)\r\n\u001b[?2004l\r\u001b[?2004h>         L3, R3 = partial_encrypt(p_left, p_right, key0, key1, key2, key3, key4)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.841068, "o", "        # Store in table\r\n\u001b[?2004l\r"]
[108.8412, "o", "\u001b[?2004h>         state = (L3, R3)\r\n\u001b[?2004l\r"]
[108.841291, "o", "\u001b[?2004h> "]
[108.841647, "o", "        if state not in forward_table:\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.84169, "o", "> "]
[108.84199, "o", "            forward_table[state] = []\r\n\u001b[?2004l\r"]
[108.842125, "o", "\u001b[?2004h> "]
[108.842494, "o", "        forward_table[state].append((seed0, seed1, seed2, seed3, seed4))\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.842538, "o", "> "]
[108.842661, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.843132, "o", "    # Now try all key[5] values and see if we get a match\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.843226, "o", "> "]
[108.843411, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.84353, "o", "> "]
[108.843845, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.843992, "o", "> "]
[108.8441, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.844367, "o", "        L3, R3 = partial_decrypt(ciphertext, key5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.844411, "o", "        "]
[108.844533, "o", "\r\n\u001b[?2004l\r"]
[108.844671, "o", "\u001b[?2004h> "]
[108.844785, "o", "        if (L3, R3) in forward_table:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.845127, "o", "            # Found a match! Verify with second plaintext\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.845353, "o", "> "]
[108.845649, "o", "            candidates = forward_table[(L3, R3)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.845826, "o", "            \r\n\u001b[?2004l\r"]
[108.845977, "o", "\u001b[?2004h> "]
[108.846309, "o", "            for seed0, seed1, seed2, seed3, seed4 in candidates:\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.846397, "o", "> "]
[108.846754, "o", "                key0 = (seed0 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.846856, "o", "> "]
[108.847259, "o", "                key1 = (seed1 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.847399, "o", "> "]
[108.847706, "o", "                key2 = (seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.847846, "o", "> "]
[108.848121, "o", "                key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.848229, "o", "> "]
[108.84849, "o", "                key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.848601, "o", "> "]
[108.848707, "o", "                \r\n\u001b[?2004l\r"]
[108.848832, "o", "\u001b[?2004h> "]
[108.849127, "o", "                # Verify with second plaintext\r\n\u001b[?2004l\r"]
[108.84931, "o", "\u001b[?2004h> "]
[108.84958, "o", "                p2_left = getleft(plaintext2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.849625, "o", "> "]
[108.849952, "o", "                p2_right = getright(plaintext2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.850054, "o", "> "]
[108.850597, "o", "                L3_2, R3_2 = partial_encrypt(p2_left, p2_right, key0, key1, key2, key3, key4)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.850776, "o", "                \r\n\u001b[?2004l\r"]
[108.850823, "o", "\u001b[?2004h> "]
[108.851309, "o", "                L3_2_dec, R3_2_dec = partial_decrypt(ciphertext2, key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.851438, "o", "> "]
[108.851571, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.851891, "o", "                if L3_2 == L3_2_dec and R3_2 == R3_2_dec:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.852181, "o", "                    # Found the correct key!\r\n\u001b[?2004l\r\u001b[?2004h"]
[108.852268, "o", "> "]
[108.85242, "o", "                    return key5\r\n\u001b[?2004l\r"]
[108.852536, "o", "\u001b[?2004h>     "]
[108.85262, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[108.85272, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[108.85285, "o", "\u001b[?2004h> "]
[108.852978, "o", "EOF\r\n\u001b[?2004l\r"]
[108.85539, "o", "\u001b[?2004hroot@506b644d66f7:/app# "]
[118.117655, "i", "cat > test_attack.py << 'EOF'\n#!/usr/bin/env python3\nimport sys\nsys.path.insert(0, '/app')\n\nfrom feal import encrypt, create_random_keys, key\nfrom attack import attack\n\n# Initialize keys\ncreate_random_keys()\n\nprint(f\"Actual key[5]: {key[5]}\")\nprint(f\"All keys: {key}\")\n\n# Run the attack\nrecovered_key5 = attack(encrypt)\n\nprint(f\"Recovered key[5]: {recovered_key5}\")\n\nif recovered_key5 == key[5]:\n    print(\"SUCCESS! Key recovered correctly.\")\nelse:\n    print(\"FAILED! Key not recovered.\")\n\nEOF\n"]
[118.118064, "o", "cat > test_attack.py << 'EOF'\r\n\u001b[?2004l\r"]
[118.118232, "o", "\u001b[?2004h> "]
[118.118529, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> import sys\r\n\u001b[?2004l\r"]
[118.118732, "o", "\u001b[?2004h> "]
[118.118921, "o", "sys.path.insert(0, '/app')\r\n\u001b[?2004l\r"]
[118.118976, "o", "\u001b[?2004h> \r\n"]
[118.119183, "o", "\u001b[?2004l\r"]
[118.119398, "o", "\u001b[?2004h> "]
[118.119606, "o", "from feal import encrypt, create_random_keys, key\r\n\u001b[?2004l\r"]
[118.119804, "o", "\u001b[?2004h> "]
[118.119963, "o", "from attack import attack\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.120202, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[118.120296, "o", "# Initialize keys\r\n\u001b[?2004l\r"]
[118.120634, "o", "\u001b[?2004h> "]
[118.120821, "o", "create_random_keys()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.120995, "o", "\u001b[?2004h> "]
[118.12131, "o", "print(f\"Actual key[5]: {key[5]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[118.121665, "o", "print(f\"All keys: {key}\")\r\n\u001b[?2004l\r"]
[118.121772, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.121804, "o", "\u001b[?2004h"]
[118.121863, "o", "> "]
[118.122278, "o", "# Run the attack\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.122487, "o", "> "]
[118.122631, "o", "recovered_key5 = attack(encrypt)\r\n\u001b[?2004l\r"]
[118.122842, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.123024, "o", "\u001b[?2004h> "]
[118.123273, "o", "print(f\"Recovered key[5]: {recovered_key5}\")\r\n\u001b[?2004l\r"]
[118.123339, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[118.123501, "o", "\u001b[?2004h> "]
[118.123853, "o", "if recovered_key5 == key[5]:\r\n\u001b[?2004l\r"]
[118.124115, "o", "\u001b[?2004h> "]
[118.124367, "o", "    print(\"SUCCESS! Key recovered correctly.\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.124446, "o", "> else:\r\n"]
[118.124491, "o", "\u001b[?2004l\r"]
[118.12466, "o", "\u001b[?2004h> "]
[118.124974, "o", "    print(\"FAILED! Key not recovered.\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[118.125123, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[118.125191, "o", "> EOF\r\n\u001b[?2004l\r"]
[118.128847, "o", "\u001b[?2004hroot@506b644d66f7:/app# "]
[121.948493, "i", "python3 test_attack.py; printf '%s\\n' '__CMDEND__4__'\n"]
