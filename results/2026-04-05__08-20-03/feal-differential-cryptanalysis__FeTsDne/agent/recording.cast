[555.391264, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef decrypt_two_rounds(ciphertext, key4, key5):\n    c_left = getleft(ciphertext)\n    c_right = getright(ciphertext)\n    R4 = c_left\n    L4 = c_right ^ R4\n    R3 = L4\n    L3 = R4 ^ f_function(R3 ^ key5)\n    R2 = L3\n    L2 = R3 ^ f_function(R2 ^ key4)\n    return L2, R2\n\ndef attack(encrypt_fn):\n    # Collect plaintext-ciphertext pairs\n    p0 = 0\n    c0 = encrypt_fn(p0"]
[555.391452, "i", ")\n    p1 = 1  \n    c1 = encrypt_fn(p1)\n    p2 = 0x100000000\n    c2 = encrypt_fn(p2)\n    \n    # Brute force - try key[5] first (outer loop)\n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # For this key5, try all key4 values\n        for seed4 in range(0x10000):\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # Decrypt two rounds for all three plaintexts\n            L2_0, R2_0 = decrypt_two_rounds(c0, key4, key5)\n            L2_1, R2_1 = decrypt_two_rounds(c1, key4, key5)\n            L2_2, R2_2 = decrypt_two_rounds(c2, key4, key5)\n            \n            # For p0=0 and p1=1 (differ by 1 in LSB of right half):\n            # After whitening: (key[0], key[1]) and (key[0], key[1]^1)\n            # After pre-round: (key[0], key[0]^key[1]) and (key[0], key[0]^key[1]^1)\n            # After round 1: the left values differ by input diff 1 to f\n            # After round 2: L2 values are the R1 values, so they should differ\n            # in a way t"]
[555.391651, "i", "hat's consistent with f having input diff 1\n            \n            # For p0=0 and p2=0x100000000 (differ by 1 in LSB of left half):\n            # After whitening: (key[0], key[1]) and (key[0]^1, key[1])\n            # After pre-round: (key[0], key[0]^key[1]) and (key[0]^1, key[0]^key[1]^1)\n            # The differences propagate differently\n            \n            # Key insight: For p0 and p1, check if L2 difference is valid\n            # L2_0 is R1 for p0, L2_1 is R1 for p1\n            # R1 = L0 ^ f(R0 ^ key[2])\n            # For p0: R1 = key[0] ^ f((key[0]^key[1]) ^ key[2])\n            # For p1: R1 = key[0] ^ f((key[0]^key[1]^1) ^ key[2])\n            # So: L2_0 ^ L2_1 = f((key[0]^key[1]) ^ key[2]) ^ f((key[0]^key[1]^1) ^ key[2])\n            # This is f(x) ^ f(x^1) for some x\n            \n            diff_L = L2_0 ^ L2_1\n            \n            # Check if this diff can be produced by f with input diff 1\n            # Instead of checking all inputs, use a probabilistic check:\n            # For random wrong"]
[555.391853, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r"]
[555.392005, "i", " keys, diff_L is random\n            # For correct keys, diff_L has structure\n            \n            # Actually, let me just check if ANY of the 256 possible byte-wise\n            # inputs produce this difference (much faster than 65536)\n            found = False\n            for i in range(256):\n                if (f_function(i) ^ f_function(i ^ 1)) == diff_L:\n                    found = True\n                    break\n            \n            if found:\n                # Do additional validation with p2\n                diff_L2 = L2_0 ^ L2_2\n                # Check if this is also valid\n                found2 = False\n                for i in range(256):\n                    # For p0 and p2, the input difference to f in round 1 is different\n                    # After pre-round for p0: R=key[0]^key[1]\n                    # After pre-round for p2: R=key[0]^key[1]^1 (because L diff is 1)\n                    # So input diff to f is still 1\n                    if (f_function(i) ^ f_function(i ^ 1)) == diff_L2:\n     "]
[555.392137, "o", "\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[555.392176, "i", "                   found2 = True\n                        break\n                \n                if found2:\n                    return key5\n    \n    return 0\n\nEOF\n"]
