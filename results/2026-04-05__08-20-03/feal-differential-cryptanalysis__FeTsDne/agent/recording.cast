[956.565731, "o", "\u001b[?2004h> "]
[956.56626, "o", "        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\r\n\u001b[?2004l\r\u001b[?2004h"]
[956.566426, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[956.566615, "o", "> "]
