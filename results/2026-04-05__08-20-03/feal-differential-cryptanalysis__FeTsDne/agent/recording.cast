[399.153989, "o", "> "]
[399.154321, "o", "            bits = bin(combined).count('1')\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.154457, "o", "> "]
[399.154757, "o", "            \r\n\u001b[?2004l\r"]
[399.154938, "o", "\u001b[?2004h> "]
[399.155514, "o", "            # This is still a weak heuristic. Let me try a different approach:\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.155659, "o", "> "]
[399.15627, "o", "            # Check if diff_01_L has very low hamming weight (indicating structure)\r\n\u001b[?2004l\r"]
[399.156319, "o", "\u001b[?2004h> "]
