[1102.091964, "o", "#!/usr/bin/env python3\r\n\r\ndef getleft(x):\r\n    return (x >> 32) & 0xFFFFFFFF\r\n\r\ndef getright(x):\r\n    return x & 0xFFFFFFFF\r\n\r\ndef g_function(a, b, x):\r\n    temp = (a + b + x) & 0xFF\r\n    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\r\n"]
[1102.092314, "o", "def f_function(input_val):\r\n    x = [0] * 4\r\n    y = [0] * 4\r\n    for i in range(4):\r\n        x[i] = input_val & 0xFF\r\n        input_val >>= 8\r\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n"]
[1102.092518, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n    y[0] = g_function(x[0], y[1], 1)\r\n    output = 0\r\n    for i in range(4):\r\n        output |= y[i] << (8 * i)\r\n    return output & 0xFFFFFFFF\r\n\r\ndef attack(encrypt_fn):\r\n    # Collect plaintext-ciphertext pairs\r\n    pairs = [(i, encrypt_fn(i)) for i in range(6)]\r\n"]
[1102.092706, "o", "__CMDEND__18__\r\n"]
[1102.09291, "o", "\u001b[?2004hroot@506b644d66f7:/app# "]
[1116.188106, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Collect plaintext-ciphertext pairs\n    pairs = [(i, encrypt_fn(i)) for i in range(4)]\n    \n    # Precompute valid output differences for f with input diff 1\n    valid_diffs = set()\n    for i in range(256):\n        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\n    \n    # Try all key[5] seeds\n    for seed5 in range(0x10000):\n       "]
[1116.188372, "i", " key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # Decrypt last round for first 2 pairs only\n        states = []\n        for i in range(2):\n            c = pairs[i][1]\n            c_left = getleft(c)\n            c_right = getright(c)\n            R4 = c_left\n            L4 = c_right ^ R4\n            R3 = L4\n            L3 = R4 ^ f_function(R3 ^ key5)\n            states.append((L3, R3))\n        \n        # Very sparse validation: try only 128 key[4] samples\n        matches = 0\n        for seed4 in range(0, 0x10000, 512):  # Only 128 samples\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # Check pairs 0 and 1\n            L2_0 = states[0][1] ^ f_function(states[0][0] ^ key4)\n            L2_1 = states[1][1] ^ f_function(states[1][0] ^ key4)\n            \n            if (L2_0 ^ L2_1) in valid_diffs:\n                matches += 1\n                if matches >= 2:  # Very low threshold for speed\n                    return key5\n    \n    return 0\n\nEOF\n"]
[1116.188504, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r"]
