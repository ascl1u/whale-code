[479.657725, "o", "def g_function(a, b, x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.658051, "o", "    temp = (a + b + x) & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.658456, "o", "    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\u001b[?2004l\r"]
[479.658672, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[479.658815, "o", "> def f_function(input_val):\r\n\u001b[?2004l\r"]
[479.65901, "o", "\u001b[?2004h> "]
[479.659171, "o", "    x = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.659281, "o", "    y = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.659511, "o", "    for i in range(4):\r\n\u001b[?2004l\r"]
[479.659651, "o", "\u001b[?2004h> "]
[479.659889, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.660169, "o", "        input_val >>= 8\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.660576, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
