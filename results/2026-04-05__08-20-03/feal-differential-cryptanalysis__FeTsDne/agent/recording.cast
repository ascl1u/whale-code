[956.602204, "o", "> "]
[956.602687, "o", "                    for test_seed2 in range(0, 0x10000, 64):\r\n\u001b[?2004l\r\u001b[?2004h"]
[956.602851, "o", "> "]
[956.603258, "o", "                        test_key4_2 = (test_seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[956.603397, "o", "> "]
