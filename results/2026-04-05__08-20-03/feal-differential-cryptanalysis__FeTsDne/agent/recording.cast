[1038.65711, "o", "\u001b[?2004h> "]
[1038.65725, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1038.657709, "o", "        # Quick validation: try a sparse sample of key[4] values\r\n\u001b[?2004l\r"]
[1038.657848, "o", "\u001b[?2004h> "]
