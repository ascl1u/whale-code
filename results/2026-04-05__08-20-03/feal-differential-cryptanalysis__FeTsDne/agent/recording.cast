[163.219023, "i", "7) & 0xFFFFFFFF\n                    \n                    # Verify with all other pairs\n                    all_match = True\n                    for p, c in pairs[1:]:\n                        L2_enc, R2_enc = encrypt_three_rounds(p, key0, key1, key2, key3)\n                        L2_dec, R2_dec = decrypt_two_rounds(c, key4, key5)\n                        \n                        if L2_enc != L2_dec or R2_enc != R2_dec:\n                            all_match = False\n                            break\n                    \n                    if all_match:\n                        print(f\"Found key[5]! seed5={seed5}, key5={key5}\")\n                        return key5\n    \n    return 0\n\nEOF\n"]
