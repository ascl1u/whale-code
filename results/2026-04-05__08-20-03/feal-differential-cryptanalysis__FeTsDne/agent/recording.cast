[201.090877, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\n    \n    # Collect many plaintext-ciphertext pairs\n    pairs = []\n    for i in range(256):\n        p = i << 32 | i  # Use pattern to create structure\n        c = encrypt_fn(p)\n        pairs.append((p, c))\n    \n    # For each candidate key[5], try to find a consistent key[4]\n    # by c"]
[201.091124, "i", "hecking if there exists a key[4] that works for multiple pairs\n    \n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # For this key5, try to find key4 that's consistent\n        # Use first two pairs to generate candidates for key4\n        \n        p0, c0 = pairs[0]\n        p1, c1 = pairs[1]\n        \n        # Decrypt last round with key5\n        c0_left = getleft(c0)\n        c0_right = getright(c0)\n        R4_0 = c0_left\n        L4_0 = c0_right ^ R4_0\n        R3_0 = L4_0\n        L3_0 = R4_0 ^ f_function(R3_0 ^ key5)\n        \n        c1_left = getleft(c1)\n        c1_right = getright(c1)\n        R4_1 = c1_left\n        L4_1 = c1_right ^ R4_1\n        R3_1 = L4_1\n        L3_1 = R4_1 ^ f_function(R3_1 ^ key5)\n        \n        # Now try all key4 values\n        for seed4 in range(0x10000):\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # Decrypt round 3 for both\n            R2_0 = L3_0\n            L2_0 = R3_0 ^ f_function(R2_0 ^ key4)\n        "]
[201.0913, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
