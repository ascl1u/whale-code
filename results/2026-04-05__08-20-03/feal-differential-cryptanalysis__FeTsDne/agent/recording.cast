[201.136276, "o", "        # Decrypt last round with key5\r\n\u001b[?2004l\r "]
[201.136459, "o", "\u001b[?2004h> "]
[201.136663, "o", "        c0_left = getleft(c0)\r\n\u001b[?2004l\r \u001b[?2004h"]
[201.136852, "o", "> "]
[201.137183, "o", "        c0_right = getright(c0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.137331, "o", "> "]
[201.137534, "o", "        R4_0 = c0_left\r\n\u001b[?2004l\r"]
[201.137659, "o", "\u001b[?2004h> "]
[201.138126, "o", "        L4_0 = c0_right ^ R4_0\r\n\u001b[?2004l\ri"]
[201.138288, "o", "\u001b[?2004h> "]
[201.138409, "o", "        R3_0 = L4_0\r\n\u001b[?2004l\r"]
[201.138571, "o", "\u001b[?2004h> "]
[201.13901, "o", "        L3_0 = R4_0 ^ f_function(R3_0 ^ key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.139152, "o", "> "]
[201.139311, "o", "        \r\n\u001b[?2004l\r"]
[201.139467, "o", "\u001b[?2004h> "]
[201.139718, "o", "        c1_left = getleft(c1)\r\n\u001b[?2004l\r"]
[201.139858, "o", "\u001b[?2004h> "]
[201.140095, "o", "        c1_right = getright(c1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.1403, "o", "        R4_1 = c1_left\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.140448, "o", "> "]
[201.140616, "o", "        L4_1 = c1_right ^ R4_1\r\n\u001b[?2004l\r"]
[201.140809, "o", "\u001b[?2004h> "]
[201.141016, "o", "        R3_1 = L4_1\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.141155, "o", "> "]
[201.141611, "o", "        L3_1 = R4_1 ^ f_function(R3_1 ^ key5)\r\n\u001b[?2004l\ro\u001b[?2004h"]
[201.141788, "o", ">         "]
[201.141971, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.142232, "o", "        # Now try all key4 values\r\n\u001b[?2004l\r"]
[201.142416, "o", "\u001b[?2004h> "]
[201.143005, "o", "        for seed4 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.143182, "o", "> "]
[201.143771, "o", "            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[201.143888, "o", "\u001b[?2004h> "]
[201.144101, "o", "            \r\n\u001b[?2004l\r"]
[201.144244, "o", "\u001b[?2004h> "]
[201.144703, "o", "            # Decrypt round 3 for both\r\n\u001b[?2004l\r"]
[201.144887, "o", "\u001b[?2004h> "]
[201.145202, "o", "            R2_0 = L3_0\r\n\u001b[?2004l\r"]
[201.145253, "o", "\u001b[?2004h> "]
[201.145967, "o", "            L2_0 = R3_0 ^ f_function(R2_0 ^ key4)\r\n\u001b[?2004l\r"]
[201.146011, "o", "\u001b[?2004h> "]
[201.14635, "o", "            \r\n\u001b[?2004l\r \u001b[?2004h"]
[201.146497, "o", "> "]
[201.14669, "o", "            R2_1 = L3_1\r\n\u001b[?2004l\r"]
[201.146734, "o", "\u001b[?2004h> "]
[201.147205, "o", "            L2_1 = R3_1 ^ f_function(R2_1 ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.147304, "o", "> "]
[201.147379, "o", "            \r\n\u001b[?2004l\r"]
[201.147496, "o", "\u001b[?2004h> "]
[201.147897, "o", "            # Now check if these states are consistent with a third pair\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.14798, "o", "> "]
[201.148201, "o", "            p2, c2 = pairs[2]\r\n\u001b[?2004l\r"]
[201.148348, "o", "\u001b[?2004h> "]
[201.14848, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.148747, "o", "            c2_left = getleft(c2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.148859, "o", "> "]
[201.149095, "o", "            c2_right = getright(c2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.14916, "o", "> "]
[201.149363, "o", "            R4_2 = c2_left\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.14945, "o", "> "]
[201.149658, "o", "            L4_2 = c2_right ^ R4_2\r\n\u001b[?2004l\r"]
[201.149769, "o", "\u001b[?2004h> "]
[201.149879, "o", "            R3_2 = L4_2\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.150021, "o", "> "]
[201.150264, "o", "            L3_2 = R4_2 ^ f_function(R3_2 ^ key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.150461, "o", "> "]
[201.150628, "o", "            R2_2 = L3_2\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.150745, "o", "> "]
[201.150924, "o", "            L2_2 = R3_2 ^ f_function(R2_2 ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.151014, "o", "> "]
[201.151152, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.151634, "o", "            # Check if we can find key0-3 that work for all three\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.151824, "o", "> "]
[201.152089, "o", "            # This is still hard, but we can use a heuristic:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.152396, "o", "            # Try to find key3 that's consistent\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.152487, "o", "> "]
[201.152552, "o", "            \r\n\u001b[?2004l\r"]
[201.152674, "o", "\u001b[?2004h> "]
[201.153003, "o", "            # Actually, let's use a simpler check:\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.153125, "o", "> "]
[201.153621, "o", "            # For the correct keys, certain differential properties should hold\r\n\u001b[?2004l\r"]
[201.153668, "o", "\u001b[?2004h> "]
[201.153824, "o", "            \r\n\u001b[?2004l\r"]
[201.153876, "o", "\u001b[?2004h> "]
[201.154201, "o", "            # Use more pairs to validate\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.154403, "o", "            valid_count = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.154565, "o", "> "]
[201.154774, "o", "            for i in range(3, min(10, len(pairs))):\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.154949, "o", "> "]
[201.155123, "o", "                pi, ci = pairs[i]\r\n\u001b[?2004l\r"]
[201.155299, "o", "\u001b[?2004h> "]
[201.155473, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h"]
[201.155583, "o", "> "]
[201.155845, "o", "                ci_left = getleft(ci)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.156151, "o", "                ci_right = getright(ci)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.156235, "o", "> "]
[201.156407, "o", "                R4_i = ci_left\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.156544, "o", "> "]
[201.156761, "o", "                L4_i = ci_right ^ R4_i\r\n\u001b[?2004l\r"]
[201.156807, "o", "\u001b[?2004h> "]
[201.157071, "o", "                R3_i = L4_i\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.157156, "o", "> "]
[201.157576, "o", "                L3_i = R4_i ^ f_function(R3_i ^ key5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.157805, "o", "                R2_i = L3_i\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.157877, "o", "> "]
[201.158266, "o", "                L2_i = R3_i ^ f_function(R2_i ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.158462, "o", "> "]
[201.158583, "o", "                \r\n\u001b[?2004l\r"]
[201.158721, "o", "\u001b[?2004h> "]
[201.159086, "o", "                # Check if the differential pattern is consistent\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.159136, "o", "> "]
[201.159569, "o", "                # This is a weak test but might work\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.159653, "o", "> "]
[201.159882, "o", "                diff_L = L2_0 ^ L2_i\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.160105, "o", "                diff_R = R2_0 ^ R2_i\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.160232, "o", "> "]
[201.160308, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.160645, "o", "                # For wrong keys, these should be random\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.160755, "o", "> "]
[201.161124, "o", "                # For right keys, there might be structure\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.161265, "o", "> "]
[201.161647, "o", "                # This test is very weak, let's try something else\r\n\u001b[?2004l\r"]
[201.161748, "o", "\u001b[?2004h> "]
[201.161849, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h"]
[201.161929, "o", "> "]
[201.162308, "o", "            # Let's try a different validation:\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.162414, "o", "> "]
[201.162691, "o", "            # Try to find key3, key2 that work\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.162957, "o", "            found_consistent_keys = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.163102, "o", "> "]
[201.163245, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.163488, "o", "            # Sample a few key3 values\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.163791, "o", "            for seed3 in range(0, 0x10000, 256):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.164121, "o", "                key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.164284, "o", "> "]
[201.164393, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.164658, "o", "                # Decrypt round 2 for first pair\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.164774, "o", "> "]
[201.164921, "o", "                R1_0 = L2_0\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.165025, "o", "> "]
[201.16527, "o", "                L1_0 = R2_0 ^ f_function(R1_0 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.165325, "o", "> "]
[201.165514, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h"]
[201.165684, "o", "> "]
[201.165741, "o", "                # Check with second pair\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.165923, "o", "> "]
[201.166117, "o", "                R1_1 = L2_1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.16637, "o", "                L1_1 = R2_1 ^ f_function(R1_1 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.166429, "o", "> "]
[201.166588, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.166901, "o", "                # Try to find key2 that works\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.166947, "o", "> "]
[201.167286, "o", "                for seed2 in range(0, 0x10000, 256):\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.167394, "o", "> "]
[201.167692, "o", "                    key2 = (seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.167837, "o", "> "]
[201.167951, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.168169, "o", "                    # Decrypt round 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.168289, "o", "> "]
[201.168432, "o", "                    R0_0 = L1_0\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.168564, "o", "> "]
[201.168847, "o", "                    L0_0 = R1_0 ^ f_function(R0_0 ^ key2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.168995, "o", "> "]
[201.169147, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.169385, "o", "                    R0_1 = L1_1\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.169446, "o", "> "]
[201.169771, "o", "                    L0_1 = R1_1 ^ f_function(R0_1 ^ key2)\r\n\u001b[?2004l\r"]
[201.169829, "o", "\u001b[?2004h> "]
[201.169975, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[201.17011, "o", "> "]
[201.170528, "o", "                    # Now check if we can find key0, key1 that match the plaintext\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.170655, "o", "> "]
[201.171102, "o", "                    # After pre-round: R0 = R XOR L (where L, R are after whitening)\r\n\u001b[?2004l\r"]
[201.171192, "o", "\u001b[?2004h> "]
[201.171606, "o", "                    # So: R_after_whitening = R0, L_after_whitening = R0 XOR L0\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.171643, "o", "> "]
[201.171857, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.172124, "o", "                    # Plaintext structure\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.172248, "o", "> "]
[201.172513, "o", "                    p0_left = getleft(p0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.172833, "o", "                    p0_right = getright(p0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.173023, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.173524, "o", "                    # After whitening: L = p0_left XOR key0, R = p0_right XOR key1\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.173565, "o", "> "]
[201.174146, "o", "                    # After pre-round: R' = R XOR L = (p0_right XOR key1) XOR (p0_left XOR key0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.174257, "o", "> "]
[201.174636, "o", "                    # So: R0_0 = p0_right XOR p0_left XOR key1 XOR key0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.174925, "o", "                    # And: L0_0 = R' = R0_0\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.175053, "o", "> "]
[201.17529, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.235468, "o", "                    # This gives us: key0 XOR key1 = p0_right XOR p0_left XOR R0_0\r\n\u001b[?2004l\r\u001b[?2004h>                     key01_xor = p0_right ^ p0_left ^ R0_0\r\n\u001b[?2004l\r\u001b[?2004h>                     \r\n\u001b[?2004l\r\u001b[?2004h>                     # Similarly for p1\r\n\u001b[?2004l\r\u001b[?2004h>                     p1_left = getleft(p1)\r\n\u001b[?2004l\r\u001b[?2004h>                     p1_right = getright(p1)"]
[201.235729, "o", "\r\n\u001b[?2004l\r"]
[201.235897, "o", "\u001b[?2004h> "]
[201.236212, "o", "                    key01_xor_check = p1_right ^ p1_left ^ R0_1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.236433, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[201.236583, "o", "> "]
[201.23693, "o", "                    if key01_xor == key01_xor_check:\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.237022, "o", "> "]
[201.237419, "o", "                        # Found consistent keys!\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.237585, "o", "> "]
[201.237906, "o", "                        found_consistent_keys = True\r\n\u001b[?2004l\r"]
[201.238032, "o", "\u001b[?2004h> "]
[201.238338, "o", "                        return key5\r\n\u001b[?2004l\r\u001b[?2004h"]
[201.238464, "o", "> "]
[201.238555, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[201.238662, "o", "> "]
[201.23895, "o", "            if found_consistent_keys:\r\n\u001b[?2004l\r"]
[201.239058, "o", "\u001b[?2004h"]
[201.239094, "o", "> "]
[201.239268, "o", "                return key5\r\n\u001b[?2004l\r"]
[201.239408, "o", "\u001b[?2004h> "]
[201.239525, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.239569, "o", "    return 0\r\n\u001b[?2004l\r"]
[201.239694, "o", "\u001b[?2004h"]
[201.239821, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[201.239927, "o", "EOF\r\n\u001b[?2004l\r"]
[201.242617, "o", "\u001b[?2004hroot@506b644d66f7:/app# "]
[208.649928, "i", "python3 test_attack.py 2>&1 | head -20\n"]
[208.650364, "o", "python3 test_attack.py 2>&1 | head -20\r\n\u001b[?2004l\r"]
[248.386194, "i", "\u0003"]
[248.38639, "o", "^C"]
[248.449239, "o", "\r\n"]
