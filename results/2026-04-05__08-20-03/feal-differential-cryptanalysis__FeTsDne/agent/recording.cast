[288.143139, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef decrypt_two_rounds(ciphertext, key4, key5):\n    \"\"\"Decrypt the last two rounds\"\"\"\n    c_left = getleft(ciphertext)\n    c_right = getright(ciphertext)\n    R4 = c_left\n    L4 = c_right ^ R4\n    R3 = L4\n    L3 = R4 ^ f_function(R3 ^ key5)\n    R2 = L3\n    L2 = R3 ^ f_function(R2 ^ key4)\n    return L2, R2\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using brute fo"]
[288.143359, "i", "rce with algebraic validation\"\"\"\n    \n    # Use specific plaintexts that create algebraic relationships\n    # Use plaintexts with simple structure\n    p0 = 0x0000000000000000\n    c0 = encrypt_fn(p0)\n    \n    p1 = 0x0000000000000001  \n    c1 = encrypt_fn(p1)\n    \n    p2 = 0x0000000100000000\n    c2 = encrypt_fn(p2)\n    \n    p3 = 0x0000000100000001\n    c3 = encrypt_fn(p3)\n    \n    # Brute force key[4] and key[5]\n    for seed4 in range(0x10000):\n        key4 = (seed4 * 1234567) & 0xFFFFFFFF\n        \n        for seed5 in range(0x10000):\n            key5 = (seed5 * 1234567) & 0xFFFFFFFF\n            \n            # Decrypt two rounds for all plaintexts\n            L2_0, R2_0 = decrypt_two_rounds(c0, key4, key5)\n            L2_1, R2_1 = decrypt_two_rounds(c1, key4, key5)\n            L2_2, R2_2 = decrypt_two_rounds(c2, key4, key5)\n            L2_3, R2_3 = decrypt_two_rounds(c3, key4, key5)\n            \n            # Check for algebraic consistency\n            # The differences in the decrypted states should follow\n    "]
[288.143487, "i", "        # certain patterns based on the plaintext differences\n            \n            # For plaintexts that differ by 1 in the right half:\n            # p0 and p1 differ by 1 in right half\n            # After whitening and pre-round, this creates a specific difference\n            \n            # Check if the differences make sense\n            # This is a heuristic check\n            \n            diff_01_L = L2_0 ^ L2_1\n            diff_01_R = R2_0 ^ R2_1\n            diff_02_L = L2_0 ^ L2_2\n            diff_02_R = R2_0 ^ R2_2\n            diff_03_L = L2_0 ^ L2_3\n            diff_03_R = R2_0 ^ R2_3\n            \n            # For correct keys, diff_03 should be related to diff_01 and diff_02\n            # Specifically: diff_03 = diff_01 XOR diff_02 (if the cipher was linear)\n            # But FEAL is non-linear, so this won't hold exactly\n            # However, we can check if it's \"close\" in some sense\n            \n            # Actually, let's use a different check:\n            # Compute what the differences sho"]
