[1561.080705, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Simple brute force with minimal validation\n    # Just try all key[5] values and return first one that seems plausible\n    \n    pairs = [(i, encrypt_fn(i)) for i in range(4)]\n    \n    # Build valid diffs\n    valid_diffs = set()\n    for i in range(256):\n        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\n    \n    best_key5 = 0\n   "]
[1561.080796, "i", " best_score = 0\n    \n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # Decrypt last round\n        states = []\n        for p, c in pairs[:2]:\n            c_left, c_right = getleft(c), getright(c)\n            R3 = c_right ^ c_left\n            L3 = c_left ^ f_function(R3 ^ key5)\n            states.append((L3, R3))\n        \n        # Score this key5\n        score = 0\n        for seed4 in range(0, 0x10000, 1024):  # 64 samples\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            L2_0 = states[0][1] ^ f_function(states[0][0] ^ key4)\n            L2_1 = states[1][1] ^ f_function(states[1][0] ^ key4)\n            if (L2_0 ^ L2_1) in valid_diffs:\n                score += 1\n        \n        if score > best_score:\n            best_score = score\n            best_key5 = key5\n            if score >= 4:  # Early termination if score is good enough\n                return key5\n    \n    return best_key5\n\nEOF\n"]
