[898.24878, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.249083, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.249219, "o", "> "]
[898.249369, "o", "        input_val >>= 8\r\n\u001b[?2004l\r"]
[898.24949, "o", "\u001b[?2004h> "]
[898.249801, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r"]
[898.249923, "o", "\u001b[?2004h> "]
[898.25019, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r"]
[898.2504, "o", "\u001b[?2004h> "]
[898.250719, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r"]
[898.2509, "o", "\u001b[?2004h> "]
[898.251188, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r"]
[898.251336, "o", "\u001b[?2004h> "]
[898.251521, "o", "    output = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.251623, "o", "> "]
[898.251712, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.251854, "o", "> "]
[898.252309, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r"]
[898.252432, "o", "\u001b[?2004h> "]
[898.25263, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[898.252773, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[898.25295, "o", "\u001b[?2004h> "]
[898.253051, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.25317, "o", "> "]
[898.253416, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.253613, "o", "> "]
[898.253829, "o", "    pairs = [(i, encrypt_fn(i)) for i in range(8)]\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.253873, "o", "> "]
[898.253985, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[898.254081, "o", "> "]
[898.25467, "o", "    # Build a set of all possible output differences for f with input diff 1\r\n"]
[898.254722, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[898.255118, "o", "    valid_diffs = set()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.255304, "o", "    for i in range(256):\r\n\u001b[?2004l\r"]
[898.255436, "o", "\u001b[?2004h> "]
[898.25593, "o", "        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\r\n\u001b[?2004l\r"]
[898.256087, "o", "\u001b[?2004h>     "]
[898.256229, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.256447, "o", "    # Try all key[5] values\r\n\u001b[?2004l\r"]
[898.25658, "o", "\u001b[?2004h> "]
[898.256816, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[898.256955, "o", "\u001b[?2004h> "]
[898.257286, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[898.25759, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[898.25775, "o", "\u001b[?2004h> "]
[898.258023, "o", "        # Decrypt last round for pairs 0 and 1\r\n\u001b[?2004l\r"]
[898.258155, "o", "\u001b[?2004h> "]
[898.258372, "o", "        c0_left = getleft(pairs[0][1])\r\n\u001b[?2004l\r"]
[898.258501, "o", "\u001b[?2004h> "]
[898.258786, "o", "        c0_right = getright(pairs[0][1])\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.258894, "o", "> "]
[898.259065, "o", "        R4_0 = c0_left\r\n\u001b[?2004l\r"]
[898.259136, "o", "\u001b[?2004h> "]
[898.259399, "o", "        L4_0 = c0_right ^ R4_0\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.259529, "o", "> "]
[898.259791, "o", "        R3_0 = L4_0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.260122, "o", "        L3_0 = R4_0 ^ f_function(R3_0 ^ key5)\r\n\u001b[?2004l\r"]
[898.260339, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.260682, "o", "        c1_left = getleft(pairs[1][1])\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.260828, "o", "> "]
[898.26106, "o", "        c1_right = getright(pairs[1][1])\r\n\u001b[?2004l\r"]
[898.261205, "o", "\u001b[?2004h> "]
[898.261329, "o", "        R4_1 = c1_left\r\n\u001b[?2004l\r"]
[898.26147, "o", "\u001b[?2004h"]
[898.261582, "o", "> "]
[898.26174, "o", "        L4_1 = c1_right ^ R4_1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.261919, "o", "        R3_1 = L4_1\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.262091, "o", "> "]
[898.262358, "o", "        L3_1 = R4_1 ^ f_function(R3_1 ^ key5)\r\n\u001b[?2004l\r"]
[898.262468, "o", "\u001b[?2004h> "]
[898.262559, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[898.262691, "o", "> "]
[898.263151, "o", "        # For p=0 and p=1, check if the L3 difference could come from\r\n\u001b[?2004l\r"]
[898.263289, "o", "\u001b[?2004h> "]
[898.263622, "o", "        # a valid differential through round 3\r\n\u001b[?2004l\r"]
[898.263735, "o", "\u001b[?2004h> "]
[898.264167, "o", "        # L3 is actually R2 (after the Feistel swap in round 3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.264298, "o", "> "]
[898.264548, "o", "        # So L3_0 and L3_1 are R2 values\r\n\u001b[?2004l\r"]
[898.264685, "o", "\u001b[?2004h> "]
[898.264846, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.265228, "o", "        # In round 3: R3 = L2 XOR f(R2 XOR key[4]), L3 = R2\r\n\u001b[?2004l\r"]
[898.265323, "o", "\u001b[?2004h> "]
[898.26568, "o", "        # So: R3_0 = L2_0 XOR f(L3_0 XOR key[4])\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.265845, "o", "> "]
[898.266147, "o", "        # And: R3_1 = L2_1 XOR f(L3_1 XOR key[4])\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.266285, "o", ">         \r\n\u001b[?2004l\r"]
[898.266396, "o", "\u001b[?2004h> "]
[898.267144, "o", "        # Therefore: R3_0 XOR R3_1 = (L2_0 XOR L2_1) XOR (f(L3_0 XOR key[4]) XOR f(L3_1 XOR key[4]))\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.267282, "o", "> "]
[898.267333, "o", "        \r\n\u001b[?2004l\r"]
[898.267368, "o", "\u001b[?2004h> "]
[898.268041, "o", "        # For the correct key[5], there should exist a key[4] such that this holds\r\n\u001b[?2004l\r"]
[898.268114, "o", "\u001b[?2004h> "]
[898.26866, "o", "        # and the difference L2_0 XOR L2_1 is valid (can be produced by earlier rounds)\r\n\u001b[?2004l\r"]
[898.268688, "o", "\u001b[?2004h"]
[898.268716, "o", "> "]
[898.268798, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[898.268829, "o", "> "]
[898.2692, "o", "        # Quick check: try just a few key[4] values\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.269363, "o", "        found = False\r\n\u001b[?2004l\r"]
[898.269404, "o", "\u001b[?2004h> "]
[898.269879, "o", "        for test_seed in [0, 1, 100, 1000, 10000, 32768, 65535]:  # Just 7 test values\r\n\u001b[?2004l\r"]
[898.269924, "o", "\u001b[?2004h> "]
[898.297346, "o", "            test_key4 = (test_seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             # Compute what L2 difference would be\r\n\u001b[?2004l\r\u001b[?2004h>             f_diff = f_function(L3_0 ^ test_key4) ^ f_function(L3_1 ^ test_key4)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.297439, "o", "            L2_diff = (R3_0 ^ R3_1) ^ f_diff\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.298086, "o", "            # Check if this L2 difference is valid (can come from round 2 with input diff 1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.298211, "o", "> "]
[898.298393, "o", "            if L2_diff in valid_diffs:\r\n\u001b[?2004l\r"]
[898.298498, "o", "\u001b[?2004h> "]
[898.298681, "o", "                found = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.298861, "o", "> "]
[898.298975, "o", "                break\r\n\u001b[?2004l\r"]
[898.299015, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.299201, "o", "        if found:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.299626, "o", "            # Do additional validation with another pair\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.299769, "o", "> "]
[898.30007, "o", "            c2_left = getleft(pairs[2][1])\r\n\u001b[?2004l\r"]
[898.30023, "o", "\u001b[?2004h> "]
[898.300528, "o", "            c2_right = getright(pairs[2][1])\r\n\u001b[?2004l\r"]
[898.30067, "o", "\u001b[?2004h> "]
[898.300823, "o", "            R4_2 = c2_left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.301055, "o", "            L4_2 = c2_right ^ R4_2\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.301197, "o", "> "]
[898.301343, "o", "            R3_2 = L4_2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.30163, "o", "            L3_2 = R4_2 ^ f_function(R3_2 ^ key5)\r\n\u001b[?2004l\r"]
[898.30167, "o", "\u001b[?2004h"]
[898.301816, "o", "> "]
[898.301951, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.302162, "o", "            # Check with pairs 1 and 2\r\n\u001b[?2004l\r"]
[898.302221, "o", "\u001b[?2004h> "]
[898.302395, "o", "            found2 = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.302506, "o", "> "]
[898.302899, "o", "            for test_seed in [0, 1, 100, 1000, 10000, 32768, 65535]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.303059, "o", "> "]
[898.303479, "o", "                test_key4 = (test_seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.303598, "o", "> "]
[898.304246, "o", "                f_diff = f_function(L3_1 ^ test_key4) ^ f_function(L3_2 ^ test_key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.304391, "o", "> "]
[898.304644, "o", "                L2_diff = (R3_1 ^ R3_2) ^ f_diff\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.304756, "o", "> "]
[898.304902, "o", "                if L2_diff in valid_diffs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.305064, "o", "> "]
[898.305262, "o", "                    found2 = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.305413, "o", "> "]
[898.305562, "o", "                    break\r\n\u001b[?2004l\r"]
[898.30572, "o", "\u001b[?2004h> "]
[898.305871, "o", "            \r\n\u001b[?2004l\r"]
[898.305939, "o", "\u001b[?2004h> "]
[898.306142, "o", "            if found2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[898.306391, "o", "                return key5\r\n\u001b[?2004l\r"]
[898.306499, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[898.30657, "o", "\u001b[?2004h> "]
[898.306676, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[898.306769, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[898.306795, "o", "> "]
[898.306916, "o", "EOF\r\n\u001b[?2004l\r"]
[898.309926, "o", "\u001b[?2004hroot@506b644d66f7:/app# "]
