[479.663346, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.663754, "o", "def decrypt_two_rounds(ciphertext, key4, key5):\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.663888, "o", "> "]
[479.664256, "o", "    c_left = getleft(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.664432, "o", "    c_right = getright(ciphertext)\r\n\u001b[?2004l\r"]
[479.664572, "o", "\u001b[?2004h> "]
[479.66472, "o", "    R4 = c_left\r\n\u001b[?2004l\r"]
[479.664913, "o", "\u001b[?2004h> "]
[479.664969, "o", "    L4 = c_right ^ R4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.665141, "o", "    R3 = L4\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.665277, "o", "> "]
[479.665466, "o", "    L3 = R4 ^ f_function(R3 ^ key5)\r\n\u001b[?2004l\r"]
[479.665596, "o", "\u001b[?2004h> "]
[479.665939, "o", "    R2 = L3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.666152, "o", "    L2 = R3 ^ f_function(R2 ^ key4)\r\n\u001b[?2004l\r"]
[479.666288, "o", "\u001b[?2004h> "]
[479.666409, "o", "    return L2, R2\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.66653, "o", "> \r\n\u001b[?2004l\r"]
[479.666623, "o", "\u001b[?2004h> "]
[479.666782, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r"]
[479.66696, "o", "\u001b[?2004h> "]
[479.667156, "o", "    # Use plaintext 0 for simplicity\r\n\u001b[?2004l\r"]
[479.667311, "o", "\u001b[?2004h> "]
[479.66742, "o", "    p0 = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.667521, "o", "> "]
[479.667718, "o", "    c0 = encrypt_fn(p0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.667763, "o", "> "]
[479.66794, "o", "    \r\n\u001b[?2004l\r"]
[479.668057, "o", "\u001b[?2004h>     p1 = 1\r\n\u001b[?2004l\r"]
[479.668177, "o", "\u001b[?2004h> "]
[479.66833, "o", "    c1 = encrypt_fn(p1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.668458, "o", ">     \r\n\u001b[?2004l\r"]
[479.66864, "o", "\u001b[?2004h> "]
[479.668781, "o", "    # For p0=0: after whitening L=key[0], R=key[1]\r\n\u001b[?2004l\r"]
[479.668884, "o", "\u001b[?2004h> "]
[479.66926, "o", "    # After pre-round: L=key[0], R=key[0]^key[1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.669379, "o", "> "]
[479.669595, "o", "    # Let K01 = key[0]^key[1]\r\n\u001b[?2004l\r"]
[479.669657, "o", "\u001b[?2004h> "]
[479.670258, "o", "    # After round 1: L=K01, R=key[0]^f(K01^key[2])\r\n\u001b[?2004l\r"]
[479.6704, "o", "\u001b[?2004h> "]
[479.670711, "o", "    # Let F2 = f(K01^key[2]), so R1=key[0]^F2\r\n\u001b[?2004l\r"]
[479.670761, "o", "\u001b[?2004h> "]
[479.671273, "o", "    # After round 2: L=key[0]^F2, R=K01^f((key[0]^F2)^key[3])\r\n\u001b[?2004l\r"]
[479.671423, "o", "\u001b[?2004h> "]
[479.671807, "o", "    # So: L2_0 = key[0]^F2, R2_0 = K01^f((key[0]^F2)^key[3])\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.671976, "o", "> "]
[479.672142, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.672402, "o", "    # For p1=1: after whitening L=key[0], R=key[1]^1\r\n\u001b[?2004l\r"]
[479.672542, "o", "\u001b[?2004h> "]
[479.672853, "o", "    # After pre-round: L=key[0], R=key[0]^key[1]^1 = K01^1\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.672979, "o", "> "]
[479.673328, "o", "    # After round 1: L=K01^1, R=key[0]^f((K01^1)^key[2])\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.67349, "o", "> "]
[479.673737, "o", "    # Let F2' = f((K01^1)^key[2]), so R1=key[0]^F2'\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.673947, "o", "> "]
[479.674584, "o", "    # After round 2: L=key[0]^F2', R=(K01^1)^f((key[0]^F2')^key[3])\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.674735, "o", "> "]
[479.675108, "o", "    # So: L2_1 = key[0]^F2', R2_1 = (K01^1)^f((key[0]^F2')^key[3])\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.675243, "o", ">     \r\n"]
[479.675374, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[479.675778, "o", "    # Key observation: L2_0 ^ L2_1 = F2 ^ F2' = f(K01^key[2]) ^ f((K01^1)^key[2])\r\n\u001b[?2004l\r"]
[479.675904, "o", "\u001b[?2004h> "]
[479.676185, "o", "    # This depends only on K01 and key[2], not on key[0] individually!\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.676299, "o", ">     \r\n\u001b[?2004l\r"]
[479.676414, "o", "\u001b[?2004h> "]
[479.676902, "o", "    # Similarly: R2_0 ^ R2_1 = [K01^f((key[0]^F2)^key[3])] ^ [(K01^1)^f((key[0]^F2')^key[3])]\r\n\u001b[?2004l\r"]
[479.677033, "o", "\u001b[?2004h> "]
[479.677549, "o", "    #                        = 1 ^ f((key[0]^F2)^key[3]) ^ f((key[0]^F2')^key[3])\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.677594, "o", "> "]
[479.677836, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.678097, "o", "    # Brute force key[4] and key[5]\r\n\u001b[?2004l\r"]
[479.678161, "o", "\u001b[?2004h> "]
[479.719204, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h>         key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         for seed4 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h>             key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             L2_0, R2_0 = decrypt_two_rounds(c0, key4, key5)\r\n\u001b[?2004l\r\u001b[?2004h>             L2_1, R2_1 = decrypt_two_rounds(c1, key4, key5)\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h"]
[479.719439, "o", "> "]
[479.719667, "o", "            # Check the differential property\r\n\u001b[?2004l\r"]
[479.71973, "o", "\u001b[?2004h> "]
[479.720027, "o", "            diff_L = L2_0 ^ L2_1\r\n\u001b[?2004l\r"]
[479.720065, "o", "\u001b[?2004h"]
[479.720288, "o", "> "]
[479.720475, "o", "            diff_R = R2_0 ^ R2_1\r\n\u001b[?2004l\r\u001b[?2004h> "]
