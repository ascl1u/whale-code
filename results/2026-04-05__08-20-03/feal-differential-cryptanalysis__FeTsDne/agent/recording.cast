[1637.940701, "o", ">     \r\n\u001b[?2004l\r"]
[1637.940797, "o", "\u001b[?2004h> "]
[1637.941643, "o", "    # Precompute possible output differences for f with input diff 1\r\n\u001b[?2004l\r"]
[1637.941905, "o", "\u001b[?2004h> "]
[1637.942106, "o", "    valid_diffs = set()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.942314, "o", "> "]
[1637.942419, "o", "    for i in range(256):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.942538, "o", "> "]
[1637.942992, "o", "        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\r\n\u001b[?2004l\r"]
[1637.943038, "o", "\u001b[?2004h> "]
[1637.943178, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.943374, "o", "> "]
[1637.94353, "o", "    # Try all possible key[5] seeds\r\n\u001b[?2004l\r"]
[1637.943652, "o", "\u001b[?2004h> "]
[1637.943869, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[1637.944011, "o", "\u001b[?2004h> "]
[1637.944354, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.944529, "o", ">         \r\n"]
[1637.944731, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[1637.945005, "o", "        # Decrypt round 4 for first two pairs\r\n\u001b[?2004l\r"]
[1637.945148, "o", "\u001b[?2004h> "]
[1637.945292, "o", "        states = []"]
[1637.945427, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1637.945671, "o", "        for p, c in pairs[:2]:\r\n\u001b[?2004l\r"]
[1637.945837, "o", "\u001b[?2004h> "]
[1637.946017, "o", "            c_left = getleft(c)\r\n\u001b[?2004l\r"]
[1637.946151, "o", "\u001b[?2004h> "]
[1637.946415, "o", "            c_right = getright(c)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1637.94663, "o", "            # Undo swap and post-round XOR\r\n\u001b[?2004l\r"]
[1637.946781, "o", "\u001b[?2004h> "]
[1637.946957, "o", "            R4 = c_left\r\n\u001b[?2004l\r"]
[1637.947091, "o", "\u001b[?2004h> "]
[1637.94729, "o", "            L4 = c_right ^ R4\r\n\u001b[?2004l\r"]
[1637.947429, "o", "\u001b[?2004h> "]
[1637.947535, "o", "            # Undo round 4\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.947646, "o", "> "]
[1637.947799, "o", "            R3 = L4\r\n\u001b[?2004l\r"]
[1637.947953, "o", "\u001b[?2004h> "]
[1637.948174, "o", "            L3 = R4 ^ f_function(R3 ^ key5)\r\n\u001b[?2004l\r"]
[1637.948303, "o", "\u001b[?2004h> "]
[1637.948538, "o", "            states.append((L3, R3))\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.948654, "o", "> "]
[1637.948819, "o", "        \r\n\u001b[?2004l\r"]
[1637.948984, "o", "\u001b[?2004h> "]
[1637.949379, "o", "        # Validate by checking if any key[4] produces valid differential\r\n\u001b[?2004l\r"]
[1637.949455, "o", "\u001b[?2004h> "]
[1637.949652, "o", "        matches = 0\r\n\u001b[?2004l\r"]
[1637.949757, "o", "\u001b[?2004h> "]
[1637.950222, "o", "        for seed4 in range(0, 0x10000, 1024):  # Sample 64 values\r\n\u001b[?2004l\r"]
[1637.950357, "o", "\u001b[?2004h> "]
[1637.950603, "o", "            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.950732, "o", "> "]
[1637.950864, "o", "            # Decrypt round 3\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.951011, "o", "> "]
[1637.951341, "o", "            L2_0 = states[0][1] ^ f_function(states[0][0] ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.951468, "o", "> "]
[1637.951829, "o", "            L2_1 = states[1][1] ^ f_function(states[1][0] ^ key4)\r\n\u001b[?2004l\r"]
[1637.951935, "o", "\u001b[?2004h> "]
[1637.952256, "o", "            # Check if difference is valid\r\n\u001b[?2004l\r\u001b[?2004h"]
[1637.952301, "o", "> "]
[1637.959147, "o", "            if (L2_0 ^ L2_1) in valid_diffs:\r\n\u001b[?2004l\r\u001b[?2004h>                 matches += 1\r\n\u001b[?2004l\r\u001b[?2004h>                 if matches >= 3:\r\n\u001b[?2004l\r\u001b[?2004h>                     return key5\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[1637.961601, "o", "\u001b[?2004hroot@506b644d66f7:/app# "]
