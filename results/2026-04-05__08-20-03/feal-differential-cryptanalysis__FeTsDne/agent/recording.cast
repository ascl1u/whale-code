[904.173054, "o", "python3 test_attack.py; printf '%s\\n' '__CMDEND__14__'\r\n\u001b[?2004l\r"]
[904.206148, "o", "Actual key[5]: 4049240757\r\nAll keys: [1614400742, 801003683, 2368721179, 3732552526, 4111473298, 4049240757]\r\n"]
[907.989237, "o", "Recovered key[5]: 0\r\nFAILED! Key not recovered.\r\n"]
[907.995504, "o", "__CMDEND__14__\r\n"]
