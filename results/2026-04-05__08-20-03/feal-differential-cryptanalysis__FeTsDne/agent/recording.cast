[796.972238, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Use many plaintext-ciphertext pairs\n    pairs = [(i, encrypt_fn(i)) for i in range(16)]\n    \n    # Precompute: for each possible output diff of f with input diff 1,\n    # store it in a set for O(1) lookup\n    valid_diffs_1 = set()\n    for i in range(256):\n        valid_diffs_1.add(f_function(i) ^ f_function(i ^ 1))\n    \n    # Try all k"]
[796.972457, "i", "ey[5] seeds\n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # Decrypt last round for all pairs\n        L3_list = []\n        R3_list = []\n        for p, c in pairs:\n            c_left = getleft(c)\n            c_right = getright(c)\n            R4 = c_left\n            L4 = c_right ^ R4\n            R3 = L4\n            L3 = R4 ^ f_function(R3 ^ key5)\n            L3_list.append(L3)\n            R3_list.append(R3)\n        \n        # Quick validation: sample a few key[4] values\n        # and count how many produce valid differentials\n        matches = 0\n        for seed4_sample in range(0, 0x10000, 256):  # Sample 256 values\n            key4 = (seed4_sample * 1234567) & 0xFFFFFFFF\n            \n            # Decrypt round 3 for first two pairs\n            L2_0 = R3_list[0] ^ f_function(L3_list[0] ^ key4)\n            L2_1 = R3_list[1] ^ f_function(L3_list[1] ^ key4)\n            \n            # Check if difference is valid\n            if (L2_0 ^ L2_1) in valid_diffs_1:\n     "]
