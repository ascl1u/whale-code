[361.650434, "o", "def getright(x):\r\n\u001b[?2004l\r"]
[361.650581, "o", "\u001b[?2004h> "]
[361.650857, "o", "    return x & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.651108, "o", "> \r\n\u001b[?2004l\r "]
[361.651152, "o", "\u001b[?2004h> "]
[361.651519, "o", "def g_function(a, b, x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.651831, "o", "    temp = (a + b + x) & 0xFF\r\n\u001b[?2004l\r"]
[361.652112, "o", "\u001b[?2004h> "]
[361.652819, "o", "    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.653001, "o", "> \r\n\u001b[?2004l\r"]
[361.65324, "o", "\u001b[?2004h> "]
[361.653566, "o", "def f_function(input_val):\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.653896, "o", "> "]
[361.654128, "o", "    x = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.654271, "o", "    y = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.654434, "o", "    for i in range(4):\r\n\u001b[?2004l\r"]
[361.654529, "o", "\u001b[?2004h> "]
[361.654997, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r"]
[361.655143, "o", "\u001b[?2004h"]
[361.655221, "o", "> "]
[361.655573, "o", "        input_val >>= 8\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.655823, "o", "> "]
[361.656395, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r"]
[361.656573, "o", "\u001b[?2004h> "]
[361.657247, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.657486, "o", "> "]
[361.658297, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r"]
[361.658448, "o", "\u001b[?2004h> "]
[361.659109, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r"]
[361.659277, "o", "\u001b[?2004h> "]
[361.659462, "o", "    output = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.659619, "o", "> "]
[361.659835, "o", "    for i in range(4):\r\n\u001b[?2004l\r   \u001b[?2004h"]
[361.659984, "o", "> "]
[361.660266, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.660645, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[361.660832, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.661392, "o", "def decrypt_last_round(ciphertext, key5):\r\n\u001b[?2004l\r \u001b[?2004h"]
[361.661531, "o", "> "]
[361.662004, "o", "    \"\"\"Decrypt only the last round\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.662144, "o", "> "]
[361.662492, "o", "    c_left = getleft(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.663035, "o", "    c_right = getright(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.663214, "o", "> "]
[361.663399, "o", "    R4 = c_left\r\n\u001b[?2004l\r"]
[361.663548, "o", "\u001b[?2004h> "]
[361.663895, "o", "    L4 = c_right ^ R4\r\n\u001b[?2004l\r"]
[361.66411, "o", "\u001b[?2004h>     R3 = L4\r\n\u001b[?2004l\r  "]
[361.664226, "o", "\u001b[?2004h> "]
[361.665065, "o", "    L3 = R4 ^ f_function(R3 ^ key5)\r\n\u001b[?2004l\r"]
[361.66534, "o", "\u001b[?2004h> "]
[361.665521, "o", "    return L3, R3\r\n\u001b[?2004l\r"]
[361.665658, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.666295, "o", "def decrypt_two_rounds(ciphertext, key4, key5):\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.666463, "o", "> "]
[361.666655, "o", "    \"\"\"Decrypt the last two rounds\"\"\"\r\n\u001b[?2004l\r"]
[361.666786, "o", "\u001b[?2004h> "]
[361.66718, "o", "    L3, R3 = decrypt_last_round(ciphertext, key5)\r\n\u001b[?2004l\r"]
[361.66742, "o", "\u001b[?2004h> "]
[361.667561, "o", "    R2 = L3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.667767, "o", "    L2 = R3 ^ f_function(R2 ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.667867, "o", "> "]
[361.667994, "o", "    return L2, R2\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.668151, "o", "> \r\n\u001b[?2004l\r"]
[361.668286, "o", "\u001b[?2004h> "]
[361.668552, "o", "def attack(encrypt_fn):"]
[361.668739, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.669152, "o", "    \"\"\"Recover key[5] using brute force with fast validation\"\"\"\r\n\u001b[?2004l\r"]
[361.669325, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[361.669456, "o", "\u001b[?2004h> "]
[361.669819, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.669991, "o", "> "]
[361.670089, "o", "    pairs = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.670337, "o", "    for i in range(8):\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.670482, "o", "> "]
[361.670546, "o", "        p = i\r\n\u001b[?2004l\r"]
[361.670699, "o", "\u001b[?2004h> "]
[361.6709, "o", "        c = encrypt_fn(p)\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.671057, "o", "> "]
[361.671252, "o", "        pairs.append((p, c))\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.671394, "o", ">     "]
[361.67156, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.671744, "o", "    # Try all key[5] values\r\n\u001b[?2004l\r"]
[361.671894, "o", "\u001b[?2004h> "]
[361.672095, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.672257, "o", "> "]
[361.672608, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.672704, "o", "> "]
[361.67282, "o", "        \r\n\u001b[?2004l\r"]
[361.672955, "o", "\u001b[?2004h> "]
[361.673259, "o", "        # Decrypt last round for all pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.673407, "o", "> "]
[361.673665, "o", "        states_after_round3 = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.673926, "o", "        for p, c in pairs:\r\n\u001b[?2004l\r"]
[361.673965, "o", "\u001b[?2004h"]
[361.674025, "o", "> "]
[361.674425, "o", "            L3, R3 = decrypt_last_round(c, key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.67456, "o", "> "]
[361.674917, "o", "            states_after_round3.append((L3, R3))\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.674963, "o", "> "]
[361.675117, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[361.67532, "o", "> "]
[361.675639, "o", "        # Now try to find a key[4] that's consistent\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.675858, "o", "> "]
[361.676465, "o", "        # Use a fast check: try all key[4] values and see if any produces\r\n\u001b[?2004l\r"]
[361.676697, "o", "\u001b[?2004h> "]
[361.676805, "o", "        # consistent results\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.676914, "o", "> "]
[361.676997, "o", "        \r\n\u001b[?2004l\r"]
[361.677095, "o", "\u001b[?2004h> "]
[361.677394, "o", "        for seed4 in range(0x10000):\r\n\u001b[?2004l\r"]
[361.67755, "o", "\u001b[?2004h> "]
[361.677903, "o", "            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[361.677953, "o", "\u001b[?2004h> "]
[361.725709, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h>             # Decrypt round 3 for all pairs\r\n\u001b[?2004l\r\u001b[?2004h>             states_after_round2 = []\r\n\u001b[?2004l\r\u001b[?2004h>             for L3, R3 in states_after_round3:\r\n\u001b[?2004l\r\u001b[?2004h>                 R2 = L3\r\n\u001b[?2004l\r\u001b[?2004h>                 L2 = R3 ^ f_function(R2 ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h>                 states_after_round2.append((L2, R2))\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             # Check for consistency\r\n\u001b[?2004l\r\u001b[?2004h>             # For the correct keys, there should exist key[0-3] that produce these states\r\n\u001b[?2004l\r\u001b[?2004h>             # For wrong keys, it's unlikely\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             # Use a simple heuristic: check if the states have low entropy differences\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.725934, "o", "            # For plaintexts 0, 1, 2, 3, ..., the differences in states should follow patterns\r\n\u001b[?2004l\r"]
[361.726065, "o", "\u001b[?2004h>             \r\n\u001b[?2004l\r"]
[361.726192, "o", "\u001b[?2004h> "]
[361.726429, "o", "            # Check specific algebraic property:\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.726484, "o", "> "]
[361.72685, "o", "            # For plaintext 0 and 1 (differ by 1 in right half)\r\n\u001b[?2004l\r"]
[361.726899, "o", "\u001b[?2004h> "]
[361.727237, "o", "            L2_0, R2_0 = states_after_round2[0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.727366, "o", "> "]
[361.727562, "o", "            L2_1, R2_1 = states_after_round2[1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.727643, "o", "> "]
[361.727733, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[361.727808, "o", "> "]
[361.728322, "o", "            # After going back through rounds 1 and 2, and pre-round, and whitening:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.728834, "o", "            # The difference should be related to the plaintext difference\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.728952, "o", "> "]
[361.729058, "o", "            \r\n\u001b[?2004l\r"]
[361.729223, "o", "\u001b[?2004h> "]
[361.729571, "o", "            # For plaintext p=0: after whitening L=key[0], R=key[1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.729721, "o", "> "]
[361.730004, "o", "            # After pre-round: L=key[0], R=key[0]^key[1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.730046, "o", "> "]
[361.73053, "o", "            # After round 1: L=key[0]^key[1], R=key[0]^f(key[0]^key[1]^key[2])\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.730572, "o", "> "]
[361.731215, "o", "            # After round 2: L=key[0]^f(key[0]^key[1]^key[2]), R=key[0]^key[1]^f(key[0]^f(key[0]^key[1]^key[2])^key[3])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.731357, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.731804, "o", "            # This is getting complex. Let me use a different check:\r\n\u001b[?2004l\r"]
[361.731847, "o", "\u001b[?2004h> "]
[361.732244, "o", "            # Just check if we can find a key[3] value that works\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.732436, "o", "> "]
[361.732511, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.732794, "o", "            # Try a few key[3] values (sample)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.73308, "o", "            found_consistent = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.733512, "o", "            for seed3 in range(0, 0x10000, 1024):  # Very sparse sampling\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.733611, "o", "> "]
[361.733922, "o", "                key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.734049, "o", "> "]
[361.734149, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.734414, "o", "                # Decrypt round 2 for first two pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.734541, "o", "> "]
[361.734778, "o", "                R1_0 = states_after_round2[0][0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.734889, "o", "> "]
[361.735274, "o", "                L1_0 = states_after_round2[0][1] ^ f_function(R1_0 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.735389, "o", "> "]
[361.735512, "o", "                \r\n\u001b[?2004l\r"]
[361.735577, "o", "\u001b[?2004h> "]
[361.735858, "o", "                R1_1 = states_after_round2[1][0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.735934, "o", "> "]
[361.736379, "o", "                L1_1 = states_after_round2[1][1] ^ f_function(R1_1 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.736455, "o", "> "]
[361.736542, "o", "                \r\n\u001b[?2004l\r"]
[361.736667, "o", "\u001b[?2004h> "]
[361.737173, "o", "                # Check a simple property: for plaintext 0 and 1, after decrypting to\r\n\u001b[?2004l\r"]
[361.737305, "o", "\u001b[?2004h> "]
[361.737728, "o", "                # before round 1, the left values should differ in a specific way\r\n\u001b[?2004l\r"]
[361.737849, "o", "\u001b[?2004h> "]
[361.738008, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.738434, "o", "                # Actually, let me just check if L1_0 and L1_1 have reasonable difference\r\n\u001b[?2004l\r"]
[361.73854, "o", "\u001b[?2004h> "]
[361.738672, "o", "                diff = L1_0 ^ L1_1\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.738827, "o", ">                 \r\n\u001b[?2004l\r"]
[361.738874, "o", "\u001b[?2004h> "]
[361.739334, "o", "                # For correct keys, this difference should have some structure\r\n\u001b[?2004l\r"]
[361.739494, "o", "\u001b[?2004h> "]
[361.739689, "o", "                # For wrong keys, it should be random\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.740082, "o", "                # This is a weak test, but let's see if it works\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.740205, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h"]
[361.740286, "o", "> "]
[361.740556, "o", "                # Count number of set bits\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.740838, "o", "                num_bits = bin(diff).count('1')\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.740961, "o", "> "]
[361.74108, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.741566, "o", "                # If difference has very low or very high hamming weight, might be correct\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.741817, "o", "                # This is a heuristic\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.742185, "o", "                if num_bits < 8 or num_bits > 24:\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.742228, "o", "> "]
[361.742511, "o", "                    found_consistent = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.742679, "o", "> "]
[361.742867, "o", "                    break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.743059, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[361.743196, "o", "> "]
[361.743308, "o", "            if found_consistent:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.743557, "o", "                return key5\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.743679, "o", "> "]
[361.743815, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.743955, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.744047, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.744111, "o", "EOF\r\n\u001b[?2004l\r"]
[361.746713, "o", "\u001b[?2004hroot@506b644d66f7:/app# "]
[368.894637, "i", "timeout 30 python3 test_attack.py; printf '%s\\n' '__CMDEND__6__'\n"]
[368.895229, "o", "timeout 30 python3 test_attack.py; printf '%s\\n' '__CMDEND__6__'\r\n\u001b[?2004l\r"]
[368.925282, "o", "Actual key[5]: 4271554114\r\nAll keys: [581572354, 2596520586, 3303836180, 1310879854, 3085591712, 4271554114]\r\n"]
[368.927711, "o", "Recovered key[5]: 0\r\nFAILED! Key not recovered.\r\n"]
[368.934321, "o", "__CMDEND__6__\r\n"]
