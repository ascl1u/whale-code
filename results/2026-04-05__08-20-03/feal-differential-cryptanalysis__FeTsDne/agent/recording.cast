[933.701138, "i", "python3 -c \"key5 = 4049240757; seed = None\nfor s in range(65536):\n    if (s * 1234567) & 0xFFFFFFFF == key5:\n        seed = s\n        break\nprint(f'Seed for key[5]: {seed}')\"\n"]
[933.701764, "o", "python3 -c \"key5 = 4049240757; seed = None\r\n\u001b[?2004l\r"]
[933.701843, "o", "\u001b[?2004h"]
[933.702146, "o", "> for s in range(65536):\r\n\u001b[?2004l\r"]
[933.702739, "o", "\u001b[?2004h>     if (s * 1234567) & 0xFFFFFFFF == key5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[933.702828, "o", "        seed = s\r\n\u001b[?2004l\r"]
[933.703056, "o", "\u001b[?2004h> "]
[933.703256, "o", "        break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[933.703606, "o", "print(f'Seed for key[5]: {seed}')\"\r\n\u001b[?2004l\r"]
