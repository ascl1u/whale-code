[479.661028, "o", "\u001b[?2004h> "]
[479.661368, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.66177, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.662067, "o", "    output = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.662118, "o", "> "]
