[555.405269, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r\u001b[?2004h"]
[555.405394, "o", "> "]
[555.405661, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r"]
[555.405819, "o", "\u001b[?2004h> "]
[555.405958, "o", "    p0 = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[555.406193, "o", "    c0 = encrypt_fn(p0)\r\n\u001b[?2004l\r"]
[555.406307, "o", "\u001b[?2004h> "]
[555.406543, "o", "    p1 = 1  \r\n\u001b[?2004l\r\u001b[?2004h> "]
[555.406699, "o", "    c1 = encrypt_fn(p1)\r\n\u001b[?2004l\r"]
[555.406819, "o", "\u001b[?2004h> "]
[555.406963, "o", "    p2 = 0x100000000\r\n\u001b[?2004l\r"]
[555.407102, "o", "\u001b[?2004h> "]
[555.407241, "o", "    c2 = encrypt_fn(p2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[555.407371, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[555.407518, "o", "> "]
[555.407762, "o", "    # Brute force - try key[5] first (outer loop)\r\n\u001b[?2004l\r"]
[555.40781, "o", "\u001b[?2004h> "]
[555.408112, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[555.408272, "o", "\u001b[?2004h> "]
[555.408546, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[555.408594, "o", "> "]
[555.408741, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[555.409369, "o", "        # For this key5, try all key4 values\r\n\u001b[?2004l\r\u001b[?2004h> "]
