[1262.570823, "o", "\u001b[?2004h> "]
[1262.571176, "o", "        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.571452, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.571568, "o", "    # Try all key[5] seeds\r\n\u001b[?2004l\r"]
[1262.571681, "o", "\u001b[?2004h> "]
[1262.571902, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[1262.572117, "o", "\u001b[?2004h> "]
[1262.572476, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.572642, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.572993, "o", "        # Decrypt last round for 2 pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[1262.573162, "o", "> "]
[1262.573314, "o", "        c0 = pairs[0][1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.573796, "o", "        c0_left, c0_right = getleft(c0), getright(c0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1262.573915, "o", "> "]
[1262.574077, "o", "        R4_0 = c0_left\r\n\u001b[?2004l\r"]
[1262.574208, "o", "\u001b[?2004h> "]
[1262.574652, "o", "        L3_0 = R4_0 ^ f_function((c0_right ^ R4_0) ^ key5)\r\n\u001b[?2004l\r"]
