[479.721204, "o", "> "]
[479.721699, "o", "            # For some value of K01 and key[2], this should be achievable\r\n\u001b[?2004l\r"]
[479.721821, "o", "\u001b[?2004h> "]
[479.722437, "o", "            # We need to check if there exists K01 and key[2] such that this holds\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.722538, "o", "> "]
