[479.722751, "o", "\u001b[?2004h> "]
[479.723204, "o", "            # Try all possible K01 values (32-bit, too many)\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.723382, "o", "> "]
[479.723703, "o", "            # But we can sample or use a different check\r\n\u001b[?2004l\r"]
[479.723898, "o", "\u001b[?2004h> "]
[479.723964, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.724431, "o", "            # Actually, let's use a different observation:\r\n\u001b[?2004l\r"]
[479.72458, "o", "\u001b[?2004h> "]
[479.725075, "o", "            # For p0 and p1, the input difference to f in round 1 is 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.725222, "o", "> "]
[479.725499, "o", "            # The output difference is diff_L\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.725608, "o", "> "]
[479.726114, "o", "            # We can check if this is a valid differential for f\r\n\u001b[?2004l\r"]
[479.726217, "o", "\u001b[?2004h"]
[479.726299, "o", ">             \r\n\u001b[?2004l\r"]
[479.726422, "o", "\u001b[?2004h> "]
[479.726708, "o", "            # Try all possible inputs to f\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.726747, "o", "> "]
[479.727027, "o", "            found_valid = False\r\n\u001b[?2004l\r"]
[479.727066, "o", "\u001b[?2004h> "]
[479.727636, "o", "            for test_input in range(0x10000):  # Sample 16-bit inputs\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.727772, "o", "> "]
[479.728061, "o", "                out1 = f_function(test_input)\r\n\u001b[?2004l\r"]
[479.728171, "o", "\u001b[?2004h> "]
[479.728507, "o", "                out2 = f_function(test_input ^ 1)\r\n\u001b[?2004l\r"]
[479.728555, "o", "\u001b[?2004h> "]
[479.728968, "o", "                if (out1 ^ out2) == diff_L:\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.729029, "o", "> "]
[479.729584, "o", "                    # Found a valid input! This means diff_L is achievable\r\n\u001b[?2004l\r"]
[479.729622, "o", "\u001b[?2004h"]
[479.729712, "o", "> "]
[479.730012, "o", "                    found_valid = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.730134, "o", "> "]
[479.730312, "o", "                    break\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.730424, "o", "> "]
[479.730559, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[479.730766, "o", "            if found_valid:\r\n\u001b[?2004l\r"]
[479.730814, "o", "\u001b[?2004h> "]
[479.731216, "o", "                # Additional check with diff_R\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.731377, "o", "> "]
[479.731913, "o", "                # This is more complex, so let's skip for now and just return\r\n\u001b[?2004l\r\u001b[?2004h"]
[479.731999, "o", "> "]
[479.732219, "o", "                return key5\r\n\u001b[?2004l\r\u001b[?2004h"]
