[399.147413, "o", "            # This is still complex. Let me use a simpler check:\r\n\u001b[?2004l\r"]
[399.147534, "o", "\u001b[?2004h> "]
[399.147976, "o", "            # For p=0 and p=0x100000000, the difference is in the left half\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.148098, "o", "> "]
