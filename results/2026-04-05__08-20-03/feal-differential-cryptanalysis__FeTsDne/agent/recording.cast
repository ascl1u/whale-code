[1262.568274, "o", "\u001b[?2004h> "]
[1262.56843, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r"]
[1262.56859, "o", "\u001b[?2004h> "]
[1262.568859, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[1262.569006, "o", "> "]
[1262.569326, "o", "    pairs = [(i, encrypt_fn(i)) for i in range(3)]\r\n\u001b[?2004l\r"]
[1262.569554, "o", "\u001b[?2004h> "]
[1262.569851, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.570024, "o", "    # Precompute valid output differences\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.570276, "o", "    valid_diffs = set()\r\n\u001b[?2004l\r"]
[1262.570423, "o", "\u001b[?2004h> "]
