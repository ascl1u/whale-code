[956.597386, "o", "> "]
[956.597632, "o", "                    R3_2 = L4_2\r\n\u001b[?2004l\r\u001b[?2004h"]
[956.597745, "o", "> "]
[956.598219, "o", "                    L3_2 = R4_2 ^ f_function(R3_2 ^ key5)\r\n\u001b[?2004l\r"]
[956.598332, "o", "\u001b[?2004h> "]
[956.598505, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[956.598616, "o", "> "]
[956.598974, "o", "                    c3_left = getleft(pairs[3][1])\r\n\u001b[?2004l\r\u001b[?2004h"]
[956.599148, "o", "> "]
[956.599432, "o", "                    c3_right = getright(pairs[3][1])\r\n\u001b[?2004l\r"]
[956.599562, "o", "\u001b[?2004h> "]
[956.599836, "o", "                    R4_3 = c3_left\r\n\u001b[?2004l\r\u001b[?2004h"]
[956.599943, "o", "> "]
[956.600203, "o", "                    L4_3 = c3_right ^ R4_3\r\n\u001b[?2004l\r"]
[956.600286, "o", "\u001b[?2004h> "]
[956.600555, "o", "                    R3_3 = L4_3\r\n\u001b[?2004l\r\u001b[?2004h"]
[956.60076, "o", "> "]
[956.601068, "o", "                    L3_3 = R4_3 ^ f_function(R3_3 ^ key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
