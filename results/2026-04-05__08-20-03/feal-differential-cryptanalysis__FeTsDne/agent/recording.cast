[1462.000842, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Get plaintext-ciphertext pairs\n    p0, c0 = 0, encrypt_fn(0)\n    p1, c1 = 1, encrypt_fn(1)\n    \n    # Precompute valid differences\n    valid_diffs = set()\n    for i in range(256):\n        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\n    \n    # Try all key[5] values\n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567)"]
[1462.001083, "i", " & 0xFFFFFFFF\n        \n        # Decrypt last round for both plaintexts\n        c0_left, c0_right = getleft(c0), getright(c0)\n        R3_0 = c0_right ^ c0_left\n        L3_0 = c0_left ^ f_function(R3_0 ^ key5)\n        \n        c1_left, c1_right = getleft(c1), getright(c1)\n        R3_1 = c1_right ^ c1_left\n        L3_1 = c1_left ^ f_function(R3_1 ^ key5)\n        \n        # Try only 32 key[4] samples for speed\n        matches = 0\n        for seed4 in range(0, 0x10000, 2048):  # Only 32 samples\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            L2_diff = (R3_0 ^ f_function(L3_0 ^ key4)) ^ (R3_1 ^ f_function(L3_1 ^ key4))\n            if L2_diff in valid_diffs:\n                matches += 1\n                if matches >= 2:\n                    return key5\n    \n    return 0\n\nEOF\n"]
