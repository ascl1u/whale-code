[399.143216, "o", "            # The key observation: \r\n\u001b[?2004l\r\u001b[?2004h"]
[399.143291, "o", "> "]
[399.143709, "o", "            # After round 1, L1_0 = key[0]^key[1], L1_1 = key[0]^key[1]^1\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.143838, "o", "> "]
[399.143993, "o", "            # So L1_0 ^ L1_1 = 1\r\n\u001b[?2004l\r"]
