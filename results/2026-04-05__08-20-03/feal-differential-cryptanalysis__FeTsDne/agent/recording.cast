[163.218763, "i", "table[state].append((seed0, seed1, seed2, seed3))\n    \n    print(f\"Forward table size: {len(forward_table)}\")\n    \n    # Now try all key[4] and key[5] combinations\n    print(\"Searching for key[4] and key[5]...\")\n    for seed4 in range(0x10000):\n        if seed4 % 0x1000 == 0:\n            print(f\"Progress: {seed4}/{0x10000}\")\n        \n        key4 = (seed4 * 1234567) & 0xFFFFFFFF\n        \n        for seed5 in range(0x10000):\n            key5 = (seed5 * 1234567) & 0xFFFFFFFF\n            \n            L2, R2 = decrypt_two_rounds(pairs[0][1], key4, key5)\n            \n            if (L2, R2) in forward_table:\n                # Found potential match! Verify with other pairs\n                candidates = forward_table[(L2, R2)]\n                \n                for seed0, seed1, seed2, seed3 in candidates:\n                    key0 = (seed0 * 1234567) & 0xFFFFFFFF\n                    key1 = (seed1 * 1234567) & 0xFFFFFFFF\n                    key2 = (seed2 * 1234567) & 0xFFFFFFFF\n                    key3 = (seed3 * 123456"]
