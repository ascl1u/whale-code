[201.092307, "i", "Plaintext structure\n                    p0_left = getleft(p0)\n                    p0_right = getright(p0)\n                    \n                    # After whitening: L = p0_left XOR key0, R = p0_right XOR key1\n                    # After pre-round: R' = R XOR L = (p0_right XOR key1) XOR (p0_left XOR key0)\n                    # So: R0_0 = p0_right XOR p0_left XOR key1 XOR key0\n                    # And: L0_0 = R' = R0_0\n                    \n                    # This gives us: key0 XOR key1 = p0_right XOR p0_left XOR R0_0\n                    key01_xor = p0_right ^ p0_left ^ R0_0\n                    \n                    # Similarly for p1\n                    p1_left = getleft(p1)\n                    p1_right = getright(p1)\n                    key01_xor_check = p1_right ^ p1_left ^ R0_1\n                    \n                    if key01_xor == key01_xor_check:\n                        # Found consistent keys!\n                        found_consistent_keys = True\n                        return key5\n            \n    "]
