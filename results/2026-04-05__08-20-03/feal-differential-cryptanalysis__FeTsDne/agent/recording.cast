[956.559268, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h>         input_val >>= 8\r\n\u001b[?2004l\r"]
[956.559476, "o", "\u001b[?2004h> "]
[956.559827, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
