[399.141598, "o", "            # For plaintext p=1: L=key[0], R=key[1]^1 after whitening\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.141711, "o", "> "]
[399.142039, "o", "            # After pre-round: L=key[0], R=key[0]^key[1]^1\r\n\u001b[?2004l\r\u001b[?2004h"]
[399.142198, "o", "> "]
[399.142741, "o", "            # After round 1: L=key[0]^key[1]^1, R=key[0]^f((key[0]^key[1]^1)^key[2])\r\n\u001b[?2004l\r"]
[399.142876, "o", "\u001b[?2004h> "]
