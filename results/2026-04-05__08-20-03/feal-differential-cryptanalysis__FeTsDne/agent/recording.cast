[1038.637668, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Collect plaintext-ciphertext pairs\n    pairs = [(i, encrypt_fn(i)) for i in range(6)]\n    \n    # Precompute valid output differences for f with input diff 1\n    valid_diffs = set()\n    for i in range(256):\n        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\n    \n    # Try all key[5] seeds\n    for seed5 in range(0x10000):\n       "]
[1038.637908, "i", " key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # Decrypt last round for first 3 pairs\n        states = []\n        for i in range(3):\n            c = pairs[i][1]\n            c_left = getleft(c)\n            c_right = getright(c)\n            R4 = c_left\n            L4 = c_right ^ R4\n            R3 = L4\n            L3 = R4 ^ f_function(R3 ^ key5)\n            states.append((L3, R3))\n        \n        # Quick validation: try a sparse sample of key[4] values\n        matches = 0\n        for seed4 in range(0, 0x10000, 256):  # 256 samples\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # Check pairs 0 and 1\n            L2_0 = states[0][1] ^ f_function(states[0][0] ^ key4)\n            L2_1 = states[1][1] ^ f_function(states[1][0] ^ key4)\n            \n            if (L2_0 ^ L2_1) in valid_diffs:\n                matches += 1\n                if matches >= 3:  # Early termination\n                    return key5\n    \n    return 0\n\nEOF\n"]
