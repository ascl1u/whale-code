[1262.559874, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Collect plaintext-ciphertext pairs\n    pairs = [(i, encrypt_fn(i)) for i in range(3)]\n    \n    # Precompute valid output differences\n    valid_diffs = set()\n    for i in range(256):\n        valid_diffs.add(f_function(i) ^ f_function(i ^ 1))\n    \n    # Try all key[5] seeds\n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567"]
[1262.559995, "i", ") & 0xFFFFFFFF\n        \n        # Decrypt last round for 2 pairs\n        c0 = pairs[0][1]\n        c0_left, c0_right = getleft(c0), getright(c0)\n        R4_0 = c0_left\n        L3_0 = R4_0 ^ f_function((c0_right ^ R4_0) ^ key5)\n        R3_0 = c0_right ^ R4_0\n        \n        c1 = pairs[1][1]\n        c1_left, c1_right = getleft(c1), getright(c1)\n        R4_1 = c1_left\n        L3_1 = R4_1 ^ f_function((c1_right ^ R4_1) ^ key5)\n        R3_1 = c1_right ^ R4_1\n        \n        # Very sparse sampling: only 64 values\n        matches = 0\n        for seed4 in range(0, 0x10000, 1024):  # Only 64 samples\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            L2_diff = (R3_0 ^ f_function(L3_0 ^ key4)) ^ (R3_1 ^ f_function(L3_1 ^ key4))\n            \n            if L2_diff in valid_diffs:\n                matches += 1\n                if matches >= 3:\n                    return key5\n    \n    return 0\n\nEOF\n"]
