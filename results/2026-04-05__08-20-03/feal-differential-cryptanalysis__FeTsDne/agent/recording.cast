[616.574243, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef decrypt_two_rounds(ciphertext, key4, key5):\n    c_left = getleft(ciphertext)\n    c_right = getright(ciphertext)\n    R4 = c_left\n    L4 = c_right ^ R4\n    R3 = L4\n    L3 = R4 ^ f_function(R3 ^ key5)\n    R2 = L3\n    L2 = R3 ^ f_function(R2 ^ key4)\n    return L2, R2\n\ndef attack(encrypt_fn):\n    # Collect plaintext-ciphertext pairs\n    pairs = []\n    for i in range"]
[616.574494, "i", "(4):\n        p = i\n        c = encrypt_fn(p)\n        pairs.append((p, c))\n    \n    # Pre-compute a differential table for f with input diff 1\n    # This maps output differences to whether they're possible\n    possible_diffs = set()\n    for i in range(256):\n        diff = f_function(i) ^ f_function(i ^ 1)\n        possible_diffs.add(diff)\n    \n    # Brute force key[5] and key[4]\n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        for seed4 in range(0x10000):\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # Decrypt two rounds for first two plaintexts\n            L2_0, R2_0 = decrypt_two_rounds(pairs[0][1], key4, key5)\n            L2_1, R2_1 = decrypt_two_rounds(pairs[1][1], key4, key5)\n            \n            # Check if the difference is in our possible set\n            diff_L = L2_0 ^ L2_1\n            \n            if diff_L in possible_diffs:\n                # Additional check with pairs 2 and 3\n                L2_2, R2_2 = decrypt_two_roun"]
[616.574689, "i", "ds(pairs[2][1], key4, key5)\n                L2_3, R2_3 = decrypt_two_rounds(pairs[3][1], key4, key5)\n                \n                diff_L2 = L2_2 ^ L2_3\n                \n                if diff_L2 in possible_diffs:\n                    return key5\n    \n    return 0\n\nEOF\n"]
[616.574786, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\rds(pairs[2][1], key4, key5)\r\n                L2_3, R2_3 = decrypt_two_rounds(pairs[3][1], key4, key5)\r\n                \r\n                diff_L2 = L2_2 ^ L2_3\r\n                \r\n                if diff_L2 in possible_diffs:\r\n                    return key5\r\n    \r\n    return 0\r\n\r\nEOF\r\n"]
