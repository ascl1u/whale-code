[163.218552, "i", "irst plaintext through first 3 rounds\n    # with all possible key[0-3] combinations\n    print(\"Building forward table...\")\n    forward_table = {}\n    \n    for seed0 in range(0x10000):\n        if seed0 % 0x1000 == 0:\n            print(f\"Progress: {seed0}/{0x10000}\")\n        \n        key0 = (seed0 * 1234567) & 0xFFFFFFFF\n        \n        for seed1 in range(0, 0x10000, 16):  # Sample every 16th\n            key1 = (seed1 * 1234567) & 0xFFFFFFFF\n            \n            for seed2 in range(0, 0x10000, 16):  # Sample every 16th\n                key2 = (seed2 * 1234567) & 0xFFFFFFFF\n                \n                for seed3 in range(0, 0x10000, 16):  # Sample every 16th\n                    key3 = (seed3 * 1234567) & 0xFFFFFFFF\n                    \n                    L2, R2 = encrypt_three_rounds(pairs[0][0], key0, key1, key2, key3)\n                    \n                    state = (L2, R2)\n                    if state not in forward_table:\n                        forward_table[state] = []\n                    forward_"]
