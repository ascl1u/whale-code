[555.401913, "o", "def decrypt_two_rounds(ciphertext, key4, key5):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[555.402158, "o", "    c_left = getleft(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h"]
[555.402361, "o", "> "]
[555.402574, "o", "    c_right = getright(ciphertext)\r\n\u001b[?2004l\r"]
[555.402707, "o", "\u001b[?2004h> "]
[555.402835, "o", "    R4 = c_left\r\n\u001b[?2004l\r"]
[555.403005, "o", "\u001b[?2004h> "]
[555.403143, "o", "    L4 = c_right ^ R4\r\n\u001b[?2004l\r"]
[555.40338, "o", "\u001b[?2004h>     R3 = L4\r\n\u001b[?2004l\r"]
[555.40343, "o", "\u001b[?2004h"]
[555.403597, "o", "> "]
[555.403747, "o", "    L3 = R4 ^ f_function(R3 ^ key5)\r\n\u001b[?2004l\r"]
[555.403875, "o", "\u001b[?2004h> "]
[555.404122, "o", "    R2 = L3\r\n\u001b[?2004l\r\u001b[?2004h> "]
