[1262.576605, "o", "\u001b[?2004h> "]
[1262.576971, "o", "        L3_1 = R4_1 ^ f_function((c1_right ^ R4_1) ^ key5)\r\n\u001b[?2004l\r"]
[1262.577145, "o", "\u001b[?2004h> "]
[1262.577285, "o", "        R3_1 = c1_right ^ R4_1"]
[1262.577441, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
