[108.763029, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef partial_encrypt(left, right, key0, key1, key2, key3, key4):\n    \"\"\"Encrypt through first 4 rounds (not including key[5])\"\"\"\n    # Initial whitening\n    left ^= key0\n    right ^= key1\n    # Pre-round\n    right ^= left\n    # Round 1\n    temp = f_function(right ^ key2)\n    left, right = right, left ^ temp\n    # Round 2\n    temp = f_function(right ^ key3)\n    left,"]
[108.76326, "i", " right = right, left ^ temp\n    # Round 3\n    temp = f_function(right ^ key4)\n    left, right = right, left ^ temp\n    return left, right\n\ndef partial_decrypt(ciphertext, key5):\n    \"\"\"Decrypt only the last round\"\"\"\n    c_left = getleft(ciphertext)\n    c_right = getright(ciphertext)\n    # Undo swap\n    R4 = c_left\n    L4_xored = c_right\n    # Undo post-round XOR\n    L4 = L4_xored ^ R4\n    # Undo round 4: R4 = L3 XOR f(R3 XOR key5), L4 = R3\n    R3 = L4\n    L3 = R4 ^ f_function(R3 ^ key5)\n    return L3, R3\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using meet-in-the-middle attack\"\"\"\n    \n    # Collect plaintext-ciphertext pairs\n    plaintext = 0\n    ciphertext = encrypt_fn(plaintext)\n    \n    plaintext2 = 1\n    ciphertext2 = encrypt_fn(plaintext2)\n    \n    # Build a table of possible states after round 3 by encrypting forward\n    # with all possible key combinations for first 5 keys\n    forward_table = {}\n    \n    # This is too many: 2^80 combinations\n    # Let's try a different approach: sample the space\n "]
[108.76343, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r right = right, left ^ temp\r\n    # Round 3\r\n    temp = f_function(right ^ key4)\r\n    left, right = right, left ^ temp\r\n    return left, right\r\n\r\ndef partial_decrypt(ci"]
[108.763543, "i", "   \n    # Sample approach: try random key combinations\n    import random\n    random.seed(42)\n    \n    for _ in range(100000):  # Sample 100k combinations\n        seed0 = random.randint(0, 0xFFFF)\n        seed1 = random.randint(0, 0xFFFF)\n        seed2 = random.randint(0, 0xFFFF)\n        seed3 = random.randint(0, 0xFFFF)\n        seed4 = random.randint(0, 0xFFFF)\n        \n        key0 = (seed0 * 1234567) & 0xFFFFFFFF\n        key1 = (seed1 * 1234567) & 0xFFFFFFFF\n        key2 = (seed2 * 1234567) & 0xFFFFFFFF\n        key3 = (seed3 * 1234567) & 0xFFFFFFFF\n        key4 = (seed4 * 1234567) & 0xFFFFFFFF\n        \n        p_left = getleft(plaintext)\n        p_right = getright(plaintext)\n        L3, R3 = partial_encrypt(p_left, p_right, key0, key1, key2, key3, key4)\n        \n        # Store in table\n        state = (L3, R3)\n        if state not in forward_table:\n            forward_table[state] = []\n        forward_table[state].append((seed0, seed1, seed2, seed3, seed4))\n    \n    # Now try all key[5] values and see if w"]
[108.76375, "o", "phertext, key5):\r\n    \"\"\"Decrypt only the last round\"\"\"\r\n    c_left = getleft(ciphertext)\r\n    c_right = getright(ciphertext)\r\n    # Undo swap\r\n    R4 = c_left\r\n    L4_xored = c_right\r\n    # Undo post-round XOR\r\n    L4 = L4_xored ^ R4\r\n    # Undo round 4: R4 = L3 XOR f(R3 XOR key5), L4 = R3\r\n    R3 = L4\r\n    L3 = R4 ^ f_function(R3 ^ key5)\r\n    return L3, R3\r\n\r\ndef attack(encrypt_fn):\r\n    \"\"\"Recover key[5] using meet-in-the-middle attack\"\"\"\r\n    \r\n    # Collect plaintext-ciphertext pairs\r\n    plaintext = 0\r\n    ciphertext = encrypt_fn(plaintext)\r\n    \r\n    plaintext2 = 1\r\n    ciphertext2 = encrypt_fn(plaintext2)\r\n    \r\n    # Build a table of possible states after round 3 by encrypting forward\r\n    # with all possible key combinations for first 5 keys\r\n    forward_table = {}\r\n    \r\n    # This is too many: 2^80 combinations\r\n    # Let's try a different approach: sample the space\r\n "]
[108.763795, "i", "e get a match\n    for seed5 in range(0x10000):\n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        L3, R3 = partial_decrypt(ciphertext, key5)\n        \n        if (L3, R3) in forward_table:\n            # Found a match! Verify with second plaintext\n            candidates = forward_table[(L3, R3)]\n            \n            for seed0, seed1, seed2, seed3, seed4 in candidates:\n                key0 = (seed0 * 1234567) & 0xFFFFFFFF\n                key1 = (seed1 * 1234567) & 0xFFFFFFFF\n                key2 = (seed2 * 1234567) & 0xFFFFFFFF\n                key3 = (seed3 * 1234567) & 0xFFFFFFFF\n                key4 = (seed4 * 1234567) & 0xFFFFFFFF\n                \n                # Verify with second plaintext\n                p2_left = getleft(plaintext2)\n                p2_right = getright(plaintext2)\n                L3_2, R3_2 = partial_encrypt(p2_left, p2_right, key0, key1, key2, key3, key4)\n                \n                L3_2_dec, R3_2_dec = partial_decrypt(ciphertext2, key5)\n                \n           "]
