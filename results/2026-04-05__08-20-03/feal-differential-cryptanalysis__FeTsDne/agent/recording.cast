[1262.57901, "o", "> "]
[1262.579358, "o", "            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[1262.579525, "o", "> "]
[1262.579669, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.58033, "o", "            L2_diff = (R3_0 ^ f_function(L3_0 ^ key4)) ^ (R3_1 ^ f_function(L3_1 ^ key4))\r\n\u001b[?2004l\r"]
[1262.580485, "o", "\u001b[?2004h> "]
[1262.580627, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.580913, "o", "            if L2_diff in valid_diffs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1262.581117, "o", "> "]
[1262.581258, "o", "                matches += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.581597, "o", "                if matches >= 3:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1262.581763, "o", "> "]
[1262.581966, "o", "                    return key5\r\n\u001b[?2004l\r"]
[1262.582102, "o", "\u001b[?2004h> "]
[1262.582287, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1262.58243, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
