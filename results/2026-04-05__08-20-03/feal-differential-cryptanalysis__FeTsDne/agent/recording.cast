[399.120287, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef decrypt_two_rounds(ciphertext, key4, key5):\n    c_left = getleft(ciphertext)\n    c_right = getright(ciphertext)\n    R4 = c_left\n    L4 = c_right ^ R4\n    R3 = L4\n    L3 = R4 ^ f_function(R3 ^ key5)\n    R2 = L3\n    L2 = R3 ^ f_function(R2 ^ key4)\n    return L2, R2\n\ndef attack(encrypt_fn):\n    # Use specific plaintexts\n    p0 = 0\n    c0 = encrypt_fn(p0)\n    \n    "]
[399.120483, "i", "p1 = 1\n    c1 = encrypt_fn(p1)\n    \n    p2 = 0x100000000\n    c2 = encrypt_fn(p2)\n    \n    # Brute force key[4] and key[5]\n    for seed4 in range(0x10000):\n        key4 = (seed4 * 1234567) & 0xFFFFFFFF\n        \n        for seed5 in range(0x10000):\n            key5 = (seed5 * 1234567) & 0xFFFFFFFF\n            \n            # Decrypt two rounds\n            L2_0, R2_0 = decrypt_two_rounds(c0, key4, key5)\n            L2_1, R2_1 = decrypt_two_rounds(c1, key4, key5)\n            L2_2, R2_2 = decrypt_two_rounds(c2, key4, key5)\n            \n            # For plaintext p=0: L=key[0], R=key[1] after whitening\n            # After pre-round: L=key[0], R=key[0]^key[1]\n            # After round 1: L=key[0]^key[1], R=key[0]^f((key[0]^key[1])^key[2])\n            # After round 2: the state is (L2_0, R2_0)\n            \n            # For plaintext p=1: L=key[0], R=key[1]^1 after whitening\n            # After pre-round: L=key[0], R=key[0]^key[1]^1\n            # After round 1: L=key[0]^key[1]^1, R=key[0]^f((key[0]^key[1]^1)^key[2])\n"]
[399.120677, "i", "            \n            # The key observation: \n            # After round 1, L1_0 = key[0]^key[1], L1_1 = key[0]^key[1]^1\n            # So L1_0 ^ L1_1 = 1\n            \n            # After round 2:\n            # R2 = L1 ^ f(R1 ^ key[3])\n            # L2 = R1\n            \n            # So: L2_0 ^ L2_1 = R1_0 ^ R1_1\n            # And: R1_0 = key[0] ^ f((key[0]^key[1]) ^ key[2])\n            # And: R1_1 = key[0] ^ f((key[0]^key[1]^1) ^ key[2])\n            \n            # This is still complex. Let me use a simpler check:\n            # For p=0 and p=0x100000000, the difference is in the left half\n            # After whitening: (key[0], key[1]) and (key[0]^1, key[1])\n            # After pre-round: (key[0], key[0]^key[1]) and (key[0]^1, key[0]^key[1]^1)\n            \n            # Check: L2_0 ^ L2_2 should relate to the plaintext difference\n            # For correct keys, there's structure. For wrong keys, it's random.\n            \n            # Use XOR relationships\n            diff_01_L = L2_0 ^ L2_1\n            dif"]
[399.120825, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r"]
[399.12094, "i", "f_02_L = L2_0 ^ L2_2\n            diff_01_R = R2_0 ^ R2_1\n            diff_02_R = R2_0 ^ R2_2\n            \n            # For the correct keys, these differences should have specific properties\n            # Try a simple check: the XOR of differences should have low hamming weight\n            combined = diff_01_L ^ diff_02_L ^ diff_01_R ^ diff_02_R\n            bits = bin(combined).count('1')\n            \n            # This is still a weak heuristic. Let me try a different approach:\n            # Check if diff_01_L has very low hamming weight (indicating structure)\n            bits_01_L = bin(diff_01_L).count('1')\n            bits_02_L = bin(diff_02_L).count('1')\n            \n            # For correct keys, these should be non-random\n            # This is a guess, but let's try it\n            if bits_01_L <= 4 and bits_02_L <= 4:\n                return key5\n    \n    return 0\n\nEOF\n"]
