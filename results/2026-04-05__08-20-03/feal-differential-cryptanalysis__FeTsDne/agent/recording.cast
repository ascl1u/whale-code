[62.454837, "o", "    \"\"\"Partially decrypt the last round given a key[5] candidate\"\"\"\r\n\u001b[?2004l\r"]
[62.454988, "o", "\u001b[?2004h> "]
[62.455263, "o", "    # Ciphertext = merge(R4, L4) after swap\r\n\u001b[?2004l\r\u001b[?2004h"]
[62.455432, "o", "> "]
[62.455888, "o", "    # So ciphertext_left = R4, ciphertext_right = L4 (after post-round XOR)\r\n\u001b[?2004l\r"]
[62.456065, "o", "\u001b[?2004h> "]
[62.456196, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.456384, "o", "    c_left = getleft(ciphertext)\r\n\u001b[?2004l\r"]
[62.456452, "o", "\u001b[?2004h"]
[62.45655, "o", "> "]
[62.456708, "o", "    c_right = getright(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h"]
[62.456873, "o", ">     \r\n\u001b[?2004l\r"]
[62.457047, "o", "\u001b[?2004h> "]
[62.457392, "o", "    # Undo the final swap: before swap we had (L4, R4)\r\n\u001b[?2004l\r"]
[62.457495, "o", "\u001b[?2004h> "]
[62.457748, "o", "    # After swap: (R4, L4)\r\n\u001b[?2004l\r"]
[62.457905, "o", "\u001b[?2004h> "]
[62.458095, "o", "    R4 = c_left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.458328, "o", "    L4_xored = c_right\r\n\u001b[?2004l\r\u001b[?2004h"]
[62.458547, "o", ">     \r\n\u001b[?2004l\r"]
[62.458731, "o", "\u001b[?2004h> "]
[62.458966, "o", "    # Undo post-round mixing: L4 = L4 XOR R4\r\n\u001b[?2004l\r\u001b[?2004h"]
[62.459162, "o", "> "]
[62.459281, "o", "    L4 = L4_xored ^ R4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.459435, "o", "    \r\n\u001b[?2004l\r"]
[62.459621, "o", "\u001b[?2004h> "]
[62.45988, "o", "    # Now we have L4 and R4 after round 4\r\n\u001b[?2004l\r"]
[62.46, "o", "\u001b[?2004h> "]
