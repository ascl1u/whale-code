[288.244912, "o", "            # This is still complex. Let me use a simpler statistical test:\r\n\u001b[?2004l\r"]
[288.245047, "o", "\u001b[?2004h> "]
[288.245893, "o", "            # For wrong keys, the decrypted values should look random\r\n\u001b[?2004l\r"]
[288.245941, "o", "\u001b[?2004h> "]
[288.246584, "o", "            # For right keys, there should be some structure\r\n\u001b[?2004l\r"]
[288.246717, "o", "\u001b[?2004h> "]
[288.24685, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.247344, "o", "            # Count how many bits are set in the differences\r\n\u001b[?2004l\r"]
[288.247459, "o", "\u001b[?2004h> "]
[288.248046, "o", "            total_bits = bin(diff_01_L).count('1') + bin(diff_01_R).count('1')\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.248242, "o", "> "]
[288.248714, "o", "            total_bits += bin(diff_02_L).count('1') + bin(diff_02_R).count('1')\r\n\u001b[?2004l\r"]
[288.248759, "o", "\u001b[?2004h> "]
[288.248947, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.249096, "o", "> "]
[288.249578, "o", "            # For wrong keys, expect about 50% of bits set (random)\r\n\u001b[?2004l\r"]
[288.249683, "o", "\u001b[?2004h> "]
[288.25008, "o", "            # For right keys, might have fewer bits set (structure)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.2504, "o", "            # This is a weak test but might work\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.250538, "o", "> "]
[288.250619, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.25074, "o", "> "]
[288.251206, "o", "            # Actually, this won't work well. Let me try yet another approach:\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.251326, "o", "> "]
[288.251671, "o", "            # Just try to find key[3] that's consistent\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.251833, "o", "            \r\n\u001b[?2004l\r"]
[288.251926, "o", "\u001b[?2004h> "]
[288.252079, "o", "            # Sample a few key[3] values\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.25218, "o", "> "]
[288.252585, "o", "            for seed3 in range(0, 0x10000, 512):  # Sample sparsely\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.25263, "o", "> "]
[288.25301, "o", "                key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.253224, "o", "> "]
[288.253373, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.253653, "o", "                # Decrypt round 2 for first two plaintexts\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.2537, "o", "> "]
[288.253892, "o", "                R1_0 = L2_0\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.254016, "o", "> "]
[288.254257, "o", "                L1_0 = R2_0 ^ f_function(R1_0 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.25436, "o", "> "]
[288.254402, "o", "                \r\n\u001b[?2004l\r"]
[288.254518, "o", "\u001b[?2004h> "]
[288.25472, "o", "                R1_1 = L2_1\r\n\u001b[?2004l\r"]
[288.254759, "o", "\u001b[?2004h> "]
[288.25514, "o", "                L1_1 = R2_1 ^ f_function(R1_1 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.255179, "o", "> "]
[288.255374, "o", "                \r\n\u001b[?2004l\r"]
[288.25546, "o", "\u001b[?2004h> "]
[288.255849, "o", "                # Check if we can find a consistent key[2]\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.255893, "o", "> "]
[288.256214, "o", "                # Sample key[2] values\r\n\u001b[?2004l\r"]
[288.256338, "o", "\u001b[?2004h> "]
[288.256752, "o", "                for seed2 in range(0, 0x10000, 512):  # Sample sparsely\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.256793, "o", "> "]
[288.257187, "o", "                    key2 = (seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.2574, "o", "> "]
[288.257557, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.257814, "o", "                    # Decrypt round 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.257948, "o", "> "]
[288.258154, "o", "                    R0_0 = L1_0\r\n\u001b[?2004l\r"]
[288.258197, "o", "\u001b[?2004h"]
[288.258302, "o", "> "]
[288.258691, "o", "                    L0_0 = R1_0 ^ f_function(R0_0 ^ key2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.258798, "o", "> "]
[288.258963, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.25909, "o", "> "]
[288.259269, "o", "                    R0_1 = L1_1\r\n\u001b[?2004l\r"]
[288.259394, "o", "\u001b[?2004h> "]
[288.259806, "o", "                    L0_1 = R1_1 ^ f_function(R0_1 ^ key2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.259938, "o", "> "]
[288.260073, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.260206, "o", "> "]
[288.260576, "o", "                    # After pre-round, before round 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.260717, "o", "> "]
[288.261334, "o", "                    # L0, R0 where R0 is the right value after pre-round\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.261715, "o", "                    # Pre-round does: R = R XOR L\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.261797, "o", "> "]
[288.262379, "o", "                    # So before pre-round: R_before = R0, L_before = R0 XOR L0\r\n\u001b[?2004l\r"]
[288.262423, "o", "\u001b[?2004h> "]
[288.262669, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.262787, "o", "> "]
[288.263311, "o", "                    # After whitening: L_before = plaintext_left XOR key[0]\r\n\u001b[?2004l\r"]
[288.263425, "o", "\u001b[?2004h> "]
[288.263967, "o", "                    #                  R_before = plaintext_right XOR key[1]\r\n\u001b[?2004l\r"]
[288.264011, "o", "\u001b[?2004h> "]
[288.26424, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.264295, "o", "> "]
[288.264605, "o", "                    # For p0 = 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.264742, "o", "> "]
[288.265175, "o", "                    # L_before_0 = key[0], R_before_0 = key[1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.265313, "o", "> "]
[288.265714, "o", "                    # After pre-round: R0_0 = key[1] XOR key[0]\r\n\u001b[?2004l\r"]
[288.265849, "o", "\u001b[?2004h> "]
[288.265986, "o", "                    \r\n\u001b[?2004l\r"]
[288.26604, "o", "\u001b[?2004h> "]
[288.266489, "o", "                    # So: key[0] XOR key[1] = R0_0\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.266584, "o", "> "]
[288.267092, "o", "                    # And: L0_0 = R0_0 (wait, that's not right)\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.267212, "o", "> "]
[288.26735, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.267468, "o", "> "]
[288.267733, "o", "                    # Let me recalculate:\r\n\u001b[?2004l\r"]
[288.267874, "o", "\u001b[?2004h> "]
[288.268531, "o", "                    # After whitening: L_w = p_left XOR key[0], R_w = p_right XOR key[1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.268684, "o", "> "]
[288.269146, "o", "                    # After pre-round: R_p = R_w XOR L_w, L_p = L_w\r\n\u001b[?2004l\r"]
[288.269306, "o", "\u001b[?2004h> "]
[288.269864, "o", "                    # After round 1: R1 = L_p XOR f(R_p XOR key[2]), L1 = R_p\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.26998, "o", "> "]
[288.27036, "o", "                    # So: L1 = R_p = R_w XOR L_w\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.270521, "o", "> "]
[288.270883, "o", "                    # And: R1 = L_w XOR f(R_p XOR key[2])\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.270928, "o", "> "]
[288.271161, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.271333, "o", "> "]
[288.271839, "o", "                    # We decrypted to get L0, R0 which are actually L_p, R_p\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.271993, "o", "> "]
[288.272641, "o", "                    # So: R0 = R_p = R_w XOR L_w = (p_right XOR key[1]) XOR (p_left XOR key[0])\r\n\u001b[?2004l\r"]
[288.272687, "o", "\u001b[?2004h> "]
[288.273217, "o", "                    # And: L0 = L_p = L_w = p_left XOR key[0]\r\n\u001b[?2004l\r"]
[288.273316, "o", "\u001b[?2004h> "]
[288.273489, "o", "                    \r\n\u001b[?2004l\r"]
[288.273687, "o", "\u001b[?2004h> "]
[288.274186, "o", "                    # For p0 = 0: R0_0 = key[1] XOR key[0], L0_0 = key[0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.274341, "o", "> "]
[288.274958, "o", "                    # For p1 = 1: R0_1 = (1 XOR key[1]) XOR key[0] = 1 XOR key[1] XOR key[0]\r\n\u001b[?2004l\r"]
[288.274999, "o", "\u001b[?2004h"]
[288.275162, "o", "> "]
[288.27543, "o", "                    #             L0_1 = key[0]\r\n\u001b[?2004l\r"]
[288.275553, "o", "\u001b[?2004h> "]
[288.275689, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.275795, "o", "> "]
[288.330419, "o", "                    # So: L0_0 should equal L0_1 (both are key[0])\r\n\u001b[?2004l\r\u001b[?2004h>                     if L0_0 == L0_1:\r\n\u001b[?2004l\r\u001b[?2004h>                         # Also check with p2\r\n\u001b[?2004l\r\u001b[?2004h>                         R1_2 = L2_2\r\n\u001b[?2004l\r\u001b[?2004h>                         L1_2 = R2_2 ^ f_function(R1_2 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h>                         R0_2 = L1_2\r\n\u001b[?2004l\r\u001b[?2004h>                         L0_2 = R1_2 ^ f_function(R0_2 ^ key2)\r\n\u001b[?2004l\r\u001b[?2004h>                         \r\n\u001b[?2004l\r\u001b[?2004h>                         # For p2 = 0x0000000100000000:\r\n\u001b[?2004l\r\u001b[?2004h>                         # p2_left = 1, p2_right = 0\r\n\u001b[?2004l\r\u001b[?2004h>                         # L0_2 = 1 XOR key[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[288.331136, "o", "                        # R0_2 = key[1] XOR (1 XOR key[0]) = key[1] XOR 1 XOR key[0]\r\n\u001b[?2004l\r"]
[288.331282, "o", "\u001b[?2004h"]
[288.331321, "o", "> "]
[288.331548, "o", "                        \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.331681, "o", "> "]
[288.332127, "o", "                        # Check: L0_0 XOR L0_2 should equal 1\r\n\u001b[?2004l\r"]
[288.332252, "o", "\u001b[?2004h> "]
[288.33264, "o", "                        if (L0_0 ^ L0_2) == 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.332825, "o", "> "]
[288.33312, "o", "                            # Found it!\r\n\u001b[?2004l\r"]
[288.333271, "o", "\u001b[?2004h> "]
[288.333565, "o", "                            return key5\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.333719, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[288.333843, "o", "> "]
[288.333935, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[288.334011, "o", "> \r\n\u001b[?2004l\r"]
[288.334136, "o", "\u001b[?2004h> "]
[288.334248, "o", "EOF\r\n\u001b[?2004l\r"]
