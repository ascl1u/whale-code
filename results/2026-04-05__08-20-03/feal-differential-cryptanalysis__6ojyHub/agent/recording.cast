[1055.683924, "o", "\u001b[?2004h"]
[1055.684072, "o", "> "]
[1055.684195, "o", "            fr1, fl1 = getleft(ct1), getright(ct1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1055.684292, "o", "> "]
[1055.684467, "o", "            fr2, fl2 = getleft(ct2), getright(ct2)\r\n\u001b[?2004l\r\u001b[?2004h"]
