[994.148577, "i", "cat > analyze_scores3.py << 'EOF'\n#!/usr/bin/env python3\nimport feal\nimport attack\n\nfeal.create_random_keys()\nprint(\"Actual key[5]:\", feal.key[5])\n\n# Find correct seed\ncorrect_seed = None\nfor seed in range(0x10000):\n    if (seed * 1234567) & 0xFFFFFFFF == feal.key[5]:\n        correct_seed = seed\n        break\n\nprint(f\"Correct seed: {correct_seed}\\n\")\n\n# Collect data\ndata = []\nfor i in range(8):\n    pt1 = i\n    pt2 = i ^ 1\n    ct1 = feal.encrypt(pt1)\n    ct2 = feal.encrypt(pt2)\n    data.append((ct1, ct2))\n\n# Test all seeds\nscores = []\nfor seed in range(0x10000):\n    candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n    score = 0\n    \n    for ct1, ct2 in data:\n        fr1, fl1 = attack.getleft(ct1), attack.getright(ct1)\n        fr2, fl2 = attack.getleft(ct2), attack.getright(ct2)\n        \n        rb1 = fl1 ^ fr1\n        rb2 = fl2 ^ fr2\n        \n        lb1 = fr1 ^ attack.f_function(rb1 ^ candidate_key5)\n        lb2 = fr2 ^ attack.f_function(rb2 ^ candidate_key5)\n        \n        left_diff = lb1 ^ lb2\n        bits "]
[994.148739, "i", "= bin(left_diff).count('1')\n        score += abs(bits - 16)\n    \n    scores.append((score, seed))\n\nscores.sort()\n\n# Find rank of correct seed\nfor rank, (score, seed) in enumerate(scores):\n    if seed == correct_seed:\n        print(f\"Correct seed rank: {rank} out of 65536\")\n        print(f\"Correct seed score: {score}\")\n        print(f\"\\nNearby scores:\")\n        for i in range(max(0, rank-5), min(len(scores), rank+6)):\n            s, sd = scores[i]\n            marker = \" <-- CORRECT\" if sd == correct_seed else \"\"\n            print(f\"  Rank {i:5d}: seed {sd:5d}, score {s:3d}{marker}\")\n        break\n\nprint(f\"\\nMin score: {scores[0][0]}, Max score: {scores[-1][0]}\")\nprint(f\"Best seed (rank 0): {scores[0][1]}\")\nEOF\n"]
[994.148914, "o", "cat > analyze_scores3.py << 'EOF'\r\n\u001b[?2004l\r"]
[994.149078, "o", "\u001b[?2004h> "]
[994.149251, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r"]
[994.149364, "o", "\u001b[?2004h> "]
[994.149464, "o", "import feal\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.149581, "o", "import attack\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[994.149711, "o", "\u001b[?2004h> "]
[994.14987, "o", "feal.create_random_keys()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.150044, "o", "print(\"Actual key[5]:\", feal.key[5])\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.150073, "o", "> "]
[994.150429, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.150579, "o", "# Find correct seed\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.15073, "o", "> "]
[994.150846, "o", "correct_seed = None\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.150924, "o", "> "]
[994.15107, "o", "for seed in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.151315, "o", "    if (seed * 1234567) & 0xFFFFFFFF == feal.key[5]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.151471, "o", "> "]
[994.151608, "o", "        correct_seed = seed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.151723, "o", "        break"]
[994.151884, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.152109, "o", "print(f\"Correct seed: {correct_seed}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.152236, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.152333, "o", "# Collect data\r\n\u001b[?2004l\r"]
[994.152472, "o", "\u001b[?2004h> data = []\r\n\u001b[?2004l\r"]
[994.152596, "o", "\u001b[?2004h> "]
[994.152733, "o", "for i in range(8):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.152908, "o", "    pt1 = i\r\n\u001b[?2004l\r"]
[994.152989, "o", "\u001b[?2004h> "]
[994.153129, "o", "    pt2 = i ^ 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.153265, "o", "    ct1 = feal.encrypt(pt1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.153371, "o", "> "]
[994.153504, "o", "    ct2 = feal.encrypt(pt2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.15366, "o", "    data.append((ct1, ct2))\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.15384, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.153986, "o", "# Test all seeds\r\n\u001b[?2004l\r\u001b[?2004h> scores = []\r\n\u001b[?2004l\r"]
[994.154027, "o", "\u001b[?2004h> "]
[994.154233, "o", "for seed in range(0x10000):\r\n\u001b[?2004l\r"]
[994.154361, "o", "\u001b[?2004h> "]
[994.154601, "o", "    candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.154718, "o", "> "]
[994.154846, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.154952, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.15515, "o", "    for ct1, ct2 in data:\r\n\u001b[?2004l\r"]
[994.155287, "o", "\u001b[?2004h> "]
[994.155564, "o", "        fr1, fl1 = attack.getleft(ct1), attack.getright(ct1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.155672, "o", "> "]
[994.15594, "o", "        fr2, fl2 = attack.getleft(ct2), attack.getright(ct2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.156087, "o", "> "]
[994.156197, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.156308, "o", "        rb1 = fl1 ^ fr1\r\n\u001b[?2004l\r"]
[994.156369, "o", "\u001b[?2004h> "]
[994.156455, "o", "        rb2 = fl2 ^ fr2\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.156546, "o", "> "]
[994.156622, "o", "        \r\n\u001b[?2004l\r"]
[994.156687, "o", "\u001b[?2004h> "]
[994.157089, "o", "        lb1 = fr1 ^ attack.f_function(rb1 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.157197, "o", "> "]
[994.157458, "o", "        lb2 = fr2 ^ attack.f_function(rb2 ^ candidate_key5)\r\n\u001b[?2004l\r"]
[994.157566, "o", "\u001b[?2004h> "]
[994.157727, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.157857, "o", "        left_diff = lb1 ^ lb2\r\n\u001b[?2004l\r"]
[994.157969, "o", "\u001b[?2004h> "]
[994.158116, "o", "        bits = bin(left_diff).count('1')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.158329, "o", "        score += abs(bits - 16)\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.15846, "o", ">     \r\n\u001b[?2004l\r"]
[994.15853, "o", "\u001b[?2004h> "]
[994.158725, "o", "    scores.append((score, seed))\r\n\u001b[?2004l\r"]
[994.158754, "o", "\u001b[?2004h"]
[994.158902, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.159039, "o", "scores.sort()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[994.159163, "o", "\u001b[?2004h> "]
[994.159295, "o", "# Find rank of correct seed\r\n\u001b[?2004l\r"]
[994.159382, "o", "\u001b[?2004h> "]
[994.159589, "o", "for rank, (score, seed) in enumerate(scores):\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.15969, "o", "> "]
[994.159793, "o", "    if seed == correct_seed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.159883, "o", "> "]
[994.1601, "o", "        print(f\"Correct seed rank: {rank} out of 65536\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.160182, "o", "> "]
[994.160348, "o", "        print(f\"Correct seed score: {score}\")\r\n\u001b[?2004l\r"]
[994.160379, "o", "\u001b[?2004h> "]
[994.160576, "o", "        print(f\"\\nNearby scores:\")\r\n\u001b[?2004l\r"]
[994.160654, "o", "\u001b[?2004h> "]
[994.160925, "o", "        for i in range(max(0, rank-5), min(len(scores), rank+6)):\r\n\u001b[?2004l\r"]
[994.16103, "o", "\u001b[?2004h> "]
[994.161181, "o", "            s, sd = scores[i]\r\n\u001b[?2004l\r"]
[994.161318, "o", "\u001b[?2004h> "]
[994.161634, "o", "            marker = \" <-- CORRECT\" if sd == correct_seed else \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.162051, "o", "            print(f\"  Rank {i:5d}: seed {sd:5d}, score {s:3d}{marker}\")\r\n\u001b[?2004l\r"]
[994.162167, "o", "\u001b[?2004h> "]
[994.16228, "o", "        break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[994.162559, "o", "print(f\"\\nMin score: {scores[0][0]}, Max score: {scores[-1][0]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.162655, "o", "> "]
[994.162858, "o", "print(f\"Best seed (rank 0): {scores[0][1]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[994.163019, "o", "> EOF\r\n\u001b[?2004l\r"]
