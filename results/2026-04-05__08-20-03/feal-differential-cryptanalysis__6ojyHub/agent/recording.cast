[729.413265, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\n    \n    # Collect plaintext pairs with zero difference (same plaintext encrypted twice should give same result)\n    # and pairs with specific differences\n    \n    # First, collect some basic pairs\n    data = []\n    for i in range(64):\n        pt1 = i\n        pt2 = i ^ 0x8080808080808"]
[729.413775, "i", "080  # Specific difference\n        ct1 = encrypt_fn(pt1)\n        ct2 = encrypt_fn(pt2)\n        data.append((ct1, ct2))\n    \n    # For each candidate, compute how many pairs give a \"reasonable\" difference after partial decryption\n    scores = {}\n    \n    for seed in range(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        \n        # Count differences that fall into a specific range\n        count = 0\n        \n        for ct1, ct2 in data:\n            # Partially decrypt\n            fr1 = getleft(ct1)\n            fl1 = getright(ct1)\n            rb1 = fl1 ^ fr1\n            lb1 = fr1 ^ f_function(rb1 ^ candidate_key5)\n            \n            fr2 = getleft(ct2)\n            fl2 = getright(ct2)\n            rb2 = fl2 ^ fr2\n            lb2 = fr2 ^ f_function(rb2 ^ candidate_key5)\n            \n            # Compute difference\n            diff_l = lb1 ^ lb2\n            diff_r = rb1 ^ rb2\n            \n            # Simple scoring: count non-zero differences\n            if diff_l != 0 and diff_r != 0"]
[729.414008, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.414066, "i", ":\n                count += 1\n        \n        scores[candidate_key5] = count\n    \n    # Return the key with maximum score\n    return max(scores, key=scores.get)\n\nEOF\n"]
