[825.534062, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\n    \n    # Use different plaintext pairs - try various differences\n    data = []\n    # Try difference of 1 in right half\n    for i in range(2):\n        pt1 = i << 32\n        pt2 = (i << 32) | 1\n        ct1 = encrypt_fn(pt1)\n        ct2 = encrypt_fn(pt2)\n        data.append((ct1, ct2))"]
[825.534281, "i", "\n    \n    # Try difference in left half\n    for i in range(2):\n        pt1 = i\n        pt2 = i | (1 << 32)\n        ct1 = encrypt_fn(pt1)\n        ct2 = encrypt_fn(pt2)\n        data.append((ct1, ct2))\n    \n    # Compute scores for all candidates\n    scores = []\n    for seed in range(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        score = 0\n        \n        for ct1, ct2 in data:\n            fr1, fl1 = getleft(ct1), getright(ct1)\n            fr2, fl2 = getleft(ct2), getright(ct2)\n            \n            rb1 = fl1 ^ fr1\n            rb2 = fl2 ^ fr2\n            \n            lb1 = fr1 ^ f_function(rb1 ^ candidate_key5)\n            lb2 = fr2 ^ f_function(rb2 ^ candidate_key5)\n            \n            # Different scoring: look at both left and right differences\n            left_diff = lb1 ^ lb2\n            right_diff = rb1 ^ rb2\n            \n            # Score based on absolute difference from expected value\n            left_bits = bin(left_diff).count('1')\n            right_bits = bin(right_"]
[825.534401, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r"]
[825.534446, "i", "diff).count('1')\n            \n            # Penalize if too similar or too different\n            # Expect around 16 bits set (half of 32)\n            score += abs(left_bits - 16) + abs(right_bits - 16)\n        \n        scores.append((score, candidate_key5))\n    \n    # Return the key with score closest to ideal (minimum penalty)\n    scores.sort()\n    return scores[0][1]\n\nEOF\n"]
