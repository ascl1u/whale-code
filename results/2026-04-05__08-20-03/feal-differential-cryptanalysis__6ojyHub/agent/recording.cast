[1055.684868, "o", "> "]
[1055.685055, "o", "            rb2 = fl2 ^ fr2\r\n\u001b[?2004l\r\u001b[?2004h"]
[1055.685145, "o", "> "]
[1055.685238, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[1055.68533, "o", "> "]
