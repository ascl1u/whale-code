[1063.777152, "o", "total 16\r\ndrwxr-xr-x 1 root root 4096 Apr  5 15:38 .\r\ndrwxr-xr-x 1 root root 4096 Apr  5 15:20 ..\r\n-rw-r--r-- 1 root root 1827 Apr  5 15:38 attack.py\r\n-rw-r--r-- 1 root root 1951 Sep 13  2025 feal.py\r\n"]
