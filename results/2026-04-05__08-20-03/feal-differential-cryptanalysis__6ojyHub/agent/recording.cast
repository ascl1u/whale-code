[173.803926, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef g_function(a, b, x):\n    \"\"\"FEAL G function (same as in feal.py)\"\"\"\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\n\ndef f_function(input_val):\n    \"\"\"FEAL F function (same as in feal.py)\"\"\"\n    x = [0] * 4\n    y = [0] * 4\n\n    # Extract bytes from input (big-endian)\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n\n    # Apply G function operations\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n\n    # Combine bytes into output (big-endian)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n\n    return output & 0xFFFFFFFF\n\n\ndef getleft(x):\n    \"\"\"Get the left (upper) 32 bits of a 64-bit value\"\"\"\n    return (x >> 32) & 0xFFFFFFFF\n\n\ndef getright(x):\n    \"\"\"Get the right (lower) 32 bits of a 64-bit value\"\"\"\n    return x & 0xFFFFFFFF\n\n\ndef attack(encrypt_fn):\n   "]
[173.804087, "i", " \"\"\"Recover key[5] using chosen plaintext attack\"\"\"\n    \n    # Collect plaintext-ciphertext pairs with specific patterns\n    # We'll use pairs that differ in controlled ways\n    pairs = []\n    \n    # Collect diverse plaintexts\n    for i in range(20):\n        plaintext = i * 0x1111111111111111\n        ciphertext = encrypt_fn(plaintext)\n        pairs.append((plaintext, ciphertext))\n    \n    # Create differential pairs (plaintexts that differ in specific bits)\n    diff_pairs = []\n    for i in range(10):\n        pt1 = i << 32\n        pt2 = (i << 32) | 1  # Differ in LSB of right half\n        ct1 = encrypt_fn(pt1)\n        ct2 = encrypt_fn(pt2)\n        diff_pairs.append((pt1, ct1, pt2, ct2))\n    \n    # Score each candidate key\n    candidate_scores = {}\n    \n    for seed in range(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        score = 0\n        \n        # Test with regular pairs - check for collisions\n        decrypted_values = set()\n        collision_count = 0\n        \n        for plaintext"]
[173.804175, "i", ", ciphertext in pairs:\n            final_right = getleft(ciphertext)\n            final_left = getright(ciphertext)\n            before_xor_left = final_left ^ final_right\n            before_xor_right = final_right\n            \n            right_before_round3 = before_xor_left\n            left_before_round3 = before_xor_right ^ f_function(right_before_round3 ^ candidate_key5)\n            \n            val = (left_before_round3, right_before_round3)\n            if val in decrypted_values:\n                collision_count += 1\n            decrypted_values.add(val)\n        \n        # Fewer collisions is better (correct key should have no collisions)\n        score -= collision_count * 1000\n        \n        # Test with differential pairs\n        for pt1, ct1, pt2, ct2 in diff_pairs:\n            # Partially decrypt both\n            fr1 = getleft(ct1)\n            fl1 = getright(ct1)\n            bxl1 = fl1 ^ fr1\n            bxr1 = fr1\n            rb1 = bxl1\n            lb1 = bxr1 ^ f_function(rb1 ^ candidate_key5)\n      "]
[173.8042, "o", "cat > attack.py << 'EOF'\r\n"]
[173.804212, "i", "      \n            fr2 = getleft(ct2)\n            fl2 = getright(ct2)\n            bxl2 = fl2 ^ fr2\n            bxr2 = fr2\n            rb2 = bxl2\n            lb2 = bxr2 ^ f_function(rb2 ^ candidate_key5)\n            \n            # Compute difference\n            left_diff = lb1 ^ lb2\n            right_diff = rb1 ^ rb2\n            \n            # For the correct key, the difference should follow certain patterns\n            # Award points for reasonable-looking differences\n            # (This is heuristic-based)\n            if left_diff != 0 or right_diff != 0:\n                score += 1\n        \n        candidate_scores[candidate_key5] = score\n    \n    # Return the candidate with the best score\n    best_key = max(candidate_scores, key=candidate_scores.get)\n    return best_key\n\nEOF\n"]
[173.804349, "o", "\u001b[?2004l\r, ciphertext in pairs:\r\n            final_right = getleft(ciphertext)\r\n            final_left = getright(ciphertext)\r\n            before_xor_left = final_left ^ final_right\r\n            before_xor_right = final_right\r\n            \r\n            right_before_round3 = before_xor_left\r\n            left_before_roun"]
[173.804472, "o", "d3 = before_xor_right ^ f_function(right_before_round3 ^ candidate_key5)\r\n            \r\n            val = (left_before_round3, right_before_round3)\r\n            if val in decrypted_values:\r\n"]
[173.804599, "o", "                collision_count += 1\r\n            decrypted_values.add(val)\r\n        \r\n        # Fewer collisions is better (correct key should have no collisions)\r\n        score -= collision_count * 1000\r\n        \r\n        # Test with differential"]
[173.804711, "o", " pairs\r\n        for pt1, ct1, pt2, ct2 in diff_pairs:\r\n            # Partially decrypt both\r\n            fr1 = getleft(ct1)\r\n            fl1 = getright(ct1)\r\n            bxl1 = fl1 ^ fr1\r\n            bxr1 = fr1\r\n            rb1 = bxl1\r\n            lb1 = bxr1 ^ f_function(rb1 ^ candidate_key5)\r\n            \r\n     "]
[173.804786, "o", "       fr2 = getleft(ct2)\r\n            fl2 = getright(ct2)\r\n            bxl2 = fl2 ^ fr2\r\n            bxr2 = fr2\r\n            rb2 = bxl2\r\n            lb2 = bxr2 ^ f_function(rb2 ^ candidate_key5)\r\n            \r\n            # Compute difference\r\n            left_diff = lb1 ^ lb2\r\n            right_diff = rb1 ^ rb2\r\n   "]
[173.804896, "o", "         \r\n            # For the correct key, the difference should follow certain patterns\r\n            # Award points for reasonable-looking differences\r\n            # (This is heuristic-based)\r\n            if left_diff != 0 or right_diff != 0:\r\n                score += 1\r\n        \r\n        can"]
[173.805003, "o", "didate_scores[candidate_key5] = score\r\n    \r\n    # Return the candidate with the best score\r\n    best_key = max(candidate_scores, key=candidate_scores.get)\r\n    return best_key\r\n\r\nEOF\r\n"]
[173.805119, "o", "\u001b[?2004h> "]
[173.805233, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r"]
[173.805389, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[173.805525, "o", "\u001b[?2004h> "]
[173.805639, "o", "def g_function(a, b, x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.805925, "o", "    \"\"\"FEAL G function (same as in feal.py)\"\"\"\r\n\u001b[?2004l\r"]
[173.806911, "o", "\u001b[?2004h> "]
[173.807011, "o", "    temp = (a + b + x) & 0xFF\r\n\u001b[?2004l\r"]
[173.807253, "o", "\u001b[?2004h>     return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def f_function(input_val):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"FEAL F function (same as in feal.py)\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     x = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h>     y = [0] * 4\r\n\u001b[?2004l\r"]
[173.807454, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.807551, "o", "    # Extract bytes from input (big-endian)\r\n\u001b[?2004l\r"]
[173.807665, "o", "\u001b[?2004h> "]
[173.807816, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.807984, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r"]
[173.808076, "o", "\u001b[?2004h> "]
[173.808236, "o", "        input_val >>= 8\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.808419, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.808633, "o", "    # Apply G function operations\r\n\u001b[?2004l\r"]
[173.808803, "o", "\u001b[?2004h> "]
[173.80909, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.809159, "o", "> "]
[173.809429, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.8097, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.809977, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.810086, "o", "> \r\n\u001b[?2004l\r"]
[173.810189, "o", "\u001b[?2004h> "]
[173.810371, "o", "    # Combine bytes into output (big-endian)\r\n\u001b[?2004l\r"]
[173.810466, "o", "\u001b[?2004h> "]
[173.810536, "o", "    output = 0\r\n\u001b[?2004l\r"]
[173.810694, "o", "\u001b[?2004h> "]
[173.810794, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.810895, "o", "> "]
[173.810992, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r"]
[173.811113, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.811272, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.811368, "o", "> \r\n\u001b[?2004l\r"]
[173.811444, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.811517, "o", "def getleft(x):\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.811559, "o", "> "]
[173.811924, "o", "    \"\"\"Get the left (upper) 32 bits of a 64-bit value\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.81203, "o", "> "]
[173.812204, "o", "    return (x >> 32) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[173.812322, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[173.812466, "o", "\u001b[?2004h"]
[173.812673, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[173.812788, "o", "> def getright(x):\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.812889, "o", "> "]
[173.813209, "o", "    \"\"\"Get the right (lower) 32 bits of a 64-bit value\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.813328, "o", "> "]
[173.813517, "o", "    return x & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.813632, "o", "> \r\n\u001b[?2004l\r"]
[173.813738, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.813901, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.813995, "o", "> "]
[173.814232, "o", "    \"\"\"Recover key[5] using chosen plaintext attack\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.814272, "o", ">     \r\n\u001b[?2004l\r"]
[173.814435, "o", "\u001b[?2004h> "]
[173.81472, "o", "    # Collect plaintext-ciphertext pairs with specific patterns\r\n\u001b[?2004l\r"]
[173.814831, "o", "\u001b[?2004h"]
[173.814903, "o", "> "]
[173.81513, "o", "    # We'll use pairs that differ in controlled ways\r\n\u001b[?2004l\r"]
[173.815267, "o", "\u001b[?2004h> "]
[173.815385, "o", "    pairs = []\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[173.815416, "o", "\u001b[?2004h> "]
[173.815616, "o", "    # Collect diverse plaintexts\r\n\u001b[?2004l\r"]
[173.815708, "o", "\u001b[?2004h> "]
[173.815813, "o", "    for i in range(20):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.816155, "o", "        plaintext = i * 0x1111111111111111\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.816192, "o", "> "]
[173.816407, "o", "        ciphertext = encrypt_fn(plaintext)\r\n\u001b[?2004l\r"]
[173.816485, "o", "\u001b[?2004h> "]
[173.816668, "o", "        pairs.append((plaintext, ciphertext))\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.816808, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.817147, "o", "    # Create differential pairs (plaintexts that differ in specific bits)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.817258, "o", "    diff_pairs = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.817453, "o", "> "]
[173.817569, "o", "    for i in range(10):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.817696, "o", "        pt1 = i << 32\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.817764, "o", "> "]
[173.818059, "o", "        pt2 = (i << 32) | 1  # Differ in LSB of right half\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.818161, "o", "> "]
[173.818272, "o", "        ct1 = encrypt_fn(pt1)"]
[173.818393, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.818513, "o", "        ct2 = encrypt_fn(pt2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.818574, "o", "> "]
[173.818831, "o", "        diff_pairs.append((pt1, ct1, pt2, ct2))\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.818925, "o", ">     \r\n\u001b[?2004l\r"]
[173.819026, "o", "\u001b[?2004h> "]
[173.819102, "o", "    # Score each candidate key\r\n\u001b[?2004l\r"]
[173.819202, "o", "\u001b[?2004h> "]
[173.819334, "o", "    candidate_scores = {}\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.819385, "o", "> "]
[173.819437, "o", "    \r\n\u001b[?2004l\r"]
[173.819573, "o", "\u001b[?2004h> "]
[173.819703, "o", "    for seed in range(0x10000):\r\n\u001b[?2004l\r"]
[173.819825, "o", "\u001b[?2004h> "]
[173.820003, "o", "        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.820142, "o", "> "]
[173.820235, "o", "        score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.820341, "o", "        \r\n"]
[173.820437, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[173.820672, "o", "        # Test with regular pairs - check for collisions\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.820767, "o", "> "]
[173.820915, "o", "        decrypted_values = set()\r\n\u001b[?2004l\r"]
[173.820988, "o", "\u001b[?2004h> "]
[173.821187, "o", "        collision_count = 0\r\n\u001b[?2004l\r"]
[173.8213, "o", "\u001b[?2004h> "]
[173.821531, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.821717, "o", "        for plaintext, ciphertext in pairs:\r\n\u001b[?2004l\r"]
[173.821835, "o", "\u001b[?2004h> "]
[173.8221, "o", "            final_right = getleft(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.822235, "o", "> "]
[173.82247, "o", "            final_left = getright(ciphertext)\r\n\u001b[?2004l\r"]
[173.822555, "o", "\u001b[?2004h> "]
[173.82286, "o", "            before_xor_left = final_left ^ final_right\r\n\u001b[?2004l\r"]
[173.822962, "o", "\u001b[?2004h> "]
[173.823222, "o", "            before_xor_right = final_right\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.823343, "o", "> "]
[173.823459, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.823756, "o", "            right_before_round3 = before_xor_left\r\n\u001b[?2004l\r"]
[173.823858, "o", "\u001b[?2004h> "]
[173.824446, "o", "            left_before_round3 = before_xor_right ^ f_function(right_before_round3 ^ candidate_key5)\r\n\u001b[?2004l\r"]
[173.824532, "o", "\u001b[?2004h> "]
[173.824643, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[173.824743, "o", "> "]
[173.825099, "o", "            val = (left_before_round3, right_before_round3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.825162, "o", "> "]
[173.82551, "o", "            if val in decrypted_values:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.825811, "o", "                collision_count += 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.825915, "o", "> "]
[173.826108, "o", "            decrypted_values.add(val)\r\n\u001b[?2004l\r"]
[173.826196, "o", "\u001b[?2004h> "]
[173.826251, "o", "        \r\n\u001b[?2004l\r"]
[173.826319, "o", "\u001b[?2004h> "]
[173.826813, "o", "        # Fewer collisions is better (correct key should have no collisions)\r\n\u001b[?2004l\r"]
[173.826929, "o", "\u001b[?2004h> "]
[173.827167, "o", "        score -= collision_count * 1000\r\n\u001b[?2004l\r"]
[173.827273, "o", "\u001b[?2004h"]
[173.827394, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h"]
[173.827503, "o", "> "]
[173.827652, "o", "        # Test with differential pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.827782, "o", "> "]
[173.828035, "o", "        for pt1, ct1, pt2, ct2 in diff_pairs:\r\n\u001b[?2004l\r"]
[173.828139, "o", "\u001b[?2004h> "]
[173.828369, "o", "            # Partially decrypt both\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.828544, "o", "> "]
[173.828722, "o", "            fr1 = getleft(ct1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.828842, "o", "> "]
[173.828954, "o", "            fl1 = getright(ct1)\r\n\u001b[?2004l\r"]
[173.829067, "o", "\u001b[?2004h> "]
[173.829237, "o", "            bxl1 = fl1 ^ fr1\r\n\u001b[?2004l\r"]
[173.829391, "o", "\u001b[?2004h> "]
[173.829558, "o", "            bxr1 = fr1\r\n\u001b[?2004l\r"]
[173.829737, "o", "\u001b[?2004h"]
[173.829834, "o", "> "]
[173.829981, "o", "            rb1 = bxl1"]
[173.83011, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.830229, "o", "> "]
[173.830759, "o", "            lb1 = bxr1 ^ f_function(rb1 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.830933, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.831169, "o", "            fr2 = getleft(ct2)\r\n\u001b[?2004l\r"]
[173.831359, "o", "\u001b[?2004h> "]
[173.831528, "o", "            fl2 = getright(ct2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.831678, "o", "> "]
[173.831812, "o", "            bxl2 = fl2 ^ fr2\r\n\u001b[?2004l\r"]
[173.83192, "o", "\u001b[?2004h> "]
[173.832039, "o", "            bxr2 = fr2\r\n\u001b[?2004l\r"]
[173.832152, "o", "\u001b[?2004h> "]
[173.832291, "o", "            rb2 = bxl2\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.83237, "o", "> "]
[173.832744, "o", "            lb2 = bxr2 ^ f_function(rb2 ^ candidate_key5)\r\n\u001b[?2004l\r"]
[173.832836, "o", "\u001b[?2004h"]
[173.832942, "o", ">             \r\n\u001b[?2004l\r"]
[173.833027, "o", "\u001b[?2004h> "]
[173.833249, "o", "            # Compute difference\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.833455, "o", "> "]
[173.833685, "o", "            left_diff = lb1 ^ lb2\r\n\u001b[?2004l\r"]
[173.833757, "o", "\u001b[?2004h> "]
[173.834027, "o", "            right_diff = rb1 ^ rb2\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.834111, "o", "> "]
[173.834185, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[173.834272, "o", "> "]
[173.83488, "o", "            # For the correct key, the difference should follow certain patterns\r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.835327, "o", "            # Award points for reasonable-looking differences\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.835451, "o", "> "]
[173.83569, "o", "            # (This is heuristic-based)\r\n\u001b[?2004l\r"]
[173.835782, "o", "\u001b[?2004h> "]
[173.83613, "o", "            if left_diff != 0 or right_diff != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.836258, "o", "> "]
[173.836423, "o", "                score += 1\r\n\u001b[?2004l\r"]
[173.836559, "o", "\u001b[?2004h"]
[173.836653, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[173.837026, "o", "        candidate_scores[candidate_key5] = score\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.837228, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[173.83754, "o", "> "]
[173.837656, "o", "    # Return the candidate with the best score\r\n\u001b[?2004l\r\u001b[?2004h"]
[173.837719, "o", "> "]
[173.838124, "o", "    best_key = max(candidate_scores, key=candidate_scores.get)\r\n\u001b[?2004l\r"]
[173.891939, "o", "\u001b[?2004h>     return best_key\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[173.894163, "o", "\u001b[?2004hroot@486aac7a4fa6:/app# "]
