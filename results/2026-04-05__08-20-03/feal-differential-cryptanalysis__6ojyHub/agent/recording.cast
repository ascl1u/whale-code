[225.815192, "i", "cat > debug_attack.py << 'EOF'\n#!/usr/bin/env python3\nimport feal\n\n# Initialize with random keys\nfeal.create_random_keys()\n\nprint(\"Actual key[5]:\", feal.key[5])\n\n# Find what seed gives this key\nfor seed in range(0x10000):\n    candidate = (seed * 1234567) & 0xFFFFFFFF\n    if candidate == feal.key[5]:\n        print(f\"Seed for key[5]: {seed}\")\n        print(f\"Verification: {seed} * 1234567 & 0xFFFFFFFF = {candidate}\")\n        break\n\nprint(\"\\nAll keys:\")\nfor i in range(6):\n    print(f\"key[{i}] = {feal.key[i]}\")\n\n# Test encryption with a simple plaintext\npt = 0x0123456789ABCDEF\nct = feal.encrypt(pt)\nprint(f\"\\nPlaintext: {pt:016x}\")\nprint(f\"Ciphertext: {ct:016x}\")\nEOF\n"]
