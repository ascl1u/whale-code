[1055.687216, "o", "\u001b[?2004h> "]
[1055.68731, "o", "            score += bits\r\n\u001b[?2004l\r\u001b[?2004h"]
[1055.687415, "o", "> "]
[1055.687519, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
