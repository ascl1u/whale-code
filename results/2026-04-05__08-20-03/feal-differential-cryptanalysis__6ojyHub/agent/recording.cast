[332.13743, "o", "            pt1 = base\r\n\u001b[?2004l\r"]
[332.137577, "o", "\u001b[?2004h> "]
[332.137794, "o", "            pt2 = base ^ diff\r\n\u001b[?2004l\r"]
[332.137832, "o", "\u001b[?2004h"]
[332.137961, "o", "> "]
[332.138138, "o", "            ct1 = encrypt_fn(pt1)\r\n\u001b[?2004l\r"]
[332.13826, "o", "\u001b[?2004h> "]
[332.138499, "o", "            ct2 = encrypt_fn(pt2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.138617, "o", "> "]
[332.139003, "o", "            diff_data.append((pt1, ct1, pt2, ct2, diff))\r\n\u001b[?2004l\r"]
[332.139182, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[332.13923, "o", "\u001b[?2004h"]
[332.139428, "o", "> "]
[332.139576, "o", "    # Score each candidate\r\n\u001b[?2004l\r"]
[332.139649, "o", "\u001b[?2004h> "]
[332.139763, "o", "    best_key = None\r\n\u001b[?2004l\r"]
[332.13991, "o", "\u001b[?2004h> "]
[332.140151, "o", "    best_score = float('-inf')\r\n\u001b[?2004l\r"]
[332.140211, "o", "\u001b[?2004h> "]
[332.140423, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.140636, "o", "    for seed in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.140725, "o", "> "]
[332.141152, "o", "        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.141306, "o", "> "]
[332.14147, "o", "        score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.141591, "o", "        \r\n\u001b[?2004l\r"]
[332.141667, "o", "\u001b[?2004h> "]
[332.14208, "o", "        for pt1, ct1, pt2, ct2, input_diff in diff_data:\r\n\u001b[?2004l\r"]
[332.142215, "o", "\u001b[?2004h> "]
[332.142575, "o", "            # Partially decrypt both ciphertexts\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.142777, "o", "> "]
[332.142959, "o", "            fr1 = getleft(ct1)\r\n\u001b[?2004l\r"]
[332.143104, "o", "\u001b[?2004h> "]
[332.143299, "o", "            fl1 = getright(ct1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.143574, "o", "            bxl1 = fl1 ^ fr1\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.143781, "o", ">             bxr1 = fr1\r\n\u001b[?2004l\r"]
[332.143948, "o", "\u001b[?2004h> "]
[332.178682, "o", "            rb1 = bxl1\r\n\u001b[?2004l\r"]
[332.178741, "o", "\u001b[?2004h> "]
[332.179162, "o", "            lb1 = bxr1 ^ f_function(rb1 ^ candidate_key5)\r\n\u001b[?2004l\r"]
[332.179279, "o", "\u001b[?2004h> "]
[332.17939, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.179558, "o", "            fr2 = getleft(ct2)\r\n\u001b[?2004l\r"]
[332.17966, "o", "\u001b[?2004h> "]
[332.179789, "o", "            fl2 = getright(ct2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.179904, "o", "> "]
[332.180084, "o", "            bxl2 = fl2 ^ fr2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.180274, "o", "            bxr2 = fr2\r\n\u001b[?2004l\r"]
[332.180403, "o", "\u001b[?2004h> "]
[332.180555, "o", "            rb2 = bxl2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.180894, "o", "            lb2 = bxr2 ^ f_function(rb2 ^ candidate_key5)\r\n\u001b[?2004l\r"]
[332.181017, "o", "\u001b[?2004h> "]
[332.181158, "o", "            \r\n\u001b[?2004l\r"]
[332.181251, "o", "\u001b[?2004h> "]
[332.181499, "o", "            # Compute the difference after partial decryption\r\n\u001b[?2004l\r"]
[332.181577, "o", "\u001b[?2004h> "]
[332.181816, "o", "            left_diff = lb1 ^ lb2\r\n\u001b[?2004l\r"]
[332.181929, "o", "\u001b[?2004h> "]
[332.182138, "o", "            right_diff = rb1 ^ rb2\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.182252, "o", "> "]
[332.182381, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.182875, "o", "            # For the correct key, certain differential properties should hold\r\n\u001b[?2004l\r"]
[332.183005, "o", "\u001b[?2004h> "]
[332.183286, "o", "            # This is heuristic-based: we're looking for patterns\r\n\u001b[?2004l\r"]
[332.18342, "o", "\u001b[?2004h> "]
[332.183567, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.183768, "o", "            # One heuristic: if the input difference is small, \r\n\u001b[?2004l\r\u001b[?2004h"]
[332.183863, "o", "> "]
[332.184205, "o", "            # the intermediate difference might show patterns\r\n\u001b[?2004l\r"]
[332.184306, "o", "\u001b[?2004h> "]
[332.184384, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[332.18452, "o", "> "]
[332.18461, "o", "            # Count bits in differences\r\n\u001b[?2004l\r"]
[332.184728, "o", "\u001b[?2004h> "]
[332.185008, "o", "            left_bits = bin(left_diff).count('1')\r\n\u001b[?2004l\r"]
[332.185097, "o", "\u001b[?2004h> "]
[332.185365, "o", "            right_bits = bin(right_diff).count('1')\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.18544, "o", "> "]
[332.185533, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[332.185669, "o", "> "]
[332.18597, "o", "            # Prefer balanced bit counts (avalanche effect)\r\n\u001b[?2004l\r"]
[332.186069, "o", "\u001b[?2004h> "]
[332.186432, "o", "            if 10 <= left_bits <= 22 and 10 <= right_bits <= 22:\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.186536, "o", "> "]
[332.186711, "o", "                score += 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.186829, "o", "> "]
[332.18697, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.187233, "o", "            # Another heuristic: check if differences are non-zero\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.187343, "o", "> "]
[332.187557, "o", "            if left_diff != 0 and right_diff != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.187608, "o", "> "]
[332.187751, "o", "                score += 1\r\n\u001b[?2004l\r"]
[332.187882, "o", "\u001b[?2004h> "]
[332.187937, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.188146, "o", "        if score > best_score:\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.188188, "o", "> "]
[332.188394, "o", "            best_score = score\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.188499, "o", "> "]
[332.188674, "o", "            best_key = candidate_key5\r\n\u001b[?2004l\r\u001b[?2004h"]
[332.188787, "o", "> "]
[332.188869, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[332.189046, "o", "    return best_key\r\n\u001b[?2004l\r"]
[332.189169, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[332.18929, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
