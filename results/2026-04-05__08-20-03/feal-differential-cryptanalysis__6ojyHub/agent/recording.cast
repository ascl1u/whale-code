[303.360047, "i", "cat > debug_uniqueness.py << 'EOF'\n#!/usr/bin/env python3\nimport feal\nimport attack\n\n# Initialize with random keys\nfeal.create_random_keys()\n\nprint(\"Actual key[5]:\", feal.key[5])\n\n# Find the correct seed\ncorrect_seed = None\nfor seed in range(0x10000):\n    if (seed * 1234567) & 0xFFFFFFFF == feal.key[5]:\n        correct_seed = seed\n        break\n\nprint(f\"Correct seed: {correct_seed}\")\n\n# Collect some pairs\npairs = []\nfor i in range(100):\n    plaintext = i\n    ciphertext = feal.encrypt(plaintext)\n    pairs.append((plaintext, ciphertext))\n\n# Test a few candidate seeds\ntest_seeds = [0, 1, 100, 1000, correct_seed]\n\nfor seed in test_seeds:\n    candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n    decrypted_states = []\n    for plaintext, ciphertext in pairs:\n        left, right = attack.partial_decrypt_last_round(ciphertext, candidate_key5)\n        decrypted_states.append((left, right))\n    \n    unique_count = len(set(decrypted_states))\n    print(f\"Seed {seed}: {unique_count} unique states out of 100\")\n    if seed == c"]
