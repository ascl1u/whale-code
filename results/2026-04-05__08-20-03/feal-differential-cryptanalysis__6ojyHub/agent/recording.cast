[1033.429524, "o", "cat attack.py; printf '%s\\n' '__CMDEND__22__'\r\n\u001b[?2004l\r"]
[1033.431363, "o", "#!/usr/bin/env python3\r\n\r\ndef g_function(a, b, x):\r\n    temp = (a + b + x) & 0xFF\r\n    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\r\ndef f_function(input_val):\r\n    x = [0] * 4\r\n    y = [0] * 4\r\n    for i in range(4):\r\n        x[i] = input_val & 0xFF\r\n        input_val >>= 8\r\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n    y[3] = g_function(x[3], y[2], 0)\r\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n    y[0] = g_function(x[0], y[1], 1)\r\n    output = 0\r\n    for i in range(4):\r\n        output |= y[i] << (8 * i)\r\n    return output & 0xFFFFFFFF\r\n\r\ndef getleft(x):\r\n    return (x >> 32) & 0xFFFFFFFF\r\n\r\ndef getright(x):\r\n    return x & 0xFFFFFFFF\r\n\r\ndef attack(encrypt_fn):\r\n    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\r\n    \r\n    # Collect plaintext pairs\r\n    data = []\r\n    for i in range(8):\r\n        pt1 = i\r\n        pt2 = i ^ 1\r\n        ct1 = encrypt_fn(pt1)\r\n        ct2 = encrypt_fn(pt2)\r\n        data.append((ct1, ct2))\r\n    \r\n    # Score based on LEFT half differences (which DO depend on key"]
[1033.431496, "o", ")\r\n    best_key = 0\r\n    best_score = float('inf')\r\n    \r\n    for seed in range(0x10000):\r\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n        score = 0\r\n        \r\n        for ct1, ct2 in data:\r\n            fr1, fl1 = getleft(ct1), getright(ct1)\r\n            fr2, fl2 = getleft(ct2), getright(ct2)\r\n            \r\n            rb1 = fl1 ^ fr1\r\n            rb2 = fl2 ^ fr2\r\n            \r\n            lb1 = fr1 ^ f_function(rb1 ^ candidate_key5)\r\n            lb2 = fr2 ^ f_function(rb2 ^ candidate_key5)\r\n            \r\n            # Score based on LEFT half difference (this depends on key!)\r\n            left_diff = lb1 ^ lb2\r\n            bits = bin(left_diff).count('1')\r\n            \r\n            # Try minimizing deviation from expected value\r\n            score += abs(bits - 16)\r\n        \r\n        if score < best_score:\r\n            best_score = score\r\n            best_key = candidate_key5\r\n    \r\n    return best_key\r\n\r\n"]
[1033.431787, "o", "__CMDEND__22__\r\n"]
