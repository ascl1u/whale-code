[80.701666, "o", "import time\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.701987, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[80.702207, "o", "> # Initialize with random keys\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.702363, "o", "feal.create_random_keys()\r\n\u001b[?2004l\r"]
