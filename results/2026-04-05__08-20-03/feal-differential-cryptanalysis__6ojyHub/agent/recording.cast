[80.704991, "o", "\u001b[?2004h> "]
[80.705252, "o", "recovered_key5 = attack.attack(feal.encrypt)\r\n\u001b[?2004l\r"]
[80.705385, "o", "\u001b[?2004h> "]
[80.705596, "o", "end_time = time.time()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.705831, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.705941, "o", "> "]
