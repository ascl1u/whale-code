[709.565783, "o", "  File \u001b[35m\"/app/test_attack.py\"\u001b[0m, line \u001b[35m13\u001b[0m, in \u001b[35m<module>\u001b[0m\r\n    recovered_key5 = attack.attack(feal.encrypt)\r\n  File \u001b[35m\"/app/attack.py\"\u001b[0m, line \u001b[35m69\u001b[0m, in \u001b[35mattack\u001b[0m\r\n    lb = fr ^ \u001b[31mf_function\u001b[0m\u001b[1;31m(rb ^ candidate_key5)\u001b[0m\r\n              \u001b[31m~~~~~~~~~~\u001b[0m\u001b[1;31m^^^^^^^^^^^^^^^^^^^^^\u001b[0m\r\n  File \u001b[35m\"/app/attack.py\"\u001b[0m, line \u001b[35m21\u001b[0m, in \u001b[35mf_function\u001b[0m\r\n    \u001b[1;31moutput\u001b[0m |= y[i] << (8 * i)\r\n    \u001b[1;31m^^^^^^\u001b[0m\r\n"]
[709.566063, "o", "\u001b[1;35mKeyboardInterrupt\u001b[0m\r\n"]
