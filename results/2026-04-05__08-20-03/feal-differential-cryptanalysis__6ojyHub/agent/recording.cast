[775.159096, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\n    \n    # Collect just 4 pairs for maximum speed\n    data = []\n    for i in range(4):\n        pt1 = i\n        pt2 = i ^ 0x0000000080000000\n        ct1 = encrypt_fn(pt1)\n        ct2 = encrypt_fn(pt2)\n        data.append((ct1, ct2))\n    \n    # Try to find the key with minimal computati"]
[775.159299, "i", "on\n    # Use a different scoring: prefer keys where XOR of differences has specific bit count\n    best_key = 0\n    best_score = 0\n    \n    for seed in range(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        score = 0\n        \n        for ct1, ct2 in data:\n            # Minimal computation\n            fr1, fl1 = getleft(ct1), getright(ct1)\n            fr2, fl2 = getleft(ct2), getright(ct2)\n            \n            rb1 = fl1 ^ fr1\n            rb2 = fl2 ^ fr2\n            \n            lb1 = fr1 ^ f_function(rb1 ^ candidate_key5)\n            lb2 = fr2 ^ f_function(rb2 ^ candidate_key5)\n            \n            # Score based on hamming weight of XOR\n            score += bin(lb1 ^ lb2).count('1')\n        \n        if score > best_score:\n            best_score = score\n            best_key = candidate_key5\n    \n    return best_key\n\nEOF\n"]
