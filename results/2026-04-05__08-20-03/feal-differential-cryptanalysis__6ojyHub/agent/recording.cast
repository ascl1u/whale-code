[649.649768, "o", "    temp = (a + b + x) & 0xFF\r\n\u001b[?2004l\r"]
[649.649923, "o", "\u001b[?2004h> "]
[649.650114, "o", "    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\u001b[?2004l\r"]
[649.650252, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.650469, "o", "def f_function(input_val):\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.650589, "o", "> "]
[649.650759, "o", "    x = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.650905, "o", "    y = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.651066, "o", "    for i in range(4):\r\n\u001b[?2004l\r"]
[649.651227, "o", "\u001b[?2004h> "]
[649.651313, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r"]
[649.651365, "o", "\u001b[?2004h> "]
[649.651551, "o", "        input_val >>= 8\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.652005, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.652193, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.652319, "o", "> "]
[649.652579, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.652785, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r"]
[649.652912, "o", "\u001b[?2004h> "]
[649.653012, "o", "    output = 0\r\n\u001b[?2004l\r"]
[649.653122, "o", "\u001b[?2004h> "]
[649.653234, "o", "    for i in range(4):\r\n\u001b[?2004l\r"]
[649.653397, "o", "\u001b[?2004h> "]
[649.65355, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.653661, "o", "> "]
[649.653842, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.653958, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.654079, "o", "def getleft(x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.654254, "o", "    return (x >> 32) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[649.654452, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.654566, "o", "def getright(x):\r\n\u001b[?2004l\r"]
[649.654675, "o", "\u001b[?2004h> "]
[649.654761, "o", "    return x & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.654911, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.655146, "o", "def compute_entropy(values):\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.655248, "o", "> "]
[649.655515, "o", "    \"\"\"Compute Shannon entropy of byte distribution\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.655671, "o", "> "]
[649.655792, "o", "    byte_counts = Counter()\r\n\u001b[?2004l\r"]
[649.655915, "o", "\u001b[?2004h> "]
[649.656046, "o", "    for val in values:\r\n\u001b[?2004l\r"]
[649.65608, "o", "\u001b[?2004h> "]
[649.656292, "o", "        for i in range(8):\r\n\u001b[?2004l\r"]
[649.65641, "o", "\u001b[?2004h> "]
[649.656757, "o", "            byte_counts[(val >> (i*8)) & 0xFF] += 1\r\n\u001b[?2004l\r"]
[649.656888, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[649.657062, "o", "\u001b[?2004h> "]
[649.657263, "o", "    total = sum(byte_counts.values())\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.657431, "o", "> "]
[649.657522, "o", "    entropy = 0\r\n\u001b[?2004l\r"]
[649.657982, "o", "\u001b[?2004h>     for count in byte_counts.values():\r\n\u001b[?2004l\r\u001b[?2004h>         if count > 0:\r\n\u001b[?2004l\r"]
[649.65815, "o", "\u001b[?2004h> "]
[649.658337, "o", "            p = count / total\r\n\u001b[?2004l\r"]
[649.658442, "o", "\u001b[?2004h> "]
[649.658666, "o", "            entropy -= p * math.log2(p)\r\n\u001b[?2004l\r"]
[649.658858, "o", "\u001b[?2004h> "]
[649.659047, "o", "    return entropy\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[649.659127, "o", "> "]
[649.659316, "o", "def attack(encrypt_fn):"]
[649.659846, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Recover key[5] using chosen plaintext attack\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.660042, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r"]
[649.660156, "o", "\u001b[?2004h> "]
[649.660247, "o", "    pairs = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.660369, "o", "> "]
[649.660499, "o", "    for i in range(100):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.660623, "o", "        pt = i\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.660729, "o", "        ct = encrypt_fn(pt)\r\n\u001b[?2004l\r"]
[649.660855, "o", "\u001b[?2004h> "]
[649.660978, "o", "        pairs.append((pt, ct))\r\n\u001b[?2004l\r"]
[649.661046, "o", "\u001b[?2004h> "]
[649.661113, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[649.661198, "o", "> "]
[649.661319, "o", "    best_key = 0\r\n\u001b[?2004l\r"]
[649.661397, "o", "\u001b[?2004h"]
[649.661479, "o", "> "]
[649.66161, "o", "    best_entropy = -1\r\n\u001b[?2004l\r"]
[649.661743, "o", "\u001b[?2004h> "]
[649.66193, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.662058, "o", "    for seed in range(0x10000):\r\n\u001b[?2004l\r"]
[649.662204, "o", "\u001b[?2004h> "]
[649.662427, "o", "        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[649.662583, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[649.662675, "o", "\u001b[?2004h> "]
[649.662839, "o", "        # Partially decrypt all ciphertexts\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.662937, "o", "> "]
[649.663065, "o", "        left_values = []\r\n\u001b[?2004l\r"]
[649.663146, "o", "\u001b[?2004h> "]
[649.663277, "o", "        right_values = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.66338, "o", "> "]
[649.663475, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[649.663543, "o", "> "]
[649.663634, "o", "        for pt, ct in pairs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.663752, "o", "> "]
[649.663889, "o", "            fr = getleft(ct)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.664072, "o", "            fl = getright(ct)\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.664181, "o", "> "]
[649.664297, "o", "            rb = fl ^ fr\r\n\u001b[?2004l\r\u001b[?2004h> "]
[649.664579, "o", "            lb = fr ^ f_function(rb ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.664645, "o", "> "]
[649.664807, "o", "            left_values.append(lb)\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.664855, "o", "> "]
[649.665053, "o", "            right_values.append(rb)\r\n\u001b[?2004l\r"]
[649.665165, "o", "\u001b[?2004h"]
[649.665259, "o", ">         \r\n\u001b[?2004l\r"]
[649.665402, "o", "\u001b[?2004h> "]
[649.66562, "o", "        # Compute entropy - correct key should give high entropy\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.665718, "o", "> "]
[649.666059, "o", "        entropy = compute_entropy(left_values + right_values)\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.666196, "o", ">         \r\n\u001b[?2004l\r"]
[649.666342, "o", "\u001b[?2004h> "]
[649.666517, "o", "        if entropy > best_entropy:\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.666542, "o", "> "]
[649.6668, "o", "            best_entropy = entropy\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.666827, "o", "> "]
[649.667063, "o", "            best_key = candidate_key5\r\n\u001b[?2004l\r\u001b[?2004h"]
[649.667099, "o", "> "]
[649.667237, "o", "    \r\n\u001b[?2004l\r"]
[649.667266, "o", "\u001b[?2004h> "]
[649.667468, "o", "    return best_key\r\n\u001b[?2004l\r"]
[649.667575, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[649.667659, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
