[1055.679662, "o", "    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1055.679766, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
