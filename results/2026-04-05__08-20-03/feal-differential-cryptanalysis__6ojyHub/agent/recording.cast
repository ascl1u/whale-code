[332.117764, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef g_function(a, b, x):\n    \"\"\"FEAL G function (same as in feal.py)\"\"\"\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\n\ndef f_function(input_val):\n    \"\"\"FEAL F function (same as in feal.py)\"\"\"\n    x = [0] * 4\n    y = [0] * 4\n\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n\n    return output & 0xFFFFFFFF\n\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using chosen plaintext attack\"\"\"\n    \n    # New strategy: Use differential cryptanalysis with chosen plaintext pairs\n    # We'll create pairs that differ in specific ways and track how differences propagate\n    \n    # C"]
[332.117953, "i", "ollect plaintext pairs that differ only in specific bits\n    diff_data = []\n    \n    # Create pairs with difference in the right half only\n    for base in range(20):\n        pt1 = base << 32  # Left = base, Right = 0\n        pt2 = (base << 32) | 1  # Left = base, Right = 1\n        ct1 = encrypt_fn(pt1)\n        ct2 = encrypt_fn(pt2)\n        diff_data.append((pt1, ct1, pt2, ct2, 1))  # difference = 1\n    \n    # Create pairs with different differences\n    for diff in [0x80000000, 0x00000001, 0x0000FF00]:\n        for base in range(10):\n            pt1 = base\n            pt2 = base ^ diff\n            ct1 = encrypt_fn(pt1)\n            ct2 = encrypt_fn(pt2)\n            diff_data.append((pt1, ct1, pt2, ct2, diff))\n    \n    # Score each candidate\n    best_key = None\n    best_score = float('-inf')\n    \n    for seed in range(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        score = 0\n        \n        for pt1, ct1, pt2, ct2, input_diff in diff_data:\n            # Partially decrypt both ciphertexts\n"]
[332.118064, "i", "            fr1 = getleft(ct1)\n            fl1 = getright(ct1)\n            bxl1 = fl1 ^ fr1\n            bxr1 = fr1\n            rb1 = bxl1\n            lb1 = bxr1 ^ f_function(rb1 ^ candidate_key5)\n            \n            fr2 = getleft(ct2)\n            fl2 = getright(ct2)\n            bxl2 = fl2 ^ fr2\n            bxr2 = fr2\n            rb2 = bxl2\n            lb2 = bxr2 ^ f_function(rb2 ^ candidate_key5)\n            \n            # Compute the difference after partial decryption\n            left_diff = lb1 ^ lb2\n            right_diff = rb1 ^ rb2\n            \n            # For the correct key, certain differential properties should hold\n            # This is heuristic-based: we're looking for patterns\n            \n            # One heuristic: if the input difference is small, \n            # the intermediate difference might show patterns\n            \n            # Count bits in differences\n            left_bits = bin(left_diff).count('1')\n            right_bits = bin(right_diff).count('1')\n            \n          "]
[332.118117, "o", "cat > attack.py << 'EOF'\r\n\u001b[?2004l\r"]
[332.118227, "i", "  # Prefer balanced bit counts (avalanche effect)\n            if 10 <= left_bits <= 22 and 10 <= right_bits <= 22:\n                score += 1\n            \n            # Another heuristic: check if differences are non-zero\n            if left_diff != 0 and right_diff != 0:\n                score += 1\n        \n        if score > best_score:\n            best_score = score\n            best_key = candidate_key5\n    \n    return best_key\n\nEOF\n"]
[332.118387, "o", "            fr1 = getleft(ct1)\r\n            fl1 = getright(ct1)\r\n            bxl1 = fl1 ^ fr1\r\n            bxr1 = fr1\r\n            rb1 = bxl1\r\n            lb1 = bxr1 ^ f_function(rb1 ^ candidate_key5)\r\n            \r\n            fr2 = getleft(ct2)\r\n            fl2 = getright(ct2)\r\n            bxl2 = fl2 ^ fr2\r\n            bxr2 = fr2\r\n            rb2 = bxl2\r\n            lb2 = bxr2 ^ f_func"]
[332.118639, "o", "tion(rb2 ^ candidate_key5)\r\n            \r\n            # Compute the difference after partial decryption\r\n            left_diff = lb1 ^ lb2\r\n            right_diff = rb1 ^ rb2\r\n            \r\n            # For the correct key, certain differential properties should hold\r\n            # This is heuristic-based: we're looking for patterns\r\n            \r\n    "]
[332.118724, "o", "        # One heuristic: if the input difference is small, \r\n            # the intermediate difference might show patterns\r\n            \r\n            # Count bits in differences\r\n            left_bits = bin(left_diff).count('1')\r\n            right_bits = bin(right_diff).count('1')\r\n            \r\n            # Prefer balanced bit counts (avalanche effect)\r\n            if 10 <= left_bits <= 22 and 10 <= right_bits <= 22:\r\n                score += 1\r\n            \r\n            # Another heuristic: check if differences are non-zero\r\n            if left_diff"]
[332.118943, "o", " != 0 and right_diff != 0:\r\n                score += 1\r\n        \r\n        if score > best_score:\r\n            best_score = score\r\n            best_key = candidate_key5\r\n    \r\n    return best_key\r\n\r\nEOF\r\n"]
