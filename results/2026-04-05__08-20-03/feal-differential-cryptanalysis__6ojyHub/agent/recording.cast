[752.787865, "i", "cat > attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\n    \n    # Use minimal pairs for speed\n    data = []\n    for i in range(8):\n        pt1 = i << 32\n        pt2 = (i << 32) | 1\n        ct1 = encrypt_fn(pt1)\n        ct2 = encrypt_fn(pt2)\n        data.append((ct1, ct2))\n    \n    best_key = 0\n    best_score = -1\n    \n    for seed in rang"]
[752.78808, "i", "e(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        score = 0\n        \n        for ct1, ct2 in data:\n            fr1 = getleft(ct1)\n            fl1 = getright(ct1)\n            rb1 = fl1 ^ fr1\n            lb1 = fr1 ^ f_function(rb1 ^ candidate_key5)\n            \n            fr2 = getleft(ct2)\n            fl2 = getright(ct2)\n            rb2 = fl2 ^ fr2\n            lb2 = fr2 ^ f_function(rb2 ^ candidate_key5)\n            \n            # Ultra-simple scoring\n            diff = (lb1 ^ lb2) ^ (rb1 ^ rb2)\n            # Count bits\n            bits = bin(diff).count('1')\n            score += bits\n        \n        if score > best_score:\n            best_score = score\n            best_key = candidate_key5\n    \n    return best_key\n\nEOF\n"]
