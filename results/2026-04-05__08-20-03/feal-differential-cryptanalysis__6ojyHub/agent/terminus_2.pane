[?2004l#!/usr/bin/env python3

def g_function(a, b, x):
    temp = (a + b + x) & 0xFF
    return ((temp << 2) | (temp >> 6)) & 0xFF

def f_function(input_val):
    x = [0] * 4
    y = [0] * 4
    for i in range(4):
        x[i] = input_val & 0xFF
        input_val >>= 8
    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)
    y[3] = g_function(x[3], y[2], 0)
    y[1] = g_function(x[1] ^ x[0], y[2], 0)
    y[0] = g_function(x[0], y[1], 1)
    output = 0
    for i in range(4):
        output |= y[i] << (8 * i)
    return output & 0xFFFFFFFF

def getleft(x):
    return (x >> 32) & 0xFFFFFFFF

def getright(x):
    return x & 0xFFFFFFFF

def attack(encrypt_fn):
    """Recover key[5] using differential cryptanalysis"""
    
    # Collect plaintext pairs
    data = []
    for i in range(8):
        pt1 = i
        pt2 = i ^ 1
        ct1 = encrypt_fn(pt1)
        ct2 = encrypt_fn(pt2)
        data.append((ct1, ct2))
    
    # Score based on LEFT half differences (which DO depend on key)
    best_key = 0
    best_score = float('inf')
    
    for seed in range(0x10000):
        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF
        score = 0
        
        for ct1, ct2 in data:
            fr1, fl1 = getleft(ct1), getright(ct1)
            fr2, fl2 = getleft(ct2), getright(ct2)
            
            rb1 = fl1 ^ fr1
            rb2 = fl2 ^ fr2
            
            lb1 = fr1 ^ f_function(rb1 ^ candidate_key5)
            lb2 = fr2 ^ f_function(rb2 ^ candidate_key5)
            
            # Score based on LEFT half difference (this depends on key!)
            left_diff = lb1 ^ lb2
            bits = bin(left_diff).count('1')
            
            # Try minimizing deviation from expected value
            score += abs(bits - 16)
        
        if score < best_score:
            best_score = score
            best_key = candidate_key5
    
    return best_key

__CMDEND__22__
