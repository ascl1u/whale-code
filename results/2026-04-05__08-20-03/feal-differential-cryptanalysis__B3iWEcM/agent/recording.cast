[388.12465, "o", "    # Search strategy: Try all combinations of (seed4, seed5) first\r\n\u001b[?2004l\r"]
[388.124758, "o", "\u001b[?2004h> "]
[388.12534, "o", "    # For each, decrypt backward and see if we can find matching (seed0, seed1, seed2, seed3)\r\n\u001b[?2004l\r\u001b[?2004h"]
