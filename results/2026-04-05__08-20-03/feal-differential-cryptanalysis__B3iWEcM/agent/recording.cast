[388.128382, "o", "> "]
[388.128466, "o", "            \r\n\u001b[?2004l\r"]
[388.128567, "o", "\u001b[?2004h> "]
[388.128754, "o", "            # Undo post-round mixing\r\n\u001b[?2004l\r"]
[388.128841, "o", "\u001b[?2004h> "]
[388.129158, "o", "            left_after_r3 = left_after_post ^ right_after_post\r\n\u001b[?2004l\r"]
[388.12924, "o", "\u001b[?2004h> "]
[388.129465, "o", "            right_after_r3 = right_after_post\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.129566, "o", "> "]
[388.129685, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.129818, "o", "            # Undo round 3\r\n\u001b[?2004l\r"]
[388.129909, "o", "\u001b[?2004h"]
[388.129952, "o", "> "]
[388.130091, "o", "            right_before_r3 = left_after_r3\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.130165, "o", "> "]
[388.130532, "o", "            left_before_r3 = right_after_r3 ^ f_function(right_before_r3 ^ key5)\r\n\u001b[?2004l\r"]
[388.130669, "o", "\u001b[?2004h>             \r\n\u001b[?2004l\r"]
[388.130761, "o", "\u001b[?2004h> "]
[388.130882, "o", "            # Undo round 2\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.130969, "o", "> "]
[388.131334, "o", "            right_before_r2 = left_before_r3\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.131426, "o", "> "]
[388.13176, "o", "            left_before_r2 = right_before_r3 ^ f_function(right_before_r2 ^ key4)\r\n\u001b[?2004l\r"]
[388.131837, "o", "\u001b[?2004h> "]
[388.131901, "o", "            \r\n\u001b[?2004l\r"]
[388.132023, "o", "\u001b[?2004h> "]
[388.132227, "o", "            # Now we have the state before round 2\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.132265, "o", "> "]
[388.132553, "o", "            # This should equal the state after round 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.132643, "o", "> "]
[388.13271, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.133036, "o", "            # Try to find keys 0,1,2,3 that produce this state\r\n\u001b[?2004l\r"]
[388.133131, "o", "\u001b[?2004h> "]
[388.133425, "o", "            for seed0 in range(0, 0x10000, 128):  # Coarse sampling\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.133515, "o", "> "]
[388.133732, "o", "                key0 = (seed0 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[388.133836, "o", "\u001b[?2004h> "]
[388.133928, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.134296, "o", "                for seed1 in range(0, 0x10000, 128):  # Coarse sampling\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.13441, "o", "> "]
[388.134627, "o", "                    key1 = (seed1 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.134719, "o", "> "]
[388.134807, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[388.134895, "o", "> "]
[388.135077, "o", "                    # Apply initial processing\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.135159, "o", "> "]
[388.135401, "o", "                    left = pt_left\r\n\u001b[?2004l\r"]
[388.135513, "o", "\u001b[?2004h> "]
[388.135623, "o", "                    right = pt_right\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.135712, "o", "> "]
[388.135931, "o", "                    left ^= key0\r\n\u001b[?2004l\r"]
[388.136066, "o", "\u001b[?2004h> "]
[388.136145, "o", "                    right ^= key1\r\n\u001b[?2004l\r"]
[388.136204, "o", "\u001b[?2004h> "]
[388.13637, "o", "                    right ^= left\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.136456, "o", "> "]
[388.136575, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.136985, "o", "                    # Now try key[2] and key[3] to reach our target state\r\n\u001b[?2004l\r"]
[388.137071, "o", "\u001b[?2004h> "]
[388.137421, "o", "                    for seed2 in range(0, 0x10000, 256):  # Very coarse sampling\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.137472, "o", "> "]
[388.137799, "o", "                        key2 = (seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.137871, "o", "> "]
[388.137933, "o", "                        \r\n\u001b[?2004l\r"]
[388.138032, "o", "\u001b[?2004h> "]
[388.138174, "o", "                        # Round 0\r\n\u001b[?2004l\r"]
[388.138285, "o", "\u001b[?2004h> "]
[388.138504, "o", "                        mixed = f_function(right ^ key2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.138591, "o", "> "]
[388.138792, "o", "                        left_after_r0 = right\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.138918, "o", "> "]
[388.139121, "o", "                        right_after_r0 = left ^ mixed\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.139261, "o", "> "]
[388.139388, "o", "                        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.139838, "o", "                        # For round 1, we need to reach (left_before_r2, right_before_r2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.139935, "o", "> "]
[388.140312, "o", "                        # After round 1: left1 = right0, right1 = left0 ^ f(right0 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.140403, "o", "> "]
[388.140713, "o", "                        # So: right_before_r2 = left0 ^ f(right0 ^ key3)\r\n\u001b[?2004l\r"]
[388.140799, "o", "\u001b[?2004h> "]
[388.141045, "o", "                        # We can solve for key3:\r\n\u001b[?2004l\r"]
[388.141074, "o", "\u001b[?2004h"]
[388.141169, "o", "> "]
[388.141284, "o", "                        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.141687, "o", "                        # right_before_r2 = left_after_r0 ^ f(right_after_r0 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.142007, "o", "                        # This means: key3 should satisfy:\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.142092, "o", "> "]
[388.142455, "o", "                        # f(right_after_r0 ^ key3) = left_after_r0 ^ right_before_r2\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.142521, "o", "> "]
[388.142639, "o", "                        \r\n\u001b[?2004l\r\u001b[?2004h"]
[388.142721, "o", "> "]
[388.14301, "o", "                        target = left_after_r0 ^ right_before_r2\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.143102, "o", "> "]
