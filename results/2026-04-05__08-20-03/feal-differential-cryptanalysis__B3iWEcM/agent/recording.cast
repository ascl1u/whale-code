[433.144971, "o", "> "]
[433.145126, "o", "        right = left ^ mixed\r\n"]
[433.14523, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[433.145328, "o", "        left = temp\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.145504, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     left ^= right\r\n\u001b[?2004l\r"]
[433.145543, "o", "\u001b[?2004h"]
[433.145648, "o", "> "]
[433.145853, "o", "    result = merge(right, left)\r\n\u001b[?2004l\r"]
[433.145971, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[433.146076, "o", "\u001b[?2004h> "]
[433.146235, "o", "    return result == ct\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.14633, "o", "> \r\n\u001b[?2004l\r"]
[433.146402, "o", "\u001b[?2004h> "]
[433.146583, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r"]
[433.146676, "o", "\u001b[?2004h> "]
[433.14679, "o", "    \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.147093, "o", "    Recover key[5] using brute force with intelligent sampling.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.147193, "o", "    \"\"\"\r\n\u001b[?2004l\r"]
[433.147312, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.147518, "o", "    # Get plaintext-ciphertext pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.147618, "o", "> "]
[433.147827, "o", "    pairs = [(i, encrypt_fn(i)) for i in range(2)]\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.147925, "o", ">     \r\n\u001b[?2004l\r"]
[433.148062, "o", "\u001b[?2004h> "]
[433.148335, "o", "    # Brute force with coarse sampling\r\n\u001b[?2004l\r"]
[433.14843, "o", "\u001b[?2004h> "]
[433.148511, "o", "    step0 = 128\r\n\u001b[?2004l\r"]
[433.148654, "o", "\u001b[?2004h> "]
[433.148748, "o", "    step1 = 128  \r\n\u001b[?2004l\r"]
[433.148856, "o", "\u001b[?2004h> "]
[433.148947, "o", "    step2 = 128\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.149048, "o", "    step3 = 128\r\n\u001b[?2004l\r"]
[433.149187, "o", "\u001b[?2004h> "]
[433.149293, "o", "    step4 = 8\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.149395, "o", ">     \r\n\u001b[?2004l\r"]
[433.149448, "o", "\u001b[?2004h> "]
[433.149645, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[433.14976, "o", "\u001b[?2004h> "]
[433.150058, "o", "        for seed4 in range(0, 0x10000, step4):\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.150133, "o", "> "]
[433.150424, "o", "            for seed0 in range(0, 0x10000, step0):\r\n\u001b[?2004l\r"]
[433.150483, "o", "\u001b[?2004h> "]
[433.150833, "o", "                for seed1 in range(0, 0x10000, step1):\r\n\u001b[?2004l\r"]
[433.150963, "o", "\u001b[?2004h> "]
[433.151293, "o", "                    for seed2 in range(0, 0x10000, step2):\r\n\u001b[?2004l\r"]
[433.1514, "o", "\u001b[?2004h> "]
[433.151761, "o", "                        for seed3 in range(0, 0x10000, step3):\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.15192, "o", "> "]
[433.152348, "o", "                            seeds = [seed0, seed1, seed2, seed3, seed4, seed5]\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.152478, "o", "> "]
[433.152606, "o", "                            \r\n\u001b[?2004l\r\u001b[?2004h"]
[433.15273, "o", "> "]
