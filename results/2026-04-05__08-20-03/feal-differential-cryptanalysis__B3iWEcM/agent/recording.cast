[433.142241, "o", "> "]
[433.142584, "o", "    keys = [(seed * 1234567) & 0xFFFFFFFF for seed in seeds]\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.142735, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.142846, "o", "    left = getleft(pt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.142909, "o", "> "]
[433.143039, "o", "    right = getright(pt)\r\n\u001b[?2004l\r\u001b[?2004h"]
