[388.098846, "i", "        if validate_keys(pt2, ct2, keys):\n                                        return key5\n    \n    return 0\n\ndef validate_keys(plaintext, ciphertext, keys):\n    \"\"\"Validate if keys produce the correct ciphertext\"\"\"\n    left = getleft(plaintext)\n    right = getright(plaintext)\n    \n    left ^= keys[0]\n    right ^= keys[1]\n    right ^= left\n    \n    for round_num in range(4):\n        mixed = f_function(right ^ keys[round_num + 2])\n        temp = right\n        right = left ^ mixed\n        left = temp\n    \n    left ^= right\n    result = merge(right, left)\n    \n    return result == ciphertext\n\nEOF\n"]
