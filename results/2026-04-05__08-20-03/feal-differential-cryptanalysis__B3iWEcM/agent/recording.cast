[147.548431, "o", "            right_after_post = ct_left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.54871, "o", "            left_after_r3 = left_after_post ^ right_after_post\r\n\u001b[?2004l\r"]
[147.548774, "o", "\u001b[?2004h> "]
[147.548979, "o", "            right_after_r3 = right_after_post\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.549061, "o", "> "]
[147.549144, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[147.549223, "o", "> "]
[147.549328, "o", "            # Undo round 3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.549555, "o", "            right_before_r3 = left_after_r3\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.549639, "o", "> "]
[147.549998, "o", "            left_before_r3 = right_after_r3 ^ f_function(right_before_r3 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.550082, "o", "> "]
[147.550362, "o", "            states_before_r3.append((left_before_r3, right_before_r3))\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.550398, "o", "> "]
[147.550517, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.550709, "o", "        # Now try to find a consistent key[4]\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.55075, "o", "> "]
[147.55109, "o", "        # We'll use a voting mechanism: for each pair of states,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.551473, "o", "        # we can derive what key[4] would need to be if those two states\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.551576, "o", "> "]
[147.551718, "o", "        # came from specific plaintexts\r\n\u001b[?2004l\r"]
[147.551777, "o", "\u001b[?2004h> "]
[147.551849, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.552103, "o", "        # Actually, let's use a different approach:\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.55216, "o", "> "]
[147.55248, "o", "        # For the correct key[5], when we try all key[4] values,\r\n\u001b[?2004l\r"]
[147.552573, "o", "\u001b[?2004h> "]
[147.55286, "o", "        # exactly one should produce states that could plausibly come\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.552959, "o", "> "]
[147.553063, "o", "        # from the earlier rounds\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.553152, "o", "> "]
[147.553254, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.553576, "o", "        # Try a subset of key[4] values and see if any produce consistent results\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.553658, "o", "> "]
[147.553759, "o", "        best_key4_score = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.553838, "o", "> "]
[147.553888, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[147.553957, "o", "> "]
[147.554277, "o", "        for seed4 in range(0, 0x10000, 256):  # Sample every 256th value for speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.554359, "o", "> "]
[147.554611, "o", "            candidate_key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.554717, "o", "> "]
[147.554828, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.554954, "o", "            # Decrypt one more round\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.555041, "o", "> "]
[147.555174, "o", "            states_before_r2 = []\r\n\u001b[?2004l\r"]
[147.555236, "o", "\u001b[?2004h> "]
[147.55545, "o", "            for left3, right3 in states_before_r3:\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.555495, "o", "> "]
[147.555641, "o", "                right2 = left3\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.55574, "o", "> "]
[147.555996, "o", "                left2 = right3 ^ f_function(right2 ^ candidate_key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.556031, "o", "> "]
[147.556304, "o", "                states_before_r2.append((left2, right2))\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.556422, "o", "> "]
[147.556617, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.556924, "o", "            # Check consistency: do these states have reasonable properties?\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.557021, "o", "> "]
[147.557293, "o", "            # For example, check if differential properties hold\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.55739, "o", "> "]
[147.557438, "o", "            score = 0\r\n\u001b[?2004l\r"]
[147.557516, "o", "\u001b[?2004h> "]
[147.557734, "o", "            for i in range(len(states_before_r2)):\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.557825, "o", "> "]
[147.558114, "o", "                for j in range(i+1, len(states_before_r2)):\r\n\u001b[?2004l\r"]
[147.558203, "o", "\u001b[?2004h> "]
[147.558399, "o", "                    l1, r1 = states_before_r2[i]\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.558481, "o", "> "]
[147.558677, "o", "                    l2, r2 = states_before_r2[j]\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.55872, "o", "> "]
[147.558936, "o", "                    # Some heuristic scoring\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.559, "o", "> "]
[147.559243, "o", "                    if (l1 ^ l2) != 0 or (r1 ^ r2) != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.559317, "o", "> "]
[147.559459, "o", "                        score += 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.55952, "o", "> "]
[147.559577, "o", "            \r\n"]
[147.559656, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[147.559818, "o", "            if score > best_key4_score:\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.55993, "o", "> "]
[147.560058, "o", "                best_key4_score = score\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.560152, "o", ">         \r\n\u001b[?2004l\r"]
[147.560208, "o", "\u001b[?2004h> "]
[147.560482, "o", "        # This heuristic still isn't strong enough\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.560567, "o", "> "]
[147.560718, "o", "        # Let me try yet another approach\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.560801, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[147.560877, "o", "> "]
[147.561148, "o", "    # Different strategy: Use the fact that for plaintext pairs with\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.561224, "o", "> "]
[147.561573, "o", "    # specific differences, the correct key will produce specific output differences\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.561663, "o", "> "]
[147.561844, "o", "    # This is classic differential cryptanalysis\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.561929, "o", ">     "]
[147.562025, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.562225, "o", "    # Collect pairs with zero difference in one half\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.562302, "o", "> "]
[147.562384, "o", "    pt1 = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.562594, "o", "    pt2 = 1  # Difference only in right half, LSB\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.56268, "o", "> "]
[147.562773, "o", "    ct1 = encrypt_fn(pt1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.56286, "o", "> "]
[147.562943, "o", "    ct2 = encrypt_fn(pt2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.563023, "o", ">     \r\n"]
[147.563112, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[147.563318, "o", "    # For each candidate key[5], check the differential\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.563404, "o", "> "]
[147.56352, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.563607, "o", "> "]
[147.563828, "o", "        candidate_key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.563914, "o", "> "]
[147.563999, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.564132, "o", "        # Partially decrypt both\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.564213, "o", "> "]
[147.564286, "o", "        # CT1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.564507, "o", "        ct1_left = getleft(ct1)\r\n\u001b[?2004l\r"]
[147.564594, "o", "\u001b[?2004h> "]
[147.564749, "o", "        ct1_right = getright(ct1)\r\n\u001b[?2004l\r"]
[147.564811, "o", "\u001b[?2004h> "]
[147.564913, "o", "        l1_post = ct1_right\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.565017, "o", "> "]
[147.565129, "o", "        r1_post = ct1_left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.565308, "o", "        l1_r3 = l1_post ^ r1_post\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.565449, "o", "        r1_r3 = r1_post\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.565546, "o", "> "]
[147.565666, "o", "        r1_before_r3 = l1_r3\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.565767, "o", "> "]
[147.566012, "o", "        l1_before_r3 = r1_r3 ^ f_function(r1_before_r3 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.566096, "o", "> "]
[147.566164, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.566283, "o", "        # CT2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.566403, "o", "        ct2_left = getleft(ct2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.566499, "o", "> "]
[147.566626, "o", "        ct2_right = getright(ct2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.566756, "o", "> "]
[147.566899, "o", "        l2_post = ct2_right\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.567023, "o", "        r2_post = ct2_left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.567171, "o", "        l2_r3 = l2_post ^ r2_post\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.567263, "o", "> "]
[147.567369, "o", "        r2_r3 = r2_post\r\n\u001b[?2004l\r"]
[147.567425, "o", "\u001b[?2004h> "]
[147.567545, "o", "        r2_before_r3 = l2_r3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.567948, "o", "        l2_before_r3 = r2_r3 ^ f_function(r2_before_r3 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.568043, "o", "> "]
[147.568133, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.568286, "o", "        # Check the differential\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.5686, "o", "        diff_left = l1_before_r3 ^ l2_before_r3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.568899, "o", "        diff_right = r1_before_r3 ^ r2_before_r3\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.568987, "o", "> "]
[147.569096, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.569459, "o", "        # The input plaintext difference was 1 (in the right half after initial processing)\r\n\u001b[?2004l\r"]
[147.569538, "o", "\u001b[?2004h> "]
[147.569792, "o", "        # We need to trace this through to see what we expect\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.56988, "o", "> "]
[147.570153, "o", "        # This is getting complex without knowing the other keys\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.570269, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[147.570506, "o", "    # Let me try the simplest possible approach:\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.5706, "o", "> "]
[147.570816, "o", "    # Just brute force and return the middle value as a guess\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.570864, "o", "> "]
[147.571134, "o", "    # This won't work but let me test the framework first\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.571167, "o", ">     "]
[147.571276, "o", "\r\n\u001b[?2004l\r"]
[147.571323, "o", "\u001b[?2004h> "]
[147.571455, "o", "    return (32768 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[147.57154, "o", "> \r\n\u001b[?2004l\r"]
[147.571634, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[147.574293, "o", "\u001b[?2004hroot@5bf583115212:/app# "]
[160.336946, "i", "cat > /app/test_attack.py << 'EOF'\n#!/usr/bin/env python3\n\nimport feal\nimport attack\nimport time\n\n# Initialize keys\nfeal.create_random_keys()\n\nprint(\"Actual key[5]:\", feal.key[5])\nprint(\"Testing attack...\")\n\nstart_time = time.time()\nrecovered_key5 = attack.attack(feal.encrypt)\nend_time = time.time()\n\nprint(f\"Recovered key[5]: {recovered_key5}\")\nprint(f\"Time taken: {end_time - start_time:.2f} seconds\")\nprint(f\"Match: {recovered_key5 == feal.key[5]}\")\nEOF\n"]
