[261.671064, "i", "cat > /app/attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"\n    Recover key[5] using meet-in-the-middle attack.\n    \n    Strategy: For each candidate key[5], partially decrypt and then\n    try to find a consistent key[4]. The correct key[5] will have\n    exactly one key[4] that produces consistent results across all pairs.\n    \"\"\"\n    \n    # Collect plaintext-ciphertext pairs\n    pairs ="]
[261.671229, "i", " []\n    for i in range(6):\n        pt = i\n        ct = encrypt_fn(pt)\n        pairs.append((pt, ct))\n    \n    best_seed5 = None\n    best_confidence = 0\n    \n    # Try each candidate key[5]\n    for seed5 in range(0x10000):\n        candidate_key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # Partially decrypt all ciphertexts to get states before round 3\n        states_before_r3 = []\n        for pt, ct in pairs:\n            ct_left = getleft(ct)\n            ct_right = getright(ct)\n            left_after_post = ct_right\n            right_after_post = ct_left\n            left_after_r3 = left_after_post ^ right_after_post\n            right_after_r3 = right_after_post\n            right_before_r3 = left_after_r3\n            left_before_r3 = right_after_r3 ^ f_function(right_before_r3 ^ candidate_key5)\n            states_before_r3.append((left_before_r3, right_before_r3))\n        \n        # Now try to find a consistent key[4]\n        # We'll use the first two pairs to derive candidate key[4] values\n        # The"]
[261.671326, "i", "n validate with the remaining pairs\n        \n        key4_candidates = set()\n        \n        # Use pairs 0 and 1 to constrain key[4]\n        # After round 2: left3 = right2, right3 = left2 ^ f(right2 ^ key[4])\n        # So: right2 = left3, and we can derive: left2 = right3 ^ f(left3 ^ key[4])\n        \n        # For a given key[4], we can compute what left2 and right2 would be\n        # Then we need to check if this is consistent across pairs\n        \n        # Sample key[4] space more densely\n        max_consistency = 0\n        best_key4_for_this_key5 = None\n        \n        for seed4 in range(0, 0x10000, 64):  # Sample every 64th value\n            candidate_key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # Decrypt one more round for all pairs\n            states_before_r2 = []\n            for left3, right3 in states_before_r3:\n                right2 = left3\n                left2 = right3 ^ f_function(right2 ^ candidate_key4)\n                states_before_r2.append((left2, right2))\n            "]
[261.671506, "o", "cat > /app/attack.py << 'EOF'\r\n\u001b[?2004l\rn validate with the remaining pairs\r\n        \r\n        key4_candidates = set()\r\n        \r\n        # Use pairs 0 and 1 to constrain key[4]\r\n        # After round 2: left3 = right2, right3 = left2 ^ f(right2 ^ key[4])\r\n        # So: righ"]
[261.67155, "i", "\n            # Check consistency: how unique are these states?\n            unique_count = len(set(states_before_r2))\n            \n            if unique_count > max_consistency:\n                max_consistency = unique_count\n                best_key4_for_this_key5 = seed4\n        \n        # The correct key[5] should produce high consistency\n        if max_consistency > best_confidence:\n            best_confidence = max_consistency\n            best_seed5 = seed5\n    \n    best_key5 = (best_seed5 * 1234567) & 0xFFFFFFFF\n    return best_key5\n\nEOF\n"]
