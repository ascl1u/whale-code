[388.117355, "o", "    pt = 0\r\n\u001b[?2004l\rxt\"\"\u001b[?2004h"]
[388.117486, "o", "> "]
[388.117681, "o", "    ct = encrypt_fn(pt)\r\n\u001b[?2004l\ra\u001b[?2004h"]
