[388.111813, "o", "\u001b[?2004h> "]
[388.111892, "o", "    \r\n\u001b[?2004l\r"]
[388.112034, "o", "\u001b[?2004h> "]
[388.112125, "o", "    Strategy:\r\n"]
[388.112223, "o", "\u001b[?2004l\r\u001b[?2004h"]
[388.112385, "o", "> "]
[388.112756, "o", "    1. Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r"]
[388.112908, "o", "\u001b[?2004h> "]
[388.113736, "o", "    2. For each candidate (key[4], key[5]), decrypt backward 2 rounds\r\n\u001b[?2004l\r"]
[388.113843, "o", "\u001b[?2004h> "]
[388.114624, "o", "    3. For each candidate (key[0], key[1]), encrypt forward through initial processing\r\n\u001b[?2004l\r"]
[388.114745, "o", "\u001b[?2004h> "]
[388.115529, "o", "    4. Try to match them by testing candidate key[2] and key[3] values\r\n\u001b[?2004l\r"]
[388.115651, "o", "\u001b[?2004h> "]
[388.116177, "o", "    5. When we find a complete match, return key[5]\r\n\u001b[?2004l\r"]
[388.11632, "o", "\u001b[?2004h> "]
[388.116402, "o", "    \"\"\"\r\n\u001b[?2004l\r)\u001b[?2004h"]
[388.116477, "o", "> "]
[388.116583, "o", "    \r\n\u001b[?2004l\r"]
[388.116714, "o", "\u001b[?2004h> "]
