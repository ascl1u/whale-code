[433.152984, "o", "> "]
[433.153371, "o", "                            if test_keys(pairs[0][0], pairs[0][1], seeds):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.153717, "o", "                                # Validate with second pair\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.15426, "o", "                                if test_keys(pairs[1][0], pairs[1][1], seeds):\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.154351, "o", "> "]
[433.15467, "o", "                                    key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[433.154703, "o", "\u001b[?2004h> "]
