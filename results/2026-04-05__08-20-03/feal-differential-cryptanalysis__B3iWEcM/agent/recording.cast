[433.143924, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[433.143995, "o", "> "]
[433.144216, "o", "    for round_num in range(4):\r\n\u001b[?2004l\r"]
[433.144284, "o", "\u001b[?2004h"]
[433.144327, "o", "> "]
[433.144653, "o", "        mixed = f_function(right ^ keys[round_num + 2])\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.144747, "o", "> "]
