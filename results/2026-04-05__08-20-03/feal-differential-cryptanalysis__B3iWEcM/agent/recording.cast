[388.143288, "o", "\u001b[?2004h> "]
[388.143501, "o", "                        # Try to find key3\r\n\u001b[?2004l\r"]
[388.143573, "o", "\u001b[?2004h"]
[388.143669, "o", "> "]
[388.143862, "o", "                        for seed3 in range(0, 0x10000, 256):\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.143947, "o", "> "]
[388.144193, "o", "                            key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.144277, "o", "> "]
