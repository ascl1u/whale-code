[147.527363, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def getleft(x):\r\n\u001b[?2004l\r"]
[147.527487, "i", "c differential cryptanalysis\n    \n    # Collect pairs with zero difference in one half\n    pt1 = 0\n    pt2 = 1  # Difference only in right half, LSB\n    ct1 = encrypt_fn(pt1)\n    ct2 = encrypt_fn(pt2)\n    \n    # For each candidate key[5], check the differential\n    for seed5 in range(0x10000):\n        candidate_key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # Partially decrypt both\n        # CT1\n        ct1_left = getleft(ct1)\n        ct1_right = getright(ct1)\n        l1_post = ct1_right\n        r1_post = ct1_left\n        l1_r3 = l1_post ^ r1_post\n        r1_r3 = r1_post\n        r1_before_r3 = l1_r3\n        l1_before_r3 = r1_r3 ^ f_function(r1_before_r3 ^ candidate_key5)\n        \n        # CT2\n        ct2_left = getleft(ct2)\n        ct2_right = getright(ct2)\n        l2_post = ct2_right\n        r2_post = ct2_left\n        l2_r3 = l2_post ^ r2_post\n        r2_r3 = r2_post\n        r2_before_r3 = l2_r3\n        l2_before_r3 = r2_r3 ^ f_function(r2_before_r3 ^ candidate_key5)\n        \n        # Check the dif"]
