[433.155461, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[433.157732, "o", "\u001b[?2004hroot@5bf583115212:/app# "]
[456.459798, "i", "cat > /app/attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef merge(left, right):\n    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef test_keys(pt, ct, seeds):\n    \"\"\"Test if seeds produce correct ciphertext\"\"\"\n    keys = [(seed * 1234567) & 0xFFFFFFFF for seed in seeds]\n    \n    left = getleft(pt)\n    right = getright(pt)\n    \n    left ^= keys[0]\n    right ^= keys[1]\n    right ^= left\n    \n    for rou"]
[456.460088, "i", "nd_num in range(4):\n        mixed = f_function(right ^ keys[round_num + 2])\n        temp = right\n        right = left ^ mixed\n        left = temp\n    \n    left ^= right\n    result = merge(right, left)\n    \n    return result == ct\n\ndef attack(encrypt_fn):\n    \"\"\"\n    Recover key[5] using brute force with aggressive sampling.\n    \"\"\"\n    \n    # Get plaintext-ciphertext pairs\n    pairs = [(i, encrypt_fn(i)) for i in range(2)]\n    \n    # Very coarse sampling - step size 512\n    step = 512\n    \n    for seed5 in range(0, 0x10000, step):\n        for seed4 in range(0, 0x10000, step):\n            for seed3 in range(0, 0x10000, step):\n                for seed2 in range(0, 0x10000, step):\n                    for seed1 in range(0, 0x10000, step):\n                        for seed0 in range(0, 0x10000, step):\n                            seeds = [seed0, seed1, seed2, seed3, seed4, seed5]\n                            \n                            # Test with first pair\n                            if test_keys(pairs[0][0], pair"]
[456.460268, "i", "s[0][1], seeds):\n                                # Validate with second pair\n                                if test_keys(pairs[1][0], pairs[1][1], seeds):\n                                    # Found it! Now refine to get exact values\n                                    # Try nearby values\n                                    for d5 in range(-step, step):\n                                        for d4 in range(-step, step):\n                                            for d3 in range(-step, step):\n                                                for d2 in range(-step, step):\n                                                    for d1 in range(-step, step):\n                                                        for d0 in range(-step, step):\n                                                            refined_seeds = [\n                                                                max(0, min(0xFFFF, seed0 + d0)),\n                                                                max(0, min(0xFFFF, seed1 + d1)),\n     "]
[456.460332, "o", "cat > /app/attack.py << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[456.460495, "i", "                                                           max(0, min(0xFFFF, seed2 + d2)),\n                                                                max(0, min(0xFFFF, seed3 + d3)),\n                                                                max(0, min(0xFFFF, seed4 + d4)),\n                                                                max(0, min(0xFFFF, seed5 + d5))\n                                                            ]\n                                                            if test_keys(pairs[0][0], pairs[0][1], refined_seeds) and \\\n                                                               test_keys(pairs[1][0], pairs[1][1], refined_seeds):\n                                                                key5 = (refined_seeds[5] * 1234567) & 0xFFFFFFFF\n                                                                return key5\n    \n    return 0\n\nEOF\n"]
