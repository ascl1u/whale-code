[388.146766, "o", "> "]
[388.146974, "o", "                                        return key5\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.147065, "o", ">     \r\n\u001b[?2004l\r"]
[388.147167, "o", "\u001b[?2004h> "]
[388.147327, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.147565, "o", "def validate_keys(plaintext, ciphertext, keys):\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.147627, "o", "> "]
[388.147856, "o", "    \"\"\"Validate if keys produce the correct ciphertext\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.147939, "o", "> "]
[388.148058, "o", "    left = getleft(plaintext)\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.148173, "o", "> "]
[388.148237, "o", "    right = getright(plaintext)\r\n\u001b[?2004l\r"]
[388.148324, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.148495, "o", "    left ^= keys[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.148614, "o", "    right ^= keys[1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.148724, "o", "> "]
[388.148817, "o", "    right ^= left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.148892, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.149032, "o", "    for round_num in range(4):\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.149124, "o", "> "]
[388.149333, "o", "        mixed = f_function(right ^ keys[round_num + 2])\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.149377, "o", "> "]
[388.149516, "o", "        temp = right\r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.149706, "o", "        right = left ^ mixed\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.14979, "o", "> "]
[388.149866, "o", "        left = temp\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.149923, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.150049, "o", "    left ^= right\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.150153, "o", "> "]
[388.150266, "o", "    result = merge(right, left)\r\n\u001b[?2004l\r\u001b[?2004h"]
[388.150399, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[388.150543, "o", "    return result == ciphertext\r\n\u001b[?2004l\r\u001b[?2004h> "]
