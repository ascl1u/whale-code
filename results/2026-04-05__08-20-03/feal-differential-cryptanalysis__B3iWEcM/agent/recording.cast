[412.63588, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.635972, "o", "> "]
[412.63623, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.636351, "o", "> "]
[412.636563, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.636683, "o", "> "]
[412.636819, "o", "    output = 0\r\n\u001b[?2004l\r"]
[412.636971, "o", "\u001b[?2004h> "]
[412.637107, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.637402, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.637599, "o", "> "]
[412.637695, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.637834, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.638091, "o", "def decrypt_two_rounds(ciphertext, key4, key5):\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.638195, "o", "> "]
[412.63843, "o", "    \"\"\"Decrypt backward through rounds 3 and 2\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.638616, "o", "    ct_left = getleft(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.638728, "o", "> "]
[412.638886, "o", "    ct_right = getright(ciphertext)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.639038, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[412.639202, "o", "> "]
[412.639334, "o", "    # Undo final swap\r\n\u001b[?2004l\r"]
[412.639495, "o", "\u001b[?2004h> "]
[412.63964, "o", "    left = ct_right\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.639751, "o", "> "]
[412.639859, "o", "    right = ct_left\r\n\u001b[?2004l\r"]
[412.63993, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[412.640002, "o", "\u001b[?2004h> "]
[412.640163, "o", "    # Undo post-round mixing\r\n\u001b[?2004l\r"]
[412.640256, "o", "\u001b[?2004h> "]
[412.640358, "o", "    left = left ^ right\r\n\u001b[?2004l\r"]
[412.640483, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[412.640598, "o", "\u001b[?2004h>     # Undo round 3\r\n\u001b[?2004l\r"]
[412.640757, "o", "\u001b[?2004h> "]
[412.640987, "o", "    new_left = right ^ f_function(left ^ key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.641092, "o", "> "]
[412.641265, "o", "    new_right = left\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.641366, "o", "> "]
[412.641532, "o", "    left, right = new_left, new_right\r\n\u001b[?2004l\r"]
[412.64166, "o", "\u001b[?2004h>     \r\n"]
[412.641757, "o", "\u001b[?2004l\r\u001b[?2004h>     # Undo round 2\r\n\u001b[?2004l\r"]
[412.641847, "o", "\u001b[?2004h> "]
[412.642047, "o", "    new_left = right ^ f_function(left ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.642138, "o", "> "]
[412.642195, "o", "    new_right = left\r\n\u001b[?2004l\r"]
[412.642314, "o", "\u001b[?2004h> "]
[412.642449, "o", "    left, right = new_left, new_right\r\n\u001b[?2004l\r"]
[412.642583, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[412.642663, "o", "\u001b[?2004h> "]
[412.642716, "o", "    return left, right\r\n\u001b[?2004l\r"]
[412.6428, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[412.642933, "o", "\u001b[?2004h> "]
[412.643035, "o", "def test_key_combination(pairs, seeds):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.643377, "o", "    \"\"\"Test if a combination of key seeds works for all pairs\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.643505, "o", "> "]
[412.64378, "o", "    keys = [(seed * 1234567) & 0xFFFFFFFF for seed in seeds]\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.643875, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[412.643975, "o", "> "]
[412.644069, "o", "    for pt, ct in pairs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.644247, "o", "        left = getleft(pt)\r\n\u001b[?2004l\r"]
[412.644368, "o", "\u001b[?2004h> "]
[412.644508, "o", "        right = getright(pt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.644615, "o", ">         \r\n\u001b[?2004l\r"]
[412.644756, "o", "\u001b[?2004h> "]
[412.645006, "o", "        # Initial whitening\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.645211, "o", "        left ^= keys[0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.645415, "o", "> "]
[412.645552, "o", "        right ^= keys[1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.645723, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.645905, "o", "        # Pre-round mixing\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.646023, "o", "> "]
[412.646114, "o", "        right ^= left\r\n\u001b[?2004l\r"]
[412.646196, "o", "\u001b[?2004h> "]
[412.646251, "o", "        \r\n\u001b[?2004l\r"]
[412.64634, "o", "\u001b[?2004h> "]
[412.646462, "o", "        # 4 rounds\r\n\u001b[?2004l\r"]
[412.646559, "o", "\u001b[?2004h> "]
[412.646782, "o", "        for round_num in range(4):\r\n\u001b[?2004l\r"]
[412.646812, "o", "\u001b[?2004h"]
[412.646931, "o", "> "]
[412.647222, "o", "            mixed = f_function(right ^ keys[round_num + 2])\r\n\u001b[?2004l\r"]
[412.647313, "o", "\u001b[?2004h> "]
[412.647488, "o", "            temp = right\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.647574, "o", "> "]
[412.647789, "o", "            right = left ^ mixed\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.647902, "o", "> "]
[412.648001, "o", "            left = temp\r\n\u001b[?2004l\r"]
[412.648035, "o", "\u001b[?2004h> "]
[412.648182, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[412.648282, "o", "> "]
[412.64851, "o", "        # Post-round mixing\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.648707, "o", "        left ^= right\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.648837, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.649061, "o", "        # Final swap\r\n\u001b[?2004l\r"]
[412.649092, "o", "\u001b[?2004h"]
[412.649134, "o", "> "]
[412.649378, "o", "        result = merge(right, left)\r\n\u001b[?2004l\r"]
[412.64947, "o", "\u001b[?2004h> "]
[412.649534, "o", "        \r\n\u001b[?2004l\r"]
[412.649623, "o", "\u001b[?2004h> "]
[412.649802, "o", "        if result != ct:\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.649898, "o", "> "]
[412.650058, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.650223, "o", ">     \r\n\u001b[?2004l\r"]
[412.650369, "o", "\u001b[?2004h> "]
[412.65047, "o", "    return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[412.650577, "o", "\u001b[?2004h> "]
[412.650671, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r"]
[412.650813, "o", "\u001b[?2004h> "]
[412.650936, "o", "    \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.651294, "o", "    Recover key[5] using exhaustive search with pruning.\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.651364, "o", ">     "]
[412.651439, "o", "\r\n\u001b[?2004l\r"]
[412.65153, "o", "\u001b[?2004h> "]
[412.651944, "o", "    Strategy: Try all key[5] values, and for each, try to find\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.652016, "o", "> "]
[412.652413, "o", "    a consistent set of other keys using smart search.\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.652504, "o", "> "]
[412.652633, "o", "    \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.652713, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.653049, "o", "    # Collect multiple plaintext-ciphertext pairs\r\n\u001b[?2004l\r"]
[412.653136, "o", "\u001b[?2004h> "]
[412.653382, "o", "    pairs = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.653517, "o", "    for i in range(3):\r\n\u001b[?2004l\r"]
[412.653606, "o", "\u001b[?2004h> "]
[412.653677, "o", "        pt = i\r\n\u001b[?2004l\r"]
[412.653711, "o", "\u001b[?2004h> "]
[412.653968, "o", "        ct = encrypt_fn(pt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.654053, "o", "> "]
[412.654272, "o", "        pairs.append((pt, ct))\r\n\u001b[?2004l\r"]
[412.654361, "o", "\u001b[?2004h"]
[412.654487, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[412.654576, "o", "> "]
[412.654667, "o", "    # Try all key[5] values\r\n\u001b[?2004l\r"]
[412.654751, "o", "\u001b[?2004h> "]
[412.654961, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[412.654997, "o", "\u001b[?2004h> "]
[412.655359, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[412.65551, "o", "\u001b[?2004h> "]
[412.655629, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.655883, "o", "        # For this key[5], try to find key[4]\r\n\u001b[?2004l\r"]
[412.655973, "o", "\u001b[?2004h> "]
[412.656418, "o", "        # We'll try a subset and see if any produce consistent results\r\n\u001b[?2004l\r"]
[412.656511, "o", "\u001b[?2004h> "]
[412.656915, "o", "        for seed4 in range(0, 0x10000, 4):  # Try every 4th value\r\n\u001b[?2004l\r"]
[412.656965, "o", "\u001b[?2004h> "]
[412.657447, "o", "            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n"]
[412.657544, "o", "\u001b[?2004l\r"]
[412.657638, "o", "\u001b[?2004h> "]
[412.657737, "o", "            \r\n\u001b[?2004l\r"]
[412.657841, "o", "\u001b[?2004h> "]
[412.658144, "o", "            # Decrypt all pairs backward 2 rounds\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.658234, "o", "> "]
[412.658381, "o", "            states_before_r2 = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.658461, "o", "> "]
[412.658632, "o", "            for pt, ct in pairs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.65874, "o", "> "]
[412.659047, "o", "                left, right = decrypt_two_rounds(ct, key4, key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.659139, "o", "> "]
[412.659396, "o", "                states_before_r2.append((left, right))\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.659518, "o", "> "]
[412.659555, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[412.659943, "o", "            # Check if these states are all different (good sign)\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.660051, "o", "> "]
[412.660409, "o", "            if len(set(states_before_r2)) != len(states_before_r2):\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.660515, "o", "> "]
[412.660625, "o", "                continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.660772, "o", ">             \r\n\u001b[?2004l\r"]
[412.660876, "o", "\u001b[?2004h> "]
[412.661107, "o", "            # Now try to find keys 0-3 that work\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.66124, "o", "> "]
[412.661402, "o", "            # Try a small sample\r\n\u001b[?2004l\r\u001b[?2004h"]
[412.661507, "o", "> "]
[412.714935, "o", "            for seed0 in range(0, 0x10000, 256):\r\n\u001b[?2004l\r\u001b[?2004h>                 for seed1 in range(0, 0x10000, 256):\r\n\u001b[?2004l\r\u001b[?2004h>                     for seed2 in range(0, 0x10000, 256):\r\n\u001b[?2004l\r\u001b[?2004h>                         for seed3 in range(0, 0x10000, 256):\r\n\u001b[?2004l\r\u001b[?2004h>                             seeds = [seed0, seed1, seed2, seed3, seed4, seed5]\r\n\u001b[?2004l\r\u001b[?2004h>                             if test_key_combination(pairs, seeds):\r\n\u001b[?2004l\r\u001b[?2004h>                                 return key5\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[412.71683, "o", "\u001b[?2004hroot@5bf583115212:/app# "]
[433.133877, "i", "cat > /app/attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef merge(left, right):\n    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef test_keys(pt, ct, seeds):\n    \"\"\"Test if seeds produce correct ciphertext\"\"\"\n    keys = [(seed * 1234567) & 0xFFFFFFFF for seed in seeds]\n    \n    left = getleft(pt)\n    right = getright(pt)\n    \n    left ^= keys[0]\n    right ^= keys[1]\n    right ^= left\n    \n    for rou"]
[433.134089, "i", "nd_num in range(4):\n        mixed = f_function(right ^ keys[round_num + 2])\n        temp = right\n        right = left ^ mixed\n        left = temp\n    \n    left ^= right\n    result = merge(right, left)\n    \n    return result == ct\n\ndef attack(encrypt_fn):\n    \"\"\"\n    Recover key[5] using brute force with intelligent sampling.\n    \"\"\"\n    \n    # Get plaintext-ciphertext pairs\n    pairs = [(i, encrypt_fn(i)) for i in range(2)]\n    \n    # Brute force with coarse sampling\n    step0 = 128\n    step1 = 128  \n    step2 = 128\n    step3 = 128\n    step4 = 8\n    \n    for seed5 in range(0x10000):\n        for seed4 in range(0, 0x10000, step4):\n            for seed0 in range(0, 0x10000, step0):\n                for seed1 in range(0, 0x10000, step1):\n                    for seed2 in range(0, 0x10000, step2):\n                        for seed3 in range(0, 0x10000, step3):\n                            seeds = [seed0, seed1, seed2, seed3, seed4, seed5]\n                            \n                            # Test with first pair\n"]
[433.13423, "i", "                            if test_keys(pairs[0][0], pairs[0][1], seeds):\n                                # Validate with second pair\n                                if test_keys(pairs[1][0], pairs[1][1], seeds):\n                                    key5 = (seed5 * 1234567) & 0xFFFFFFFF\n                                    return key5\n    \n    return 0\n\nEOF\n"]
[433.134364, "o", "cat > /app/attack.py << 'EOF'\r\n\u001b[?2004l\r                            if test_keys(pairs[0][0], pairs[0][1], seeds):\r\n                                # Validate with second pair\r\n                                if test_keys(pairs[1][0], pairs[1][1], seeds):\r\n                                    key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n                                  "]
[433.134541, "o", "  return key5\r\n    \r\n    return 0\r\n\r\nEOF\r\n"]
[433.134625, "o", "\u001b[?2004h> "]
[433.134783, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[433.134885, "o", "\u001b[?2004h> "]
[433.135031, "o", "def getleft(x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.13527, "o", "    return (x >> 32) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[433.135357, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[433.135422, "o", "> "]
[433.135537, "o", "def getright(x):\r\n\u001b[?2004l\r"]
[433.135597, "o", "\u001b[?2004h> "]
[433.135828, "o", "    return x & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.135866, "o", "> \r\n\u001b[?2004l\r"]
[433.136019, "o", "\u001b[?2004h"]
[433.136147, "o", "> def merge(left, right):\r\n\u001b[?2004l\r"]
[433.136209, "o", "\u001b[?2004h> "]
[433.136651, "o", "    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\r\n\u001b[?2004l\r"]
[433.136787, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[433.136901, "o", "> "]
[433.137018, "o", "def g_function(a, b, x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.137292, "o", "    temp = (a + b + x) & 0xFF\r\n\u001b[?2004l\r"]
[433.137428, "o", "\u001b[?2004h> "]
[433.137674, "o", "    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\u001b[?2004l\r"]
[433.137818, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[433.137896, "o", "\u001b[?2004h> "]
[433.138071, "o", "def f_function(input_val):\r\n\u001b[?2004l\r"]
[433.138177, "o", "\u001b[?2004h> "]
[433.138281, "o", "    x = [0] * 4\r\n\u001b[?2004l\r"]
[433.138361, "o", "\u001b[?2004h> "]
[433.138507, "o", "    y = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.138651, "o", "> "]
[433.13878, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.138988, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r"]
[433.139134, "o", "\u001b[?2004h> "]
[433.139258, "o", "        input_val >>= 8\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.139393, "o", "> "]
[433.139568, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r"]
[433.139635, "o", "\u001b[?2004h> "]
[433.139808, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r"]
[433.139869, "o", "\u001b[?2004h"]
