def attack(encrypt_fn):
    """
    Recover key[5] by trying all combinations with moderate sampling.
    Use step size 64 which gives (2^16/64)^6 = 2^60 operations.
    Too large, so use step 128: (2^16/128)^6 = 2^54 still too large.
    Use step 256: (2^16/256)^6 = 2^48 still too large.
    Use step 1024: (2^16/1024)^6 = 64^6 = 2^36 = 68 billion, borderline.
    
    Actually, let's use step 2048: (2^16/2048)^6 = 32^6 = 2^30 = 1 billion, feasible!
    """
    
    pairs = [(i, encrypt_fn(i)) for i in range(2)]
    
    step = 2048
    
    for seed5 in range(0, 0x10000, step):
        for seed4 in range(0, 0x10000, step):
            for seed3 in range(0, 0x10000, step):
                for seed2 in range(0, 0x10000, step):
                    for seed1 in range(0, 0x10000, step):
                        for seed0 in range(0, 0x10000, step):
                            seeds = [seed0, seed1, seed2, seed3, seed4, seed5]
                            if encrypt_with_seeds(pairs[0][0], seeds) == pairs[0][1]:
                                if encrypt_with_seeds(pairs[1][0], seeds) == pairs[1][1]:
                                    # Found approximate match, refine
                                    for key_idx in range(6):
                                        for offset in range(-step, step+1):
                                            test_seeds = list(seeds)
                                            test_seeds[key_idx] = max(0, min(0xFFFF, seeds[key_idx] + offset))
                                            if encrypt_with_seeds(pairs[0][0], test_seeds) == pairs[0][1]:
                                                if encrypt_with_seeds(pairs[1][0], test_seeds) == pairs[1][1]:
                                                    seeds = test_seeds
