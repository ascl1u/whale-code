[35.830946, "o", "\u001b[?2004h> "]
[35.831234, "o", "            # where right4 = left3 ^ f(right3 ^ key[5])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.831429, "o", "            # and left4 = right3\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.831471, "o", "> "]
[35.831598, "o", "            \r\n\u001b[?2004l\r"]
[35.831703, "o", "\u001b[?2004h> "]
