[585.397672, "o", "\u001b[?2004h> "]
[585.398045, "o", "                        for seed0 in range(0, 0x10000, step):\r\n\u001b[?2004l\r"]
[585.398151, "o", "\u001b[?2004h> "]
[585.398508, "o", "                            key0 = (seed0 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[585.398611, "o", "\u001b[?2004h> "]
