[585.389695, "o", "> "]
[585.389858, "o", "    # Collect a plaintext-ciphertext pair\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.38999, "o", ">     pt = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[585.390122, "o", "    ct = encrypt_fn(pt)\r\n\u001b[?2004l\r"]
[585.390158, "o", "\u001b[?2004h>     "]
[585.39026, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[585.390504, "o", "    # Brute force: try combinations of seeds\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.390602, "o", "> "]
[585.390855, "o", "    # Strategy: try all seeds for key[5] and key[4]\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.390974, "o", "> "]
