[398.266933, "i", "        \n        for seed4 in range(0, 0x10000, 256):  # Sample every 256th value\n            candidate_key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # For each round3 state, compute what round2 would be\n            consistency = 0\n            for l3, r3 in round3_states:\n                # Round 3: left3, right3 came from\n                # left3 = right2\n                # right3 = left2 ^ f(right2 ^ key[4])\n                \n                right2 = l3\n                left2 = r3 ^ f_function(right2 ^ candidate_key4)\n                \n                # Check if left2 and right2 look \"reasonable\"\n                # This is still heuristic, but let's count something\n                # For now, just count non-zero values\n                if left2 != 0 or right2 != 0:\n                    consistency += 1\n            \n            if consistency > max_consistency:\n                max_consistency = consistency\n        \n        if max_consistency > best_consistency:\n            best_consistency = max_consi"]
