[35.830006, "o", "\u001b[?2004h> "]
[35.830069, "o", "        score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.830138, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.830342, "o", "        for p1, c1, p2, c2 in diff_pairs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.830427, "o", "> "]
