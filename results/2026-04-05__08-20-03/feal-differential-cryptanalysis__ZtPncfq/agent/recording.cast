[944.991308, "o", "> "]
[944.991646, "o", "    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.991826, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[944.991974, "o", "def g_function(a, b, x):\r\n\u001b[?2004l\r"]
[944.992101, "o", "\u001b[?2004h> "]
[944.992321, "o", "    temp = (a + b + x) & 0xFF\r\n\u001b[?2004l\r"]
[944.992462, "o", "\u001b[?2004h> "]
[944.99272, "o", "    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\u001b[?2004l\r"]
[944.992866, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[944.993215, "o", "def f_function(input_val):\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.993407, "o", "> "]
[944.993555, "o", "    x = [0] * 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[944.993715, "o", "    y = [0] * 4\r\n\u001b[?2004l\r"]
[944.993838, "o", "\u001b[?2004h"]
[944.993951, "o", ">     for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.994057, "o", "> "]
[944.994211, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.994285, "o", "> "]
[944.994488, "o", "        input_val >>= 8\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.994578, "o", "> "]
[944.994813, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.994912, "o", "> "]
[944.995071, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.995214, "o", "> "]
[944.995346, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.995521, "o", "> "]
[944.995667, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r"]
[944.995786, "o", "\u001b[?2004h> "]
[944.995879, "o", "    output = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.995951, "o", "> "]
[944.996163, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.996296, "o", "> "]
[944.996472, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.996556, "o", "> "]
[944.996766, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[944.996897, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[944.997069, "o", "\u001b[?2004h> "]
[944.997242, "o", "def encrypt_with_keys(plaintext, keys):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[944.997444, "o", "    left = getleft(plaintext)\r\n\u001b[?2004l\r"]
[944.997537, "o", "\u001b[?2004h> "]
[944.997745, "o", "    right = getright(plaintext)\r\n\u001b[?2004l\r"]
[944.997893, "o", "\u001b[?2004h> "]
[944.998006, "o", "    left ^= keys[0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.998153, "o", "> "]
[944.998298, "o", "    right ^= keys[1]\r\n\u001b[?2004l\r"]
[944.998422, "o", "\u001b[?2004h> "]
[944.998522, "o", "    right ^= left\r\n\u001b[?2004l\r"]
[944.998622, "o", "\u001b[?2004h> "]
[944.998721, "o", "    for round_num in range(4):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[944.99908, "o", "        mixed = f_function(right ^ keys[round_num + 2])\r\n\u001b[?2004l\r\u001b[?2004h"]
[944.999188, "o", "> "]
[944.999346, "o", "        temp = right\r\n"]
[944.999402, "o", "\u001b[?2004l\r"]
[944.999527, "o", "\u001b[?2004h"]
[944.999645, "o", "> "]
[944.999825, "o", "        right = left ^ mixed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[945.00005, "o", "        left = temp\r\n\u001b[?2004l\r\u001b[?2004h> "]
[945.000195, "o", "    left ^= right\r\n\u001b[?2004l\r\u001b[?2004h> "]
[945.000392, "o", "    return merge(right, left)\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.000514, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[945.000625, "o", "> "]
[945.000719, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r"]
[945.000792, "o", "\u001b[?2004h> "]
[945.001111, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r"]
[945.00124, "o", "\u001b[?2004h> "]
[945.00159, "o", "    pairs = [(i, encrypt_fn(i)) for i in range(3)]\r\n\u001b[?2004l\r"]
[945.001752, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[945.001853, "o", "\u001b[?2004h> "]
[945.002302, "o", "    # Try candidates evenly spaced across 16-bit range\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.002436, "o", "> "]
[945.002799, "o", "    # Using 6 values: 0, 13107, 26214, 39321, 52428, 65535\r\n\u001b[?2004l\r"]
[945.00289, "o", "\u001b[?2004h> "]
[945.003297, "o", "    candidates = [0, 13107, 26214, 39321, 52428]\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.003406, "o", "> "]
[945.003531, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[945.003767, "o", "    for c0 in candidates:\r\n\u001b[?2004l\r"]
[945.003826, "o", "\u001b[?2004h> "]
[945.004211, "o", "        key0 = (c0 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.004301, "o", "> "]
[945.004525, "o", "        for c1 in candidates:\r\n\u001b[?2004l\r"]
[945.00456, "o", "\u001b[?2004h"]
[945.00467, "o", "> "]
[945.00504, "o", "            key1 = (c1 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[945.005137, "o", "\u001b[?2004h> "]
[945.005422, "o", "            for c2 in candidates:\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.005515, "o", "> "]
[945.00593, "o", "                key2 = (c2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[945.006069, "o", "\u001b[?2004h> "]
[945.00637, "o", "                for c3 in candidates:\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.00649, "o", "> "]
[945.00681, "o", "                    key3 = (c3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.006915, "o", "> "]
[945.007112, "o", "                    for c4 in candidates:\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.007205, "o", "> "]
[945.007581, "o", "                        key4 = (c4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[945.007733, "o", "\u001b[?2004h> "]
[945.007965, "o", "                        \r\n\u001b[?2004l\r\u001b[?2004h"]
[945.008188, "o", "> "]
[945.008466, "o", "                        # Try all seeds for key[5]\r\n\u001b[?2004l\r"]
[945.008571, "o", "\u001b[?2004h> "]
[945.008919, "o", "                        for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[945.009014, "o", "\u001b[?2004h> "]
[945.009451, "o", "                            key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[945.009895, "o", "                            keys = [key0, key1, key2, key3, key4, key5]\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.010007, "o", "> "]
[945.010167, "o", "                            \r\n\u001b[?2004l\r\u001b[?2004h"]
[945.010223, "o", "> "]
[945.010656, "o", "                            # Quick check with first pair only for speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.010766, "o", "> "]
[945.011199, "o", "                            if encrypt_with_keys(pairs[0][0], keys) == pairs[0][1]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.011298, "o", "> "]
[945.011588, "o", "                                # Verify with other pairs\r\n\u001b[?2004l\r"]
[945.011755, "o", "\u001b[?2004h> "]
[945.012303, "o", "                                if all(encrypt_with_keys(pt, keys) == ct for pt, ct in pairs[1:]):\r\n\u001b[?2004l\r\u001b[?2004h"]
[945.012445, "o", "> "]
[945.012694, "o", "                                    return key5\r\n\u001b[?2004l\r"]
[945.012848, "o", "\u001b[?2004h> "]
[945.012995, "o", "    \r\n\u001b[?2004l\r"]
[945.013134, "o", "\u001b[?2004h>     return 0\r\n\u001b[?2004l\r"]
[945.0133, "o", "\u001b[?2004h> "]
[945.013449, "o", "EOF\r\n\u001b[?2004l\r"]
[945.015702, "o", "\u001b[?2004hroot@e46f4ec08a64:/app# "]
[962.576759, "i", "python3 << 'PYEOF'\nimport sys\nsys.path.insert(0, '/app')\nimport feal\nimport attack\nimport time\n\nfeal.create_random_keys()\nprint(f\"Actual key[5] = {feal.key[5]}\")\n\nstart = time.time()\nrecovered = attack.attack(feal.encrypt)\nend = time.time()\n\nprint(f\"Recovered key[5] = {recovered}\")\nprint(f\"Time: {end-start:.2f}s\")\nprint(f\"Success: {recovered == feal.key[5]}\")\nPYEOF\n"]
