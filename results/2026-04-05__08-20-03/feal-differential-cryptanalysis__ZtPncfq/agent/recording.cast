[507.231783, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.23185, "o", "> "]
[507.232189, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[507.232537, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r"]
[507.232649, "o", "\u001b[?2004h> "]
[507.232907, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\r"]
[507.232979, "o", "\u001b[?2004h> "]
[507.23323, "o", "    output = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[507.233469, "o", "    for i in range(4):\r\n\u001b[?2004l\r"]
[507.233609, "o", "\u001b[?2004h> "]
[507.233843, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r"]
[507.234064, "o", "\u001b[?2004h> "]
[507.234304, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.234363, "o", "> \r\n\u001b[?2004l\r"]
[507.234547, "o", "\u001b[?2004h"]
[507.234684, "o", "> def attack(encrypt_fn):\r\n\u001b[?2004l\r"]
[507.234833, "o", "\u001b[?2004h> "]
[507.235122, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.235296, "o", "> "]
[507.235383, "o", "    pairs = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[507.235719, "o", "    for i in range(100):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[507.236118, "o", "        pt = i * 0x0101010101010101\r\n\u001b[?2004l\r"]
[507.236284, "o", "\u001b[?2004h> "]
[507.236472, "o", "        ct = encrypt_fn(pt)\r\n\u001b[?2004l\r"]
[507.236597, "o", "\u001b[?2004h> "]
[507.236831, "o", "        pairs.append((pt, ct))\r\n\u001b[?2004l\r"]
[507.236931, "o", "\u001b[?2004h> "]
[507.237024, "o", "    \r\n\u001b[?2004l\r"]
[507.237176, "o", "\u001b[?2004h> "]
[507.237557, "o", "    # For each candidate key[5], compute left3 values\r\n\u001b[?2004l\r"]
[507.237601, "o", "\u001b[?2004h> "]
[507.238223, "o", "    # The correct key should produce left3 values with lowest variance\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.239081, "o", "> "]
[507.239561, "o", "    # (because they should follow the Feistel structure from earlier rounds)\r\n\u001b[?2004l\r"]
[507.239802, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[507.239912, "o", "    best_seed = 0\r\n\u001b[?2004l\r"]
[507.240057, "o", "\u001b[?2004h> "]
[507.240219, "o", "    best_variance = float('inf')\r\n\u001b[?2004l\r"]
[507.240256, "o", "\u001b[?2004h> "]
[507.240465, "o", "    \r\n\u001b[?2004l\r"]
[507.240618, "o", "\u001b[?2004h> "]
[507.240883, "o", "    for seed in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.240984, "o", "> "]
[507.24136, "o", "        key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.241554, "o", "> "]
[507.241602, "o", "        \r\n\u001b[?2004l\r"]
[507.241801, "o", "\u001b[?2004h> "]
[507.241987, "o", "        # Compute left3 for all pairs\r\n\u001b[?2004l\r"]
[507.242148, "o", "\u001b[?2004h> "]
[507.242334, "o", "        left3_values = []\r\n\u001b[?2004l\r"]
[507.242553, "o", "\u001b[?2004h> "]
[507.24277, "o", "        for pt, ct in pairs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.242902, "o", "> "]
[507.243276, "o", "            CT_L, CT_R = getleft(ct), getright(ct)\r\n\u001b[?2004l\r"]
[507.24333, "o", "\u001b[?2004h> "]
[507.243546, "o", "            r3 = CT_R ^ CT_L\r\n\u001b[?2004l\r"]
[507.243716, "o", "\u001b[?2004h> "]
[507.24405, "o", "            l3 = CT_L ^ f_function(r3 ^ key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.244193, "o", "> "]
[507.244494, "o", "            left3_values.append(l3)\r\n\u001b[?2004l\r"]
[507.244669, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[507.24483, "o", "\u001b[?2004h> "]
[507.244986, "o", "        # Compute variance\r\n\u001b[?2004l\r"]
[507.245055, "o", "\u001b[?2004h> "]
[507.24533, "o", "        if len(left3_values) > 1:\r\n\u001b[?2004l\r"]
[507.245476, "o", "\u001b[?2004h> "]
[507.2458, "o", "            mean = sum(left3_values) / len(left3_values)\r\n\u001b[?2004l\r"]
[507.245949, "o", "\u001b[?2004h> "]
[507.246498, "o", "            variance = sum((x - mean) ** 2 for x in left3_values) / len(left3_values)\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.246637, "o", ">             \r\n\u001b[?2004l\r"]
[507.246792, "o", "\u001b[?2004h> "]
[507.247047, "o", "            if variance < best_variance:\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.247172, "o", "> "]
[507.247451, "o", "                best_variance = variance\r\n\u001b[?2004l\r\u001b[?2004h"]
[507.247602, "o", "> "]
[507.247825, "o", "                best_seed = seed\r\n\u001b[?2004l\r"]
[507.247899, "o", "\u001b[?2004h> "]
[507.248006, "o", "    \r\n\u001b[?2004l\r"]
[507.248158, "o", "\u001b[?2004h> "]
[507.248403, "o", "    return (best_seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[507.248588, "o", "\u001b[?2004h> "]
[507.248719, "o", "EOF\r\n\u001b[?2004l\r"]
[507.254462, "o", "\u001b[?2004hroot@e46f4ec08a64:/app# "]
