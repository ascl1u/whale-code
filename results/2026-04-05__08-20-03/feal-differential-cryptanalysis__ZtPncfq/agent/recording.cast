[585.396679, "o", "> "]
[585.397015, "o", "                    for seed1 in range(0, 0x10000, step):\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.397151, "o", "> "]
[585.397449, "o", "                        key1 = (seed1 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[585.397536, "o", "\u001b[?2004h> "]
