[564.188091, "i", "python3 << 'PYEOF'\nrecovered_key5 = 207681147\nmultiplier = 1234567\n\nfor seed in range(0x10000):\n    if (seed * multiplier) & 0xFFFFFFFF == recovered_key5:\n        print(f\"Seed that produces recovered key[5] = {recovered_key5}: {seed}\")\n        print(f\"Seed in hex: 0x{seed:04x}\")\n        print(f\"Correct seed was: 22960 (0x59b0)\")\n        print(f\"Difference: {abs(seed - 22960)}\")\n        break\nPYEOF\n"]
