[66.605511, "o", "\u001b[?2004h> "]
[66.60569, "o", "    # Collect plaintext-ciphertext pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.605795, "o", "> "]
[66.605967, "o", "    # Use plaintexts with known structure\r\n\u001b[?2004l\r"]
[66.606049, "o", "\u001b[?2004h> "]
[66.606121, "o", "    pairs = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.606239, "o", ">     \r\n\u001b[?2004l\r"]
[66.606347, "o", "\u001b[?2004h> "]
[66.606554, "o", "    # Collect pairs with zero plaintext and simple patterns\r\n\u001b[?2004l\r"]
[66.606614, "o", "\u001b[?2004h> "]
[66.606778, "o", "    for i in range(8):\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.60686, "o", "> "]
[66.607075, "o", "        pt = (i << 32) | (i * 0x01010101)\r\n\u001b[?2004l\r"]
[66.607119, "o", "\u001b[?2004h> "]
[66.607296, "o", "        ct = encrypt_fn(pt)\r\n\u001b[?2004l\r"]
[66.607382, "o", "\u001b[?2004h> "]
[66.607557, "o", "        pairs.append((pt, ct))\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.607655, "o", ">     \r\n\u001b[?2004l\r"]
[66.607744, "o", "\u001b[?2004h> "]
[66.607861, "o", "    # Also try some specific differences\r\n\u001b[?2004l\r"]
[66.607941, "o", "\u001b[?2004h"]
[66.608048, "o", ">     base_pt = 0x0000000000000000\r\n\u001b[?2004l\r"]
[66.608124, "o", "\u001b[?2004h> "]
[66.608265, "o", "    base_ct = encrypt_fn(base_pt)\r\n\u001b[?2004l\r"]
[66.608351, "o", "\u001b[?2004h> "]
[66.608497, "o", "    pairs.append((base_pt, base_ct))\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.608604, "o", ">     \r\n\u001b[?2004l\r"]
[66.60869, "o", "\u001b[?2004h> "]
[66.608722, "o", "    # Try all 16-bit seeds\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.608839, "o", "> "]
[66.608882, "o", "    candidates = {}\r\n\u001b[?2004l\r"]
[66.608968, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[66.609061, "o", "> "]
[66.60917, "o", "    for seed in range(0x10000):\r\n\u001b[?2004l\r"]
[66.609247, "o", "\u001b[?2004h> "]
[66.609457, "o", "        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[66.609523, "o", "\u001b[?2004h> "]
[66.609586, "o", "        \r\n"]
[66.609614, "o", "\u001b[?2004l\r"]
[66.60973, "o", "\u001b[?2004h> "]
[66.609968, "o", "        # For each pair, check if this key makes sense\r\n\u001b[?2004l\r"]
[66.610045, "o", "\u001b[?2004h> "]
[66.610114, "o", "        score = 0\r\n\u001b[?2004l\r"]
[66.610183, "o", "\u001b[?2004h> "]
[66.61025, "o", "        \r\n\u001b[?2004l\r"]
[66.610288, "o", "\u001b[?2004h> "]
[66.610395, "o", "        for pt, ct in pairs:\r\n\u001b[?2004l\r"]
[66.610531, "o", "\u001b[?2004h> "]
[66.610727, "o", "            # Extract ciphertext components\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.610808, "o", "> "]
[66.610984, "o", "            ct_L = getleft(ct)\r\n\u001b[?2004l\r"]
[66.611086, "o", "\u001b[?2004h> "]
[66.611259, "o", "            ct_R = getright(ct)\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.611383, "o", "> "]
[66.611509, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.611694, "o", "            # From the encryption:\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.611763, "o", "> "]
[66.612147, "o", "            # After round 4 and post-mixing: output = merge(right4, left4 ^ right4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.612268, "o", "> "]
[66.612497, "o", "            # So: ct_L = right4, ct_R = left4 ^ right4\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.612593, "o", "> "]
[66.61287, "o", "            # Therefore: left4 = ct_L ^ ct_R, right4 = ct_L\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.612953, "o", "> "]
[66.613034, "o", "            \r\n\u001b[?2004l\r"]
[66.613143, "o", "\u001b[?2004h> "]
[66.613293, "o", "            left4 = ct_L ^ ct_R\r\n\u001b[?2004l\r"]
[66.613422, "o", "\u001b[?2004h> "]
[66.613571, "o", "            right4 = ct_L\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.613721, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.613911, "o", "            # Before round 4 (after round 3):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.614335, "o", "            # left4 = right3, right4 = left3 ^ f(right3 ^ key[5])\r\n\u001b[?2004l\r"]
[66.614519, "o", "\u001b[?2004h> "]
[66.61478, "o", "            # So: right3 = left4\r\n\u001b[?2004l\r"]
[66.61487, "o", "\u001b[?2004h> "]
[66.615155, "o", "            # And: left3 = right4 ^ f(right3 ^ key[5])\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.615267, "o", "> "]
[66.615407, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.61548, "o", "            right3 = left4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.615623, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.616061, "o", "            # We can compute what left3 should be given our candidate key[5]\r\n\u001b[?2004l\r"]
[66.616169, "o", "\u001b[?2004h> "]
[66.61645, "o", "            f_output = f_function(right3 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.616615, "o", "> "]
[66.616727, "o", "            left3 = right4 ^ f_output\r\n\u001b[?2004l\r"]
[66.616811, "o", "\u001b[?2004h>             \r\n\u001b[?2004l\r"]
[66.616937, "o", "\u001b[?2004h> "]
[66.617138, "o", "            # Now we need to check if this is consistent\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.617254, "o", "> "]
[66.617595, "o", "            # We can't fully verify without other keys, but we can use heuristics\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.617677, "o", "> "]
[66.617773, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.618073, "o", "            # Store the computed left3, right3 for this pair\r\n\u001b[?2004l\r"]
[66.618185, "o", "\u001b[?2004h> "]
[66.618582, "o", "            # If the key is correct, these should lead to consistent patterns\r\n\u001b[?2004l\r"]
[66.61868, "o", "\u001b[?2004h> "]
[66.618821, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.619113, "o", "            # For now, just count - we'll use multiple pairs to vote\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.619209, "o", "> "]
[66.619422, "o", "            score += 1  # This doesn't actually validate yet\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.619511, "o", "> "]
[66.619634, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.619861, "o", "        candidates[seed] = candidate_key5\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.61999, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.620168, "o", "    # Need a better validation method\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.620305, "o", "> "]
[66.620511, "o", "    # Let's use differential analysis\r\n\u001b[?2004l\r"]
[66.620584, "o", "\u001b[?2004h> "]
[66.620665, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[66.620755, "o", "> "]
[66.621078, "o", "    # Try pairs with specific input differences\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.621219, "o", "> "]
[66.621352, "o", "    diff_pairs = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.621441, "o", "> "]
[66.621524, "o", "    for i in range(5):\r\n\u001b[?2004l\r"]
[66.621639, "o", "\u001b[?2004h> "]
[66.621866, "o", "        p1 = i * 0x0101010101010101\r\n\u001b[?2004l\r"]
[66.622001, "o", "\u001b[?2004h> "]
[66.622334, "o", "        p2 = p1 ^ 0x0000000080000000  # Small difference\r\n\u001b[?2004l\r"]
[66.622433, "o", "\u001b[?2004h> "]
[66.622673, "o", "        c1 = encrypt_fn(p1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.622807, "o", "> "]
[66.622935, "o", "        c2 = encrypt_fn(p2)\r\n\u001b[?2004l\r"]
[66.623087, "o", "\u001b[?2004h> "]
[66.623294, "o", "        diff_pairs.append((p1, c1, p2, c2))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.623475, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.623559, "o", "    best_seed = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.623728, "o", "    best_score = float('inf')\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.623851, "o", "> "]
[66.623925, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.624062, "o", "    for seed in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.624302, "o", "        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.624459, "o", ">         \r\n\u001b[?2004l\r"]
[66.624599, "o", "\u001b[?2004h> "]
[66.624751, "o", "        # Check consistency across differential pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.624837, "o", "> "]
[66.624975, "o", "        total_inconsistency = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.625132, "o", "> "]
[66.625209, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.625401, "o", "        for p1, c1, p2, c2 in diff_pairs:\r\n\u001b[?2004l\r"]
[66.625488, "o", "\u001b[?2004h> "]
[66.625767, "o", "            # Partial decrypt last round for both ciphertexts\r\n\u001b[?2004l\r"]
[66.625853, "o", "\u001b[?2004h> "]
[66.62606, "o", "            c1_L, c1_R = getleft(c1), getright(c1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.626102, "o", "> "]
[66.62638, "o", "            c2_L, c2_R = getleft(c2), getright(c2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.626569, "o", "> "]
[66.626662, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.626915, "o", "            left4_1 = c1_L ^ c1_R\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.627038, "o", "> "]
[66.627192, "o", "            right4_1 = c1_L\r\n\u001b[?2004l\r"]
[66.627218, "o", "\u001b[?2004h"]
[66.627264, "o", "> "]
[66.627441, "o", "            left4_2 = c2_L ^ c2_R\r\n\u001b[?2004l\r"]
[66.689792, "o", "\u001b[?2004h>             right4_2 = c2_L\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             right3_1 = left4_1\r\n\u001b[?2004l\r\u001b[?2004h>             right3_2 = left4_2\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             f_out_1 = f_function(right3_1 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h>             f_out_2 = f_function(right3_2 ^ candidate_key5)\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             left3_1 = right4_1 ^ f_out_1\r\n\u001b[?2004l\r\u001b[?2004h>             left3_2 = right4_2 ^ f_out_2\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             # Check if the differences make sense\r\n\u001b[?2004l\r\u001b[?2004h>             # This is still heuristic, but better\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.689954, "o", "            diff_left3 = left3_1 ^ left3_2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.69007, "o", "            diff_right3 = right3_1 ^ right3_2\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.690149, "o", "> "]
[66.690202, "o", "            \r\n\u001b[?2004l\r"]
[66.690247, "o", "\u001b[?2004h> "]
[66.690518, "o", "            # Some consistency check\r\n\u001b[?2004l\r"]
[66.690591, "o", "\u001b[?2004h> "]
[66.691031, "o", "            inconsistency = bin(diff_left3).count('1') + bin(diff_right3).count('1')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.691308, "o", "            total_inconsistency += inconsistency\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.691416, "o", "> "]
[66.691539, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[66.691643, "o", "        if total_inconsistency < best_score:\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.691715, "o", "> "]
[66.691917, "o", "            best_score = total_inconsistency\r\n\u001b[?2004l\r"]
[66.692021, "o", "\u001b[?2004h> "]
[66.692106, "o", "            best_seed = seed\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.692149, "o", ">     \r\n"]
[66.692236, "o", "\u001b[?2004l\r"]
[66.692303, "o", "\u001b[?2004h> "]
[66.692553, "o", "    return (best_seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[66.692644, "o", "> EOF\r\n\u001b[?2004l\r"]
[66.694874, "o", "\u001b[?2004hroot@e46f4ec08a64:/app# "]
[76.448911, "i", "cat > /app/test_attack.py << 'EOF'\n#!/usr/bin/env python3\n\nimport feal\nimport attack\nimport time\n\n# Initialize keys\nfeal.create_random_keys()\nprint(f\"Actual key[5] = {feal.key[5]}\")\n\n# Run attack\nstart_time = time.time()\nrecovered_key5 = attack.attack(feal.encrypt)\nend_time = time.time()\n\nprint(f\"Recovered key[5] = {recovered_key5}\")\nprint(f\"Time taken: {end_time - start_time:.2f} seconds\")\n\nif recovered_key5 == feal.key[5]:\n    print(\"SUCCESS! Key recovered correctly.\")\nelse:\n    print(\"FAILED! Key not recovered correctly.\")\n    print(f\"Difference: {recovered_key5 ^ feal.key[5]}\")\nEOF\n"]
