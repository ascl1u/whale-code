[329.723083, "i", "cat > /app/attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Collect a few plaintext-ciphertext pairs\n    pairs = []\n    for i in range(10):\n        pt = i\n        ct = encrypt_fn(pt)\n        pairs.append((pt, ct))\n    \n    # Use differential pairs with zero input difference\n    # Encrypt the same plaintext multiple times - should give same ciphertext\n    pt_test = 0x123456789ABCDEF0\n    ct"]
[329.723241, "i", "_test = encrypt_fn(pt_test)\n    \n    # Now try a different approach: use the fact that for certain\n    # input differences, the F-function has predictable behavior\n    \n    # Collect pairs with single-bit differences in specific positions\n    diff_pairs = []\n    base_pt = 0\n    base_ct = encrypt_fn(base_pt)\n    \n    for bit_pos in range(64):\n        pt = base_pt ^ (1 << bit_pos)\n        ct = encrypt_fn(pt)\n        diff_pairs.append((base_pt, base_ct, pt, ct))\n    \n    # For each candidate key[5], score based on how well it explains\n    # the differential behavior\n    candidate_scores = {}\n    \n    for seed in range(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        \n        # For each differential pair, compute the state after round 3\n        score = 0\n        \n        for pt1, ct1, pt2, ct2 in diff_pairs[:20]:  # Use first 20 to speed up\n            CT1_L, CT1_R = getleft(ct1), getright(ct1)\n            CT2_L, CT2_R = getleft(ct2), getright(ct2)\n            \n            # Compute round "]
[329.723358, "i", "3 states\n            r3_1 = CT1_R ^ CT1_L\n            l3_1 = CT1_L ^ f_function(r3_1 ^ candidate_key5)\n            \n            r3_2 = CT2_R ^ CT2_L\n            l3_2 = CT2_L ^ f_function(r3_2 ^ candidate_key5)\n            \n            # Compute input difference to plaintext\n            pt_diff = pt1 ^ pt2\n            \n            # Compute difference in round 3 states\n            state_diff_l = l3_1 ^ l3_2\n            state_diff_r = r3_1 ^ r3_2\n            \n            # For a single-bit input difference, we expect specific behavior\n            # The correct key should produce consistent patterns\n            \n            # Simple scoring: XOR of differences\n            combined_diff = state_diff_l ^ state_diff_r\n            \n            # Count bits - prefer keys that give specific bit counts\n            bit_count = bin(combined_diff).count('1')\n            score += bit_count\n        \n        candidate_scores[seed] = score\n    \n    # Find the seed with minimum score (most structure)\n    best_seed = min(candid"]
