[229.510788, "i", "cat > /app/attack.py << 'EOF'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    # Strategy: Use zero-difference pairs to find the key\n    # If we encrypt the same plaintext twice, we should get the same ciphertext\n    # This helps us verify our key recovery\n    \n    # Collect pairs where we know the input difference\n    data = []\n    \n    # Use pairs with zero plaintext\n    pt0 = 0x0000000000000000\n    ct0 = en"]
[229.511005, "i", "crypt_fn(pt0)\n    \n    # Collect many pairs with small differences\n    for i in range(256):\n        pt = i\n        ct = encrypt_fn(pt)\n        data.append((pt, ct))\n    \n    # Also collect pairs with differences in different positions\n    for i in range(1, 33):\n        pt = 1 << i\n        ct = encrypt_fn(pt)\n        data.append((pt, ct))\n    \n    # Try all seeds and use a voting mechanism\n    vote_count = {}\n    \n    for seed in range(0x10000):\n        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\n        vote_count[seed] = 0\n    \n    # For each pair of data points, check which keys are consistent\n    for i in range(len(data)):\n        for j in range(i+1, min(i+20, len(data))):\n            pt1, ct1 = data[i]\n            pt2, ct2 = data[j]\n            \n            CT1_L, CT1_R = getleft(ct1), getright(ct1)\n            CT2_L, CT2_R = getleft(ct2), getright(ct2)\n            \n            # For each candidate key, compute the state after round 3\n            for seed in range(0x10000):\n                candidate_ke"]
[229.511121, "i", "y5 = (seed * 1234567) & 0xFFFFFFFF\n                \n                right3_1 = CT1_R ^ CT1_L\n                left3_1 = CT1_L ^ f_function(right3_1 ^ candidate_key5)\n                \n                right3_2 = CT2_R ^ CT2_L\n                left3_2 = CT2_L ^ f_function(right3_2 ^ candidate_key5)\n                \n                # Check if the relationship between (left3_1, right3_1) and (left3_2, right3_2)\n                # makes sense given the plaintext difference\n                # This is still heuristic, but let's try:\n                \n                # If plaintexts are the same, states should be the same\n                if pt1 == pt2:\n                    if left3_1 == left3_2 and right3_1 == right3_2:\n                        vote_count[seed] += 10\n                    else:\n                        vote_count[seed] -= 10\n    \n    # Find the seed with the most votes\n    best_seed = max(vote_count, key=vote_count.get)\n    return (best_seed * 1234567) & 0xFFFFFFFF\nEOF\n"]
