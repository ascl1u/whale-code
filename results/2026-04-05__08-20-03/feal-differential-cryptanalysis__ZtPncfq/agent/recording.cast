[585.384334, "o", "\u001b[?2004h> "]
[585.384525, "o", "def encrypt_with_keys(plaintext, keys):\r\n\u001b[?2004l\r"]
[585.384637, "o", "\u001b[?2004h> "]
[585.38469, "o", "    \"\"\"Encrypt with given keys\"\"\"\r\n\u001b[?2004l\r"]
[585.38482, "o", "\u001b[?2004h> "]
[585.385026, "o", "    left = getleft(plaintext)\r\n\u001b[?2004l\r"]
[585.385172, "o", "\u001b[?2004h> "]
[585.385412, "o", "    right = getright(plaintext)\r\n\u001b[?2004l\r"]
[585.38562, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[585.38576, "o", "\u001b[?2004h> "]
[585.385858, "o", "    # Initial key whitening\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.385961, "o", "> "]
[585.386096, "o", "    left ^= keys[0]\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.386202, "o", "> "]
[585.386317, "o", "    right ^= keys[1]\r\n\u001b[?2004l\r"]
[585.386425, "o", "\u001b[?2004h>     "]
[585.386552, "o", "\r\n\u001b[?2004l\r"]
[585.386659, "o", "\u001b[?2004h> "]
[585.386754, "o", "    # Pre-round mixing\r\n\u001b[?2004l\r\u001b[?2004h> "]
[585.386841, "o", "    right ^= left\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.387027, "o", "> "]
[585.387187, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     # 4 rounds\r\n\u001b[?2004l\r"]
[585.387323, "o", "\u001b[?2004h> "]
[585.387693, "o", "    for round_num in range(4):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[585.387886, "o", "        mixed = f_function(right ^ keys[round_num + 2])\r\n\u001b[?2004l\r"]
[585.387939, "o", "\u001b[?2004h> "]
[585.388085, "o", "        temp = right\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.388225, "o", "> "]
