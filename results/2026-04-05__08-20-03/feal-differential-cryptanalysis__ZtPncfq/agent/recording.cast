[35.8261, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.826173, "o", "> "]
[35.826367, "o", "    # Alternative: Use the structure of FEAL more directly\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.826404, "o", "> "]
[35.826681, "o", "    # Since we can't easily reverse without knowing all keys,\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.826794, "o", "> "]
[35.826998, "o", "    # let's use differential cryptanalysis properly\r\n\u001b[?2004l\r"]
[35.82704, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[35.827121, "o", "\u001b[?2004h> "]
[35.82735, "o", "    # Collect pairs with specific input differences\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.827436, "o", "> "]
[35.827533, "o", "    diff_pairs = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.827656, "o", "    for i in range(10):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.8278, "o", "        p1 = (i << 32) | i\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.827909, "o", "> "]
[35.828093, "o", "        p2 = p1 ^ (0x8000000000000000)  # Flip high bit\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.828173, "o", "> "]
[35.828303, "o", "        c1 = encrypt_fn(p1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.828472, "o", "        c2 = encrypt_fn(p2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.828677, "o", "        diff_pairs.append((p1, c1, p2, c2))\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.828711, "o", "> "]
[35.828778, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.828914, "o", "> "]
[35.829053, "o", "    # Score each candidate key\r\n\u001b[?2004l\r"]
[35.82913, "o", "\u001b[?2004h> "]
[35.829212, "o", "    best_score = -1\r\n\u001b[?2004l\r"]
[35.829289, "o", "\u001b[?2004h> "]
