[585.380598, "o", "    y = [0] * 4\r\n"]
[585.380764, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[585.380982, "o", "    for i in range(4):\r\n\u001b[?2004l\r\u001b[?2004h"]
[585.381118, "o", "> "]
