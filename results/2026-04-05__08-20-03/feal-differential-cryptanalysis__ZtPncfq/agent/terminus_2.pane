    # Alternative: Use the structure of FEAL more directly
    # Since we can't easily reverse without knowing all keys,
    # let's use differential cryptanalysis properly
    
    # Collect pairs with specific input differences
    diff_pairs = []
    for i in range(10):
        p1 = (i << 32) | i
        p2 = p1 ^ (0x8000000000000000)  # Flip high bit
        c1 = encrypt_fn(p1)
        c2 = encrypt_fn(p2)
        diff_pairs.append((p1, c1, p2, c2))
    
    # Score each candidate key
    best_score = -1
    best_key = 0
    
    for seed in range(0x10000):
        candidate_key5 = (seed * 1234567) & 0xFFFFFFFF
