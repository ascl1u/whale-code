[405.612373, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rr"]
[405.612495, "o", "\u001b[?2004h> "]
[405.612765, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r"]
[405.612872, "o", "\u001b[?2004h> "]
[405.613673, "o", "    \"\"\"Recover key[5] using meet-in-the-middle attack\"\"\"\r\n\u001b[?2004l\r"]
[405.61377, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[405.613843, "o", "\u001b[?2004h> "]
[405.614455, "o", "    # Collect 2 plaintext-ciphertext pairs\r\n\u001b[?2004l\r"]
[405.614569, "o", "\u001b[?2004h> "]
[405.614734, "o", "    pt1 = merge(0, 0)\r\n\u001b[?2004l\r"]
[405.61482, "o", "\u001b[?2004h> "]
[405.615133, "o", "    ct1 = encrypt_fn(pt1)\r\n\u001b[?2004l\r"]
[405.615225, "o", "\u001b[?2004h> "]
[405.615501, "o", "    pt2 = merge(0, 1)\r\n\u001b[?2004l\r"]
[405.615586, "o", "\u001b[?2004h"]
[405.615698, "o", "> "]
[405.615884, "o", "    ct2 = encrypt_fn(pt2)\r\n\u001b[?2004l\r"]
[405.615998, "o", "\u001b[?2004h> "]
[405.616141, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[405.616261, "o", "> "]
