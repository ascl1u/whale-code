[405.702516, "o", "        \r\n\u001b[?2004l\r \u001b[?2004h"]
[405.702583, "o", "> "]
[405.702846, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r \u001b[?2004h> "]
