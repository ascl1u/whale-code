[450.767912, "i", "_ar0 ^ f_function(right1_ap ^ key2)\n                    right2_ap = left2_ar0\n                    left2_ap = right2_ar0 ^ f_function(right2_ap ^ key2)\n                    \n                    # Undo pre-mixing\n                    left1_aw = left1_ap\n                    right1_aw = right1_ap ^ left1_ap\n                    left2_aw = left2_ap\n                    right2_aw = right2_ap ^ left2_ap\n                    \n                    # Derive and check key0 and key1\n                    k0_1 = 0 ^ left1_aw\n                    k1_1 = 0 ^ right1_aw\n                    k0_2 = 0 ^ left2_aw\n                    k1_2 = 1 ^ right2_aw\n                    \n                    if k0_1 == k0_2 and k1_1 == k1_2:\n                        candidates.append((seed5, seed4, seed3, seed2))\n                        print(f\"  Found candidate: seed5={seed5}, seed4={seed4}, seed3={seed3}, seed2={seed2}\")\n    \n    print(f\"Coarse search complete. Found {len(candidates)} candidates.\")\n    \n    # Refined search around each candidate\n    fo"]
