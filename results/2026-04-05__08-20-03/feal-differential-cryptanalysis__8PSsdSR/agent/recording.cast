[405.621005, "o", "\u001b[?2004h> "]
[405.621525, "o", "        for seed4 in range(0x10000):\r\n\u001b[?2004l\r"]
[405.621669, "o", "\u001b[?2004h> "]
[405.622274, "o", "            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[405.622409, "o", "\u001b[?2004h> "]
[405.62251, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[405.623056, "o", "            # Partially decrypt both ciphertexts\r\n\u001b[?2004l\r\u001b[?2004h> "]
[405.623241, "o", "            states = []\r\n\u001b[?2004l\r"]
[405.623311, "o", "\u001b[?2004h> "]
