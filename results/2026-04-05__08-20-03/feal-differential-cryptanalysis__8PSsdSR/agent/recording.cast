[744.72646, "i", "ing the first plaintext\n    \n    print(\"Searching forward...\")\n    \n    # For plaintext (0, 0), after whitening: left = key[0], right = key[1]\n    # After pre-mixing: left = key[0], right = key[1] ^ key[0]\n    \n    # Try all combinations of key[0], key[1], key[2], key[3]\n    # This is still 2^128, too many\n    \n    # Better approach: for each (key[2], key[3]), and each possible (key[0], key[1]),\n    # compute the states and check if they're in the backward table\n    \n    # But this is still 2^64 combinations\n    \n    # Let me try a sampled approach on the forward side\n    step_forward = 256\n    \n    for seed3 in range(0, 0x10000, step_forward):\n        if seed3 % 2000 == 0:\n            print(f\"  Forward: seed3={seed3}/65536\")\n        \n        key3 = (seed3 * 1234567) & 0xFFFFFFFF\n        \n        for seed2 in range(0, 0x10000, step_forward):\n            key2 = (seed2 * 1234567) & 0xFFFFFFFF\n            \n            for seed1 in range(0, 0x10000, step_forward):\n                key1 = (seed1 * 1234567) & 0xFFFF"]
