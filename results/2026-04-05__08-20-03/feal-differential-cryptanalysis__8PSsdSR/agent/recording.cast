[1088.60672, "o", "                    right1_ap = left1_ar0\r\n                    left1_ap = right1_ar0 ^ f_function(right1_ap ^ key2)\r\n                    right2_ap = left2_ar0\r\n                    left2_ap = right2_ar0 ^ f_function(right2_ap ^ key2)\r\n                    \r\n                    left1_aw = left1_ap\r\n                    right1_aw = right1_ap ^ left1_ap\r\n                    left2_aw = left2_ap\r\n                    right2_aw = right2_ap ^ left2_ap\r\n                    \r\n                    k0_1 = 0 ^ left1_aw\r\n                    k1_1 = 0 ^ right1_aw\r\n                    k0_2 = 0 ^ left2_aw\r\n                    k1_2 = 1 ^ right2_aw\r\n                    \r\n                    if k0_1 == k0_2 and k1_1 == k1_2:\r\n                        return key5\r\n    \r\n    return 0\r\n\r\n"]
