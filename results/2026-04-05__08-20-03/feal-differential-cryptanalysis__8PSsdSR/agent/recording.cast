[1034.221866, "i", "cat > /app/attack.py << 'EOFPYTHON'\n#!/usr/bin/env python3\nimport random\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef merge(left, right):\n    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using optimized exhaustive search\"\"\"\n    \n    pt1 = merge(0, 0)\n    ct1 = encrypt_fn(pt1)\n    pt2 = merge(0, 1)\n    ct2 = encrypt_fn(pt2)\n    \n    print(\"Starting optimized exhaustive search...\")\n    \n    # Cr"]
[1034.222037, "i", "eate a randomized search order to increase chances of finding early\n    seeds = list(range(0x10000))\n    random.shuffle(seeds)\n    \n    checked = 0\n    for idx5, seed5 in enumerate(seeds):\n        if idx5 % 5000 == 0:\n            print(f\"  Progress: {idx5}/65536 (checked {checked} combinations)\")\n        \n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        for seed4 in seeds[:1000]:  # Only check first 1000 for each seed5\n            key4 = (seed4 * 1234567) & 0xFFFFFFFF\n            \n            # Partially decrypt\n            ct1_left = getleft(ct1)\n            ct1_right = getright(ct1)\n            left1_bpm = ct1_right ^ ct1_left\n            right1_bpm = ct1_left\n            right1_ar2 = left1_bpm\n            f1_r3 = f_function(right1_ar2 ^ key5)\n            left1_ar2 = right1_bpm ^ f1_r3\n            right1_ar1 = left1_ar2\n            f1_r2 = f_function(right1_ar1 ^ key4)\n            left1_ar1 = right1_ar2 ^ f1_r2\n            \n            ct2_left = getleft(ct2)\n            ct2_right = getright(c"]
[1034.222167, "i", "t2)\n            left2_bpm = ct2_right ^ ct2_left\n            right2_bpm = ct2_left\n            right2_ar2 = left2_bpm\n            f2_r3 = f_function(right2_ar2 ^ key5)\n            left2_ar2 = right2_bpm ^ f2_r3\n            right2_ar1 = left2_ar2\n            f2_r2 = f_function(right2_ar1 ^ key4)\n            left2_ar1 = right2_ar2 ^ f2_r2\n            \n            for seed3 in seeds[:100]:  # Only check first 100\n                key3 = (seed3 * 1234567) & 0xFFFFFFFF\n                \n                for seed2 in seeds[:100]:  # Only check first 100\n                    key2 = (seed2 * 1234567) & 0xFFFFFFFF\n                    checked += 1\n                    \n                    # Undo rounds\n                    right1_ar0 = left1_ar1\n                    left1_ar0 = right1_ar1 ^ f_function(right1_ar0 ^ key3)\n                    right2_ar0 = left2_ar1\n                    left2_ar0 = right2_ar1 ^ f_function(right2_ar0 ^ key3)\n                    \n                    right1_ap = left1_ar0\n                    left1_ap"]
[1034.222348, "o", "cat > /app/attack.py << 'EOFPYTHON'\r\n"]
[1034.222403, "i", " = right1_ar0 ^ f_function(right1_ap ^ key2)\n                    right2_ap = left2_ar0\n                    left2_ap = right2_ar0 ^ f_function(right2_ap ^ key2)\n                    \n                    left1_aw = left1_ap\n                    right1_aw = right1_ap ^ left1_ap\n                    left2_aw = left2_ap\n                    right2_aw = right2_ap ^ left2_ap\n                    \n                    k0_1 = 0 ^ left1_aw\n                    k1_1 = 0 ^ right1_aw\n                    k0_2 = 0 ^ left2_aw\n                    k1_2 = 1 ^ right2_aw\n                    \n                    if k0_1 == k0_2 and k1_1 == k1_2:\n                        print(f\"\\nFound match! seed5={seed5}, key5={key5}\")\n                        return key5\n    \n    print(f\"No match found after checking {checked} combinations\")\n    return 0\n\nEOFPYTHON\n"]
