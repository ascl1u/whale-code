[405.697847, "o", ">     \r\n\u001b[?2004l\rr\u001b[?2004h> "]
[405.698297, "o", "    # Try key2 and key3 in outer loops, key4 and key5 in inner loops\r\n\u001b[?2004l\r"]
[405.698389, "o", "\u001b[?2004h> "]
[405.699051, "o", "    # For each combination, we can derive key0 and key1 and check consistency\r\n\u001b[?2004l\r"]
[405.699155, "o", "\u001b[?2004h> "]
[405.699484, "o", "    # This is still 2^64 but with better cache locality\r\n\u001b[?2004l\r"]
[405.699597, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[405.699675, "o", " l1_a\u001b[?2004h> "]
[405.700001, "o", "    # Actually, let me try an even simpler approach:\r\n\u001b[?2004l\r\u001b[?2004h"]
[405.700052, "o", "> "]
[405.700385, "o", "    # Just brute force key4 and key5, and for each combination,\r\n\u001b[?2004l\r"]
[405.700424, "o", "\u001b[?2004h> "]
