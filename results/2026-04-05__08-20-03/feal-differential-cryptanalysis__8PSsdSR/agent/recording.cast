[744.727212, "o", "    return (x >> 32) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.727307, "o", "def getright(x):\r\n\u001b[?2004l\r"]
[744.727369, "o", "\u001b[?2004h> "]
[744.727691, "o", "    return x & 0xFFFFFFFF\r\n\u001b[?2004l\r      \u001b[?2004h"]
[744.727821, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.728016, "o", "def merge(left, right):\r\n\u001b[?2004l\r"]
[744.728123, "o", "\u001b[?2004h> "]
[744.7288, "o", "    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.728926, "o", "> \r\n\u001b[?2004l\rr\u001b[?2004h"]
[744.729048, "o", "> "]
[744.729413, "o", "def g_function(a, b, x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.729915, "o", "    temp = (a + b + x) & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.73006, "o", "> "]
[744.730536, "o", "    return ((temp << 2) | (temp >> 6)) & 0xFF\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.730973, "o", "def f_function(input_val):\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.731144, "o", "> "]
[744.731274, "o", "    x = [0] * 4\r\n\u001b[?2004l\r"]
[744.731403, "o", "\u001b[?2004h> "]
[744.731507, "o", "    y = [0] * 4\r\n\u001b[?2004l\r"]
[744.731554, "o", "\u001b[?2004h> "]
[744.731754, "o", "    for i in range(4):\r\n\u001b[?2004l\r"]
[744.731894, "o", "\u001b[?2004h> "]
[744.732245, "o", "        x[i] = input_val & 0xFF\r\n\u001b[?2004l\r"]
[744.732293, "o", "\u001b[?2004h> "]
[744.73279, "o", "        input_val >>= 8"]
[744.733009, "o", "\r\n"]
[744.733131, "o", "\u001b[?2004l\r\u001b[?2004h"]
[744.733283, "o", "> "]
[744.733704, "o", "    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\r\n\u001b[?2004l\r"]
[744.733893, "o", "\u001b[?2004h> "]
[744.73445, "o", "    y[3] = g_function(x[3], y[2], 0)\r\n"]
[744.734566, "o", "\u001b[?2004l\r"]
[744.734791, "o", "\u001b[?2004h> "]
[744.735429, "o", "    y[1] = g_function(x[1] ^ x[0], y[2], 0)\r\n\u001b[?2004l\r"]
[744.735598, "o", "\u001b[?2004h> "]
[744.736053, "o", "    y[0] = g_function(x[0], y[1], 1)\r\n\u001b[?2004l\rn"]
[744.736189, "o", "\u001b[?2004h> "]
[744.736509, "o", "    output = 0\r\n\u001b[?2004l\r"]
[744.736788, "o", "\u001b[?2004h> "]
[744.737051, "o", "    for i in range(4):\r\n\u001b[?2004l\r"]
[744.737185, "o", "\u001b[?2004h> "]
[744.737598, "o", "        output |= y[i] << (8 * i)\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.737754, "o", "> "]
[744.738041, "o", "    return output & 0xFFFFFFFF\r\n\u001b[?2004l\r^\u001b[?2004h"]
[744.738167, "o", "> \r\n\u001b[?2004l\r"]
[744.738264, "o", " \u001b[?2004h> "]
[744.738453, "o", "def attack(encrypt_fn):\r\n\u001b[?2004l\r \u001b[?2004h"]
[744.738622, "o", "> "]
[744.739039, "o", "    \"\"\"Recover key[5] using meet-in-the-middle attack\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.739148, "o", ">     \r\n"]
[744.739255, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[744.739697, "o", "    # Collect 2 plaintext-ciphertext pairs\r\n\u001b[?2004l\r \u001b[?2004h"]
[744.739827, "o", "> "]
[744.740082, "o", "    pt1 = merge(0, 0)\r\n\u001b[?2004l\r"]
[744.740188, "o", "\u001b[?2004h> "]
[744.740475, "o", "    ct1 = encrypt_fn(pt1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.740722, "o", "    pt2 = merge(0, 1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.741192, "o", "    ct2 = encrypt_fn(pt2)\r\n\u001b[?2004l\r"]
[744.741323, "o", "\u001b[?2004h> "]
[744.741446, "o", "    \r\n\u001b[?2004l\r"]
[744.741559, "o", "\u001b[?2004h> "]
[744.74238, "o", "    print(\"Starting meet-in-the-middle attack...\")\r\n\u001b[?2004l\r"]
[744.742593, "o", "\u001b[?2004h> "]
[744.742663, "o", "    \r\n\u001b[?2004l\r"]
[744.742825, "o", "\u001b[?2004h> "]
[744.743584, "o", "    # Backward side: compute states after undoing 2 rounds\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.74401, "o", "    # For each (key[4], key[5]) combination\r\n\u001b[?2004l\r"]
[744.74405, "o", "\u001b[?2004h> "]
[744.744495, "o", "    print(\"Building backward table...\")\r\n\u001b[?2004l\r"]
[744.744614, "o", "\u001b[?2004h> "]
[744.744879, "o", "    backward_table = {}\r\n\u001b[?2004l\r"]
[744.744994, "o", "\u001b[?2004h> "]
[744.74507, "o", "    \r\n\u001b[?2004l\r"]
[744.745159, "o", "\u001b[?2004h> "]
[744.745415, "o", "    count = 0\r\n\u001b[?2004l\r"]
[744.74553, "o", "\u001b[?2004h> "]
[744.745805, "o", "    for seed5 in range(0x10000):\r\n\u001b[?2004l\r"]
[744.745848, "o", "\u001b[?2004h> "]
[744.746336, "o", "        if seed5 % 5000 == 0:\r\n\u001b[?2004l\r"]
[744.74645, "o", "\u001b[?2004h> "]
[744.747658, "o", "            print(f\"  Backward: {seed5}/65536 ({len(backward_table)} entries)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.748136, "o", "> "]
[744.748224, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.748538, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r           \u001b[?2004h"]
[744.748676, "o", ">         \r\n\u001b[?2004l\r"]
[744.74876, "o", "\u001b[?2004h> "]
[744.749516, "o", "        for seed4 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.749656, "o", "> "]
[744.750142, "o", "            key4 = (seed4 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[744.750275, "o", "\u001b[?2004h> "]
[744.750454, "o", "            \r\n\u001b[?2004l\r \u001b[?2004h"]
[744.750591, "o", "> "]
[744.751227, "o", "            # Partially decrypt both ciphertexts\r\n\u001b[?2004l\r"]
[744.751355, "o", "\u001b[?2004h> "]
[744.751605, "o", "            # For ct1\r\n\u001b[?2004l\r"]
[744.75173, "o", "\u001b[?2004h> "]
[744.752184, "o", "            ct1_left = getleft(ct1)\r\n\u001b[?2004l\r \u001b[?2004h"]
[744.752313, "o", "> "]
[744.75262, "o", "            ct1_right = getright(ct1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.752767, "o", "> "]
[744.753, "o", "            left1_bpm = ct1_right ^ ct1_left\r\n\u001b[?2004l\r"]
[744.753159, "o", "\u001b[?2004h> "]
[744.753625, "o", "            right1_bpm = ct1_left\r\n\u001b[?2004l\r"]
[744.753725, "o", "\u001b[?2004h> "]
[744.754167, "o", "            right1_ar2 = left1_bpm\r\n\u001b[?2004l\r \u001b[?2004h"]
[744.754217, "o", "> "]
[744.755028, "o", "            f1_r3 = f_function(right1_ar2 ^ key5)\r\n\u001b[?2004l\r"]
[744.755089, "o", "\u001b[?2004h> "]
[744.755622, "o", "            left1_ar2 = right1_bpm ^ f1_r3\r\n\u001b[?2004l\rB\u001b[?2004h"]
[744.75567, "o", "> "]
[744.768012, "o", "            right1_ar1 = left1_ar2\r\n\u001b[?2004l\r\u001b[?2004h>             f1_r2 = f_function(right1_ar1 ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h>             left1_ar1 = right1_ar2 ^ f1_r2\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             # For ct2\r\n\u001b[?2004l\r\u001b[?2004h>             ct2_left = getleft(ct2)\r\n\u001b[?2004l\rO\u001b[?2004h> "]
[744.768117, "o", "            ct2_right = getright(ct2)\r\n\u001b[?2004l\r"]
[744.768245, "o", "\u001b[?2004h> "]
[744.768595, "o", "            left2_bpm = ct2_right ^ ct2_left\r\n"]
[744.768686, "o", "\u001b[?2004l\r"]
[744.768748, "o", "\u001b[?2004h> "]
[744.768975, "o", "            right2_bpm = ct2_left\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.769099, "o", "> "]
[744.769282, "o", "            right2_ar2 = left2_bpm\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.769376, "o", "> "]
[744.76961, "o", "            f2_r3 = f_function(right2_ar2 ^ key5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.769726, "o", "> "]
[744.769943, "o", "            left2_ar2 = right2_bpm ^ f2_r3\r\n\u001b[?2004l\r"]
[744.770124, "o", "\u001b[?2004h> "]
[744.770298, "o", "            right2_ar1 = left2_ar2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.770651, "o", "            f2_r2 = f_function(right2_ar1 ^ key4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.770804, "o", "> "]
[744.771012, "o", "            left2_ar1 = right2_ar2 ^ f2_r2\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.771113, "o", "> "]
[744.771265, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.771474, "o", "            # Store in hash table\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.771953, "o", "            state_key = (left1_ar1, right1_ar1, left2_ar1, right2_ar1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.77237, "o", "            backward_table[state_key] = (key4, key5, seed4, seed5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.772482, "o", "> "]
[744.772598, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.772705, "o", "            count += 1\r\n\u001b[?2004l\r"]
[744.772856, "o", "\u001b[?2004h> "]
[744.773325, "o", "            if count >= 10000000:  # Limit to 10M entries to avoid memory issues\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.773465, "o", "> "]
[744.773605, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.773715, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.773945, "o", "        if count >= 10000000:\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.774058, "o", "> "]
[744.774157, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.774202, "o", ">     "]
[744.774356, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.774797, "o", "    print(f\"Backward table built: {len(backward_table)} entries\")\r\n\u001b[?2004l\r"]
[744.774837, "o", "\u001b[?2004h"]
[744.774947, "o", ">     \r\n\u001b[?2004l\r"]
[744.77511, "o", "\u001b[?2004h> "]
[744.775309, "o", "    # Forward side: compute states after 2 rounds\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.775444, "o", "> "]
[744.775791, "o", "    # For each (key[0], key[1], key[2], key[3]) combination\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.776234, "o", "    # But we can constrain key[0] and key[1] using the first plaintext\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.776403, "o", "> "]
[744.776523, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.776638, "o", "    print(\"Searching forward...\")\r\n\u001b[?2004l\r"]
[744.776791, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[744.776855, "o", "> "]
[744.777239, "o", "    # For plaintext (0, 0), after whitening: left = key[0], right = key[1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.777628, "o", "    # After pre-mixing: left = key[0], right = key[1] ^ key[0]\r\n\u001b[?2004l\r"]
[744.777669, "o", "\u001b[?2004h> "]
[744.777782, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.77826, "o", "    # Try all combinations of key[0], key[1], key[2], key[3]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.778417, "o", "    # This is still 2^128, too many\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.778479, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[744.778615, "o", "> "]
[744.779061, "o", "    # Better approach: for each (key[2], key[3]), and each possible (key[0], key[1]),\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.779166, "o", "> "]
[744.779484, "o", "    # compute the states and check if they're in the backward table\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.779615, "o", "> "]
[744.77966, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.779936, "o", "    # But this is still 2^64 combinations\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.779976, "o", "> "]
[744.780061, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.780402, "o", "    # Let me try a sampled approach on the forward side\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.78062, "o", "    step_forward = 256\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.780781, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.78114, "o", "    for seed3 in range(0, 0x10000, step_forward):\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.781271, "o", "> "]
[744.781381, "o", "        if seed3 % 2000 == 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.781503, "o", "> "]
[744.781882, "o", "            print(f\"  Forward: seed3={seed3}/65536\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.782035, "o", "        \r\n\u001b[?2004l\r"]
[744.782157, "o", "\u001b[?2004h> "]
[744.782446, "o", "        key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.782623, "o", ">         "]
[744.782718, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.78296, "o", "        for seed2 in range(0, 0x10000, step_forward):\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.783092, "o", "> "]
[744.783355, "o", "            key2 = (seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.783481, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[744.783624, "o", "> "]
[744.784007, "o", "            for seed1 in range(0, 0x10000, step_forward):\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.784126, "o", "> "]
[744.784439, "o", "                key1 = (seed1 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.78451, "o", "> "]
[744.784691, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.785139, "o", "                for seed0 in range(0, 0x10000, step_forward):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.785546, "o", "                    key0 = (seed0 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.785716, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[744.785808, "o", "> "]
[744.786254, "o", "                    # Encrypt pt1 through 2 rounds\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.786379, "o", "> "]
[744.786733, "o", "                    # After whitening\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.786948, "o", "> "]
[744.78714, "o", "                    left1 = 0 ^ key0\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.787277, "o", "> "]
[744.787453, "o", "                    right1 = 0 ^ key1\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.787536, "o", "> "]
[744.787787, "o", "                    # After pre-mixing\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.788124, "o", "                    right1 = right1 ^ left1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.788361, "o", "                    # Round 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.788682, "o", "                    new_left1 = right1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.789096, "o", "                    new_right1 = left1 ^ f_function(right1 ^ key2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.789244, "o", "> "]
[744.789462, "o", "                    left1 = new_left1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.789705, "o", "                    right1 = new_right1\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.789785, "o", "> "]
[744.790011, "o", "                    # Round 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[744.79027, "o", "                    new_left1 = right1\r\n\u001b[?2004l\r\u001b[?2004h"]
[744.790429, "o", "> "]
[744.790718, "o", "                    new_right1 = left1 ^ f_function(right1 ^ key3)\r\n\u001b[?2004l\r\u001b[?2004h> "]
