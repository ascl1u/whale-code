[405.620075, "o", "\u001b[?2004h> "]
[405.620624, "o", "        key5 = (seed5 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[405.620768, "o", "\u001b[?2004h> "]
