[405.634511, "o", "\u001b[?2004h> "]
[405.635805, "o", "    # Forward side: compute states after 2 rounds for all (key[2], key[3])\r\n\u001b[?2004l\r"]
[405.635914, "o", "\u001b[?2004h> "]
[405.637029, "o", "    # We also need key[0] and key[1], but we can derive them from the constraints\r\n\u001b[?2004l\r"]
