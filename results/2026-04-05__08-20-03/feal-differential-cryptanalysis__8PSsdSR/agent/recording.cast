[405.637666, "o", "\u001b[?2004h"]
[405.637809, "o", "> "]
[405.638012, "o", "    for seed3 in range(0x10000):\r\n\u001b[?2004l\r"]
[405.63813, "o", "\u001b[?2004h> "]
