[345.895846, "o", "def getright(x):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[345.895893, "i", "     key1_candidate = pt1_right ^ right1_aw\n                    \n                    # Verify with the second plaintext\n                    pt2_left = getleft(pt2)  # = 0\n                    pt2_right = getright(pt2)  # = 1\n                    key0_check = pt2_left ^ left2_aw\n                    key1_check = pt2_right ^ right2_aw\n                    \n                    # If the keys match, we found the correct combination!\n                    if key0_candidate == key0_check and key1_candidate == key1_check:\n                        # Found it!\n                        return key5\n    \n    # If we get here, something went wrong\n    return 0\n\nEOFPYTHON\n"]
