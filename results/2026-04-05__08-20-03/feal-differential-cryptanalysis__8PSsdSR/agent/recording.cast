[405.61657, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[405.61669, "o", "> "]
[405.616803, "o", "    # Meet-in-the-middle attack\r\n\u001b[?2004l\r\u001b[?2004h"]
[405.616888, "o", "> "]
[405.617655, "o", "    # Backward side: compute states after undoing 2 rounds for all (key[4], key[5])\r\n\u001b[?2004l\r\u001b[?2004h"]
[405.617755, "o", "> "]
