[963.361974, "i", "cat > /app/attack.py << 'EOFPYTHON'\n#!/usr/bin/env python3\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef merge(left, right):\n    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0] * 4\n    y = [0] * 4\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    output = 0\n    for i in range(4):\n        output |= y[i] << (8 * i)\n    return output & 0xFFFFFFFF\n\ndef attack(encrypt_fn):\n    \"\"\"Recover key[5] using differential cryptanalysis\"\"\"\n    \n    print(\"Collecting plaintext-ciphertext pairs for differential attack...\")\n    \n    # Collect pairs for differential analysis\n    pairs = []\n    for i in range(20):\n        pt = m"]
[963.362127, "i", "erge(0, i)\n        ct = encrypt_fn(pt)\n        pairs.append((pt, ct))\n    \n    print(f\"Collected {len(pairs)} pairs\")\n    print(\"Brute forcing key[5] with differential verification...\")\n    \n    # For each candidate key[5], use differential properties to score it\n    # The correct key should produce consistent patterns when partially decrypting\n    \n    best_score = -1\n    best_key5 = 0\n    \n    for seed5 in range(0x10000):\n        if seed5 % 5000 == 0:\n            print(f\"  Checking seed5: {seed5}/65536\")\n        \n        key5 = (seed5 * 1234567) & 0xFFFFFFFF\n        \n        # Partially decrypt all ciphertexts with this key5\n        states_after_round2 = []\n        for pt, ct in pairs:\n            ct_left = getleft(ct)\n            ct_right = getright(ct)\n            left_bpm = ct_right ^ ct_left\n            right_bpm = ct_left\n            right_ar2 = left_bpm\n            f_r3 = f_function(right_ar2 ^ key5)\n            left_ar2 = right_bpm ^ f_r3\n            states_after_round2.append((left_ar2, right_ar2))\n"]
[963.362249, "i", "        \n        # Score based on differential properties\n        # For consecutive plaintexts (0,i) and (0,i+1), check the differential\n        score = 0\n        for i in range(len(states_after_round2) - 1):\n            left1, right1 = states_after_round2[i]\n            left2, right2 = states_after_round2[i+1]\n            \n            # The plaintexts differ by 1 in the right half\n            # After undoing round 3, the differential should have certain properties\n            # For the correct key, the right parts should be equal (since right_after_round2 = left_before_postmix)\n            # and the left differential should follow a pattern\n            \n            right_diff = right1 ^ right2\n            left_diff = left1 ^ left2\n            \n            # Heuristic: for the correct key, certain bit patterns should appear\n            # Count the number of set bits in the differentials\n            right_bits = bin(right_diff).count('1')\n            left_bits = bin(left_diff).count('1')\n            \n         "]
