[405.639404, "o", "\u001b[?2004h> "]
[405.639843, "o", "        key3 = (seed3 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r"]
[405.639934, "o", "\u001b[?2004h> "]
[405.640051, "o", "        \r\n\u001b[?2004l\r"]
[405.640179, "o", "\u001b[?2004h> "]
[405.640555, "o", "        for seed2 in range(0x10000):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[405.64114, "o", "            key2 = (seed2 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r # \u001b[?2004h"]
[405.641271, "o", "> "]
[405.641371, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[405.642287, "o", "            # For each (key2, key3), we need to try all (key0, key1)\r\n\u001b[?2004l\r"]
[405.642361, "o", "\u001b[?2004h> "]
[405.642854, "o", "            # But that's another 2^64 combinations!\r\n\u001b[?2004l\r"]
[405.642951, "o", "\u001b[?2004h> "]
[405.692123, "o", "            # \r\n\u001b[?2004l\r\u001b[?2004h"]
[405.692379, "o", "> "]
[405.692605, "o", "            # However, we can constrain key0 and key1:\r\n\u001b[?2004l\r"]
[405.692643, "o", "\u001b[?2004h> "]
[405.693022, "o", "            # Given pt1 = (0, 0), after whitening and pre-mixing:\r\n\u001b[?2004l\r\u001b[?2004h"]
[405.693137, "o", "> "]
[405.693405, "o", "            # left = key0, right = key1 ^ key0\r\n\u001b[?2004l\r000\u001b[?2004h> "]
[405.694265, "o", "            # So for any choice of key0, key1 is determined by the state after pre-mixing\r\n\u001b[?2004l\r\u001b[?2004h"]
[405.694379, "o", "> "]
[405.69487, "o", "            # But we don't know the state after pre-mixing without going through the rounds\r\n\u001b[?2004l\r\u001b[?2004h"]
[405.695022, "o", "> "]
[405.69514, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[405.695476, "o", "            # This is still too complex. Let me try a different approach.\r\n\u001b[?2004l\r\u001b[?2004h"]
[405.695518, "o", "> "]
[405.695673, "o", "            pass\r\n\u001b[?2004l\r \u001b[?2004h"]
[405.695776, "o", ">     \r\n\u001b[?2004l\r"]
[405.695861, "o", "\u001b[?2004h> "]
[405.696707, "o", "    # The meet-in-the-middle is still too complex because we have 6 keys total\r\n\u001b[?2004l\r"]
[405.69681, "o", "\u001b[?2004h> "]
[405.697335, "o", "    # Let me try a different optimization: iterate in a smarter order\r\n\u001b[?2004l\r"]
[405.697405, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[405.697486, "o", "\u001b[?2004h> "]
