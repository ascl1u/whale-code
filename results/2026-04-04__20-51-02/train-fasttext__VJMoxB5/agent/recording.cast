[285.527879, "o", "prepare_fasttext_data(test_df, 'test.txt')\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.528033, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[285.528139, "o", "> "]
[285.528341, "o", "print(\"\\nTraining fasttext model...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.528432, "o", "> "]
[285.529137, "o", "# Train with parameters to keep model size small but maintain accuracy\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.529458, "o", "# dim: lower dimension for smaller model\r\n\u001b[?2004l\r"]
[285.529508, "o", "\u001b[?2004h> "]
[285.529843, "o", "# epoch: more epochs for better accuracy\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.529981, "o", "> "]
[285.530172, "o", "# lr: learning rate\r\n\u001b[?2004l\r"]
[285.530294, "o", "\u001b[?2004h> "]
[285.530456, "o", "# wordNgrams: use bigrams for better accuracy\r\n\u001b[?2004l\r"]
[285.530607, "o", "\u001b[?2004h> "]
[285.530776, "o", "model = fasttext.train_supervised(\r\n\u001b[?2004l\r"]
[285.530835, "o", "\u001b[?2004h> "]
[285.531055, "o", "    input='train.txt',\r\n\u001b[?2004l\r"]
[285.531175, "o", "\u001b[?2004h> "]
[285.531347, "o", "    epoch=25,\r\n\u001b[?2004l\r"]
[285.531482, "o", "\u001b[?2004h> "]
[285.531641, "o", "    lr=0.5,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.531792, "o", "    dim=100,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.531875, "o", "    wordNgrams=2,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.532099, "o", "    loss='softmax',\r\n\u001b[?2004l\r"]
[285.532229, "o", "\u001b[?2004h> "]
[285.532357, "o", "    verbose=2\r\n\u001b[?2004l\r"]
[285.53249, "o", "\u001b[?2004h> )\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.532643, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.532852, "o", "print(\"\\nEvaluating on test set...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.532896, "o", "> "]
[285.533201, "o", "result = model.test('test.txt')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.533493, "o", "print(f\"Test samples: {result[0]}\")\r\n\u001b[?2004l\r"]
[285.533599, "o", "\u001b[?2004h> "]
[285.533829, "o", "print(f\"Precision: {result[1]:.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.533875, "o", "> "]
[285.53413, "o", "print(f\"Recall: {result[2]:.4f}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.534215, "o", "> \r\n\u001b[?2004l\r"]
[285.534289, "o", "\u001b[?2004h> "]
[285.534477, "o", "# Save the model\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.534565, "o", "> "]
[285.534769, "o", "print(\"\\nSaving model...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.534876, "o", "> "]
[285.53512, "o", "model.save_model('/app/model.bin')\r\n\u001b[?2004l\r"]
[285.535278, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[285.535446, "o", "\u001b[?2004h> "]
[285.535594, "o", "# Check model size\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.535971, "o", "model_size = os.path.getsize('/app/model.bin') / (1024 * 1024)  # MB\r\n\u001b[?2004l\r"]
[285.536019, "o", "\u001b[?2004h> "]
[285.536335, "o", "print(f\"\\nModel size: {model_size:.2f} MB\")\r\n\u001b[?2004l\r"]
[285.536469, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[285.536607, "o", "\u001b[?2004h> "]
[285.53666, "o", "if model_size >= 150:\r\n\u001b[?2004l\r"]
[285.536822, "o", "\u001b[?2004h> "]
[285.537094, "o", "    print(\"WARNING: Model size exceeds 150MB!\")\r\n\u001b[?2004l\r"]
[285.537232, "o", "\u001b[?2004h> "]
[285.537385, "o", "if result[1] < 0.62:\r\n\u001b[?2004l\r\u001b[?2004h"]
[285.537593, "o", "> "]
[285.537828, "o", "    print(\"WARNING: Accuracy is below 0.62!\")\r\n\u001b[?2004l\r"]
[285.537903, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[285.538103, "o", "> "]
[285.538305, "o", "print(\"\\nTraining complete!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[285.538461, "o", "EOF\r\n\u001b[?2004l\r"]
[285.545469, "o", "\u001b[?2004hroot@7f9aa432215a:/app# "]
