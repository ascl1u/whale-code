[2790.332685, "o", "\u001b[?2004hroot@7f9aa432215a:/app# "]
[2790.726678, "i", "cat > train_model_v2.py << 'EOF'\nimport pandas as pd\nimport fasttext\nimport os\n\nprint(\"Loading data...\")\ntrain_df = pd.read_parquet('data/train-00000-of-00001.parquet')\ntest_df = pd.read_parquet('data/test-00000-of-00001.parquet')\n\nprint(\"\\nTraining fasttext model with optimized parameters...\")\n# Parameters optimized for size and accuracy:\n# - minCount: filter rare words to reduce vocabulary size\n# - dim: lower dimension for smaller model\n# - epoch: sufficient epochs for good accuracy\n# - wordNgrams: use bigrams for better accuracy\n# - minn, maxn: character n-grams for better generalization\nmodel = fasttext.train_supervised(\n    input='train.txt',\n    epoch=20,\n    lr=0.5,\n    dim=50,\n    wordNgrams=2,\n    minCount=5,\n    minn=0,\n    maxn=0,\n    loss='softmax',\n    verbose=2\n)\n\nprint(\"\\nEvaluating on test set...\")\nresult = model.test('test.txt')\nprint(f\"Test samples: {result[0]}\")\nprint(f\"Precision: {result[1]:.4f}\")\nprint(f\"Recall: {result[2]:.4f}\")\n\n# Quantize the model to reduce size\nprint(\"\\nQuantizing mo"]
[2790.726856, "i", "del...\")\nmodel.quantize(input='train.txt', retrain=True, qnorm=True, cutoff=100000)\n\nprint(\"\\nEvaluating quantized model on test set...\")\nresult_q = model.test('test.txt')\nprint(f\"Test samples: {result_q[0]}\")\nprint(f\"Precision: {result_q[1]:.4f}\")\nprint(f\"Recall: {result_q[2]:.4f}\")\n\n# Save the quantized model\nprint(\"\\nSaving quantized model...\")\nmodel.save_model('/app/model.bin')\n\n# Check model size\nmodel_size = os.path.getsize('/app/model.bin') / (1024 * 1024)  # MB\nprint(f\"\\nModel size: {model_size:.2f} MB\")\n\nif model_size >= 150:\n    print(\"WARNING: Model size exceeds 150MB!\")\nelse:\n    print(\"✓ Model size is within 150MB limit\")\n    \nif result_q[1] < 0.62:\n    print(\"WARNING: Accuracy is below 0.62!\")\nelse:\n    print(\"✓ Accuracy meets the 0.62 threshold\")\n\nprint(\"\\nTraining complete!\")\nEOF\n"]
