[254.578529, "i", "python3 << 'EOF'\nimport pandas as pd\n\n# Load the training data\ntrain_df = pd.read_parquet('data/train-00000-of-00001.parquet')\ntest_df = pd.read_parquet('data/test-00000-of-00001.parquet')\n\nprint(\"Training data shape:\", train_df.shape)\nprint(\"Test data shape:\", test_df.shape)\nprint(\"\\nTraining data columns:\", train_df.columns.tolist())\nprint(\"\\nFirst few rows of training data:\")\nprint(train_df.head())\nprint(\"\\nData types:\")\nprint(train_df.dtypes)\nprint(\"\\nLabel distribution:\")\nif 'label' in train_df.columns:\n    print(train_df['label'].value_counts())\nelif 'stars' in train_df.columns:\n    print(train_df['stars'].value_counts())\nEOF\n"]
