[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import fasttext
[?2004l[?2004h> import os
[?2004l[?2004h> 
[?2004l[?2004h> print("Loading data...")
[?2004l[?2004h> train_df = pd.read_parquet('data/train-00000-of-00001.parquet')
[?2004l[?2004h> test_df = pd.read_parquet('data/test-00000-of-00001.parquet')
[?2004l[?2004h> 
[?2004l[?2004h> print("\nTraining fasttext model with optimized parameters...")
[?2004l[?2004h> # Parameters optimized for size and accuracy:
[?2004l[?2004h> # - minCount: filter rare words to reduce vocabulary size
[?2004l[?2004h> # - dim: lower dimension for smaller model
[?2004l[?2004h> # - epoch: sufficient epochs for good accuracy
[?2004l[?2004h> # - wordNgrams: use bigrams for better accuracy
[?2004l[?2004h> # - minn, maxn: character n-grams for better generalization
[?2004l[?2004h> model = fasttext.train_supervised(
[?2004l[?2004h>     input='train.txt',
[?2004l[?2004h>     epoch=20,
[?2004l[?2004h>     lr=0.5,
[?2004l[?2004h>     dim=50,
[?2004l[?2004h>     wordNgrams=2,
[?2004l[?2004h>     minCount=5,
[?2004l[?2004h>     minn=0,
[?2004l[?2004h>     maxn=0,
[?2004l[?2004h>     loss='softmax',
[?2004l[?2004h>     verbose=2
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> print("\nEvaluating on test set...")
[?2004l[?2004h> result = model.test('test.txt')
[?2004l[?2004h> print(f"Test samples: {result[0]}")
[?2004l[?2004h> print(f"Precision: {result[1]:.4f}")
[?2004l[?2004h> print(f"Recall: {result[2]:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Quantize the model to reduce size
[?2004l[?2004h> print("\nQuantizing model...")
[?2004l[?2004h> model.quantize(input='train.txt', retrain=True, qnorm=True, cutoff=100000)
[?2004l[?2004h> 
[?2004l[?2004h> print("\nEvaluating quantized model on test set...")
[?2004l[?2004h> result_q = model.test('test.txt')
[?2004l[?2004h> print(f"Test samples: {result_q[0]}")
[?2004l[?2004h> print(f"Precision: {result_q[1]:.4f}")
[?2004l[?2004h> print(f"Recall: {result_q[2]:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save the quantized model
[?2004l[?2004h> print("\nSaving quantized model...")
[?2004l[?2004h> model.save_model('/app/model.bin')
[?2004l[?2004h> 
