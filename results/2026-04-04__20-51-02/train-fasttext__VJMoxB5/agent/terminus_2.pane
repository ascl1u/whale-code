[?2004hroot@7f9aa432215a:/app# cat > train_model.py << 'EOF'
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import fasttext
[?2004l[?2004h> import os
[?2004l[?2004h> 
[?2004l[?2004h> # Load data
[?2004l[?2004h> print("Loading data...")
[?2004l[?2004h> train_df = pd.read_parquet('data/train-00000-of-00001.parquet')
[?2004l[?2004h> test_df = pd.read_parquet('data/test-00000-of-00001.parquet')
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare fasttext format: __label__<label> <text>
[?2004l[?2004h> def prepare_fasttext_data(df, output_file):
[?2004l[?2004h>     with open(output_file, 'w', encoding='utf-8') as f:
[?2004l[?2004h>         for _, row in df.iterrows():
[?2004l[?2004h>             # Clean text: remove newlines and extra spaces
[?2004l[?2004h>             text = ' '.join(str(row['text']).replace('\n', ' ').split())
[?2004l[?2004h>             label = row['label']
[?2004l[?2004h>             f.write(f'__label__{label} {text}\n')
[?2004l[?2004h>     print(f"Saved {len(df)} samples to {output_file}")
[?2004l[?2004h> 
[?2004l[?2004h> print("Preparing training data...")
[?2004l[?2004h> prepare_fasttext_data(train_df, 'train.txt')
[?2004l[?2004h> 
[?2004l[?2004h> print("Preparing test data...")
[?2004l[?2004h> prepare_fasttext_data(test_df, 'test.txt')
[?2004l[?2004h> 
[?2004l[?2004h> print("\nTraining fasttext model...")
[?2004l[?2004h> # Train with parameters to keep model size small but maintain accuracy
[?2004l[?2004h> # dim: lower dimension for smaller model
[?2004l[?2004h> # epoch: more epochs for better accuracy
[?2004l[?2004h> # lr: learning rate
[?2004l[?2004h> # wordNgrams: use bigrams for better accuracy
[?2004l[?2004h> model = fasttext.train_supervised(
[?2004l[?2004h>     input='train.txt',
[?2004l[?2004h>     epoch=25,
[?2004l[?2004h>     lr=0.5,
[?2004l[?2004h>     dim=100,
[?2004l[?2004h>     wordNgrams=2,
[?2004l[?2004h>     loss='softmax',
[?2004l[?2004h>     verbose=2
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> print("\nEvaluating on test set...")
[?2004l[?2004h> result = model.test('test.txt')
[?2004l[?2004h> print(f"Test samples: {result[0]}")
[?2004l[?2004h> print(f"Precision: {result[1]:.4f}")
[?2004l[?2004h> print(f"Recall: {result[2]:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save the model
[?2004l[?2004h> print("\nSaving model...")
[?2004l[?2004h> model.save_model('/app/model.bin')
[?2004l[?2004h> 
[?2004l[?2004h> # Check model size
[?2004l[?2004h> model_size = os.path.getsize('/app/model.bin') / (1024 * 1024)  # MB
