[45.784867, "i", "python3 << 'EOF'\nimport pandas as pd\nimport re\n\ndef clean_text(text):\n    \"\"\"Clean text for fasttext training\"\"\"\n    # Convert to string and lowercase\n    text = str(text).lower()\n    # Remove newlines and extra spaces\n    text = re.sub(r'\\s+', ' ', text)\n    # Remove special characters but keep basic punctuation\n    text = re.sub(r'[^a-z0-9\\s.,!?\\'\\-]', '', text)\n    return text.strip()\n\n# Read train data\nprint(\"Reading train data...\")\ntrain_df = pd.read_parquet('data/train-00000-of-00001.parquet')\n\n# Read test data\nprint(\"Reading test data...\")\ntest_df = pd.read_parquet('data/test-00000-of-00001.parquet')\n\n# Convert to fasttext format\nprint(\"Converting train data to fasttext format...\")\nwith open('train.txt', 'w', encoding='utf-8') as f:\n    for idx, row in train_df.iterrows():\n        text = clean_text(row['text'])\n        label = row['label']\n        f.write(f'__label__{label} {text}\\n')\n        if idx % 100000 == 0:\n            print(f\"Processed {idx} train examples...\")\n\nprint(\"Converting test data to f"]
[45.785055, "i", "asttext format...\")\nwith open('test.txt', 'w', encoding='utf-8') as f:\n    for idx, row in test_df.iterrows():\n        text = clean_text(row['text'])\n        label = row['label']\n        f.write(f'__label__{label} {text}\\n')\n\nprint(\"Data conversion complete!\")\nprint(f\"Train examples: {len(train_df)}\")\nprint(f\"Test examples: {len(test_df)}\")\nEOF\n"]
