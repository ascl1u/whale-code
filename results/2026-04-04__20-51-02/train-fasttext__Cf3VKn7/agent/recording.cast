[261.797035, "i", "python3 << 'EOF'\nimport fasttext\nimport os\n\nprint(\"Training fasttext model...\")\nprint(\"Parameters: dim=100, epoch=25, lr=0.5, wordNgrams=2\")\n\n# Train the model with size-optimized parameters\nmodel = fasttext.train_supervised(\n    input='train.txt',\n    dim=100,           # Lower dimension to reduce size\n    epoch=25,          # Good number of epochs for convergence\n    lr=0.5,            # Learning rate\n    wordNgrams=2,      # Bigrams help with accuracy\n    bucket=200000,     # Smaller bucket size to reduce memory\n    loss='softmax',    # Softmax for multi-class\n    verbose=2\n)\n\nprint(\"\\nTraining complete!\")\n\n# Save the model\nmodel.save_model('model.bin')\nprint(\"\\nModel saved as model.bin\")\n\n# Check model size\nmodel_size = os.path.getsize('model.bin') / (1024 * 1024)\nprint(f\"Model size: {model_size:.2f} MB\")\n\n# Test on test set\nprint(\"\\nEvaluating on test set...\")\nresult = model.test('test.txt')\nprint(f\"Test samples: {result[0]}\")\nprint(f\"Precision: {result[1]:.4f}\")\nprint(f\"Recall: {result[2]:.4f}\")\n\nEOF\n"]
