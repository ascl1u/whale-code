Sending keys: ['cat > train_model_v2.py << \'EOF\'\nimport pandas as pd\nimport fasttext\nimport os\nimport re\n\ndef clean_text(text):\n    """Clean text for fasttext training"""\n    text = re.sub(r\'\\s+\', \' \', text)\n    text = text.strip()\n    return text\n\ndef convert_to_fasttext_format(df, output_file):\n    """Convert dataframe to fasttext format"""\n    with open(output_file, \'w\', encoding=\'utf-8\') as f:\n        for idx, row in df.iterrows():\n            label = row[\'label\']\n            text = clean_text(row[\'text\'])\n            f.write(f\'__label__{label} {text}\\n\')\n    print(f"Saved {len(df)} samples to {output_file}")\n\nprint("Loading data...")\ntrain_df = pd.read_parquet(\'data/train-00000-of-00001.parquet\')\ntest_df = pd.read_parquet(\'data/test-00000-of-00001.parquet\')\n\nprint("Converting to fasttext format...")\nif not os.path.exists(\'train.txt\'):\n    convert_to_fasttext_format(train_df, \'train.txt\')\nelse:\n    print("train.txt already exists, skipping conversion")\n\nif not os.path.exists(\'test.txt\'):\n    convert_to_fasttext_format(test_df, \'test.txt\')\nelse:\n    print("test.txt already exists, skipping conversion")\n\nprint("\\nTraining fasttext model with optimized parameters...")\n\n# More aggressive size reduction while maintaining accuracy\nmodel = fasttext.train_supervised(\n    input=\'train.txt\',\n    lr=0.5,              # Learning rate\n    dim=50,              # Smaller embedding dimension\n    ws=5,                # Context window size\n    epoch=30,            # More epochs for better accuracy\n    wordNgrams=2,        # Use bigrams\n    bucket=50000,        # Much smaller bucket size\n    minn=0,              # No subword info\n    maxn=0,              \n    loss=\'softmax\',\n    thread=4,\n    verbose=2\n)\n\nprint("\\nEvaluating on test set...")\nresult = model.test(\'test.txt\')\nprint(f"Test samples: {result[0]}")\nprint(f"Precision: {result[1]:.4f}")\nprint(f"Recall: {result[2]:.4f}")\n\nprint("\\nSaving model...")\nmodel.save_model(\'/app/model.bin\')\n\nmodel_size = os.path.getsize(\'/app/model.bin\') / (1024 * 1024)\nprint(f"\\nModel size: {model_size:.2f} MB")\n\nif model_size > 150:\n    print(f"WARNING: Model size {model_size:.2f}MB still exceeds 150MB!")\n    print("Attempting quantization...")\n    # Quantize the model to reduce size\n    model.quantize(input=\'train.txt\', qnorm=True, retrain=True, cutoff=100000)\n    model.save_model(\'/app/model.bin\')\n    model_size = os.path.getsize(\'/app/model.bin\') / (1024 * 1024)\n    print(f"Quantized model size: {model_size:.2f} MB")\n    \n    # Re-evaluate after quantization\n    result = model.test(\'test.txt\')\n    print(f"After quantization - Precision: {result[1]:.4f}")\n\nif model_size <= 150:\n    print("Model size is within the 150MB limit.")\n\nif result[1] >= 0.62:\n    print(f"Accuracy {result[1]:.4f} meets the 0.62 threshold.")\nelse:\n    print(f"WARNING: Accuracy {result[1]:.4f} is below 0.62 threshold.")\n\nprint("\\nDone!")\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
