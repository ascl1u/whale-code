Sending keys: ['python3 << \'EOF\'\nimport pandas as pd\nimport fasttext\nimport os\n\n# Load data\nprint("Loading data...")\ntrain_df = pd.read_parquet(\'data/train-00000-of-00001.parquet\')\ntest_df = pd.read_parquet(\'data/test-00000-of-00001.parquet\')\n\nprint(f"Train size: {len(train_df)}")\nprint(f"Test size: {len(test_df)}")\n\n# Prepare fasttext format: __label__X text\ndef prepare_fasttext_line(row):\n    # Clean text: remove newlines and extra spaces\n    text = \' \'.join(str(row[\'text\']).replace(\'\\n\', \' \').replace(\'\\r\', \' \').split())\n    return f"__label__{row[\'label\']} {text}"\n\nprint("\\nPreparing train data...")\ntrain_lines = [prepare_fasttext_line(row) for _, row in train_df.iterrows()]\n\nprint("Preparing test data...")\ntest_lines = [prepare_fasttext_line(row) for _, row in test_df.iterrows()]\n\n# Write to files\nprint("\\nWriting train file...")\nwith open(\'/tmp/train.txt\', \'w\', encoding=\'utf-8\') as f:\n    f.write(\'\\n\'.join(train_lines))\n\nprint("Writing test file...")\nwith open(\'/tmp/test.txt\', \'w\', encoding=\'utf-8\') as f:\n    f.write(\'\\n\'.join(test_lines))\n\nprint("\\nData preparation complete!")\nEOF\n'] min_timeout_sec: 15 max_timeout_sec: 180.0
