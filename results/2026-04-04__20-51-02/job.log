Sending keys: ['python3 << \'EOF\'\nimport fasttext\nimport os\n\nprint("Training fasttext model...")\nprint("Using parameters optimized for size and accuracy")\n\n# Train model with controlled parameters\n# dim: embedding dimension (lower = smaller model)\n# wordNgrams: use bigrams for better accuracy\n# epoch: training epochs\n# lr: learning rate\nmodel = fasttext.train_supervised(\n    input=\'/tmp/train.txt\',\n    dim=100,           # Lower dimension to reduce size\n    epoch=10,          # More epochs for better accuracy\n    lr=0.5,            # Learning rate\n    wordNgrams=2,      # Use bigrams\n    loss=\'softmax\',    # Multi-class classification\n    verbose=2\n)\n\nprint("\\nTraining complete!")\n\n# Test on test set\nprint("\\nEvaluating on test set...")\nresult = model.test(\'/tmp/test.txt\')\nprint(f"Samples: {result[0]}")\nprint(f"Precision: {result[1]:.4f}")\nprint(f"Recall: {result[2]:.4f}")\n\n# Save model\nprint("\\nSaving model to /app/model.bin...")\nmodel.save_model(\'/app/model.bin\')\n\n# Check model size\nsize_mb = os.path.getsize(\'/app/model.bin\') / (1024 * 1024)\nprint(f"Model size: {size_mb:.2f} MB")\n\nif size_mb > 150:\n    print("\\nModel is too large, applying quantization...")\n    model.quantize(input=\'/tmp/train.txt\', retrain=True)\n    model.save_model(\'/app/model.bin\')\n    size_mb = os.path.getsize(\'/app/model.bin\') / (1024 * 1024)\n    print(f"Quantized model size: {size_mb:.2f} MB")\n    \n    # Test quantized model\n    result = model.test(\'/tmp/test.txt\')\n    print(f"\\nQuantized model accuracy: {result[1]:.4f}")\n\nprint("\\nDone!")\nEOF\n'] min_timeout_sec: 60 max_timeout_sec: 180.0
