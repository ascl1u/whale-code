Sending keys: ["cat > train_fasttext_v2.py << 'EOF'\nimport pandas as pd\nimport fasttext\nimport os\n\n# Convert parquet to fasttext format\ndef convert_to_fasttext(parquet_file, output_file):\n    df = pd.read_parquet(parquet_file)\n    with open(output_file, 'w', encoding='utf-8') as f:\n        for idx, row in df.iterrows():\n            # Clean text: remove newlines and extra spaces\n            text = str(row['text']).replace('\\n', ' ').replace('\\r', ' ').strip()\n            label = row['label']\n            f.write(f'__label__{label} {text}\\n')\n    print(f'Converted {parquet_file} to {output_file}')\n\n# Convert training and test data\nprint('Converting training data...')\nconvert_to_fasttext('data/train-00000-of-00001.parquet', 'train.txt')\nprint('Converting test data...')\nconvert_to_fasttext('data/test-00000-of-00001.parquet', 'test.txt')\n\n# Train the model with better hyperparameters\nprint('\\nTraining fasttext model...')\nmodel = fasttext.train_supervised(\n    input='train.txt',\n    epoch=10,\n    lr=0.5,\n    wordNgrams=2,\n    dim=100,\n    bucket=200000,  # Reduce bucket size to limit vocabulary\n    minn=3,  # Use character n-grams for subword info\n    maxn=6,\n    loss='softmax',\n    verbose=2\n)\n\nprint('\\nBefore quantization:')\nresult_before = model.test('test.txt')\nprint(f'Test precision: {result_before[1]:.4f}')\nprint(f'Test recall: {result_before[2]:.4f}')\n\n# Quantize the model to reduce size\nprint('\\nQuantizing model...')\nmodel.quantize(input='train.txt', qnorm=True, retrain=True, cutoff=100000)\n\n# Save the quantized model\nmodel.save_model('/app/model.bin')\nprint('\\nModel saved to /app/model.bin')\n\n# Check model size\nmodel_size = os.path.getsize('/app/model.bin') / (1024 * 1024)\nprint(f'Model size: {model_size:.2f} MB')\n\n# Test accuracy on quantized model\nresult = model.test('test.txt')\nprint(f'\\nAfter quantization:')\nprint(f'Test samples: {result[0]}')\nprint(f'Test precision: {result[1]:.4f}')\nprint(f'T