Sending keys: ['cat > train_model.py << \'EOF\'\nimport pandas as pd\nimport fasttext\nimport os\n\n# Load data\nprint("Loading data...")\ntrain_df = pd.read_parquet(\'data/train-00000-of-00001.parquet\')\ntest_df = pd.read_parquet(\'data/test-00000-of-00001.parquet\')\n\n# Prepare fasttext format: __label__<label> <text>\ndef prepare_fasttext_data(df, output_file):\n    with open(output_file, \'w\', encoding=\'utf-8\') as f:\n        for _, row in df.iterrows():\n            # Clean text: remove newlines and extra spaces\n            text = \' \'.join(str(row[\'text\']).replace(\'\\n\', \' \').split())\n            label = row[\'label\']\n            f.write(f\'__label__{label} {text}\\n\')\n    print(f"Saved {len(df)} samples to {output_file}")\n\nprint("Preparing training data...")\nprepare_fasttext_data(train_df, \'train.txt\')\n\nprint("Preparing test data...")\nprepare_fasttext_data(test_df, \'test.txt\')\n\nprint("\\nTraining fasttext model...")\n# Train with parameters to keep model size small but maintain accuracy\n# dim: lower dimension for smaller model\n# epoch: more epochs for better accuracy\n# lr: learning rate\n# wordNgrams: use bigrams for better accuracy\nmodel = fasttext.train_supervised(\n    input=\'train.txt\',\n    epoch=25,\n    lr=0.5,\n    dim=100,\n    wordNgrams=2,\n    loss=\'softmax\',\n    verbose=2\n)\n\nprint("\\nEvaluating on test set...")\nresult = model.test(\'test.txt\')\nprint(f"Test samples: {result[0]}")\nprint(f"Precision: {result[1]:.4f}")\nprint(f"Recall: {result[2]:.4f}")\n\n# Save the model\nprint("\\nSaving model...")\nmodel.save_model(\'/app/model.bin\')\n\n# Check model size\nmodel_size = os.path.getsize(\'/app/model.bin\') / (1024 * 1024)  # MB\nprint(f"\\nModel size: {model_size:.2f} MB")\n\nif model_size >= 150:\n    print("WARNING: Model size exceeds 150MB!")\nif result[1] < 0.62:\n    print("WARNING: Accuracy is below 0.62!")\n\nprint("\\nTraining complete!")\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
