[?2004l[?2004h> # Load data
[?2004l[?2004h> print("Loading data...")
[?2004l[?2004h> train_df = pd.read_parquet('data/train-00000-of-00001.parquet')
[?2004l[?2004h> test_df = pd.read_parquet('data/test-00000-of-00001.parquet')
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Train size: {len(train_df)}")
[?2004l[?2004h> print(f"Test size: {len(test_df)}")
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare fasttext format: __label__X text
[?2004l[?2004h> def prepare_fasttext_line(row):
[?2004l[?2004h>     # Clean text: remove newlines and extra spaces
[?2004l[?2004h>     text = ' '.join(str(row['text']).replace('\n', ' ').replace('\r', ' ').split())
[?2004l[?2004h>     return f"__label__{row['label']} {text}"
[?2004l[?2004h> 
[?2004l[?2004h> print("\nPreparing train data...")
[?2004l[?2004h> train_lines = [prepare_fasttext_line(row) for _, row in train_df.iterrows()]
[?2004l[?2004h> 
[?2004l[?2004h> print("Preparing test data...")
[?2004l[?2004h> test_lines = [prepare_fasttext_line(row) for _, row in test_df.iterrows()]
[?2004l[?2004h> 
[?2004l[?2004h> # Write to files
[?2004l[?2004h> print("\nWriting train file...")
[?2004l[?2004h> with open('/tmp/train.txt', 'w', encoding='utf-8') as f:
[?2004l[?2004h>     f.write('\n'.join(train_lines))
[?2004l[?2004h> 
[?2004l[?2004h> print("Writing test file...")
[?2004l[?2004h> with open('/tmp/test.txt', 'w', encoding='utf-8') as f:
[?2004l[?2004h>     f.write('\n'.join(test_lines))
[?2004l[?2004h> 
[?2004l[?2004h> print("\nData preparation complete!")
