[1834.623145, "o", "\u001b[?2004h"]
[1834.623321, "o", "root@b212fec9db4d:/app# "]
[1876.902579, "i", "python3 << 'EOF'\nimport fasttext\nimport os\n\nprint(\"Training fasttext model with optimized parameters...\")\n\n# Train with higher minCount to reduce vocabulary size\n# This will significantly reduce model size\nmodel = fasttext.train_supervised(\n    input='/tmp/train.txt',\n    dim=50,            # Smaller dimension\n    epoch=15,          # More epochs for better accuracy\n    lr=0.5,\n    wordNgrams=2,\n    minCount=5,        # Ignore words appearing less than 5 times\n    loss='softmax',\n    verbose=2\n)\n\nprint(\"\\nTraining complete!\")\n\n# Test on test set\nprint(\"\\nEvaluating on test set...\")\nresult = model.test('/tmp/test.txt')\nprint(f\"Samples: {result[0]}\")\nprint(f\"Precision: {result[1]:.4f}\")\nprint(f\"Recall: {result[2]:.4f}\")\n\n# Apply quantization with more aggressive settings\nprint(\"\\nApplying quantization...\")\nmodel.quantize(input='/tmp/train.txt', retrain=True, qnorm=True, cutoff=100000)\nmodel.save_model('/app/model.bin')\n\nsize_mb = os.path.getsize('/app/model.bin') / (1024 * 1024)\nprint(f\"\\nQuantized model size: "]
[1876.903905, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r"]
[1876.903967, "i", "{size_mb:.2f} MB\")\n\n# Test quantized model\nresult = model.test('/tmp/test.txt')\nprint(f\"Quantized model accuracy: {result[1]:.4f}\")\n\nprint(\"\\nDone!\")\nEOF\n"]
