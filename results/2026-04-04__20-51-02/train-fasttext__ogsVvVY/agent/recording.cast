[3211.906287, "i", "python3 << 'EOF'\nimport fasttext\nimport os\n\nprint(\"Training fasttext model with improved parameters...\")\n\n# Train with better parameters for accuracy\nmodel = fasttext.train_supervised(\n    input='/tmp/train.txt',\n    dim=100,           # Larger dimension for better accuracy\n    epoch=25,          # More epochs\n    lr=0.5,\n    wordNgrams=2,\n    minCount=5,        # Keep vocabulary manageable\n    loss='softmax',\n    verbose=2\n)\n\nprint(\"\\nTraining complete!\")\n\n# Test on test set\nprint(\"\\nEvaluating on test set...\")\nresult = model.test('/tmp/test.txt')\nprint(f\"Samples: {result[0]}\")\nprint(f\"Precision (before quantization): {result[1]:.4f}\")\nprint(f\"Recall: {result[2]:.4f}\")\n\n# Save unquantized model first to check size\nmodel.save_model('/tmp/model_unquantized.bin')\nsize_mb = os.path.getsize('/tmp/model_unquantized.bin') / (1024 * 1024)\nprint(f\"\\nUnquantized model size: {size_mb:.2f} MB\")\n\nif size_mb > 150:\n    print(\"\\nApplying quantization...\")\n    model.quantize(input='/tmp/train.txt', retrain=True, qnorm=True,"]
[3211.907251, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r"]
[3211.907279, "i", " cutoff=50000)\n    model.save_model('/app/model.bin')\n    \n    size_mb = os.path.getsize('/app/model.bin') / (1024 * 1024)\n    print(f\"Quantized model size: {size_mb:.2f} MB\")\n    \n    # Test quantized model\n    result = model.test('/tmp/test.txt')\n    print(f\"Quantized model accuracy: {result[1]:.4f}\")\nelse:\n    print(\"\\nModel is already under 150MB, saving without quantization...\")\n    model.save_model('/app/model.bin')\n    size_mb = os.path.getsize('/app/model.bin') / (1024 * 1024)\n    print(f\"Final model size: {size_mb:.2f} MB\")\n    print(f\"Final model accuracy: {result[1]:.4f}\")\n\nprint(\"\\nDone!\")\nEOF\n"]
