[?2004hroot@85d65680eec8:/app# cat > train_fasttext_v2.py << 'EOF'
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import fasttext
[?2004l[?2004h> import os
[?2004l[?2004h> 
[?2004l[?2004h> # Convert parquet to fasttext format
[?2004l[?2004h> def convert_to_fasttext(parquet_file, output_file):
[?2004l[?2004h>     df = pd.read_parquet(parquet_file)
[?2004l[?2004h>     with open(output_file, 'w', encoding='utf-8') as f:
[?2004l[?2004h>         for idx, row in df.iterrows():
[?2004l[?2004h>             # Clean text: remove newlines and extra spaces
[?2004l[?2004h>             text = str(row['text']).replace('\n', ' ').replace('\r', ' ').strip()
[?2004l[?2004h>             label = row['label']
[?2004l[?2004h>             f.write(f'__label__{label} {text}\n')
[?2004l[?2004h>     print(f'Converted {parquet_file} to {output_file}')
[?2004l[?2004h> 
[?2004l[?2004h> # Convert training and test data
[?2004l[?2004h> print('Converting training data...')
[?2004l[?2004h> convert_to_fasttext('data/train-00000-of-00001.parquet', 'train.txt')
[?2004l[?2004h> print('Converting test data...')
[?2004l[?2004h> convert_to_fasttext('data/test-00000-of-00001.parquet', 'test.txt')
[?2004l[?2004h> 
[?2004l[?2004h> # Train the model with better hyperparameters
[?2004l[?2004h> print('\nTraining fasttext model...')
[?2004l[?2004h> model = fasttext.train_supervised(
[?2004l[?2004h>     input='train.txt',
[?2004l[?2004h>     epoch=10,
[?2004l[?2004h>     lr=0.5,
[?2004l[?2004h>     wordNgrams=2,
[?2004l[?2004h>     dim=100,
[?2004l[?2004h>     bucket=200000,  # Reduce bucket size to limit vocabulary
[?2004l[?2004h>     minn=3,  # Use character n-grams for subword info
[?2004l[?2004h>     maxn=6,
[?2004l[?2004h>     loss='softmax',
[?2004l[?2004h>     verbose=2
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> print('\nBefore quantization:')
[?2004l[?2004h> result_before = model.test('test.txt')
[?2004l[?2004h> print(f'Test precision: {result_before[1]:.4f}')
[?2004l[?2004h> print(f'Test recall: {result_before[2]:.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> # Quantize the model to reduce size
[?2004l[?2004h> print('\nQuantizing model...')
[?2004l[?2004h> model.quantize(input='train.txt', qnorm=True, retrain=True, cutoff=100000)
[?2004l[?2004h> 
[?2004l[?2004h> # Save the quantized model
[?2004l[?2004h> model.save_model('/app/model.bin')
[?2004l[?2004h> print('\nModel saved to /app/model.bin')
[?2004l[?2004h> 
[?2004l[?2004h> # Check model size
[?2004l[?2004h> model_size = os.path.getsize('/app/model.bin') / (1024 * 1024)
[?2004l[?2004h> print(f'Model size: {model_size:.2f} MB')
[?2004l[?2004h> 
[?2004l[?2004h> # Test accuracy on quantized model
[?2004l[?2004h> result = model.test('test.txt')
[?2004l[?2004h> print(f'\nAfter quantization:')
[?2004l[?2004h> print(f'Test samples: {result[0]}')
[?2004l[?2004h> print(f'Test precision: {result[1]:.4f}')
[?2004l[?2004h> print(f'Test recall: {result[2]:.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> # Clean up intermediate files
[?2004l[?2004h> os.remove('train.txt')
[?2004l[?2004h> os.remove('test.txt')
[?2004l[?2004h> print('\nCleaned up intermediate files')
[?2004l[?2004h> EOF
