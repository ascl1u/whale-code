[218.139771, "o", "\r\u001b[2K   \u001b[38;5;70m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m3/3\u001b[0m [fasttext]\r\n\u001b[?25h\r\u001b[1A\u001b[2K"]
[218.142652, "o", "Successfully installed fasttext-0.9.3 pybind11-3.0.3 setuptools-82.0.1\r\n"]
[218.145185, "o", "\u001b[33mWARNING: Running pip as the 'root' user can result in broken permissions and conflicting behaviour with the system package manager, possibly rendering your system unusable. It is recommended to use a virtual environment instead: https://pip.pypa.io/warnings/venv. Use the --root-user-action option if you know what you are doing and want to suppress this warning.\u001b[0m\u001b[33m\r\n\u001b[0m"]
[218.153818, "o", "\r\n\u001b[1m[\u001b[0m\u001b[34;49mnotice\u001b[0m\u001b[1;39;49m]\u001b[0m\u001b[39;49m A new release of pip is available: \u001b[0m\u001b[31;49m25.2\u001b[0m\u001b[39;49m -> \u001b[0m\u001b[32;49m26.0.1\u001b[0m\r\n\u001b[1m[\u001b[0m\u001b[34;49mnotice\u001b[0m\u001b[1;39;49m]\u001b[0m\u001b[39;49m To update, run: \u001b[0m\u001b[32;49mpip install --upgrade pip\u001b[0m\r\n"]
[218.34801, "o", "__CMDEND__7__\r\n"]
[218.348079, "o", "\u001b[?2004hroot@85d65680eec8:/app# "]
[382.131433, "i", "cat > train_fasttext.py << 'EOF'\nimport pandas as pd\nimport fasttext\nimport os\n\n# Convert parquet to fasttext format\ndef convert_to_fasttext(parquet_file, output_file):\n    df = pd.read_parquet(parquet_file)\n    with open(output_file, 'w', encoding='utf-8') as f:\n        for idx, row in df.iterrows():\n            # Clean text: remove newlines and extra spaces\n            text = str(row['text']).replace('\\n', ' ').replace('\\r', ' ').strip()\n            label = row['label']\n            f.write(f'__label__{label} {text}\\n')\n    print(f'Converted {parquet_file} to {output_file}')\n\n# Convert training and test data\nprint('Converting training data...')\nconvert_to_fasttext('data/train-00000-of-00001.parquet', 'train.txt')\nprint('Converting test data...')\nconvert_to_fasttext('data/test-00000-of-00001.parquet', 'test.txt')\n\n# Train the model with hyperparameters to keep size < 150MB\nprint('\\nTraining fasttext model...')\nmodel = fasttext.train_supervised(\n    input='train.txt',\n    epoch=25,\n    lr=0.5,\n    wordNgrams=2"]
[382.131699, "i", ",\n    dim=100,  # Reduced dimension to keep model size down\n    loss='softmax',\n    verbose=2\n)\n\n# Save the model\nmodel.save_model('/app/model.bin')\nprint('\\nModel saved to /app/model.bin')\n\n# Check model size\nmodel_size = os.path.getsize('/app/model.bin') / (1024 * 1024)\nprint(f'Model size: {model_size:.2f} MB')\n\n# Test accuracy\nresult = model.test('test.txt')\nprint(f'\\nTest samples: {result[0]}')\nprint(f'Test precision: {result[1]:.4f}')\nprint(f'Test recall: {result[2]:.4f}')\n\n# Clean up intermediate files\nos.remove('train.txt')\nos.remove('test.txt')\nprint('\\nCleaned up intermediate files')\nEOF\n"]
