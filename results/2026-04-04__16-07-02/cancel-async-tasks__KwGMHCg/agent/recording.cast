[23.411603, "o", "import asyncio\r\nfrom typing import Callable, Awaitable\r\n\r\n\r\nasync def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:\r\n    \"\"\"Run async tasks with a maximum concurrency limit.\r\n    \r\n    Args:\r\n        tasks: List of async callables to execute\r\n        max_concurrent: Maximum number of tasks to run concurrently\r\n    \"\"\"\r\n    if not tasks:\r\n        return\r\n    \r\n    semaphore = asyncio.Semaphore(max_concurrent)\r\n    \r\n    async def run_with_semaphore(task: Callable[[], Awaitable[None]]) -> None:\r\n        \"\"\"Execute a task with semaphore-controlled concurrency.\"\"\"\r\n        async with semaphore:\r\n            await task()\r\n    \r\n    # Create all task coroutines\r\n    task_coroutines = [run_with_semaphore(task) for task in tasks]\r\n    \r\n    # Gather all tasks\r\n    gathered = asyncio.gather(*task_coroutines, return_exceptions=True)\r\n    \r\n    try:\r\n        # Wait for all tasks to complete\r\n        results = await gathered\r\n        \r\n        # Re-raise any exceptions that occurred "]
[23.411824, "o", "(except CancelledError)\r\n        for result in results:\r\n            if isinstance(result, Exception) and not isinstance(result, asyncio.CancelledError):\r\n                raise result\r\n    except KeyboardInterrupt:\r\n        # On keyboard interrupt, cancel all tasks but let them cleanup\r\n        gathered.cancel()\r\n        try:\r\n            # Wait for tasks to finish their cleanup\r\n            await gathered\r\n        except asyncio.CancelledError:\r\n            # This is expected when tasks are cancelled\r\n            pass\r\n        # Re-raise the KeyboardInterrupt\r\n        raise\r\n"]
