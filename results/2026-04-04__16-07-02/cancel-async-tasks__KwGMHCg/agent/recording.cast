[41.00296, "i", "python3 << 'EOF'\nimport asyncio\nimport time\nfrom run import run_tasks\n\nprint(\"Test 1: Import successful\")\n\n# Test 2: Basic concurrency limiting\nasync def test_concurrency():\n    concurrent_count = 0\n    max_concurrent_seen = 0\n    completed = []\n    \n    async def task(task_id):\n        nonlocal concurrent_count, max_concurrent_seen\n        concurrent_count += 1\n        max_concurrent_seen = max(max_concurrent_seen, concurrent_count)\n        print(f\"Task {task_id} started (concurrent: {concurrent_count})\")\n        await asyncio.sleep(0.1)\n        concurrent_count -= 1\n        completed.append(task_id)\n        print(f\"Task {task_id} completed\")\n    \n    tasks = [lambda i=i: task(i) for i in range(10)]\n    await run_tasks(tasks, max_concurrent=3)\n    \n    print(f\"Test 2: Max concurrent seen: {max_concurrent_seen} (expected: 3)\")\n    print(f\"Test 2: All tasks completed: {len(completed) == 10}\")\n    assert max_concurrent_seen <= 3, \"Concurrency limit exceeded!\"\n    assert len(completed) == 10, \"Not all tasks comp"]
[41.003104, "i", "leted!\"\n\nasyncio.run(test_concurrency())\n\n# Test 3: Cleanup code runs\nasync def test_cleanup():\n    cleanup_ran = []\n    \n    async def task_with_cleanup(task_id):\n        try:\n            print(f\"Task {task_id} running\")\n            await asyncio.sleep(0.05)\n        finally:\n            cleanup_ran.append(task_id)\n            print(f\"Task {task_id} cleanup ran\")\n    \n    tasks = [lambda i=i: task_with_cleanup(i) for i in range(5)]\n    await run_tasks(tasks, max_concurrent=2)\n    \n    print(f\"Test 3: Cleanup ran for all tasks: {len(cleanup_ran) == 5}\")\n    assert len(cleanup_ran) == 5, \"Cleanup didn't run for all tasks!\"\n\nasyncio.run(test_cleanup())\n\nprint(\"\\nAll tests passed!\")\nEOF\n"]
