[104.492306, "o", "            raise  # Re-raise to propagate cancellation\r\n\u001b[?2004l\r"]
[104.492428, "o", "\u001b[?2004h> "]
[104.492658, "o", "        finally:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.493119, "o", "            cancellation_log.append(f\"Task {task_id} cleanup executed\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.493246, "o", "> "]
[104.493368, "o", "    return task\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.493459, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[104.493574, "o", "> "]
[104.493751, "o", "async def test_cancellation():\r\n\u001b[?2004l\r"]
[104.493831, "o", "\u001b[?2004h> "]
[104.494224, "o", "    tasks = [await long_task_with_cleanup(i) for i in range(3)]\r\n\u001b[?2004l\r"]
[104.49434, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[104.494449, "o", "\u001b[?2004h> "]
[104.494645, "o", "    # Create a task that will be cancelled\r\n\u001b[?2004l\r"]
[104.494695, "o", "\u001b[?2004h> "]
[104.49514, "o", "    main_task = asyncio.create_task(run_tasks(tasks, max_concurrent=2))\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.495282, "o", ">     \r\n\u001b[?2004l\r"]
[104.495398, "o", "\u001b[?2004h> "]
[104.495473, "o", "    # Let tasks start\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.495766, "o", "    await asyncio.sleep(0.1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.495965, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.496263, "o", "    # Cancel the main task (simulating keyboard interrupt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.496403, "o", "> "]
[104.496621, "o", "    main_task.cancel()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[104.496795, "o", "\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[104.496914, "o", "\u001b[?2004h> "]
[104.497094, "o", "        await main_task\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.497268, "o", "    except asyncio.CancelledError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.49759, "o", "        cancellation_log.append(\"Main task cancelled\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.497716, "o", "> "]
[104.497857, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[104.497969, "o", "> "]
[104.498112, "o", "    # Give cleanup time to complete\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.498389, "o", "    await asyncio.sleep(0.1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.498589, "o", ">     \r\n\u001b[?2004l\r"]
[104.498743, "o", "\u001b[?2004h> "]
[104.498889, "o", "    for log in cancellation_log:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.499071, "o", "        print(f\"  {log}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.499218, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[104.499311, "o", "> "]
[104.499495, "o", "    # Verify cleanup ran for all started tasks\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.499593, "o", "> "]
[104.500059, "o", "    started_tasks = [i for i in range(3) if f\"Task {i} started\" in cancellation_log]\r\n\u001b[?2004l\r"]
[104.50017, "o", "\u001b[?2004h> "]
[104.500376, "o", "    for task_id in started_tasks:\r\n\u001b[?2004l\r"]
[104.500479, "o", "\u001b[?2004h> "]
[104.501121, "o", "        assert f\"Task {task_id} cleanup executed\" in cancellation_log, f\"Task {task_id} cleanup did not execute!\"\r\n\u001b[?2004l\r"]
[104.501338, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[104.501451, "o", "\u001b[?2004h> "]
[104.501622, "o", "    print(\"✓ Cancellation test passed\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[104.501761, "o", "\u001b[?2004h> "]
[104.501917, "o", "asyncio.run(test_cancellation())\r\n\u001b[?2004l\r"]
[104.502056, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.502265, "o", "print(\"All tests passed! ✓\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.502378, "o", "> "]
[104.502483, "o", "EOF\r\n\u001b[?2004l\r"]
