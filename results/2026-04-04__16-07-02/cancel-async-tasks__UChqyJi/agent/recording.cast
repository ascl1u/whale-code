[104.475331, "i", "cat > /tmp/test_run.py << 'EOF'\nimport asyncio\nimport time\nfrom run import run_tasks\n\nprint(\"Test 1: Basic import test\")\nprint(f\"run_tasks function imported: {run_tasks}\")\nprint(\"✓ Import successful\\n\")\n\nprint(\"Test 2: Concurrent execution with max_concurrent limit\")\nexecution_log = []\n\nasync def task_factory(task_id: int, duration: float):\n    async def task():\n        start = time.time()\n        execution_log.append(f\"Task {task_id} started at {start:.2f}\")\n        await asyncio.sleep(duration)\n        end = time.time()\n        execution_log.append(f\"Task {task_id} finished at {end:.2f}\")\n    return task\n\nasync def test_concurrency():\n    tasks = [await task_factory(i, 0.1) for i in range(5)]\n    start_time = time.time()\n    await run_tasks(tasks, max_concurrent=2)\n    end_time = time.time()\n    print(f\"Total time: {end_time - start_time:.2f}s\")\n    print(f\"Expected: ~0.3s (5 tasks / 2 concurrent = 3 batches * 0.1s)\")\n    for log in execution_log:\n        print(f\"  {log}\")\n    print(\"✓ Concurrency test "]
[104.475563, "i", "passed\\n\")\n\nasyncio.run(test_concurrency())\n\nprint(\"Test 3: Cleanup code execution\")\ncleanup_log = []\n\nasync def task_with_cleanup(task_id: int):\n    async def task():\n        try:\n            cleanup_log.append(f\"Task {task_id} started\")\n            await asyncio.sleep(0.1)\n            cleanup_log.append(f\"Task {task_id} completed\")\n        finally:\n            cleanup_log.append(f\"Task {task_id} cleanup executed\")\n    return task\n\nasync def test_cleanup():\n    tasks = [await task_with_cleanup(i) for i in range(3)]\n    await run_tasks(tasks, max_concurrent=2)\n    for log in cleanup_log:\n        print(f\"  {log}\")\n    assert all(f\"Task {i} cleanup executed\" in cleanup_log for i in range(3))\n    print(\"✓ Cleanup test passed\\n\")\n\nasyncio.run(test_cleanup())\n\nprint(\"Test 4: Cancellation handling (simulating keyboard interrupt)\")\ncancellation_log = []\n\nasync def long_task_with_cleanup(task_id: int):\n    async def task():\n        try:\n            cancellation_log.append(f\"Task {task_id} started\")\n            awai"]
[104.475677, "o", "cat > /tmp/test_run.py << 'EOF'\r\n\u001b[?2004l\r"]
[104.475712, "i", "t asyncio.sleep(10)  # Long sleep\n            cancellation_log.append(f\"Task {task_id} completed normally\")\n        except asyncio.CancelledError:\n            cancellation_log.append(f\"Task {task_id} was cancelled\")\n            raise  # Re-raise to propagate cancellation\n        finally:\n            cancellation_log.append(f\"Task {task_id} cleanup executed\")\n    return task\n\nasync def test_cancellation():\n    tasks = [await long_task_with_cleanup(i) for i in range(3)]\n    \n    # Create a task that will be cancelled\n    main_task = asyncio.create_task(run_tasks(tasks, max_concurrent=2))\n    \n    # Let tasks start\n    await asyncio.sleep(0.1)\n    \n    # Cancel the main task (simulating keyboard interrupt)\n    main_task.cancel()\n    \n    try:\n        await main_task\n    except asyncio.CancelledError:\n        cancellation_log.append(\"Main task cancelled\")\n    \n    # Give cleanup time to complete\n    await asyncio.sleep(0.1)\n    \n    for log in cancellation_log:\n        print(f\"  {log}\")\n    \n    # Verify cleanup "]
[104.475863, "o", "\u001b[?2004h> "]
[104.475997, "i", "ran for all started tasks\n    started_tasks = [i for i in range(3) if f\"Task {i} started\" in cancellation_log]\n    for task_id in started_tasks:\n        assert f\"Task {task_id} cleanup executed\" in cancellation_log, f\"Task {task_id} cleanup did not execute!\"\n    \n    print(\"✓ Cancellation test passed\\n\")\n\nasyncio.run(test_cancellation())\n\nprint(\"All tests passed! ✓\")\nEOF\n"]
