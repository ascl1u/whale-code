d: int):\n    async def task():\n        try:\n            cancellation_log.append(f"Task {task_id} started")\n            await asyncio.sleep(10)  # Long sleep\n            cancellation_log.append(f"Task {task_id} completed normally")\n        except asyncio.CancelledError:\n            cancellation_log.append(f"Task {task_id} was cancelled")\n            raise  # Re-raise to propagate cancellation\n        finally:\n            cancellation_log.append(f"Task {task_id} cleanup executed")\n    return task\n\nasync def test_cancellation():\n    tasks = [await long_task_with_cleanup(i) for i in range(3)]\n    \n    # Create a task that will be cancelled\n    main_task = asyncio.create_task(run_tasks(tasks, max_concurrent=2))\n    \n    # Let tasks start\n    await asyncio.sleep(0.1)\n    \n    # Cancel the main task (simulating keyboard interrupt)\n    main_task.cancel()\n    \n    try:\n        await main_task\n    except asyncio.CancelledError:\n        cancellation_log.append("Main task cancelled")\n    \n    # Give cleanup time to complete\n    await asyncio.sleep(0.1)\n    \n    for log in cancellation_log:\n        print(f"  {log}")\n    \n    # Verify cleanup ran for all started tasks\n    started_tasks = [i for i in range(3) if f"Task {i} started" in cancellation_log]\n    for task_id in started_tasks:\n        assert f"Task {task_id} cleanup executed" in cancellation_log, f"Task {task_id} cleanup did not execute!"\n    \n    print("✓ Cancellation test passed\\n")\n\nasyncio.run(test_cancellation())\n\nprint("All tests passed! ✓")\nEOF\n'] min_timeout_sec: 0.2 max_timeout_sec: 180.0
