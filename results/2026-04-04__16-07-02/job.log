_tasks(tasks, max_concurrent=3)\n    \n    print(f"  Max concurrent tasks observed: {max_concurrent_observed}")\n    print(f"  Cleanup ran {len(cleanup_log)} times")\n    assert max_concurrent_observed <= 3, "Should not exceed max_concurrent limit"\n    assert len(cleanup_log) == 10, "All tasks should have cleanup run"\n    print("  ✓ Test passed")\n\nasync def test_cancellation_cleanup():\n    """Test that cleanup runs even when tasks are cancelled."""\n    print("\\nTest 3: Cancellation cleanup")\n    execution_log.clear()\n    cleanup_log.clear()\n    \n    async def long_task(task_id: int):\n        execution_log.append(f"Task {task_id} started")\n        try:\n            await asyncio.sleep(10)  # Long sleep\n            execution_log.append(f"Task {task_id} completed")\n        finally:\n            cleanup_log.append(f"Task {task_id} cleanup")\n    \n    tasks = [lambda tid=i: long_task(tid) for i in range(5)]\n    \n    # Run tasks but cancel after a short time\n    async def run_and_cancel():\n        task = asyncio.create_task(run_tasks(tasks, max_concurrent=3))\n        await asyncio.sleep(0.2)  # Let some tasks start\n        task.cancel()\n        try:\n            await task\n        except asyncio.CancelledError:\n            pass\n    \n    await run_and_cancel()\n    \n    print(f"  Started tasks: {len([e for e in execution_log if \'started\' in e])}")\n    print(f"  Completed tasks: {len([e for e in execution_log if \'completed\' in e])}")\n    print(f"  Cleanup ran {len(cleanup_log)} times")\n    # Cleanup should run for all started tasks\n    assert len(cleanup_log) > 0, "Cleanup should run for started tasks"\n    print("  ✓ Test passed")\n\nasync def test_empty_tasks():\n    """Test with empty task list."""\n    print("\\nTest 4: Empty task list")\n    await run_tasks([], max_concurrent=5)\n    print("  ✓ Test passed")\n\nasync def main():\n    print("Running tests for run_tasks function\\n")\n    print("="*50)\n    \n    await test_basic_execution()\n    await test_concurrency_limit()\n    await test_cancellation_cleanup()\n    await test_empty_tasks()\n    \n    print("\\n" + "="*50)\n    print("All tests passed! ✓")\n\nif __name__ == "__main__":\n    asyncio.run(main())\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
