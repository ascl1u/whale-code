Sending keys: ['cat > /app/run.py << \'EOF\'\nimport asyncio\nfrom typing import Callable, Awaitable\n\n\nasync def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:\n    """Run async tasks with a maximum concurrency limit.\n    \n    Args:\n        tasks: List of callables that return awaitables (async functions)\n        max_concurrent: Maximum number of tasks that can run concurrently\n    \n    This function ensures that cleanup code in tasks runs even when cancelled\n    via keyboard interrupt (Ctrl+C).\n    """\n    if not tasks:\n        return\n    \n    semaphore = asyncio.Semaphore(max_concurrent)\n    \n    async def run_task_with_semaphore(task_func: Callable[[], Awaitable[None]]) -> None:\n        """Wrapper to run a task with semaphore control."""\n        async with semaphore:\n            try:\n                await task_func()\n            except asyncio.CancelledError:\n                # Re-raise to allow proper cancellation propagation\n                # but the task\'s own cleanup code will have run\n                raise\n            except Exception as e:\n                # Log or handle other exceptions as needed\n                # For now, we\'ll just let them be collected by gather\n                raise\n    \n    # Create coroutines for all tasks\n    task_coroutines = [run_task_with_semaphore(task) for task in tasks]\n    \n    # Run all tasks concurrently with the semaphore limiting concurrency\n    # return_exceptions=True ensures all tasks complete even if some fail\n    try:\n        await asyncio.gather(*task_coroutines, return_exceptions=False)\n    except asyncio.CancelledError:\n        # If we receive a cancellation (e.g., from Ctrl+C), we need to\n        # cancel all running tasks but give them time to clean up\n        running_tasks = [t for t in asyncio.all_tasks() if not t.done() and t != asyncio.current_task()]\n        \n        # Cancel all running tasks\n        for task in running_tasks:\n            task.cancel()\n        \n        # Wait for all tasks to complete their cleanup\n        # Use return_exceptions=True to collect any exceptions during cleanup\n        if running_tasks:\n            await asyncio.gather(*running_tasks, return_exceptions=True)\n        \n        # Re-raise the cancellation\n        raise\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
