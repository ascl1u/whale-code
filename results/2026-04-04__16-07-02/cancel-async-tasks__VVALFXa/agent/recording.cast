[353.620275, "o", "assert max_active <= 5\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.620354, "o", "> "]
[353.620559, "o", "print(\"   ✓ Concurrency control works\")\r\n\u001b[?2004l\r"]
[353.620641, "o", "\u001b[?2004h> "]
[353.620784, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[353.620949, "o", "# Test 4: Cleanup on cancellation\r\n\u001b[?2004l\r"]
[353.621079, "o", "\u001b[?2004h> "]
[353.621268, "o", "print(\"\\n4. Testing cleanup on cancellation...\")\r\n\u001b[?2004l\r"]
[353.62135, "o", "\u001b[?2004h> "]
[353.621453, "o", "cleanup_log = []\r\n\u001b[?2004l\r"]
[353.621534, "o", "\u001b[?2004h> "]
[353.621636, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.621667, "o", "> "]
[353.621834, "o", "async def task_with_cleanup(tid):\r\n\u001b[?2004l\r"]
[353.621922, "o", "\u001b[?2004h> "]
[353.621986, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[353.622292, "o", "        cleanup_log.append(f\"start_{tid}\")\r\n\u001b[?2004l\r"]
[353.622374, "o", "\u001b[?2004h> "]
[353.622535, "o", "        await asyncio.sleep(5)\r\n\u001b[?2004l\r"]
[353.622639, "o", "\u001b[?2004h> "]
[353.622799, "o", "    except asyncio.CancelledError:\r\n\u001b[?2004l\r"]
[353.622903, "o", "\u001b[?2004h> "]
[353.623179, "o", "        cleanup_log.append(f\"cleanup_{tid}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.62326, "o", "> "]
[353.623322, "o", "        raise\r\n\u001b[?2004l\r"]
[353.623421, "o", "\u001b[?2004h> "]
[353.623532, "o", "    finally:\r\n\u001b[?2004l\r"]
[353.623642, "o", "\u001b[?2004h> "]
[353.623806, "o", "        cleanup_log.append(f\"finally_{tid}\")\r\n\u001b[?2004l\r"]
[353.623878, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[353.623965, "o", "\u001b[?2004h"]
[353.624008, "o", "> "]
[353.6241, "o", "async def test_cleanup():\r\n\u001b[?2004l\r"]
[353.6242, "o", "\u001b[?2004h> "]
[353.624372, "o", "    task = asyncio.create_task(\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.62448, "o", "> "]
[353.624915, "o", "        run_tasks([lambda i=i: task_with_cleanup(i) for i in range(3)], max_concurrent=3)\r\n\u001b[?2004l\r"]
[353.625001, "o", "\u001b[?2004h> "]
[353.625082, "o", "    )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[353.625229, "o", "    await asyncio.sleep(0.1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[353.625311, "o", "    task.cancel()\r\n\u001b[?2004l\r"]
[353.625394, "o", "\u001b[?2004h> "]
[353.625504, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[353.625624, "o", "        await task\r\n\u001b[?2004l\r"]
[353.625699, "o", "\u001b[?2004h> "]
[353.6259, "o", "    except asyncio.CancelledError:\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.625982, "o", "> "]
[353.626068, "o", "        pass\r\n\u001b[?2004l\r"]
[353.626163, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[353.626217, "o", "asyncio.run(test_cleanup())\r\n\u001b[?2004l\r"]
[353.626291, "o", "\u001b[?2004h> "]
[353.626537, "o", "started = len([x for x in cleanup_log if x.startswith('start_')])\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.626601, "o", "> "]
[353.62688, "o", "cleaned = len([x for x in cleanup_log if x.startswith('cleanup_')])\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.62693, "o", "> "]
[353.627191, "o", "finalized = len([x for x in cleanup_log if x.startswith('finally_')])\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.62726, "o", "> "]
[353.627572, "o", "print(f\"   Started: {started}, Cleaned up: {cleaned}, Finally blocks: {finalized}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.627651, "o", "> "]
[353.627908, "o", "assert cleaned == started, \"All started tasks should run cleanup\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.627985, "o", "> "]
[353.628273, "o", "assert finalized == started, \"All started tasks should run finally blocks\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.628353, "o", "> "]
[353.628537, "o", "print(\"   ✓ Cleanup on cancellation works\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.628567, "o", "> \r\n\u001b[?2004l\r"]
[353.628656, "o", "\u001b[?2004h> "]
[353.628869, "o", "print(\"\\n=== All Tests Passed! ===\")\r\n\u001b[?2004l\r"]
[353.628947, "o", "\u001b[?2004h> "]
[353.62917, "o", "print(\"\\nThe run_tasks function is ready to use:\")\r\n\u001b[?2004l\r"]
[353.629255, "o", "\u001b[?2004h"]
[353.629335, "o", "> "]
[353.629452, "o", "print(\"  from run import run_tasks\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[353.629692, "o", "print(\"  await run_tasks(task_list, max_concurrent=N)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[353.629766, "o", "> "]
