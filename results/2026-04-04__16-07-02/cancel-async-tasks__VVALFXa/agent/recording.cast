[434.118706, "o", "python3 -c \"import sys; sys.path.insert(0, '/app'); from run import run_tasks; print('✓ Import works: from run import run_tasks'); print(f'✓ Function signature: {run_tasks.__name__}'); import inspect; print(f'✓ Is coroutine function: {inspect.iscoroutinefunction(run_tasks)}')\"\r\n\u001b[?2004l\r"]
