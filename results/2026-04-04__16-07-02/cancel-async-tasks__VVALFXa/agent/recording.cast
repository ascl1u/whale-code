[66.463038, "i", "cat > /tmp/test_run.py << 'EOF'\nimport asyncio\nimport time\nfrom run import run_tasks\n\n# Test 1: Basic import and functionality\nprint(\"Test 1: Basic import and functionality\")\n\nresults = []\n\nasync def task1():\n    results.append(\"task1_start\")\n    await asyncio.sleep(0.1)\n    results.append(\"task1_end\")\n\nasync def task2():\n    results.append(\"task2_start\")\n    await asyncio.sleep(0.1)\n    results.append(\"task2_end\")\n\nasync def test_basic():\n    await run_tasks([task1, task2], max_concurrent=2)\n    print(f\"Results: {results}\")\n    assert \"task1_start\" in results\n    assert \"task1_end\" in results\n    assert \"task2_start\" in results\n    assert \"task2_end\" in results\n    print(\"✓ Basic test passed\")\n\nasyncio.run(test_basic())\n\n# Test 2: Concurrency limiting\nprint(\"\\nTest 2: Concurrency limiting\")\n\nconcurrent_count = 0\nmax_concurrent_seen = 0\n\nasync def concurrent_task():\n    global concurrent_count, max_concurrent_seen\n    concurrent_count += 1\n    max_concurrent_seen = max(max_concurrent_seen, concurrent_count)"]
[66.463202, "i", "\n    await asyncio.sleep(0.1)\n    concurrent_count -= 1\n\nasync def test_concurrency():\n    global max_concurrent_seen\n    max_concurrent_seen = 0\n    tasks = [concurrent_task for _ in range(10)]\n    await run_tasks(tasks, max_concurrent=3)\n    print(f\"Max concurrent tasks seen: {max_concurrent_seen}\")\n    assert max_concurrent_seen <= 3, f\"Expected max 3 concurrent, got {max_concurrent_seen}\"\n    print(\"✓ Concurrency limiting test passed\")\n\nasyncio.run(test_concurrency())\n\n# Test 3: Cleanup on cancellation\nprint(\"\\nTest 3: Cleanup on cancellation\")\n\ncleanup_ran = []\n\nasync def task_with_cleanup(task_id):\n    try:\n        cleanup_ran.append(f\"task{task_id}_start\")\n        await asyncio.sleep(1)  # Long running\n        cleanup_ran.append(f\"task{task_id}_complete\")\n    except asyncio.CancelledError:\n        cleanup_ran.append(f\"task{task_id}_cleanup\")\n        raise\n\nasync def test_cleanup():\n    global cleanup_ran\n    cleanup_ran = []\n    \n    async def run_and_cancel():\n        tasks = [lambda tid=i: task_wit"]
[66.463297, "i", "h_cleanup(tid) for i in range(3)]\n        await run_tasks(tasks, max_concurrent=3)\n    \n    task = asyncio.create_task(run_and_cancel())\n    await asyncio.sleep(0.2)  # Let tasks start\n    task.cancel()\n    \n    try:\n        await task\n    except asyncio.CancelledError:\n        pass\n    \n    print(f\"Cleanup results: {cleanup_ran}\")\n    # Check that cleanup ran for started tasks\n    for i in range(3):\n        if f\"task{i}_start\" in cleanup_ran:\n            assert f\"task{i}_cleanup\" in cleanup_ran, f\"Cleanup didn't run for task{i}\"\n    print(\"✓ Cleanup test passed\")\n\nasyncio.run(test_cleanup())\n\nprint(\"\\n✓ All tests passed!\")\nEOF\n"]
