[353.609986, "i", "cat > /tmp/final_test.py << 'EOF'\nimport asyncio\nimport sys\nsys.path.insert(0, '/app')\nfrom run import run_tasks\n\nprint(\"=== Final Comprehensive Test ===\")\n\n# Test 1: Import works\nprint(\"\\n1. Testing import...\")\nprint(\"   ✓ Import successful\")\n\n# Test 2: Basic functionality\nprint(\"\\n2. Testing basic functionality...\")\nresults = []\n\nasync def basic_task(name):\n    results.append(f\"{name}_start\")\n    await asyncio.sleep(0.05)\n    results.append(f\"{name}_end\")\n\nasync def test_basic():\n    await run_tasks(\n        [lambda: basic_task(\"A\"), lambda: basic_task(\"B\"), lambda: basic_task(\"C\")],\n        max_concurrent=2\n    )\n\nasyncio.run(test_basic())\nprint(f\"   Results: {len([r for r in results if 'end' in r])}/3 tasks completed\")\nprint(\"   ✓ Basic functionality works\")\n\n# Test 3: Concurrency control\nprint(\"\\n3. Testing concurrency control...\")\nactive = 0\nmax_active = 0\n\nasync def concurrent_task():\n    global active, max_active\n    active += 1\n    max_active = max(max_active, active)\n    await asyncio.sleep(0.05"]
[353.610145, "i", ")\n    active -= 1\n\nasync def test_concurrency():\n    global max_active\n    max_active = 0\n    await run_tasks([concurrent_task for _ in range(20)], max_concurrent=5)\n\nasyncio.run(test_concurrency())\nprint(f\"   Max concurrent: {max_active} (limit was 5)\")\nassert max_active <= 5\nprint(\"   ✓ Concurrency control works\")\n\n# Test 4: Cleanup on cancellation\nprint(\"\\n4. Testing cleanup on cancellation...\")\ncleanup_log = []\n\nasync def task_with_cleanup(tid):\n    try:\n        cleanup_log.append(f\"start_{tid}\")\n        await asyncio.sleep(5)\n    except asyncio.CancelledError:\n        cleanup_log.append(f\"cleanup_{tid}\")\n        raise\n    finally:\n        cleanup_log.append(f\"finally_{tid}\")\n\nasync def test_cleanup():\n    task = asyncio.create_task(\n        run_tasks([lambda i=i: task_with_cleanup(i) for i in range(3)], max_concurrent=3)\n    )\n    await asyncio.sleep(0.1)\n    task.cancel()\n    try:\n        await task\n    except asyncio.CancelledError:\n        pass\n\nasyncio.run(test_cleanup())\nstarted = len([x for x in "]
[353.610232, "i", "cleanup_log if x.startswith('start_')])\ncleaned = len([x for x in cleanup_log if x.startswith('cleanup_')])\nfinalized = len([x for x in cleanup_log if x.startswith('finally_')])\nprint(f\"   Started: {started}, Cleaned up: {cleaned}, Finally blocks: {finalized}\")\nassert cleaned == started, \"All started tasks should run cleanup\"\nassert finalized == started, \"All started tasks should run finally blocks\"\nprint(\"   ✓ Cleanup on cancellation works\")\n\nprint(\"\\n=== All Tests Passed! ===\")\nprint(\"\\nThe run_tasks function is ready to use:\")\nprint(\"  from run import run_tasks\")\nprint(\"  await run_tasks(task_list, max_concurrent=N)\")\nEOF\n"]
