[293.359533, "i", "cat > /tmp/test_finally3.py << 'EOF'\nimport asyncio\nimport sys\nsys.path.insert(0, '/app')\nfrom run import run_tasks\n\nprint(\"Test: Finally with async cleanup\")\n\nlog = []\n\nasync def task_with_async_cleanup(task_id):\n    try:\n        log.append(f\"task{task_id}_start\")\n        await asyncio.sleep(10)\n        log.append(f\"task{task_id}_done\")\n    except asyncio.CancelledError:\n        log.append(f\"task{task_id}_cleanup\")\n        await asyncio.sleep(0.01)  # Async cleanup work\n        print(f\"Cleanup for task{task_id} executed\")\n        raise\n    finally:\n        log.append(f\"task{task_id}_finally\")\n        print(f\"Finally block for task{task_id} executed\")\n\nasync def test():\n    task = asyncio.create_task(\n        run_tasks([lambda: task_with_async_cleanup(0)], max_concurrent=1)\n    )\n    await asyncio.sleep(0.1)\n    task.cancel()\n    \n    try:\n        await task\n    except asyncio.CancelledError:\n        print(\"Main task cancelled\")\n    \n    print(f\"\\nLog: {log}\")\n    print(f\"Cleanup in log: {'task0_cleanup' in l"]
[293.359693, "i", "og}\")\n    print(f\"Finally in log: {'task0_finally' in log}\")\n\nasyncio.run(test())\nEOF\n"]
