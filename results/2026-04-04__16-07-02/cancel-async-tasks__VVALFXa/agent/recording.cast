[104.387993, "i", "cat > /tmp/test_keyboard_interrupt.py << 'EOF'\nimport asyncio\nimport signal\nimport sys\nsys.path.insert(0, '/app')\nfrom run import run_tasks\n\nprint(\"Test: KeyboardInterrupt handling with cleanup\")\n\ncleanup_log = []\n\nasync def task_with_cleanup(task_id):\n    try:\n        cleanup_log.append(f\"task{task_id}_start\")\n        await asyncio.sleep(10)  # Long running task\n        cleanup_log.append(f\"task{task_id}_complete\")\n    except asyncio.CancelledError:\n        cleanup_log.append(f\"task{task_id}_cleanup\")\n        await asyncio.sleep(0.01)  # Simulate cleanup work\n        raise\n    finally:\n        cleanup_log.append(f\"task{task_id}_finally\")\n\nasync def main():\n    tasks = [lambda tid=i: task_with_cleanup(tid) for i in range(5)]\n    try:\n        await run_tasks(tasks, max_concurrent=3)\n    except KeyboardInterrupt:\n        print(\"KeyboardInterrupt caught in main\")\n        raise\n\nasync def test_with_interrupt():\n    main_task = asyncio.create_task(main())\n    await asyncio.sleep(0.3)  # Let tasks start\n    \n    # "]
[104.388158, "i", "Simulate KeyboardInterrupt by cancelling\n    main_task.cancel()\n    \n    try:\n        await main_task\n    except asyncio.CancelledError:\n        print(\"Task was cancelled\")\n    \n    print(f\"\\nCleanup log: {cleanup_log}\")\n    \n    # Verify cleanup ran for all started tasks\n    started_tasks = [i for i in range(5) if f\"task{i}_start\" in cleanup_log]\n    print(f\"Started tasks: {started_tasks}\")\n    \n    for task_id in started_tasks:\n        assert f\"task{task_id}_cleanup\" in cleanup_log, f\"Cleanup didn't run for task{task_id}\"\n        assert f\"task{task_id}_finally\" in cleanup_log, f\"Finally block didn't run for task{task_id}\"\n    \n    print(f\"✓ Cleanup ran for all {len(started_tasks)} started tasks\")\n    print(\"✓ KeyboardInterrupt handling test passed\")\n\nasyncio.run(test_with_interrupt())\nEOF\n"]
