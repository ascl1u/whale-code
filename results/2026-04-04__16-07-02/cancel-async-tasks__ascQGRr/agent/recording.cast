[161.653925, "i", "python3 << 'PYEOF'\nimport asyncio\nimport sys\nsys.path.insert(0, '/app')\nfrom run import run_tasks\n\nprint(\"Final Verification Test\")\nprint(\"=\" * 50)\n\n# Test 1: Import and basic functionality\nprint(\"\\n1. Testing import and basic execution...\")\nexecuted = []\n\nasync def simple_task(n):\n    executed.append(n)\n    await asyncio.sleep(0.05)\n\nasync def test1():\n    tasks = [lambda i=i: simple_task(i) for i in range(5)]\n    await run_tasks(tasks, max_concurrent=2)\n    assert len(executed) == 5\n    print(f\"   ✓ All {len(executed)} tasks executed\")\n\nasyncio.run(test1())\n\n# Test 2: Cleanup on cancellation\nprint(\"\\n2. Testing cleanup on cancellation...\")\ncleanup_count = 0\n\nasync def task_with_cleanup():\n    try:\n        await asyncio.sleep(10)\n    finally:\n        global cleanup_count\n        cleanup_count += 1\n\nasync def test2():\n    global cleanup_count\n    cleanup_count = 0\n    tasks = [task_with_cleanup for _ in range(3)]\n    task = asyncio.create_task(run_tasks(tasks, max_concurrent=2))\n    await asyncio.sleep(0.1)"]
[161.654131, "i", "\n    task.cancel()\n    try:\n        await task\n    except asyncio.CancelledError:\n        pass\n    await asyncio.sleep(0.1)\n    print(f\"   ✓ Cleanup ran for {cleanup_count} tasks\")\n\nasyncio.run(test2())\n\nprint(\"\\n\" + \"=\" * 50)\nprint(\"✅ All verification tests passed!\")\nprint(\"\\nFunction is ready to use:\")\nprint(\"  from run import run_tasks\")\nPYEOF\n"]
