[62.126114, "i", "cat > /tmp/test_interrupt.py << 'EOF'\nimport asyncio\nimport signal\nimport sys\nsys.path.insert(0, '/app')\nfrom run import run_tasks\n\nprint(\"Test: Cleanup on cancellation\")\ncleanup_ran = []\nstarted = []\n\nasync def task_with_cleanup(task_id):\n    try:\n        started.append(task_id)\n        await asyncio.sleep(10)  # Long running task\n    except asyncio.CancelledError:\n        print(f\"Task {task_id} cancelled, running cleanup...\")\n        raise\n    finally:\n        cleanup_ran.append(task_id)\n        print(f\"Task {task_id} cleanup completed\")\n\nasync def test_interrupt():\n    global cleanup_ran, started\n    cleanup_ran = []\n    started = []\n    \n    # Create tasks\n    tasks = [lambda i=i: task_with_cleanup(i) for i in range(5)]\n    \n    # Start tasks and cancel after a short delay\n    task = asyncio.create_task(run_tasks(tasks, max_concurrent=2))\n    await asyncio.sleep(0.3)  # Let some tasks start\n    \n    # Cancel the task\n    task.cancel()\n    \n    try:\n        await task\n    except asyncio.CancelledError:\n   "]
[62.126204, "i", "     print(\"run_tasks was cancelled\")\n    \n    # Give time for cleanup\n    await asyncio.sleep(0.1)\n    \n    print(f\"\\nStarted: {len(started)} tasks\")\n    print(f\"Cleanup ran for: {len(cleanup_ran)} tasks\")\n    print(f\"✓ Cleanup code executed for all started tasks\")\n\nasyncio.run(test_interrupt())\nEOF\n"]
