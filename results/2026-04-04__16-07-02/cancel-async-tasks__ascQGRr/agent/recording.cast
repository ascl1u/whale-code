[26.446407, "i", "cat > /tmp/test_run.py << 'EOF'\nimport asyncio\nimport time\nfrom run import run_tasks\n\n# Test 1: Basic functionality\nprint(\"Test 1: Basic functionality\")\nexecuted = []\n\nasync def task1():\n    executed.append(1)\n    await asyncio.sleep(0.1)\n\nasync def task2():\n    executed.append(2)\n    await asyncio.sleep(0.1)\n\nasync def task3():\n    executed.append(3)\n    await asyncio.sleep(0.1)\n\nasync def test_basic():\n    await run_tasks([task1, task2, task3], max_concurrent=2)\n    assert len(executed) == 3\n    print(f\"✓ All 3 tasks executed: {executed}\")\n\nasyncio.run(test_basic())\n\n# Test 2: Concurrency limiting\nprint(\"\\nTest 2: Concurrency limiting\")\nconcurrent_count = 0\nmax_concurrent_seen = 0\n\nasync def concurrent_task():\n    global concurrent_count, max_concurrent_seen\n    concurrent_count += 1\n    max_concurrent_seen = max(max_concurrent_seen, concurrent_count)\n    await asyncio.sleep(0.2)\n    concurrent_count -= 1\n\nasync def test_concurrency():\n    global max_concurrent_seen\n    max_concurrent_seen = 0\n    tasks ="]
[26.446605, "i", " [concurrent_task for _ in range(10)]\n    await run_tasks(tasks, max_concurrent=3)\n    assert max_concurrent_seen <= 3\n    print(f\"✓ Max concurrent tasks was {max_concurrent_seen} (limit: 3)\")\n\nasyncio.run(test_concurrency())\n\n# Test 3: Cleanup code runs\nprint(\"\\nTest 3: Cleanup code runs\")\ncleanup_ran = []\n\nasync def task_with_cleanup(task_id):\n    try:\n        await asyncio.sleep(0.1)\n    finally:\n        cleanup_ran.append(task_id)\n\nasync def test_cleanup():\n    global cleanup_ran\n    cleanup_ran = []\n    tasks = [lambda i=i: task_with_cleanup(i) for i in range(5)]\n    await run_tasks(tasks, max_concurrent=2)\n    assert len(cleanup_ran) == 5\n    print(f\"✓ Cleanup ran for all {len(cleanup_ran)} tasks\")\n\nasyncio.run(test_cleanup())\n\nprint(\"\\n✅ All tests passed!\")\nEOF\n"]
