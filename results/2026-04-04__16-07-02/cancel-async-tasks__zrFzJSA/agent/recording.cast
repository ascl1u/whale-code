[52.045869, "o", "async def test_basic_execution():\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.04597, "o", "> "]
[52.046174, "o", "    \"\"\"Test basic task execution.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.046275, "o", "> "]
[52.046459, "o", "    print(\"Test 1: Basic execution\")\r\n\u001b[?2004l\r"]
[52.046595, "o", "\u001b[?2004h> "]
[52.046753, "o", "    execution_log.clear()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.046901, "o", "    cleanup_log.clear()\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.047003, "o", "> "]
