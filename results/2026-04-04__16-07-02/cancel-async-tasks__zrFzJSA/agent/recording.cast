[52.04011, "i", "      try:\n            await task\n        except asyncio.CancelledError:\n            pass\n    \n    await run_and_cancel()\n    \n    print(f\"  Started tasks: {len([e for e in execution_log if 'started' in e])}\")\n    print(f\"  Completed tasks: {len([e for e in execution_log if 'completed' in e])}\")\n    print(f\"  Cleanup ran {len(cleanup_log)} times\")\n    # Cleanup should run for all started tasks\n    assert len(cleanup_log) > 0, \"Cleanup should run for started tasks\"\n    print(\"  ✓ Test passed\")\n\nasync def test_empty_tasks():\n    \"\"\"Test with empty task list.\"\"\"\n    print(\"\\nTest 4: Empty task list\")\n    await run_tasks([], max_concurrent=5)\n    print(\"  ✓ Test passed\")\n\nasync def main():\n    print(\"Running tests for run_tasks function\\n\")\n    print(\"=\"*50)\n    \n    await test_basic_execution()\n    await test_concurrency_limit()\n    await test_cancellation_cleanup()\n    await test_empty_tasks()\n    \n    print(\"\\n\" + \"=\"*50)\n    print(\"All tests passed! ✓\")\n\nif __name__ == \"__main__\":\n    asyncio.run(main()"]
