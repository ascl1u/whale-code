[52.058949, "o", ">     "]
[52.059052, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.059223, "o", "    async def long_task(task_id: int):\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.0593, "o", "> "]
[52.05963, "o", "        execution_log.append(f\"Task {task_id} started\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.059693, "o", "> "]
[52.059781, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.059887, "o", "> "]
