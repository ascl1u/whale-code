[52.057563, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.057742, "o", "async def test_cancellation_cleanup():\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.057826, "o", "> "]
[52.058082, "o", "    \"\"\"Test that cleanup runs even when tasks are cancelled.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.058186, "o", "> "]
