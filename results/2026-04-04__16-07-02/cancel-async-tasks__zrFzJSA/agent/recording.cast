[312.593705, "i", "python3 << 'EOF'\nimport asyncio\nfrom run import run_tasks\n\ncleanup_ran = []\n\nasync def long_task(task_id):\n    try:\n        print(f\"Task {task_id} started\")\n        await asyncio.sleep(10)\n        print(f\"Task {task_id} completed\")\n    finally:\n        cleanup_ran.append(task_id)\n        print(f\"Task {task_id} cleanup executed\")\n\nasync def test_cancellation():\n    tasks = [lambda tid=i: long_task(tid) for i in range(5)]\n    task = asyncio.create_task(run_tasks(tasks, max_concurrent=3))\n    await asyncio.sleep(0.2)  # Let tasks start\n    task.cancel()\n    try:\n        await task\n    except asyncio.CancelledError:\n        print(\"\\nCancellation handled correctly\")\n    print(f\"Cleanup ran for {len(cleanup_ran)} tasks that started\")\n    print(\"✓ Cancellation test passed!\")\n\nasyncio.run(test_cancellation())\nEOF\n"]
