[52.065072, "o", "> "]
[52.065291, "o", "    print(f\"  Cleanup ran {len(cleanup_log)} times\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.065389, "o", "> "]
[52.06558, "o", "    # Cleanup should run for all started tasks\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.065668, "o", "> "]
[52.065994, "o", "    assert len(cleanup_log) > 0, \"Cleanup should run for started tasks\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.066094, "o", "> "]
[52.066201, "o", "    print(\"  ✓ Test passed\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.066299, "o", "> \r\n\u001b[?2004l\r"]
