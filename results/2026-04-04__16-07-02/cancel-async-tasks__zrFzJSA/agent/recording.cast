[52.049481, "o", "async def test_concurrency_limit():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.049703, "o", "    \"\"\"Test that concurrency limit is respected.\"\"\"\r\n\u001b[?2004l\r"]
[52.049783, "o", "\u001b[?2004h> "]
[52.050025, "o", "    print(\"\\nTest 2: Concurrency limit\")\r\n\u001b[?2004l\r"]
[52.050138, "o", "\u001b[?2004h> "]
[52.050218, "o", "    execution_log.clear()\r\n\u001b[?2004l\r"]
[52.0503, "o", "\u001b[?2004h> "]
[52.050463, "o", "    cleanup_log.clear()\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.050557, "o", ">     \r\n\u001b[?2004l\r"]
[52.050626, "o", "\u001b[?2004h> "]
[52.050726, "o", "    start_times = {}\r\n\u001b[?2004l\r"]
[52.05082, "o", "\u001b[?2004h> "]
[52.050984, "o", "    max_concurrent_observed = 0\r\n\u001b[?2004l\r"]
[52.051069, "o", "\u001b[?2004h> "]
[52.051226, "o", "    current_concurrent = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.051303, "o", "> "]
[52.051493, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.051556, "o", "    async def tracked_task(task_id: int):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.051965, "o", "        nonlocal current_concurrent, max_concurrent_observed\r\n\u001b[?2004l\r"]
[52.052056, "o", "\u001b[?2004h> "]
[52.052215, "o", "        current_concurrent += 1\r\n\u001b[?2004l\r"]
[52.052313, "o", "\u001b[?2004h"]
[52.052406, "o", "> "]
[52.052714, "o", "        max_concurrent_observed = max(max_concurrent_observed, current_concurrent)\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.052809, "o", "> "]
[52.053292, "o", "        execution_log.append(f\"Task {task_id} running (concurrent: {current_concurrent})\")\r\n\u001b[?2004l\r"]
[52.05333, "o", "\u001b[?2004h> "]
[52.053447, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.053557, "o", "> "]
[52.053709, "o", "            await asyncio.sleep(0.1)\r\n\u001b[?2004l\r"]
[52.053811, "o", "\u001b[?2004h> "]
[52.053904, "o", "        finally:\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.054006, "o", "> "]
[52.054185, "o", "            current_concurrent -= 1\r\n\u001b[?2004l\r"]
[52.054227, "o", "\u001b[?2004h> "]
[52.054573, "o", "            cleanup_log.append(f\"Task {task_id} cleanup\")\r\n\u001b[?2004l\r"]
[52.054667, "o", "\u001b[?2004h> "]
[52.054755, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.055122, "o", "    tasks = [lambda tid=i: tracked_task(tid) for i in range(10)]\r\n\u001b[?2004l\r"]
[52.055203, "o", "\u001b[?2004h> "]
[52.055452, "o", "    await run_tasks(tasks, max_concurrent=3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.055628, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.056069, "o", "    print(f\"  Max concurrent tasks observed: {max_concurrent_observed}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.056336, "o", "    print(f\"  Cleanup ran {len(cleanup_log)} times\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.056448, "o", "> "]
[52.056777, "o", "    assert max_concurrent_observed <= 3, \"Should not exceed max_concurrent limit\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.056899, "o", "> "]
