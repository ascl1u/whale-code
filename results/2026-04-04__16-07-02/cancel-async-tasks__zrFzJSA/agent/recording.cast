[52.060161, "o", "> "]
[52.060426, "o", "            execution_log.append(f\"Task {task_id} completed\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.060514, "o", "> "]
[52.060646, "o", "        finally:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.060911, "o", "            cleanup_log.append(f\"Task {task_id} cleanup\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.061023, "o", ">     \r\n\u001b[?2004l\r"]
[52.061126, "o", "\u001b[?2004h> "]
[52.06135, "o", "    tasks = [lambda tid=i: long_task(tid) for i in range(5)]\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.061452, "o", ">     \r\n\u001b[?2004l\r"]
[52.061578, "o", "\u001b[?2004h> "]
[52.061692, "o", "    # Run tasks but cancel after a short time\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.061732, "o", "> "]
[52.061902, "o", "    async def run_and_cancel():\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.061988, "o", "> "]
[52.062272, "o", "        task = asyncio.create_task(run_tasks(tasks, max_concurrent=3))\r\n\u001b[?2004l\r"]
[52.062383, "o", "\u001b[?2004h> "]
[52.062678, "o", "        await asyncio.sleep(0.2)  # Let some tasks start\r\n\u001b[?2004l\r"]
[52.062818, "o", "\u001b[?2004h> "]
[52.062932, "o", "        task.cancel()\r\n\u001b[?2004l\r"]
[52.063022, "o", "\u001b[?2004h> "]
[52.06317, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.0633, "o", "            await task\r\n\u001b[?2004l\r"]
[52.063401, "o", "\u001b[?2004h> "]
[52.063559, "o", "        except asyncio.CancelledError:\r\n\u001b[?2004l\r"]
[52.063686, "o", "\u001b[?2004h> "]
[52.063762, "o", "            pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.063864, "o", "    \r\n\u001b[?2004l\r"]
[52.063908, "o", "\u001b[?2004h> "]
[52.063938, "o", "    await run_and_cancel()\r\n\u001b[?2004l\r"]
[52.063986, "o", "\u001b[?2004h"]
[52.064035, "o", "> "]
[52.064119, "o", "    \r\n\u001b[?2004l\r"]
[52.064202, "o", "\u001b[?2004h> "]
[52.064511, "o", "    print(f\"  Started tasks: {len([e for e in execution_log if 'started' in e])}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.064639, "o", "> "]
