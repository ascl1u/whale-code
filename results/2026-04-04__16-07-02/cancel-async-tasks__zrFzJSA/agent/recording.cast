[293.439697, "i", "python3 << 'EOF'\nimport asyncio\nfrom run import run_tasks\n\ncleanup_ran = []\n\nasync def task_with_cleanup(task_id):\n    try:\n        print(f\"Task {task_id} started\")\n        await asyncio.sleep(0.1)\n        print(f\"Task {task_id} completed\")\n    finally:\n        cleanup_ran.append(task_id)\n        print(f\"Task {task_id} cleanup executed\")\n\nasync def main():\n    tasks = [lambda tid=i: task_with_cleanup(tid) for i in range(5)]\n    await run_tasks(tasks, max_concurrent=2)\n    print(f\"\\nAll {len(cleanup_ran)} cleanups ran successfully\")\n    assert len(cleanup_ran) == 5, \"All cleanups should have run\"\n    print(\"✓ Validation successful!\")\n\nasyncio.run(main())\nEOF\n"]
