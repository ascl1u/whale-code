[52.039646, "i", "cat > /app/test_run.py << 'EOF'\nimport asyncio\nimport time\nfrom run import run_tasks\n\n# Track execution for testing\nexecution_log = []\ncleanup_log = []\n\nasync def create_task(task_id: int, duration: float):\n    \"\"\"Create a test task that logs execution and cleanup.\"\"\"\n    async def task():\n        execution_log.append(f\"Task {task_id} started\")\n        try:\n            await asyncio.sleep(duration)\n            execution_log.append(f\"Task {task_id} completed\")\n        finally:\n            # This cleanup code should run even on cancellation\n            cleanup_log.append(f\"Task {task_id} cleanup\")\n    return task\n\nasync def test_basic_execution():\n    \"\"\"Test basic task execution.\"\"\"\n    print(\"Test 1: Basic execution\")\n    execution_log.clear()\n    cleanup_log.clear()\n    \n    tasks = [await create_task(i, 0.1) for i in range(5)]\n    await run_tasks(tasks, max_concurrent=2)\n    \n    print(f\"  Executed {len(execution_log)} log entries\")\n    print(f\"  Cleanup ran {len(cleanup_log)} times\")\n    assert len(cleanup"]
[52.039793, "i", "_log) == 5, \"All tasks should have cleanup run\"\n    print(\"  ✓ Test passed\")\n\nasync def test_concurrency_limit():\n    \"\"\"Test that concurrency limit is respected.\"\"\"\n    print(\"\\nTest 2: Concurrency limit\")\n    execution_log.clear()\n    cleanup_log.clear()\n    \n    start_times = {}\n    max_concurrent_observed = 0\n    current_concurrent = 0\n    \n    async def tracked_task(task_id: int):\n        nonlocal current_concurrent, max_concurrent_observed\n        current_concurrent += 1\n        max_concurrent_observed = max(max_concurrent_observed, current_concurrent)\n        execution_log.append(f\"Task {task_id} running (concurrent: {current_concurrent})\")\n        try:\n            await asyncio.sleep(0.1)\n        finally:\n            current_concurrent -= 1\n            cleanup_log.append(f\"Task {task_id} cleanup\")\n    \n    tasks = [lambda tid=i: tracked_task(tid) for i in range(10)]\n    await run_tasks(tasks, max_concurrent=3)\n    \n    print(f\"  Max concurrent tasks observed: {max_concurrent_observed}\")\n    print(f\""]
[52.039882, "i", "  Cleanup ran {len(cleanup_log)} times\")\n    assert max_concurrent_observed <= 3, \"Should not exceed max_concurrent limit\"\n    assert len(cleanup_log) == 10, \"All tasks should have cleanup run\"\n    print(\"  ✓ Test passed\")\n\nasync def test_cancellation_cleanup():\n    \"\"\"Test that cleanup runs even when tasks are cancelled.\"\"\"\n    print(\"\\nTest 3: Cancellation cleanup\")\n    execution_log.clear()\n    cleanup_log.clear()\n    \n    async def long_task(task_id: int):\n        execution_log.append(f\"Task {task_id} started\")\n        try:\n            await asyncio.sleep(10)  # Long sleep\n            execution_log.append(f\"Task {task_id} completed\")\n        finally:\n            cleanup_log.append(f\"Task {task_id} cleanup\")\n    \n    tasks = [lambda tid=i: long_task(tid) for i in range(5)]\n    \n    # Run tasks but cancel after a short time\n    async def run_and_cancel():\n        task = asyncio.create_task(run_tasks(tasks, max_concurrent=3))\n        await asyncio.sleep(0.2)  # Let some tasks start\n        task.cancel()\n  "]
