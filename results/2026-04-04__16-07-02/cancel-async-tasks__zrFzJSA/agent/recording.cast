[52.043301, "o", "> "]
[52.043438, "o", "    async def task():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[52.043725, "o", "        execution_log.append(f\"Task {task_id} started\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[52.043855, "o", ">         try:\r\n\u001b[?2004l\r"]
