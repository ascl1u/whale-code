[369.427296, "o", "def read_books_file(filename):\r\n\u001b[?2004l\r"]
[369.42738, "o", "\u001b[?2004h> "]
[369.428036, "o", "    \"\"\"Read books file and return list of book records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.42812, "o", "> "]
