[369.436309, "o", "def read_transactions_file(filename):\r\n\u001b[?2004l\r"]
[369.436379, "o", "\u001b[?2004h> "]
[369.436795, "o", "    \"\"\"Read transactions file and return list of transaction records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.436884, "o", "> "]
[369.436985, "o", "    transactions = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.437096, "o", "> "]
[369.4372, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[369.437301, "o", "\u001b[?2004h> "]
[369.437416, "o", "        while True:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.437476, "o", "> "]
[369.437679, "o", "            record = f.read(22)  # 4 + 10 + 4 + 4\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.43779, "o", "> "]
[369.437944, "o", "            if not record or len(record) < 22:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.438033, "o", "> "]
[369.43809, "o", "                break\r\n\u001b[?2004l\r"]
[369.438208, "o", "\u001b[?2004h> "]
[369.438284, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.438538, "o", "            trans_book = record[0:4].decode('ascii')\r\n\u001b[?2004l\r"]
[369.43856, "o", "\u001b[?2004h> "]
[369.438864, "o", "            trans_amount = int(record[4:14].decode('ascii'))\r\n\u001b[?2004l\r"]
[369.43893, "o", "\u001b[?2004h> "]
[369.439217, "o", "            trans_seller = record[14:18].decode('ascii')\r\n\u001b[?2004l\r"]
[369.439245, "o", "\u001b[?2004h"]
[369.439298, "o", "> "]
[369.439554, "o", "            trans_buyer = record[18:22].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.439594, "o", "> "]
[369.439687, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[369.439781, "o", "> "]
[369.439912, "o", "            transactions.append({\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.439953, "o", "> "]
[369.440154, "o", "                'book': trans_book,\r\n\u001b[?2004l\r"]
[369.440191, "o", "\u001b[?2004h> "]
[369.465304, "o", "                'amount': trans_amount,\r\n\u001b[?2004l\r\u001b[?2004h>                 'seller': trans_seller,\r\n\u001b[?2004l\r\u001b[?2004h>                 'buyer': trans_buyer\r\n\u001b[?2004l\r\u001b[?2004h>             })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     return transactions\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_transaction(transaction, accounts, books):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Validate the transaction.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     buyer_found = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.465407, "o", "    seller_found = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.465521, "o", "    book_found = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.465626, "o", "> "]
[369.465691, "o", "    valid_owner = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.465748, "o", "    \r\n\u001b[?2004l\r"]
[369.465848, "o", "\u001b[?2004h> "]
[369.46603, "o", "    # Check if buyer and seller exist\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.466077, "o", "> "]
[369.466244, "o", "    for account in accounts:\r\n\u001b[?2004l\r"]
[369.466353, "o", "\u001b[?2004h> "]
[369.466538, "o", "        if account['id'] == transaction['buyer_id']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.466618, "o", "> "]
[369.46672, "o", "            buyer_found = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.466767, "o", "> "]
[369.467023, "o", "        if account['id'] == transaction['seller_id']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.467115, "o", "> "]
[369.467197, "o", "            seller_found = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.467305, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.46758, "o", "    # Check if book exists and is owned by seller\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.467618, "o", "> "]
[369.467743, "o", "    for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.467814, "o", "> "]
[369.468011, "o", "        if book['id'] == transaction['book_id']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.468088, "o", "> "]
[369.468182, "o", "            book_found = True\r\n\u001b[?2004l\r"]
[369.468279, "o", "\u001b[?2004h> "]
[369.46849, "o", "            if book['owner'] == transaction['seller_id']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.468568, "o", "> "]
[369.468691, "o", "                valid_owner = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.468818, "o", "> "]
[369.468894, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.469143, "o", "    return buyer_found and seller_found and book_found and valid_owner\r\n\u001b[?2004l\r"]
[369.469206, "o", "\u001b[?2004h"]
[369.469237, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.469432, "o", "def write_accounts_file(filename, accounts):\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.469511, "o", "> "]
[369.469671, "o", "    \"\"\"Write accounts to file.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.469746, "o", "> "]
[369.469898, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.469947, "o", "> "]
[369.470119, "o", "        for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.470279, "o", "            record = (\r\n\u001b[?2004l\r"]
[369.470368, "o", "\u001b[?2004h> "]
[369.470586, "o", "                account['id'].encode('ascii') +\r\n\u001b[?2004l\r"]
[369.470692, "o", "\u001b[?2004h> "]
[369.470884, "o", "                account['name'].encode('ascii') +\r\n\u001b[?2004l\r"]
[369.470977, "o", "\u001b[?2004h> "]
[369.471189, "o", "                f\"{account['balance']:010d}\".encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.471266, "o", "> "]
[369.471298, "o", "            )\r\n\u001b[?2004l\r"]
[369.471378, "o", "\u001b[?2004h> "]
[369.471485, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.471595, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[369.471678, "o", "> "]
[369.471781, "o", "def write_books_file(filename, books):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.471903, "o", "    \"\"\"Write books to file.\"\"\"\r\n\u001b[?2004l\r"]
[369.471981, "o", "\u001b[?2004h> "]
[369.472098, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.472166, "o", "> "]
[369.472271, "o", "        for book in books:\r\n\u001b[?2004l\r"]
[369.472301, "o", "\u001b[?2004h"]
[369.47236, "o", "> "]
[369.472445, "o", "            record = (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.472683, "o", "                book['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.472729, "o", "> "]
[369.472932, "o", "                book['title'].encode('ascii') +\r\n\u001b[?2004l\r"]
[369.472958, "o", "\u001b[?2004h"]
[369.473057, "o", "> "]
[369.473197, "o", "                book['owner'].encode('ascii')\r\n\u001b[?2004l\r"]
[369.473315, "o", "\u001b[?2004h> "]
[369.473475, "o", "            )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.473572, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[369.473659, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[369.473892, "o", "def append_transaction_file(filename, transaction):\r\n\u001b[?2004l\r"]
[369.473964, "o", "\u001b[?2004h"]
[369.474026, "o", "> "]
[369.47408, "o", "    \"\"\"Append transaction to file.\"\"\""]
[369.474129, "o", "\r\n\u001b[?2004l\r"]
[369.474209, "o", "\u001b[?2004h> "]
[369.4744, "o", "    with open(filename, 'ab') as f:\r\n\u001b[?2004l\r"]
[369.474482, "o", "\u001b[?2004h"]
[369.474559, "o", ">         record = (\r\n\u001b[?2004l\r"]
[369.474653, "o", "\u001b[?2004h> "]
[369.474805, "o", "            transaction['book_id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.47487, "o", "> "]
[369.4751, "o", "            f\"{transaction['amount']:010d}\".encode('ascii') +\r\n\u001b[?2004l\r"]
[369.475162, "o", "\u001b[?2004h"]
[369.475223, "o", "> "]
[369.47538, "o", "            transaction['seller_id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.475425, "o", "> "]
[369.475648, "o", "            transaction['buyer_id'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.475718, "o", "> "]
[369.475775, "o", "        )\r\n\u001b[?2004l\r"]
[369.475885, "o", "\u001b[?2004h> "]
[369.475965, "o", "        f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[369.476026, "o", "\u001b[?2004h> "]
[369.476225, "o", "def process_transaction(transaction, accounts, books):\r\n\u001b[?2004l\r"]
[369.476291, "o", "\u001b[?2004h> "]
[369.476556, "o", "    \"\"\"Process the transaction by updating accounts and books.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.476618, "o", "> "]
[369.476739, "o", "    # Update account balances\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.47683, "o", "> "]
[369.47695, "o", "    for account in accounts:\r\n\u001b[?2004l\r"]
[369.477026, "o", "\u001b[?2004h> "]
[369.47719, "o", "        if account['id'] == transaction['buyer_id']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.47722, "o", "> "]
[369.477474, "o", "            account['balance'] -= transaction['amount']\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.477518, "o", "> "]
[369.47775, "o", "        if account['id'] == transaction['seller_id']:\r\n\u001b[?2004l\r"]
[369.477776, "o", "\u001b[?2004h"]
[369.477814, "o", "> "]
[369.478042, "o", "            account['balance'] += transaction['amount']\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.478095, "o", "> "]
[369.478139, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[369.478237, "o", "> "]
[369.478361, "o", "    # Update book ownership\r\n\u001b[?2004l\r"]
[369.478461, "o", "\u001b[?2004h> "]
[369.478567, "o", "    for book in books:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.47878, "o", "        if book['id'] == transaction['book_id']:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.479012, "o", "            book['owner'] = transaction['buyer_id']\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.479111, "o", "> \r\n\u001b[?2004l\r"]
[369.479196, "o", "\u001b[?2004h> def main():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.479371, "o", "    # Read input transaction\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.479622, "o", "    transaction = read_input_file('src/INPUT.DAT')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.47977, "o", "    if transaction is None:\r\n\u001b[?2004l\r"]
[369.479852, "o", "\u001b[?2004h> "]
[369.479961, "o", "        return\r\n\u001b[?2004l\r"]
[369.480037, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.480123, "o", "    # Read data files\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.480211, "o", "> "]
[369.480508, "o", "    accounts = read_accounts_file('data/ACCOUNTS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.480728, "o", "    books = read_books_file('data/BOOKS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.480807, "o", "> "]
[369.480879, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.481004, "o", "    # Validate transaction\r\n\u001b[?2004l\r"]
[369.481088, "o", "\u001b[?2004h> "]
[369.481298, "o", "    if validate_transaction(transaction, accounts, books):\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.481383, "o", "> "]
[369.481504, "o", "        # Process the transaction\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.481617, "o", "> "]
[369.481792, "o", "        process_transaction(transaction, accounts, books)\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.481863, "o", "> "]
[369.481927, "o", "        \r\n\u001b[?2004l\r"]
[369.481966, "o", "\u001b[?2004h> "]
[369.482093, "o", "        # Write updated data files\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.482185, "o", "> "]
[369.482441, "o", "        write_accounts_file('data/ACCOUNTS.DAT', accounts)\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.482498, "o", "> "]
[369.482707, "o", "        write_books_file('data/BOOKS.DAT', books)\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.482787, "o", "> "]
[369.482855, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.483021, "o", "        # Append to transactions file\r\n\u001b[?2004l\r"]
[369.483104, "o", "\u001b[?2004h> "]
[369.483411, "o", "        append_transaction_file('data/TRANSACTIONS.DAT', transaction)\r\n\u001b[?2004l\r"]
