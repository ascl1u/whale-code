[369.428356, "o", "\u001b[?2004h> "]
[369.428685, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[369.428765, "o", "\u001b[?2004h> "]
[369.428925, "o", "        while True:\r\n\u001b[?2004l\r"]
[369.429001, "o", "\u001b[?2004h> "]
[369.429416, "o", "            record = f.read(28)  # 4 + 20 + 4\r\n\u001b[?2004l\r"]
[369.429519, "o", "\u001b[?2004h> "]
[369.430094, "o", "            if not record or len(record) < 28:\r\n\u001b[?2004l\r"]
[369.430249, "o", "\u001b[?2004h> "]
[369.430489, "o", "                break\r\n\u001b[?2004l\r"]
[369.430603, "o", "\u001b[?2004h> "]
[369.430712, "o", "            \r\n\u001b[?2004l\r"]
[369.430858, "o", "\u001b[?2004h> "]
[369.431554, "o", "            book_id = record[0:4].decode('ascii')\r\n\u001b[?2004l\r"]
[369.431714, "o", "\u001b[?2004h> "]
[369.432275, "o", "            book_title = record[4:24].decode('ascii')\r\n\u001b[?2004l\r"]
[369.43236, "o", "\u001b[?2004h> "]
[369.433185, "o", "            book_owner = record[24:28].decode('ascii')\r\n\u001b[?2004l\rI\u001b[?2004h"]
[369.433291, "o", "> "]
[369.43339, "o", "            \r\n\u001b[?2004l\r"]
[369.433519, "o", "\u001b[?2004h> "]
[369.433737, "o", "            books.append({\r\n\u001b[?2004l\r"]
[369.433835, "o", "\u001b[?2004h> "]
[369.43423, "o", "                'id': book_id,\r\n\u001b[?2004l\r"]
[369.434319, "o", "\u001b[?2004h> "]
[369.434667, "o", "                'title': book_title,\r\n\u001b[?2004l\re\u001b[?2004h"]
[369.434756, "o", "> "]
[369.435009, "o", "                'owner': book_owner\r\n\u001b[?2004l\r"]
[369.435096, "o", "\u001b[?2004h> "]
[369.435342, "o", "            })\r\n\u001b[?2004l\r \u001b[?2004h"]
[369.435448, "o", ">     \r\n\u001b[?2004l\rfaile\u001b[?2004h"]
[369.435546, "o", "> "]
[369.435701, "o", "    return books\r\n\u001b[?2004l\r"]
