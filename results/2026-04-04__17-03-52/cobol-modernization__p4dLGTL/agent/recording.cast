[369.40672, "i", "cat > /app/program.py << 'EOF'\n#!/usr/bin/env python3\n\ndef read_input_file(filename):\n    \"\"\"Read the input file and parse the transaction data.\"\"\"\n    with open(filename, 'rb') as f:\n        data = f.read()\n    \n    if len(data) == 0:\n        print(\"Error: Input file is empty\")\n        return None\n    \n    # Parse the input record\n    buyer_id = data[0:4].decode('ascii')\n    seller_id = data[4:8].decode('ascii')\n    book_id = data[8:12].decode('ascii')\n    \n    # Amount field - handle variable length\n    if len(data) > 12:\n        amount_str = data[12:].decode('ascii')\n        amount = int(amount_str)\n    else:\n        amount = 0\n    \n    return {\n        'buyer_id': buyer_id,\n        'seller_id': seller_id,\n        'book_id': book_id,\n        'amount': amount\n    }\n\ndef read_accounts_file(filename):\n    \"\"\"Read accounts file and return list of account records.\"\"\"\n    accounts = []\n    with open(filename, 'rb') as f:\n        while True:\n            record = f.read(34)  # 4 + 20 + 10\n            if not record"]
[369.406889, "i", " or len(record) < 34:\n                break\n            \n            account_id = record[0:4].decode('ascii')\n            account_name = record[4:24].decode('ascii')\n            account_balance = int(record[24:34].decode('ascii'))\n            \n            accounts.append({\n                'id': account_id,\n                'name': account_name,\n                'balance': account_balance\n            })\n    \n    return accounts\n\ndef read_books_file(filename):\n    \"\"\"Read books file and return list of book records.\"\"\"\n    books = []\n    with open(filename, 'rb') as f:\n        while True:\n            record = f.read(28)  # 4 + 20 + 4\n            if not record or len(record) < 28:\n                break\n            \n            book_id = record[0:4].decode('ascii')\n            book_title = record[4:24].decode('ascii')\n            book_owner = record[24:28].decode('ascii')\n            \n            books.append({\n                'id': book_id,\n                'title': book_title,\n                'owner': book_owner\n  "]
[369.406981, "o", "cat > /app/program.py << 'EOF'\r\n"]
[369.407089, "i", "          })\n    \n    return books\n\ndef read_transactions_file(filename):\n    \"\"\"Read transactions file and return list of transaction records.\"\"\"\n    transactions = []\n    with open(filename, 'rb') as f:\n        while True:\n            record = f.read(22)  # 4 + 10 + 4 + 4\n            if not record or len(record) < 22:\n                break\n            \n            trans_book = record[0:4].decode('ascii')\n            trans_amount = int(record[4:14].decode('ascii'))\n            trans_seller = record[14:18].decode('ascii')\n            trans_buyer = record[18:22].decode('ascii')\n            \n            transactions.append({\n                'book': trans_book,\n                'amount': trans_amount,\n                'seller': trans_seller,\n                'buyer': trans_buyer\n            })\n    \n    return transactions\n\ndef validate_transaction(transaction, accounts, books):\n    \"\"\"Validate the transaction.\"\"\"\n    buyer_found = False\n    seller_found = False\n    book_found = False\n    valid_owner = False\n    \n  "]
[369.40719, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[369.407306, "i", "  # Check if buyer and seller exist\n    for account in accounts:\n        if account['id'] == transaction['buyer_id']:\n            buyer_found = True\n        if account['id'] == transaction['seller_id']:\n            seller_found = True\n    \n    # Check if book exists and is owned by seller\n    for book in books:\n        if book['id'] == transaction['book_id']:\n            book_found = True\n            if book['owner'] == transaction['seller_id']:\n                valid_owner = True\n    \n    return buyer_found and seller_found and book_found and valid_owner\n\ndef write_accounts_file(filename, accounts):\n    \"\"\"Write accounts to file.\"\"\"\n    with open(filename, 'wb') as f:\n        for account in accounts:\n            record = (\n                account['id'].encode('ascii') +\n                account['name'].encode('ascii') +\n                f\"{account['balance']:010d}\".encode('ascii')\n            )\n            f.write(record)\n\ndef write_books_file(filename, books):\n    \"\"\"Write books to file.\"\"\"\n    with open(filen"]
[369.407421, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.40749, "i", "ame, 'wb') as f:\n        for book in books:\n            record = (\n                book['id'].encode('ascii') +\n                book['title'].encode('ascii') +\n                book['owner'].encode('ascii')\n            )\n            f.write(record)\n\ndef append_transaction_file(filename, transaction):\n    \"\"\"Append transaction to file.\"\"\"\n    with open(filename, 'ab') as f:\n        record = (\n            transaction['book_id'].encode('ascii') +\n            f\"{transaction['amount']:010d}\".encode('ascii') +\n            transaction['seller_id'].encode('ascii') +\n            transaction['buyer_id'].encode('ascii')\n        )\n        f.write(record)\n\ndef process_transaction(transaction, accounts, books):\n    \"\"\"Process the transaction by updating accounts and books.\"\"\"\n    # Update account balances\n    for account in accounts:\n        if account['id'] == transaction['buyer_id']:\n            account['balance'] -= transaction['amount']\n        if account['id'] == transaction['seller_id']:\n            account['balance']"]
[369.407543, "o", "def read_input_file(filename):\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.407604, "i", " += transaction['amount']\n    \n    # Update book ownership\n    for book in books:\n        if book['id'] == transaction['book_id']:\n            book['owner'] = transaction['buyer_id']\n\ndef main():\n    # Read input transaction\n    transaction = read_input_file('src/INPUT.DAT')\n    if transaction is None:\n        return\n    \n    # Read data files\n    accounts = read_accounts_file('data/ACCOUNTS.DAT')\n    books = read_books_file('data/BOOKS.DAT')\n    \n    # Validate transaction\n    if validate_transaction(transaction, accounts, books):\n        # Process the transaction\n        process_transaction(transaction, accounts, books)\n        \n        # Write updated data files\n        write_accounts_file('data/ACCOUNTS.DAT', accounts)\n        write_books_file('data/BOOKS.DAT', books)\n        \n        # Append to transactions file\n        append_transaction_file('data/TRANSACTIONS.DAT', transaction)\n        \n        print(\" \")\n        print(\"Transaction completed successfully\")\n    else:\n        print(\" \")\n        print(\""]
