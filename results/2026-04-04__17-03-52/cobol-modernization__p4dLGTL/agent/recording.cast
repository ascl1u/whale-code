[369.420901, "o", "\u001b[?2004h> "]
[369.421382, "o", "            if not record or len(record) < 34:\r\n\u001b[?2004l\r"]
[369.421428, "o", "\u001b[?2004h> "]
[369.421735, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.421885, "o", ">             \r\n\u001b[?2004l\r"]
[369.422, "o", "\u001b[?2004h> "]
[369.422566, "o", "            account_id = record[0:4].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.422655, "o", "> "]
[369.423454, "o", "            account_name = record[4:24].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.423547, "o", "> "]
[369.424226, "o", "            account_balance = int(record[24:34].decode('ascii'))\r\n\u001b[?2004l\r\u001b[?2004h"]
[369.42435, "o", "> "]
[369.424414, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[369.424713, "o", "            accounts.append({\r\n\u001b[?2004l\rT\u001b[?2004h"]
[369.424841, "o", "> "]
[369.425145, "o", "                'id': account_id,\r\n\u001b[?2004l\r"]
[369.425192, "o", "\u001b[?2004h> "]
[369.425592, "o", "                'name': account_name,\r\n\u001b[?2004l\r"]
[369.425691, "o", "\u001b[?2004h> "]
[369.426014, "o", "                'balance': account_balance\r\n\u001b[?2004l\rC\u001b[?2004h> "]
[369.426414, "o", "            })\r\n\u001b[?2004l\r \u001b[?2004h"]
[369.4265, "o", ">     \r\n\u001b[?2004l\r"]
[369.426619, "o", "  boo\u001b[?2004h"]
[369.426775, "o", "> "]
[369.426865, "o", "    return accounts\r\n\u001b[?2004l\r"]
