[520.910009, "i", "cat > /app/program.py << 'EOF'\n#!/usr/bin/env python3\n\ndef read_input_file(filename):\n    \"\"\"Read the input file and parse the transaction data.\"\"\"\n    with open(filename, 'rb') as f:\n        data = f.read()\n    \n    if len(data) == 0:\n        print(\"Error: Input file is empty\")\n        return None\n    \n    # Parse input based on COBOL structure\n    # INPUT-BUYER-ID: PIC X(4)\n    # INPUT-SELLER-ID: PIC X(4)\n    # INPUT-BOOK-ID: PIC X(4)\n    # INPUT-AMOUNT: PIC 9(10)\n    \n    buyer_id = data[0:4].decode('ascii')\n    seller_id = data[4:8].decode('ascii')\n    book_id = data[8:12].decode('ascii')\n    \n    # Handle variable-length amount field\n    if len(data) >= 22:\n        amount_str = data[12:22].decode('ascii')\n    else:\n        amount_str = data[12:].decode('ascii')\n    \n    # Convert amount to integer\n    amount = int(amount_str)\n    \n    return {\n        'buyer_id': buyer_id,\n        'seller_id': seller_id,\n        'book_id': book_id,\n        'amount': amount\n    }\n\ndef read_accounts_file(filename):\n    \"\"\""]
[520.91021, "i", "Read accounts file and return list of account records.\"\"\"\n    accounts = []\n    with open(filename, 'rb') as f:\n        while True:\n            record = f.read(34)  # 4 + 20 + 10\n            if not record:\n                break\n            account_id = record[0:4].decode('ascii')\n            account_name = record[4:24].decode('ascii')\n            account_balance = int(record[24:34].decode('ascii'))\n            accounts.append({\n                'id': account_id,\n                'name': account_name,\n                'balance': account_balance\n            })\n    return accounts\n\ndef read_books_file(filename):\n    \"\"\"Read books file and return list of book records.\"\"\"\n    books = []\n    with open(filename, 'rb') as f:\n        while True:\n            record = f.read(28)  # 4 + 20 + 4\n            if not record:\n                break\n            book_id = record[0:4].decode('ascii')\n            book_title = record[4:24].decode('ascii')\n            book_owner = record[24:28].decode('ascii')\n            books.append({"]
[520.910345, "o", "cat > /app/program.py << 'EOF'\r\n\u001b[?2004l\r"]
[520.910384, "i", "\n                'id': book_id,\n                'title': book_title,\n                'owner': book_owner\n            })\n    return books\n\ndef write_accounts_file(filename, accounts):\n    \"\"\"Write accounts to file.\"\"\"\n    with open(filename, 'wb') as f:\n        for account in accounts:\n            record = (\n                account['id'].encode('ascii') +\n                account['name'].encode('ascii') +\n                f\"{account['balance']:010d}\".encode('ascii')\n            )\n            f.write(record)\n\ndef write_books_file(filename, books):\n    \"\"\"Write books to file.\"\"\"\n    with open(filename, 'wb') as f:\n        for book in books:\n            record = (\n                book['id'].encode('ascii') +\n                book['title'].encode('ascii') +\n                book['owner'].encode('ascii')\n            )\n            f.write(record)\n\ndef append_transaction(filename, trans_data):\n    \"\"\"Append transaction to transactions file.\"\"\"\n    with open(filename, 'ab') as f:\n        record = (\n            trans_data["]
