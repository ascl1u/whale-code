[520.931482, "o", "            book_title = record[4:24].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.93175, "o", "            book_owner = record[24:28].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.931835, "o", "> "]
[520.93194, "o", "            books.append({\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.932024, "o", "> "]
[520.932152, "o", "                'id': book_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.932236, "o", "> "]
[520.93237, "o", "                'title': book_title,\r\n\u001b[?2004l\r"]
[520.932452, "o", "\u001b[?2004h> "]
[520.932582, "o", "                'owner': book_owner\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.932673, "o", "> "]
[520.932764, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.932851, "o", "> "]
[520.932955, "o", "    return books\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.933046, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.933226, "o", "def write_accounts_file(filename, accounts):\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.933326, "o", "> "]
[520.933444, "o", "    \"\"\"Write accounts to file.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.933526, "o", "> "]
[520.933757, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.933842, "o", "> "]
[520.934018, "o", "        for account in accounts:\r\n\u001b[?2004l\r"]
[520.93406, "o", "\u001b[?2004h"]
[520.934085, "o", "> "]
[520.934191, "o", "            record = (\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.934294, "o", "> "]
[520.934473, "o", "                account['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.934552, "o", "> "]
[520.934741, "o", "                account['name'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.934862, "o", "> "]
[520.935078, "o", "                f\"{account['balance']:010d}\".encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.935175, "o", "> "]
[520.935276, "o", "            )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.935388, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.935427, "o", "> \r\n\u001b[?2004l\r"]
[520.93557, "o", "\u001b[?2004h> "]
[520.935705, "o", "def write_books_file(filename, books):\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.935782, "o", "> "]
[520.935893, "o", "    \"\"\"Write books to file.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.9361, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.936188, "o", "> "]
[520.936291, "o", "        for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.936377, "o", "> "]
[520.936464, "o", "            record = (\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.936545, "o", "> "]
[520.936732, "o", "                book['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.936833, "o", "> "]
[520.937006, "o", "                book['title'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.937099, "o", "> "]
[520.937363, "o", "                book['owner'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.937497, "o", ">             )\r\n\u001b[?2004l\r"]
[520.937633, "o", "\u001b[?2004h> "]
[520.937716, "o", "            f.write(record)"]
[520.962645, "o", "\r\n\u001b[?2004l\r"]
[520.962832, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[520.962981, "o", "\u001b[?2004h> "]
[520.963109, "o", "def append_transaction(filename, trans_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.963351, "o", "    \"\"\"Append transaction to transactions file.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.963484, "o", "> "]
[520.963597, "o", "    with open(filename, 'ab') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.963712, "o", "> "]
[520.963852, "o", "        record = (\r\n\u001b[?2004l\r"]
[520.96395, "o", "\u001b[?2004h> "]
[520.964112, "o", "            trans_data['book_id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.964496, "o", "            f\"{trans_data['amount']:010d}\".encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.964812, "o", "            trans_data['seller_id'].encode('ascii') +\r\n\u001b[?2004l\r"]
[520.964918, "o", "\u001b[?2004h> "]
[520.965157, "o", "            trans_data['buyer_id'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.965291, "o", "> "]
[520.965382, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.96553, "o", "        f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.965673, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[520.965753, "o", "> "]
[520.965864, "o", "def validate_and_process():\r\n\u001b[?2004l\r"]
[520.965975, "o", "\u001b[?2004h> "]
[520.96626, "o", "    \"\"\"Main function to validate and process transaction.\"\"\"\r\n\u001b[?2004l\r"]
[520.966438, "o", "\u001b[?2004h> "]
[520.966582, "o", "    # Read input\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.966692, "o", "> "]
[520.966825, "o", "    input_data = read_input_file('src/INPUT.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.966859, "o", "> "]
[520.967025, "o", "    if input_data is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.967162, "o", "> "]
[520.967333, "o", "        return\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.967435, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.967695, "o", "    buyer_id = input_data['buyer_id']\r\n\u001b[?2004l\r"]
[520.967787, "o", "\u001b[?2004h> "]
[520.968035, "o", "    seller_id = input_data['seller_id']\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.968106, "o", "> "]
[520.968355, "o", "    book_id = input_data['book_id']\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.968462, "o", "> "]
[520.968653, "o", "    amount = input_data['amount']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.968829, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.969023, "o", "    # Read accounts and books\r\n\u001b[?2004l\r"]
[520.969167, "o", "\u001b[?2004h> "]
[520.969393, "o", "    accounts = read_accounts_file('data/ACCOUNTS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.969531, "o", "> "]
[520.969725, "o", "    books = read_books_file('data/BOOKS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.969846, "o", ">     \r\n\u001b[?2004l\r"]
[520.969954, "o", "\u001b[?2004h> "]
[520.97003, "o", "    # Validate\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.970099, "o", "    buyer_found = False\r\n\u001b[?2004l\r"]
[520.970134, "o", "\u001b[?2004h> "]
[520.970322, "o", "    seller_found = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.970508, "o", "    book_found = False\r\n\u001b[?2004l\r"]
[520.970601, "o", "\u001b[?2004h> "]
[520.970676, "o", "    valid_owner = False\r\n\u001b[?2004l\r"]
[520.970788, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[520.97088, "o", "\u001b[?2004h> "]
[520.970996, "o", "    for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.971029, "o", "> "]
[520.971285, "o", "        if account['id'] == buyer_id:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.971508, "o", "            buyer_found = True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.971759, "o", "        if account['id'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.971953, "o", "            seller_found = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.972005, "o", ">     \r\n\u001b[?2004l\r"]
[520.972071, "o", "\u001b[?2004h> "]
[520.972185, "o", "    for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.972225, "o", "> "]
[520.972412, "o", "        if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.97254, "o", "> "]
[520.972596, "o", "            book_found = True\r\n\u001b[?2004l\r"]
[520.972719, "o", "\u001b[?2004h> "]
[520.972969, "o", "            if book['owner'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.973206, "o", "                valid_owner = True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.97325, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[520.973317, "o", "> "]
[520.973458, "o", "    print(\" \")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.973507, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[520.973564, "o", "> "]
[520.973929, "o", "    if buyer_found and seller_found and book_found and valid_owner:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.974034, "o", "> "]
[520.974227, "o", "        # Process transaction\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.974489, "o", "        # Update account balances\r\n\u001b[?2004l\r"]
[520.974587, "o", "\u001b[?2004h> "]
[520.974767, "o", "        for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.975027, "o", "            if account['id'] == buyer_id:\r\n\u001b[?2004l\r"]
[520.975109, "o", "\u001b[?2004h> "]
[520.975332, "o", "                account['balance'] -= amount\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.975484, "o", "> "]
[520.97565, "o", "            if account['id'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.975712, "o", "> "]
[520.975926, "o", "                account['balance'] += amount\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.976059, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.976192, "o", "        # Update book ownership\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.976307, "o", "> "]
[520.976419, "o", "        for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.976547, "o", "> "]
[520.976738, "o", "            if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.976836, "o", "> "]
[520.976981, "o", "                book['owner'] = buyer_id\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.977122, "o", "> "]
[520.977268, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.97741, "o", "        # Write updated files\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.977746, "o", "        write_accounts_file('data/ACCOUNTS.DAT', accounts)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.978038, "o", "        write_books_file('data/BOOKS.DAT', books)\r\n\u001b[?2004l\r"]
[520.978177, "o", "\u001b[?2004h> "]
[520.978287, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.97841, "o", "        # Append transaction\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.978479, "o", "> "]
[520.978701, "o", "        append_transaction('data/TRANSACTIONS.DAT', {\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.978772, "o", "> "]
[520.978929, "o", "            'book_id': book_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.978997, "o", "> "]
[520.979189, "o", "            'amount': amount,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.979382, "o", "            'seller_id': seller_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.979474, "o", "> "]
[520.979646, "o", "            'buyer_id': buyer_id\r\n\u001b[?2004l\r\u001b[?2004h"]
[520.979772, "o", "> "]
[520.979934, "o", "        })\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.980222, "o", "        print(\"Transaction completed successfully\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.98037, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.980734, "o", "        print(\"Transaction failed due to validation errors\")\r\n\u001b[?2004l\r"]
[520.980774, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[520.980929, "o", "\u001b[?2004h> "]
[520.981108, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[520.981269, "o", "    validate_and_process()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
