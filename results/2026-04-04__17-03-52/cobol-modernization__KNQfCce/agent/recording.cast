[656.771435, "i", "python3 << 'EOF'\n# Let me check various interpretations\nbalance = 1180\namount = 2000000000\nresult = balance - amount\n\nprint(f\"Result: {result}\")\nprint(f\"Abs value: {abs(result)}\")\nprint(f\"Modulo 10^10: {result % (10**10)}\")\nprint(f\"COBOL shows: 1999998820\")\n\n# Check if it's 2's complement or something else\nprint(f\"\\n10^10 - abs(result): {10**10 - abs(result)}\")\nprint(f\"10^10 + result: {10**10 + result}\")\n\n# Maybe COBOL is interpreting the minus sign differently?\n# What if the format string in COBOL is just taking the last 10 digits?\nresult_str = str(result)\nprint(f\"\\nResult as string: '{result_str}'\")\nprint(f\"Last 10 chars: '{result_str[-10:]}'\")\nEOF\n"]
