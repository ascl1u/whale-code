[758.921357, "i", "python3 << 'EOF'\nimport os\nimport shutil\nimport subprocess\n\ndef backup_files():\n    \"\"\"Backup data files\"\"\"\n    for fname in ['ACCOUNTS.DAT', 'BOOKS.DAT', 'TRANSACTIONS.DAT']:\n        shutil.copy(f'data/{fname}', f'data/{fname}.bak')\n\ndef restore_files():\n    \"\"\"Restore data files from backup\"\"\"\n    for fname in ['ACCOUNTS.DAT', 'BOOKS.DAT', 'TRANSACTIONS.DAT']:\n        shutil.copy(f'data/{fname}.bak', f'data/{fname}')\n\ndef cleanup_backups():\n    \"\"\"Remove backup files\"\"\"\n    for fname in ['ACCOUNTS.DAT', 'BOOKS.DAT', 'TRANSACTIONS.DAT']:\n        try:\n            os.remove(f'data/{fname}.bak')\n        except:\n            pass\n\nprint(\"=\" * 60)\nprint(\"Comprehensive Test: Python vs COBOL\")\nprint(\"=\" * 60)\n\n# Test 1: Validation failure (B007)\nprint(\"\\nTest 1: Validation Failure (Book B007 doesn't exist)\")\nprint(\"-\" * 60)\nbackup_files()\n\n# Run COBOL\nresult_cobol = subprocess.run(['./program'], capture_output=True, text=True)\ncobol_stdout = result_cobol.stdout\ncobol_files = {}\nfor fname in ['ACCOUNTS.DAT', 'BOOKS.D"]
[758.921521, "i", "AT', 'TRANSACTIONS.DAT']:\n    with open(f'data/{fname}', 'rb') as f:\n        cobol_files[fname] = f.read()\n\n# Restore and run Python\nrestore_files()\nresult_python = subprocess.run(['python3', '/app/program.py'], capture_output=True, text=True)\npython_stdout = result_python.stdout\npython_files = {}\nfor fname in ['ACCOUNTS.DAT', 'BOOKS.DAT', 'TRANSACTIONS.DAT']:\n    with open(f'data/{fname}', 'rb') as f:\n        python_files[fname] = f.read()\n\nprint(f\"COBOL output: {repr(cobol_stdout)}\")\nprint(f\"Python output: {repr(python_stdout)}\")\nprint(f\"Output matches: {cobol_stdout == python_stdout}\")\n\nfor fname in ['ACCOUNTS.DAT', 'BOOKS.DAT', 'TRANSACTIONS.DAT']:\n    match = cobol_files[fname] == python_files[fname]\n    print(f\"{fname} matches: {match}\")\n    if not match:\n        print(f\"  COBOL:  {len(cobol_files[fname])} bytes\")\n        print(f\"  Python: {len(python_files[fname])} bytes\")\n\n# Test 2: Successful transaction (B001)\nprint(\"\\nTest 2: Successful Transaction (Book B001)\")\nprint(\"-\" * 60)\n\n# Change INPUT.DAT "]
