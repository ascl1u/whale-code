[596.849307, "i", "python3 << 'EOF'\n# Test the modulo approach\nbalance = 1180\namount = 2000000000\nresult = balance - amount\nprint(f\"Direct subtraction: {result}\")\nprint(f\"Modulo 10^10: {result % (10**10)}\")\nprint(f\"COBOL output: 1999998820\")\n\n# Check if it matches\nif result % (10**10) == 8000001180:\n    print(\"Modulo approach gives: 8000001180\")\nelse:\n    print(f\"Modulo approach gives: {result % (10**10)}\")\n\n# Maybe COBOL just formats it without the sign?\nprint(f\"\\nAbsolute value: {abs(result)}\")\nprint(f\"Formatted as 10 digits: {abs(result):010d}\")\nEOF\n"]
