[210.512865, "i", "python3 << 'EOF'\nimport os\n\n# Read and display all data files\nfor filename in ['data/ACCOUNTS.DAT', 'data/BOOKS.DAT', 'data/TRANSACTIONS.DAT']:\n    with open(filename, 'rb') as f:\n        data = f.read()\n        print(f\"\\n{filename} ({len(data)} bytes):\")\n        print(repr(data))\nEOF\n"]
