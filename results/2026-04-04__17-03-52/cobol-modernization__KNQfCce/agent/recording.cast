[627.768249, "o", "    # Handle the amount field - COBOL expects 10 bytes but file may have less\r\n\u001b[?2004l\r"]
[627.768435, "o", "\u001b[?2004h> "]
[627.76932, "o", "    # When COBOL reads beyond file end, it pads with spaces\r\n\u001b[?2004l\r"]
[627.769473, "o", "\u001b[?2004h> "]
[627.770063, "o", "    # PIC 9(10) field starting at position 12\r\n\u001b[?2004l\r\u001b[?2004h"]
[627.770314, "o", "> "]
[627.770935, "o", "    amount_bytes = data[12:] if len(data) > 12 else b''\r\n\u001b[?2004l\rprint\u001b[?2004h"]
[627.771102, "o", "> "]
[627.771962, "o", "    # Pad to 10 bytes with spaces (COBOL behavior)\r\n\u001b[?2004l\rt"]
[627.772204, "o", "\u001b[?2004h> "]
[627.773227, "o", "    amount_str = (amount_bytes + b' ' * 10)[:10].decode('ascii')\r\n\u001b[?2004l\r"]
[627.7734, "o", "\u001b[?2004h> "]
[627.774283, "o", "    # Convert to numeric - spaces on right are treated as zeros in COBOL numeric context\r\n\u001b[?2004l\r"]
[627.774708, "o", "\u001b[?2004h> "]
[627.775149, "o", "    # \"200       \" becomes 2000000000 when interpreted left-to-right\r\n\u001b[?2004l\r\u001b[?2004h"]
[627.775329, "o", "> "]
[627.775903, "o", "    amount_str_stripped = amount_str.rstrip()\r\n\u001b[?2004l\rle\u001b[?2004h"]
[627.776077, "o", "> "]
[627.776253, "o", "    if amount_str_stripped:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[627.777189, "o", "        # Pad with zeros on the right to make 10 digits\r\n\u001b[?2004l\r"]
[627.777336, "o", "\u001b[?2004h> "]
[627.778034, "o", "        amount = int(amount_str_stripped.ljust(10, '0'))\r\n\u001b[?2004l\r"]
[627.778326, "o", "\u001b[?2004h> "]
[627.778522, "o", "    else:\r\n\u001b[?2004l\r"]
[627.778687, "o", "\u001b[?2004h> "]
