[341.700424, "i", "python3 << 'EOF'\nimport os\n\n# Read and display modified data files\nfor filename in ['data/ACCOUNTS.DAT', 'data/BOOKS.DAT', 'data/TRANSACTIONS.DAT']:\n    with open(filename, 'rb') as f:\n        data = f.read()\n        print(f\"\\n{filename} ({len(data)} bytes):\")\n        print(repr(data))\n        \nprint(\"\\n--- Comparing with backup ---\")\nwith open('data_backup/ACCOUNTS.DAT', 'rb') as f:\n    orig = f.read()\nwith open('data/ACCOUNTS.DAT', 'rb') as f:\n    new = f.read()\nprint(f\"\\nACCOUNTS.DAT changed: {orig != new}\")\nif orig != new:\n    print(f\"Original: {repr(orig)}\")\n    print(f\"New:      {repr(new)}\")\n\nwith open('data_backup/BOOKS.DAT', 'rb') as f:\n    orig = f.read()\nwith open('data/BOOKS.DAT', 'rb') as f:\n    new = f.read()\nprint(f\"\\nBOOKS.DAT changed: {orig != new}\")\nif orig != new:\n    print(f\"Original: {repr(orig)}\")\n    print(f\"New:      {repr(new)}\")\n\nwith open('data_backup/TRANSACTIONS.DAT', 'rb') as f:\n    orig = f.read()\nwith open('data/TRANSACTIONS.DAT', 'rb') as f:\n    new = f.read()\nprint(f\"\\nTRANSA"]
[341.700761, "i", "CTIONS.DAT changed: {orig != new}\")\nif orig != new:\n    print(f\"Original length: {len(orig)}, New length: {len(new)}\")\n    print(f\"Added: {repr(new[len(orig):])}\")\nEOF\n"]
