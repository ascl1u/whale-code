[540.221952, "i", "cat > /app/program.py << 'EOF'\n#!/usr/bin/env python3\n\ndef read_input_file(filename):\n    \"\"\"Read the input file and parse the transaction data.\"\"\"\n    with open(filename, 'rb') as f:\n        data = f.read()\n    \n    if len(data) == 0:\n        print(\"Error: Input file is empty\")\n        return None\n    \n    # Parse input record\n    buyer_id = data[0:4].decode('ascii')\n    seller_id = data[4:8].decode('ascii')\n    book_id = data[8:12].decode('ascii')\n    \n    # Handle the amount field - COBOL expects 10 bytes but file may have less\n    # When COBOL reads beyond file end, it pads with spaces\n    # PIC 9(10) field starting at position 12\n    amount_bytes = data[12:] if len(data) > 12 else b''\n    # Pad to 10 bytes with spaces (COBOL behavior)\n    amount_str = (amount_bytes + b' ' * 10)[:10].decode('ascii')\n    # Convert to numeric - spaces on right are treated as zeros in COBOL numeric context\n    # \"200       \" becomes 2000000000 when interpreted left-to-right\n    amount_str_stripped = amount_str.rstrip()\n    i"]
[540.222197, "i", "f amount_str_stripped:\n        # Pad with zeros on the right to make 10 digits\n        amount = int(amount_str_stripped.ljust(10, '0'))\n    else:\n        amount = 0\n    \n    return {\n        'buyer_id': buyer_id,\n        'seller_id': seller_id,\n        'book_id': book_id,\n        'amount': amount\n    }\n\ndef read_accounts(filename):\n    \"\"\"Read all account records.\"\"\"\n    accounts = []\n    with open(filename, 'rb') as f:\n        data = f.read()\n    \n    # Each account record is 34 bytes: ID(4) + Name(20) + Balance(10)\n    record_size = 34\n    for i in range(0, len(data), record_size):\n        if i + record_size <= len(data):\n            record = data[i:i+record_size]\n            account = {\n                'id': record[0:4].decode('ascii'),\n                'name': record[4:24].decode('ascii'),\n                'balance': int(record[24:34].decode('ascii'))\n            }\n            accounts.append(account)\n    \n    return accounts\n\ndef read_books(filename):\n    \"\"\"Read all book records.\"\"\"\n    books = []\n    wit"]
[540.222313, "i", "h open(filename, 'rb') as f:\n        data = f.read()\n    \n    # Each book record is 28 bytes: ID(4) + Title(20) + Owner(4)\n    record_size = 28\n    for i in range(0, len(data), record_size):\n        if i + record_size <= len(data):\n            record = data[i:i+record_size]\n            book = {\n                'id': record[0:4].decode('ascii'),\n                'title': record[4:24].decode('ascii'),\n                'owner': record[24:28].decode('ascii')\n            }\n            books.append(book)\n    \n    return books\n\ndef write_accounts(filename, accounts):\n    \"\"\"Write all account records.\"\"\"\n    with open(filename, 'wb') as f:\n        for account in accounts:\n            # Format: ID(4) + Name(20) + Balance(10)\n            record = (\n                account['id'].encode('ascii') +\n                account['name'].encode('ascii') +\n                f\"{account['balance']:010d}\".encode('ascii')\n            )\n            f.write(record)\n\ndef write_books(filename, books):\n    \"\"\"Write all book records.\"\"\"\n    wit"]
[540.222489, "o", "cat > /app/program.py << 'EOF'\r\n\u001b[?2004l\r"]
[540.222646, "i", "h open(filename, 'wb') as f:\n        for book in books:\n            # Format: ID(4) + Title(20) + Owner(4)\n            record = (\n                book['id'].encode('ascii') +\n                book['title'].encode('ascii') +\n                book['owner'].encode('ascii')\n            )\n            f.write(record)\n\ndef append_transaction(filename, book_id, amount, seller_id, buyer_id):\n    \"\"\"Append a transaction record.\"\"\"\n    with open(filename, 'ab') as f:\n        # Format: Book(4) + Amount(10) + Seller(4) + Buyer(4)\n        record = (\n            book_id.encode('ascii') +\n            f\"{amount:010d}\".encode('ascii') +\n            seller_id.encode('ascii') +\n            buyer_id.encode('ascii')\n        )\n        f.write(record)\n\ndef main():\n    # Read input\n    input_data = read_input_file('src/INPUT.DAT')\n    if input_data is None:\n        return\n    \n    buyer_id = input_data['buyer_id']\n    seller_id = input_data['seller_id']\n    book_id = input_data['book_id']\n    amount = input_data['amount']\n    \n    # Va"]
[540.222762, "o", "\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r"]
[540.222844, "i", "lidate users and book\n    accounts = read_accounts('data/ACCOUNTS.DAT')\n    books = read_books('data/BOOKS.DAT')\n    \n    buyer_found = False\n    seller_found = False\n    book_found = False\n    valid_owner = False\n    \n    for account in accounts:\n        if account['id'] == buyer_id:\n            buyer_found = True\n        if account['id'] == seller_id:\n            seller_found = True\n    \n    for book in books:\n        if book['id'] == book_id:\n            book_found = True\n            if book['owner'] == seller_id:\n                valid_owner = True\n    \n    print(\" \")\n    \n    # Process transaction if all validations pass\n    if buyer_found and seller_found and book_found and valid_owner:\n        # Update account balances\n        for account in accounts:\n            if account['id'] == buyer_id:\n                account['balance'] -= amount\n            if account['id'] == seller_id:\n                account['balance'] += amount\n        \n        write_accounts('data/ACCOUNTS.DAT', accounts)\n        \n        #"]
[540.222964, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.223012, "i", " Update book ownership\n        for book in books:\n            if book['id'] == book_id:\n                book['owner'] = buyer_id\n        \n        write_books('data/BOOKS.DAT', books)\n        \n        # Append transaction record\n        append_transaction('data/TRANSACTIONS.DAT', book_id, amount, seller_id, buyer_id)\n        \n        print(\"Transaction completed successfully\")\n    else:\n        print(\"Transaction failed due to validation errors\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
[540.223217, "o", "def read_input_file(filename):\r\n\u001b[?2004l\r"]
[540.223253, "o", "\u001b[?2004h> "]
[540.223858, "o", "    \"\"\"Read the input file and parse the transaction data.\"\"\"\r\n\u001b[?2004l\r"]
[540.224019, "o", "\u001b[?2004h> "]
[540.224389, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\rd =\u001b[?2004h> "]
[540.224904, "o", "        data = f.read()\r\n\u001b[?2004l\r"]
[540.225023, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[540.225082, "o", "\u001b[?2004h> "]
[540.225361, "o", "    if len(data) == 0:\r\n\u001b[?2004l\r"]
[540.225477, "o", "\u001b[?2004h> "]
[540.225983, "o", "        print(\"Error: Input file is empty\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.226127, "o", "> "]
[540.226269, "o", "        return None\r\n\u001b[?2004l\rb\u001b[?2004h"]
[540.226345, "o", ">     \r\n\u001b[?2004l\r"]
[540.226458, "o", "\u001b[?2004h> "]
[540.226756, "o", "    # Parse input record\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.226881, "o", "> "]
[540.227307, "o", "    buyer_id = data[0:4].decode('ascii')\r\n\u001b[?2004l\r se\u001b[?2004h"]
[540.227415, "o", "> "]
[540.227841, "o", "    seller_id = data[4:8].decode('ascii')\r\n\u001b[?2004l\r"]
[540.227881, "o", "\u001b[?2004h> "]
[540.228588, "o", "    book_id = data[8:12].decode('ascii')\r\n\u001b[?2004l\r"]
[540.228812, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r     \u001b[?2004h"]
[540.228989, "o", "> "]
[540.229769, "o", "    # Handle the amount field - COBOL expects 10 bytes but file may have less\r\n\u001b[?2004l\r"]
[540.229922, "o", "\u001b[?2004h> "]
[540.230544, "o", "    # When COBOL reads beyond file end, it pads with spaces\r\n\u001b[?2004l\r"]
[540.230661, "o", "\u001b[?2004h> "]
[540.231101, "o", "    # PIC 9(10) field starting at position 12\r\n\u001b[?2004l\r"]
[540.231256, "o", "\u001b[?2004h> "]
[540.232019, "o", "    amount_bytes = data[12:] if len(data) > 12 else b''\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.232138, "o", "> "]
[540.232774, "o", "    # Pad to 10 bytes with spaces (COBOL behavior)\r\n\u001b[?2004l\r"]
[540.232911, "o", "\u001b[?2004h> "]
[540.233595, "o", "    amount_str = (amount_bytes + b' ' * 10)[:10].decode('ascii')\r\n\u001b[?2004l\r"]
[540.233643, "o", "\u001b[?2004h> "]
[540.234538, "o", "    # Convert to numeric - spaces on right are treated as zeros in COBOL numeric context\r\n\u001b[?2004l\r"]
[540.234669, "o", "\u001b[?2004h> "]
[540.235562, "o", "    # \"200       \" becomes 2000000000 when interpreted left-to-right\r\n\u001b[?2004l\r"]
[540.235689, "o", "\u001b[?2004h> "]
[540.235985, "o", "    amount_str_stripped = amount_str.rstrip()\r\n\u001b[?2004l\r \u001b[?2004h"]
[540.236151, "o", "> "]
[540.236386, "o", "    if amount_str_stripped:\r\n\u001b[?2004l\r"]
[540.236493, "o", "\u001b[?2004h> "]
[540.237034, "o", "        # Pad with zeros on the right to make 10 digits\r\n\u001b[?2004l\r=\u001b[?2004h"]
[540.237132, "o", "> "]
[540.237564, "o", "        amount = int(amount_str_stripped.ljust(10, '0'))\r\n\u001b[?2004l\r"]
[540.237716, "o", "\u001b[?2004h> "]
[540.2379, "o", "    else:\r\n\u001b[?2004l\r"]
[540.237988, "o", "\u001b[?2004h> "]
[540.238171, "o", "        amount = 0\r\n\u001b[?2004l\ra/\u001b[?2004h> "]
[540.238288, "o", "    \r\n\u001b[?2004l\r"]
[540.238397, "o", "\u001b[?2004h> "]
[540.238571, "o", "    return {\r\n\u001b[?2004l\r"]
[540.23866, "o", "\u001b[?2004h> "]
[540.239116, "o", "        'buyer_id': buyer_id,\r\n\u001b[?2004l\r"]
[540.239238, "o", "\u001b[?2004h> "]
[540.239594, "o", "        'seller_id': seller_id,\r\n\u001b[?2004l\r"]
[540.239706, "o", "\u001b[?2004h> "]
[540.240066, "o", "        'book_id': book_id,\r\n\u001b[?2004l\r"]
[540.240175, "o", "\u001b[?2004h> "]
[540.240525, "o", "        'amount': amount\r\n\u001b[?2004l\r"]
[540.24064, "o", "\u001b[?2004h"]
[540.240737, "o", ">     }"]
[540.240773, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.240878, "o", "\r\n\u001b[?2004l\r_\u001b[?2004h> "]
[540.241403, "o", "def read_accounts(filename):\r\n\u001b[?2004l\r"]
[540.241497, "o", "\u001b[?2004h> "]
[540.242217, "o", "    \"\"\"Read all account records.\"\"\"\r\n\u001b[?2004l\r"]
[540.242308, "o", "\u001b[?2004h> "]
[540.242577, "o", "    accounts = []\r\n\u001b[?2004l\r"]
[540.242714, "o", "\u001b[?2004h> "]
[540.243295, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[540.243391, "o", "\u001b[?2004h> "]
[540.24386, "o", "        data = f.read()\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.243942, "o", "> "]
[540.244024, "o", "    \r\n\u001b[?2004l\ri"]
[540.244123, "o", "\u001b[?2004h"]
[540.244185, "o", "> "]
[540.245096, "o", "    # Each account record is 34 bytes: ID(4) + Name(20) + Balance(10)\r\n\u001b[?2004l\r"]
[540.245182, "o", "\u001b[?2004h> "]
[540.245332, "o", "    record_size = 34\r\n\u001b[?2004l\r"]
[540.245421, "o", "\u001b[?2004h> "]
[540.245632, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\r"]
[540.245738, "o", "\u001b[?2004h> "]
[540.245908, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.245996, "o", "> "]
[540.246171, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.246306, "o", "> "]
[540.246348, "o", "            account = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.246659, "o", "                'id': record[0:4].decode('ascii'),\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.246773, "o", "> "]
[540.246977, "o", "                'name': record[4:24].decode('ascii'),\r\n\u001b[?2004l\r"]
[540.247061, "o", "\u001b[?2004h"]
[540.247136, "o", "> "]
[540.24735, "o", "                'balance': int(record[24:34].decode('ascii'))\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.247446, "o", "> "]
[540.247489, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.247752, "o", "            accounts.append(account)\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.2479, "o", "> "]
[540.247988, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.248056, "o", "    return accounts\r\n\u001b[?2004l\r"]
[540.248145, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[540.248221, "o", "\u001b[?2004h> "]
[540.248386, "o", "def read_books(filename):\r\n\u001b[?2004l\r"]
[540.248509, "o", "\u001b[?2004h> "]
[540.248648, "o", "    \"\"\"Read all book records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.248739, "o", "> "]
[540.248837, "o", "    books = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.249058, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.249189, "o", "> "]
[540.249362, "o", "        data = f.read()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[540.249497, "o", "\u001b[?2004h> "]
[540.249737, "o", "    # Each book record is 28 bytes: ID(4) + Title(20) + Owner(4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.24984, "o", "> "]
[540.249969, "o", "    record_size = 28\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.250243, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.250472, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.250568, "o", "> "]
[540.250746, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.25084, "o", "> "]
[540.250964, "o", "            book = {\r\n\u001b[?2004l\r"]
[540.25104, "o", "\u001b[?2004h> "]
[540.251292, "o", "                'id': record[0:4].decode('ascii'),\r\n\u001b[?2004l\r"]
[540.251394, "o", "\u001b[?2004h> "]
[540.251651, "o", "                'title': record[4:24].decode('ascii'),\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.251789, "o", "> "]
[540.251989, "o", "                'owner': record[24:28].decode('ascii')\r\n\u001b[?2004l\r"]
[540.252031, "o", "\u001b[?2004h> "]
[540.252139, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.252245, "o", "> "]
[540.252367, "o", "            books.append(book)\r\n\u001b[?2004l\r"]
[540.252432, "o", "\u001b[?2004h>     "]
[540.252484, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.252618, "o", "    return books\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.252749, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.25294, "o", "def write_accounts(filename, accounts):\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.253038, "o", "> "]
[540.253181, "o", "    \"\"\"Write all account records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.253276, "o", "> "]
[540.253441, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r"]
[540.253519, "o", "\u001b[?2004h> "]
[540.253786, "o", "        for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.253924, "o", "> "]
[540.254188, "o", "            # Format: ID(4) + Name(20) + Balance(10)\r\n\u001b[?2004l\r"]
[540.254285, "o", "\u001b[?2004h> "]
[540.254404, "o", "            record = (\r\n\u001b[?2004l\r"]
[540.254493, "o", "\u001b[?2004h> "]
[540.254725, "o", "                account['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.254824, "o", "> "]
[540.255057, "o", "                account['name'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.255372, "o", "                f\"{account['balance']:010d}\".encode('ascii')\r\n\u001b[?2004l\r"]
[540.255469, "o", "\u001b[?2004h> "]
[540.255577, "o", "            )\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.255665, "o", "> "]
[540.255793, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[540.255883, "o", "\u001b[?2004h> "]
[540.256037, "o", "def write_books(filename, books):\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.256144, "o", "> "]
[540.256264, "o", "    \"\"\"Write all book records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.256353, "o", "> "]
[540.256492, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r"]
[540.256577, "o", "\u001b[?2004h> "]
[540.256717, "o", "        for book in books:\r\n\u001b[?2004l\r"]
[540.256809, "o", "\u001b[?2004h> "]
[540.257079, "o", "            # Format: ID(4) + Title(20) + Owner(4)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.257226, "o", "            record = (\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.257394, "o", "> "]
[540.257508, "o", "                book['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.257639, "o", "> "]
[540.257831, "o", "                book['title'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.257949, "o", "> "]
[540.258157, "o", "                book['owner'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.258224, "o", "> "]
[540.258307, "o", "            )\r\n\u001b[?2004l\r"]
[540.258429, "o", "\u001b[?2004h> "]
[540.258585, "o", "            f.write(record)\r\n\u001b[?2004l\r"]
[540.258656, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[540.258717, "o", "\u001b[?2004h> "]
[540.259169, "o", "def append_transaction(filename, book_id, amount, seller_id, buyer_id):\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.259263, "o", "> "]
[540.259427, "o", "    \"\"\"Append a transaction record.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.259521, "o", "> "]
[540.259685, "o", "    with open(filename, 'ab') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.259753, "o", "> "]
[540.260127, "o", "        # Format: Book(4) + Amount(10) + Seller(4) + Buyer(4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.260236, "o", "> "]
[540.260305, "o", "        record = (\r\n\u001b[?2004l\r"]
[540.260442, "o", "\u001b[?2004h> "]
[540.260577, "o", "            book_id.encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.260688, "o", "> "]
[540.260925, "o", "            f\"{amount:010d}\".encode('ascii') +\r\n\u001b[?2004l\r"]
[540.261071, "o", "\u001b[?2004h> "]
[540.261203, "o", "            seller_id.encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.261243, "o", "> "]
[540.261451, "o", "            buyer_id.encode('ascii')\r\n\u001b[?2004l\r"]
[540.261559, "o", "\u001b[?2004h> "]
[540.26168, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.261826, "o", "        f.write(record)\r\n\u001b[?2004l\r"]
[540.261998, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[540.262142, "o", "\u001b[?2004h> def main():\r\n\u001b[?2004l\r"]
[540.262239, "o", "\u001b[?2004h> "]
[540.262364, "o", "    # Read input\r\n\u001b[?2004l\r"]
[540.262478, "o", "\u001b[?2004h> "]
[540.262835, "o", "    input_data = read_input_file('src/INPUT.DAT')\r\n\u001b[?2004l\r"]
[540.262926, "o", "\u001b[?2004h> "]
[540.263161, "o", "    if input_data is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.26333, "o", "        return\r\n\u001b[?2004l\r"]
[540.263466, "o", "\u001b[?2004h> "]
[540.263533, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[540.263662, "o", "> "]
[540.263908, "o", "    buyer_id = input_data['buyer_id']\r\n\u001b[?2004l\r"]
[540.263995, "o", "\u001b[?2004h> "]
[540.264278, "o", "    seller_id = input_data['seller_id']\r\n\u001b[?2004l\r"]
[540.264368, "o", "\u001b[?2004h> "]
[540.264663, "o", "    book_id = input_data['book_id']\r\n\u001b[?2004l\r"]
[540.264751, "o", "\u001b[?2004h> "]
[540.265023, "o", "    amount = input_data['amount']\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.265157, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[540.265309, "o", "> "]
[540.265455, "o", "    # Validate users and book\r\n\u001b[?2004l\r"]
[540.265546, "o", "\u001b[?2004h> "]
[540.26592, "o", "    accounts = read_accounts('data/ACCOUNTS.DAT')\r\n\u001b[?2004l\r"]
[540.266022, "o", "\u001b[?2004h> "]
[540.266295, "o", "    books = read_books('data/BOOKS.DAT')\r\n\u001b[?2004l\r"]
[540.266387, "o", "\u001b[?2004h> "]
[540.266484, "o", "    \r\n\u001b[?2004l\r"]
[540.266599, "o", "\u001b[?2004h> "]
[540.266779, "o", "    buyer_found = False\r\n\u001b[?2004l\r"]
[540.266872, "o", "\u001b[?2004h> "]
[540.267061, "o", "    seller_found = False\r\n\u001b[?2004l\r"]
[540.26719, "o", "\u001b[?2004h> "]
[540.26732, "o", "    book_found = False\r\n\u001b[?2004l\r"]
[540.267425, "o", "\u001b[?2004h> "]
[540.267606, "o", "    valid_owner = False\r\n\u001b[?2004l\r"]
[540.267776, "o", "\u001b[?2004h"]
[540.267871, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.268132, "o", "    for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.268237, "o", "> "]
[540.268553, "o", "        if account['id'] == buyer_id:\r\n\u001b[?2004l\r"]
[540.268701, "o", "\u001b[?2004h"]
[540.268786, "o", "> "]
[540.268957, "o", "            buyer_found = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.269056, "o", "> "]
[540.269306, "o", "        if account['id'] == seller_id:\r\n\u001b[?2004l\r"]
[540.269489, "o", "\u001b[?2004h> "]
[540.269655, "o", "            seller_found = True\r\n"]
[540.269779, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[540.269933, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.270151, "o", "    for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.270289, "o", "> "]
[540.270421, "o", "        if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.270694, "o", "            book_found = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.270874, "o", "> "]
[540.271095, "o", "            if book['owner'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.271188, "o", "> "]
[540.271432, "o", "                valid_owner = True\r\n\u001b[?2004l\r"]
[540.271592, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[540.271911, "o", "\u001b[?2004h> "]
[540.27207, "o", "    print(\" \")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[540.272177, "o", "\u001b[?2004h> "]
[540.272401, "o", "    # Process transaction if all validations pass\r\n\u001b[?2004l\r"]
[540.272504, "o", "\u001b[?2004h> "]
[540.27296, "o", "    if buyer_found and seller_found and book_found and valid_owner:\r\n\u001b[?2004l\r"]
[540.273102, "o", "\u001b[?2004h> "]
[540.273354, "o", "        # Update account balances\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.273509, "o", "> "]
[540.273699, "o", "        for account in accounts:\r\n\u001b[?2004l\r"]
[540.273863, "o", "\u001b[?2004h> "]
[540.274107, "o", "            if account['id'] == buyer_id:\r\n\u001b[?2004l\r"]
[540.274223, "o", "\u001b[?2004h> "]
[540.274539, "o", "                account['balance'] -= amount\r\n\u001b[?2004l\r"]
[540.27468, "o", "\u001b[?2004h> "]
[540.27492, "o", "            if account['id'] == seller_id:\r\n\u001b[?2004l\r"]
[540.275028, "o", "\u001b[?2004h> "]
[540.275321, "o", "                account['balance'] += amount\r\n"]
[540.335051, "o", "\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         write_accounts('data/ACCOUNTS.DAT', accounts)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         # Update book ownership\r\n\u001b[?2004l\r\u001b[?2004h>         for book in books:\r\n\u001b[?2004l\r\u001b[?2004h>             if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h>                 book['owner'] = buyer_id\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         write_books('data/BOOKS.DAT', books)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         # Append transaction record\r\n\u001b[?2004l\r\u001b[?2004h>         append_transaction('data/TRANSACTIONS.DAT', book_id, amount, seller_id, buyer_id)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[540.335399, "o", "        print(\"Transaction completed successfully\")\r\n\u001b[?2004l\r"]
[540.335454, "o", "\u001b[?2004h> "]
[540.335552, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.335767, "o", "> "]
[540.336, "o", "        print(\"Transaction failed due to validation errors\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[540.336126, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
