[384.365067, "i", "python3 << 'EOF'\nwith open('src/INPUT.DAT', 'rb') as f:\n    data = f.read()\n    print(f\"INPUT.DAT: {repr(data)}\")\n    print(f\"Length: {len(data)} bytes\")\n    \n# The COBOL program expects:\n# INPUT-BUYER-ID   PIC X(4)  -> bytes 0-3\n# INPUT-SELLER-ID  PIC X(4)  -> bytes 4-7  \n# INPUT-BOOK-ID    PIC X(4)  -> bytes 8-11\n# INPUT-AMOUNT     PIC 9(10) -> bytes 12-21 (but file only has 15 bytes total)\n\n# When COBOL reads beyond file length, remaining bytes are typically spaces or zeros\n# The \"200\" at position 12-14 would be read, then padded\nprint(f\"\\nBuyer: {data[0:4]}\")\nprint(f\"Seller: {data[4:8]}\")\nprint(f\"Book: {data[8:12]}\")\nprint(f\"Amount bytes: {data[12:15]}\")\nprint(f\"Amount as string: '{data[12:15].decode()}'\")\nEOF\n"]
