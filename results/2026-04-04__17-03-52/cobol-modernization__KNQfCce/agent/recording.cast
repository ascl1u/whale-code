[580.145202, "i", "python3 << 'EOF'\nwith open('cobol_output/ACCOUNTS.DAT', 'rb') as f:\n    cobol = f.read()\nwith open('data/ACCOUNTS.DAT', 'rb') as f:\n    python = f.read()\n\nprint(f\"COBOL length: {len(cobol)}\")\nprint(f\"Python length: {len(python)}\")\nprint(f\"\\nCOBOL:  {repr(cobol)}\")\nprint(f\"\\nPython: {repr(python)}\")\n\n# Find the difference\nfor i in range(min(len(cobol), len(python))):\n    if cobol[i] != python[i]:\n        print(f\"\\nFirst difference at byte {i}:\")\n        print(f\"COBOL:  {repr(cobol[max(0,i-5):i+15])}\")\n        print(f\"Python: {repr(python[max(0,i-5):i+15])}\")\n        break\nEOF\n"]
