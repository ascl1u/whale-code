[680.537158, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r\r\n\r\n"]
[680.537307, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.537682, "o", "def read_input_file(filename):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.538292, "o", "    \"\"\"Read the input file and parse the transaction data.\"\"\"\r\n\u001b[?2004l\r"]
[680.53845, "o", "\u001b[?2004h> "]
[680.538941, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r \u001b[?2004h"]
[680.53908, "o", "> "]
[680.53943, "o", "        data = f.read()\r\n\u001b[?2004l\r"]
[680.539602, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[680.539673, "o", "> "]
[680.539978, "o", "    if len(data) == 0:\r\n\u001b[?2004l\rn"]
[680.540118, "o", "\u001b[?2004h> "]
[680.540671, "o", "        print(\"Error: Input file is empty\")\r\n\u001b[?2004l\r"]
[680.540723, "o", "\u001b[?2004h> "]
[680.540984, "o", "        return None\r\n\u001b[?2004l\r"]
[680.541148, "o", "\u001b[?2004h>     \r\n"]
[680.541245, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[680.541567, "o", "    # Parse input record\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.541658, "o", "> "]
[680.542028, "o", "    buyer_id = data[0:4].decode('ascii')\r\n\u001b[?2004l\r"]
[680.542077, "o", "\u001b[?2004h> "]
[680.542617, "o", "    seller_id = data[4:8].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.542733, "o", "> "]
[680.54305, "o", "    book_id = data[8:12].decode('ascii')\r\n\u001b[?2004l\r\r\n\u001b[?2004h"]
[680.543164, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.543924, "o", "    # Handle the amount field - COBOL expects 10 bytes but file may have less\r\n\u001b[?2004l\r"]
[680.544035, "o", "\u001b[?2004h> "]
[680.544733, "o", "    # When COBOL reads beyond file end, it pads with spaces\r\n\u001b[?2004l\r"]
[680.544773, "o", "\u001b[?2004h> "]
[680.545279, "o", "    # PIC 9(10) field starting at position 12\r\n\u001b[?2004l\re\u001b[?2004h"]
[680.545429, "o", "> "]
[680.546045, "o", "    amount_bytes = data[12:] if len(data) > 12 else b''\r\n\u001b[?2004l\r"]
[680.546147, "o", "\u001b[?2004h> "]
[680.546657, "o", "    # Pad to 10 bytes with spaces (COBOL behavior)\r\n\u001b[?2004l\r"]
[680.54681, "o", "\u001b[?2004h> "]
[680.547748, "o", "    amount_str = (amount_bytes + b' ' * 10)[:10].decode('ascii')\r\n\u001b[?2004l\r"]
[680.547866, "o", "\u001b[?2004h> "]
[680.549167, "o", "    # Convert to numeric - spaces on right are treated as zeros in COBOL numeric context\r\n\u001b[?2004l\r"]
[680.549274, "o", "\u001b[?2004h> "]
[680.550504, "o", "    # \"200       \" becomes 2000000000 when interpreted left-to-right\r\n\u001b[?2004l\r"]
[680.550604, "o", "\u001b[?2004h"]
[680.550742, "o", "> "]
[680.551447, "o", "    amount_str_stripped = amount_str.rstrip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.551841, "o", "    if amount_str_stripped:\r\n\u001b[?2004l\r"]
[680.55196, "o", "\u001b[?2004h> "]
[680.552425, "o", "        # Pad with zeros on the right to make 10 digits\r\n\u001b[?2004l\r"]
[680.552554, "o", "\u001b[?2004h> "]
[680.553378, "o", "        amount = int(amount_str_stripped.ljust(10, '0'))\r\n\u001b[?2004l\r"]
[680.553494, "o", "\u001b[?2004h> "]
[680.553587, "o", "    else:\r\n\u001b[?2004l\r"]
[680.553664, "o", "\u001b[?2004h> "]
[680.553896, "o", "        amount = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.554014, "o", "> "]
[680.554081, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.554199, "o", "    return {\r\n\u001b[?2004l\r"]
[680.554287, "o", "\u001b[?2004h> "]
[680.554606, "o", "        'buyer_id': buyer_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.55478, "o", "> "]
[680.554924, "o", "        'seller_id': seller_id,\r\n\u001b[?2004l\rn\u001b[?2004h"]
[680.555041, "o", "> "]
[680.555263, "o", "        'book_id': book_id,\r\n\u001b[?2004l\r \u001b[?2004h"]
[680.55542, "o", "> "]
[680.555559, "o", "        'amount': amount\r\n\u001b[?2004l\r"]
[680.555678, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\rACCOUN\u001b[?2004h"]
[680.555753, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.55604, "o", "def read_accounts(filename):\r\n\u001b[?2004l\r"]
[680.556159, "o", "\u001b[?2004h> "]
[680.556384, "o", "    \"\"\"Read all account records.\"\"\"\r\n\u001b[?2004l\r"]
[680.55649, "o", "\u001b[?2004h> "]
[680.55663, "o", "    accounts = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.55716, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[680.557283, "o", "\u001b[?2004h> "]
[680.557487, "o", "        data = f.read()\r\n\u001b[?2004l\r"]
[680.557579, "o", "\u001b[?2004h"]
[680.55768, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[680.557739, "o", "> "]
[680.558431, "o", "    # Each account record is 34 bytes: ID(4) + Name(20) + Balance(10)\r\n\u001b[?2004l\r"]
[680.558556, "o", "\u001b[?2004h> "]
[680.558722, "o", "    record_size = 34\r\n\u001b[?2004l\r"]
[680.558811, "o", "\u001b[?2004h> "]
[680.559313, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\rc\u001b[?2004h"]
[680.559442, "o", "> "]
[680.559999, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r"]
[680.560099, "o", "\u001b[?2004h> "]
[680.560613, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r"]
[680.560662, "o", "\u001b[?2004h> "]
[680.560931, "o", "            account = {\r\n\u001b[?2004l\r"]
[680.561042, "o", "\u001b[?2004h> "]
[680.561692, "o", "                'id': record[0:4].decode('ascii'),\r\n\u001b[?2004l\rns\u001b[?2004h"]
[680.561807, "o", "> "]
[680.562469, "o", "                'name': record[4:24].decode('ascii'),\r\n\u001b[?2004l\r"]
[680.562622, "o", "\u001b[?2004h> "]
[680.562932, "o", "                'balance': int(record[24:34].decode('ascii'))\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.563055, "o", "> "]
[680.563189, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.563282, "o", "> "]
[680.563439, "o", "            accounts.append(account)\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.563577, "o", "> "]
[680.563712, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.563956, "o", "    return accounts\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.564008, "o", "> \r\n\u001b[?2004l\r"]
[680.564042, "o", "\u001b[?2004h"]
[680.564241, "o", "> "]
[680.564428, "o", "def read_books(filename):\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.564585, "o", "> "]
[680.56476, "o", "    \"\"\"Read all book records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.564852, "o", "> "]
[680.565037, "o", "    books = []\r\n\u001b[?2004l\r"]
[680.565186, "o", "\u001b[?2004h> "]
[680.565414, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[680.565504, "o", "\u001b[?2004h> "]
[680.565697, "o", "        data = f.read()\r\n"]
[680.565798, "o", "\u001b[?2004l\r"]
[680.565844, "o", "\u001b[?2004h> "]
[680.565888, "o", "    \r\n\u001b[?2004l\r"]
[680.566018, "o", "\u001b[?2004h> "]
[680.566489, "o", "    # Each book record is 28 bytes: ID(4) + Title(20) + Owner(4)\r\n\u001b[?2004l\r"]
[680.566544, "o", "\u001b[?2004h> "]
[680.566767, "o", "    record_size = 28\r\n\u001b[?2004l\r"]
[680.566893, "o", "\u001b[?2004h> "]
[680.567193, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\r"]
[680.567241, "o", "\u001b[?2004h"]
[680.567291, "o", "> "]
[680.567471, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r"]
[680.567562, "o", "\u001b[?2004h"]
[680.567638, "o", "> "]
[680.567758, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.567878, "o", "> "]
[680.567972, "o", "            book = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.568226, "o", "                'id': record[0:4].decode('ascii'),\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.568307, "o", "> "]
[680.568569, "o", "                'title': record[4:24].decode('ascii'),\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.568659, "o", "> "]
[680.569046, "o", "                'owner': record[24:28].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.569143, "o", "> "]
[680.569211, "o", "            }\r\n\u001b[?2004l\r"]
[680.569322, "o", "\u001b[?2004h> "]
[680.569527, "o", "            books.append(book)\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.569569, "o", ">     "]
[680.569674, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.569813, "o", "> "]
[680.569978, "o", "    return books\r\n\u001b[?2004l\r"]
[680.570081, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.570222, "o", "def write_accounts(filename, accounts):\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.570331, "o", "> "]
[680.570495, "o", "    \"\"\"Write all account records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.570631, "o", "> "]
[680.570731, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.570824, "o", "> "]
[680.570963, "o", "        for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.571001, "o", "> "]
[680.571315, "o", "            # Format: ID(4) + Name(20) + Balance(10)\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.571383, "o", "> "]
[680.571798, "o", "            # COBOL PIC 9(10) with REWRITE drops the minus sign for negative numbers\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.571913, "o", "> "]
[680.572394, "o", "            # It essentially takes the rightmost 10 digits of the string representation\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.572575, "o", "> "]
[680.572859, "o", "            balance_str = str(account['balance'])\r\n\u001b[?2004l\r"]
[680.572956, "o", "\u001b[?2004h> "]
[680.573325, "o", "            # Take last 10 characters (drops minus sign if present)\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.573427, "o", "> "]
[680.573703, "o", "            balance_formatted = balance_str[-10:].zfill(10)\r\n\u001b[?2004l\r"]
[680.57384, "o", "\u001b[?2004h> "]
[680.573956, "o", "            record = (\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.574089, "o", "> "]
[680.574277, "o", "                account['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.574411, "o", "> "]
[680.574645, "o", "                account['name'].encode('ascii') +\r\n\u001b[?2004l\r"]
[680.574774, "o", "\u001b[?2004h> "]
[680.574995, "o", "                balance_formatted.encode('ascii')\r\n\u001b[?2004l\r"]
[680.575098, "o", "\u001b[?2004h> "]
[680.575189, "o", "            )\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.628018, "o", "> "]
[680.628261, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def write_books(filename, books):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Write all book records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h>         for book in books:\r\n\u001b[?2004l\r\u001b[?2004h>             # Format: ID(4) + Title(20) + Owner(4)\r\n\u001b[?2004l\r\u001b[?2004h>             record = (\r\n\u001b[?2004l\r\u001b[?2004h>                 book['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h>                 book['title'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h>                 book['owner'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h>             )\r\n\u001b[?2004l\r\u001b[?2004h>             f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def append_transaction(filename, book_id, amount, seller_id, buyer_id):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Append a transaction record.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     with open(filename, 'ab') as f:\r\n\u001b[?2004l\r\u001b[?2004h>         # Format: Book(4) + Amount(10) + Seller(4) + Buyer(4)\r\n\u001b[?2004l\r\u001b[?2004h>         record = (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.628417, "o", "            book_id.encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.628629, "o", "            f\"{amount:010d}\".encode('ascii') +\r\n\u001b[?2004l\r"]
[680.628723, "o", "\u001b[?2004h> "]
[680.62913, "o", "            seller_id.encode('ascii') +\r\n\u001b[?2004l\r"]
[680.629308, "o", "\u001b[?2004h> "]
[680.629558, "o", "            buyer_id.encode('ascii')\r\n\u001b[?2004l\r"]
[680.629701, "o", "\u001b[?2004h> "]
[680.629929, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.630103, "o", "        f.write(record)\r\n\u001b[?2004l\r"]
[680.63025, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[680.63037, "o", "> "]
[680.630529, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.63069, "o", "    # Read input"]
[680.630763, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.630893, "o", "> "]
[680.631201, "o", "    input_data = read_input_file('src/INPUT.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.631358, "o", "> "]
[680.631528, "o", "    if input_data is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.631687, "o", "> "]
[680.631903, "o", "        return\r\n\u001b[?2004l\r"]
[680.632066, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.632343, "o", "    buyer_id = input_data['buyer_id']\r\n\u001b[?2004l\r"]
[680.632492, "o", "\u001b[?2004h> "]
[680.632823, "o", "    seller_id = input_data['seller_id']\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.632928, "o", "> "]
[680.633227, "o", "    book_id = input_data['book_id']\r\n\u001b[?2004l\r"]
[680.633402, "o", "\u001b[?2004h> "]
[680.633636, "o", "    amount = input_data['amount']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.633701, "o", "    \r\n\u001b[?2004l\r"]
[680.63378, "o", "\u001b[?2004h"]
[680.633905, "o", "> "]
[680.63406, "o", "    # Validate users and book\r\n\u001b[?2004l\r"]
[680.634106, "o", "\u001b[?2004h> "]
[680.634498, "o", "    accounts = read_accounts('data/ACCOUNTS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.634643, "o", "> "]
[680.634828, "o", "    books = read_books('data/BOOKS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.635017, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.635082, "o", "    buyer_found = False\r\n\u001b[?2004l\r"]
[680.635287, "o", "\u001b[?2004h> "]
[680.635439, "o", "    seller_found = False\r\n\u001b[?2004l\r"]
[680.635576, "o", "\u001b[?2004h> "]
[680.635737, "o", "    book_found = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.635866, "o", "> "]
[680.636107, "o", "    valid_owner = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.636258, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[680.636381, "o", "> "]
[680.636543, "o", "    for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.636904, "o", "        if account['id'] == buyer_id:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.637241, "o", "            buyer_found = True\r\n\u001b[?2004l\r"]
[680.637446, "o", "\u001b[?2004h> "]
[680.637568, "o", "        if account['id'] == seller_id:\r\n\u001b[?2004l\r"]
[680.637698, "o", "\u001b[?2004h> "]
[680.637836, "o", "            seller_found = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.638032, "o", "> "]
[680.63817, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.638356, "o", "    for book in books:\r\n\u001b[?2004l\r"]
[680.638462, "o", "\u001b[?2004h> "]
[680.638603, "o", "        if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.638731, "o", "> "]
[680.638889, "o", "            book_found = True\r\n\u001b[?2004l\r"]
[680.639023, "o", "\u001b[?2004h> "]
[680.639345, "o", "            if book['owner'] == seller_id:\r\n\u001b[?2004l\r"]
[680.639395, "o", "\u001b[?2004h> "]
[680.63974, "o", "                valid_owner = True\r\n\u001b[?2004l\r"]
[680.639884, "o", "\u001b[?2004h> "]
[680.640112, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[680.640203, "o", "> "]
[680.640486, "o", "    print(\" \")\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.640674, "o", ">     \r\n\u001b[?2004l\r"]
[680.640918, "o", "\u001b[?2004h> "]
[680.64114, "o", "    # Process transaction if all validations pass\r\n\u001b[?2004l\r"]
[680.641266, "o", "\u001b[?2004h> "]
[680.64159, "o", "    if buyer_found and seller_found and book_found and valid_owner:\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.641668, "o", "> "]
[680.641936, "o", "        # Update account balances\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.642285, "o", "        for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.642458, "o", "> "]
[680.642678, "o", "            if account['id'] == buyer_id:\r\n\u001b[?2004l\r"]
[680.642823, "o", "\u001b[?2004h> "]
[680.643081, "o", "                account['balance'] -= amount\r\n\u001b[?2004l\r"]
[680.643213, "o", "\u001b[?2004h> "]
[680.643425, "o", "            if account['id'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.643575, "o", "> "]
[680.643751, "o", "                account['balance'] += amount\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.643855, "o", "> "]
[680.643941, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[680.644072, "o", "> "]
[680.644377, "o", "        write_accounts('data/ACCOUNTS.DAT', accounts)\r\n\u001b[?2004l\r"]
[680.644482, "o", "\u001b[?2004h> "]
[680.644638, "o", "        \r\n\u001b[?2004l\r"]
[680.644832, "o", "\u001b[?2004h> "]
[680.644977, "o", "        # Update book ownership\r\n\u001b[?2004l\r"]
[680.645135, "o", "\u001b[?2004h> "]
[680.645282, "o", "        for book in books:\r\n\u001b[?2004l\r"]
[680.645387, "o", "\u001b[?2004h"]
[680.645515, "o", "> "]
[680.645702, "o", "            if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.645986, "o", "                book['owner'] = buyer_id\r\n\u001b[?2004l\r"]
[680.646133, "o", "\u001b[?2004h> "]
[680.646279, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.646529, "o", "        write_books('data/BOOKS.DAT', books)\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.646663, "o", "> "]
[680.646745, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.647161, "o", "        # Append transaction record\r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.647813, "o", "        append_transaction('data/TRANSACTIONS.DAT', book_id, amount, seller_id, buyer_id)\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.648, "o", "> "]
[680.648164, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[680.64847, "o", "        print(\"Transaction completed successfully\")\r\n\u001b[?2004l\r"]
[680.648604, "o", "\u001b[?2004h> "]
[680.648752, "o", "    else:\r\n\u001b[?2004l\r"]
[680.648841, "o", "\u001b[?2004h> "]
[680.649228, "o", "        print(\"Transaction failed due to validation errors\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.649282, "o", "> \r\n\u001b[?2004l\r"]
[680.649484, "o", "\u001b[?2004h> "]
[680.649621, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h"]
[680.649732, "o", "> "]
