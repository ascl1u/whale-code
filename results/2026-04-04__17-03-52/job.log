Sending keys: ['cat > /app/program.py << \'EOF\'\n#!/usr/bin/env python3\n\ndef read_input_file(filename):\n    """Read the input file and parse the transaction data."""\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    if len(data) == 0:\n        print("Error: Input file is empty")\n        return None\n    \n    # Parse fixed-width fields\n    # INPUT-BUYER-ID   PIC X(4)\n    # INPUT-SELLER-ID  PIC X(4)\n    # INPUT-BOOK-ID    PIC X(4)\n    # INPUT-AMOUNT     PIC 9(10)\n    \n    buyer_id = data[0:4].decode(\'ascii\')\n    seller_id = data[4:8].decode(\'ascii\')\n    book_id = data[8:12].decode(\'ascii\')\n    \n    # Handle amount field - may be shorter than 10 bytes in the file\n    if len(data) > 12:\n        amount_str = data[12:].decode(\'ascii\')\n        # Pad with leading zeros to make it 10 digits\n        amount_str = amount_str.zfill(10)\n    else:\n        amount_str = \'0000000000\'\n    \n    amount = int(amount_str)\n    \n    return {\n        \'buyer_id\': buyer_id,\n        \'seller_id\': seller_id,\n        \'book_id\': book_id,\n        \'amount\': amount\n    }\n\ndef read_accounts(filename):\n    """Read all account records."""\n    accounts = []\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    # Each account record is 34 bytes:\n    # ACCOUNT-ID        PIC X(4)   - 4 bytes\n    # ACCOUNT-NAME      PIC X(20)  - 20 bytes\n    # ACCOUNT-BALANCE   PIC 9(10)  - 10 bytes\n    record_size = 34\n    \n    for i in range(0, len(data), record_size):\n        if i + record_size <= len(data):\n            record = data[i:i+record_size]\n            account = {\n                \'id\': record[0:4].decode(\'ascii\'),\n                \'name\': record[4:24].decode(\'ascii\'),\n                \'balance\': int(record[24:34].decode(\'ascii\'))\n            }\n            accounts.append(account)\n    \n    return accounts\n\ndef write_accounts(filename, accounts):\n    """Write all account records back to file."""\n    with open(filename, \'wb\') as f:\n        for account in accounts:\n            record = (\n                account[\'id\'].encode(\'ascii\') +\n                account[\'name\'].encode(\'ascii\') +\n                str(account[\'balance\']).zfill(10).encode(\'ascii\')\n            )\n            f.write(record)\n\ndef read_books(filename):\n    """Read all book records."""\n    books = []\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    # Each book record is 28 bytes:\n    # BOOK-ID          PIC X(4)   - 4 bytes\n    # BOOK-TITLE       PIC X(20)  - 20 bytes\n    # BOOK-OWNER       PIC X(4)   - 4 bytes\n    record_size = 28\n    \n    for i in range(0, len(data), record_size):\n        if i + record_size <= len(data):\n            record = data[i:i+record_size]\n            book = {\n                \'id\': record[0:4].decode(\'ascii\'),\n                \'title\': record[4:24].decode(\'ascii\'),\n                \'owner\': record[24:28].decode(\'ascii\')\n            }\n            books.append(book)\n    \n    return books\n\ndef write_books(filename, books):\n    """Write all book records back to file."""\n    with open(filename, \'wb\') as f:\n        for book in books:\n            record = (\n                book[\'id\'].encode(\'ascii\') +\n                book[\'title\'].encode(\'ascii\') +\n                book[\'owner\'].encode(\'ascii\')\n            )\n            f.write(record)\n\ndef append_transaction(filename, transaction):\n    """Append a transaction record to the file."""\n    with open(filename, \'ab\') as f:\n        # Each transaction record is 22 bytes:\n        # TRANS-BOOK       PIC X(4)   - 4 bytes\n        # TRANS-AMOUNT     PIC 9(10)  - 10 bytes\n        # TRANS-SELLER     PIC X(4)   - 4 bytes\n        # TRANS-BUYER      PIC X(4)   - 4 bytes\n        record = (\n            transaction[\'book_id\'].encode(\'ascii\') +\n            str(transaction[\'amount\']).zfill(10).encode(\'ascii\') +\n            transaction[\'seller_id\'].encode(\'ascii\') +\n            transaction[\'buyer_id\'].encode(\'ascii\')\n        )\n        f.write(record)\n\ndef validate_and_process_transaction():\n    """Main logic to validate and process the transaction."""\n    # Read input\n    transaction = read_input_file(\'src/INPUT.DAT\')\n    if transaction is None:\n        return\n    \n    buyer_id = transaction[\'buyer_id\']\n    seller_id = transaction[\'seller_id\']\n    book_id = transaction[\'book_id\']\n    amount = transaction[\'amount\']\n    \n    # Validate users and book\n    accounts = read_accounts(\'data/ACCOUNTS.DAT\')\n    books = read_books(\'data/BOOKS.DAT\')\n    \n    buyer_found = False\n    seller_found = False\n    book_found = False\n    valid_owner = False\n    \n    # Check if buyer and seller exist\n    for account in accounts:\n        if account[\'id\'] == buyer_id:\n            buyer_found = True\n        if account[\'id\'] == seller_id:\n            seller_found = True\n    \n    # Check if book exists and seller owns it\n    for book in books:\n        if book[\'id\'] == book_id:\n            book_found = True\n            if book[\'owner\'] == seller_id:\n                valid_owner = True\n    \n    print(" ")\n    \n    # If validation passes, process the transaction\n    if buyer_found and seller_found and book_found and valid_owner:\n        # Update account balances\n        for account in accounts:\n            if account[\'id\'] == buyer_id:\n                account[\'balance\'] -= amount\n            if account[\'id\'] == seller_id:\n                account[\'balance\'] += amount\n        write_accounts(\'data/ACCOUNTS.DAT\', accounts)\n        \n        # Update book ownership\n        for book in books:\n            if book[\'id\'] == book_id:\n                book[\'owner\'] = buyer_id\n        write_books(\'data/BOOKS.DAT\', books)\n        \n        # Append transaction record\n        append_transaction(\'data/TRANSACTIONS.DAT\', transaction)\n        \n        print("Transaction completed successfully")\n    else:\n        print("Transaction failed due to validation errors")\n\nif __name__ == \'__main__\':\n    validate_and_process_transaction()\nEOF\n'] min_timeout_sec: 1 max_timeout_sec: 180.0
