Sending keys: ['cat > /app/program.py << \'EOF\'\n#!/usr/bin/env python3\n\ndef read_input_file(filename):\n    """Read the input file and parse the transaction data."""\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    if len(data) == 0:\n        print("Error: Input file is empty")\n        return None\n    \n    # Parse input based on COBOL structure\n    # INPUT-BUYER-ID: PIC X(4)\n    # INPUT-SELLER-ID: PIC X(4)\n    # INPUT-BOOK-ID: PIC X(4)\n    # INPUT-AMOUNT: PIC 9(10)\n    \n    buyer_id = data[0:4].decode(\'ascii\')\n    seller_id = data[4:8].decode(\'ascii\')\n    book_id = data[8:12].decode(\'ascii\')\n    \n    # Handle variable-length amount field\n    if len(data) >= 22:\n        amount_str = data[12:22].decode(\'ascii\')\n    else:\n        amount_str = data[12:].decode(\'ascii\')\n    \n    # Convert amount to integer\n    amount = int(amount_str)\n    \n    return {\n        \'buyer_id\': buyer_id,\n        \'seller_id\': seller_id,\n        \'book_id\': book_id,\n        \'amount\': amount\n    }\n\ndef read_accounts_file(filename):\n    """Read accounts file and return list of account records."""\n    accounts = []\n    with open(filename, \'rb\') as f:\n        while True:\n            record = f.read(34)  # 4 + 20 + 10\n            if not record:\n                break\n            account_id = record[0:4].decode(\'ascii\')\n            account_name = record[4:24].decode(\'ascii\')\n            account_balance = int(record[24:34].decode(\'ascii\'))\n            accounts.append({\n                \'id\': account_id,\n                \'name\': account_name,\n                \'balance\': account_balance\n            })\n    return accounts\n\ndef read_books_file(filename):\n    """Read books file and return list of book records."""\n    books = []\n    with open(filename, \'rb\') as f:\n        while True:\n            record = f.read(28)  # 4 + 20 + 4\n            if not record:\n                break\n            book_id = record[0:4].decode(\'ascii\')\n            book_title = record[4:24].decode(\'ascii\')\n            book_owner = record[24:28].decode(\'ascii\')\n            books.append({\n                \'id\': book_id,\n                \'title\': book_title,\n                \'owner\': book_owner\n            })\n    return books\n\ndef write_accounts_file(filename, accounts):\n    """Write accounts to file."""\n    with open(filename, \'wb\') as f:\n        for account in accounts:\n            record = (\n                account[\'id\'].encode(\'ascii\') +\n                account[\'name\'].encode(\'ascii\') +\n                f"{account[\'balance\']:010d}".encode(\'ascii\')\n            )\n            f.write(record)\n\ndef write_books_file(filename, books):\n    """Write books to file."""\n    with open(filename, \'wb\') as f:\n        for book in books:\n            record = (\n                book[\'id\'].encode(\'ascii\') +\n                book[\'title\'].encode(\'ascii\') +\n                book[\'owner\'].encode(\'ascii\')\n            )\n            f.write(record)\n\ndef append_transaction(filename, trans_data):\n    """Append transaction to transactions file."""\n    with open(filename, \'ab\') as f:\n        record = (\n            trans_data[\'book_id\'].encode(\'ascii\') +\n            f"{trans_data[\'amount\']:010d}".encode(\'ascii\') +\n            trans_data[\'seller_id\'].encode(\'ascii\') +\n            trans_data[\'buyer_id\'].encode(\'ascii\')\n        )\n        f.write(record)\n\ndef validate_and_process():\n    """Main function to validate and process transaction."""\n    # Read input\n    input_data = read_input_file(\'src/INPUT.DAT\')\n    if input_data is None:\n        return\n    \n    buyer_id = input_data[\'buyer_id\']\n    seller_id = input_data[\'seller_id\']\n    book_id = input_data[\'book_id\']\n    amount = input_data[\'amount\']\n    \n    # Read accounts and books\n    accounts = read_accounts_file(\'data/ACCOUNTS.DAT\')\n    books = read_books_file(\'data/BOOKS.DAT\')\n    \n    # Validate\n    buyer_found = False\n    seller_found = False\n    book_found = False\n    valid_owner = False\n    \n    for account in accounts:\n        if account[\'id\'] == buyer_id:\n            buyer_found = True\n        if account[\'id\'] == seller_id:\n            seller_found = True\n    \n    for book in books:\n        if book[\'id\'] == book_id:\n            book_found = True\n            if book[\'owner\'] == seller_id:\n                valid_owner = True\n    \n    print(" ")\n    \n    if buyer_found and seller_found and book_found and valid_owner:\n        # Process transaction\n        # Update account balances\n        for account in accounts:\n            if account[\'id\'] == buyer_id:\n                account[\'balance\'] -= amount\n            if account[\'id\'] == seller_id:\n                account[\'balance\'] += amount\n        \n        # Update book ownership\n        for book in books:\n            if book[\'id\'] == book_id:\n                book[\'owner\'] = buyer_id\n        \n        # Write updated files\n        write_accounts_file(\'data/ACCOUNTS.DAT\', accounts)\n        write_books_file(\'data/BOOKS.DAT\', books)\n        \n        # Append transaction\n        append_transaction(\'data/TRANSACTIONS.DAT\', {\n            \'book_id\': book_id,\n            \'amount\': amount,\n            \'seller_id\': seller_id,\n            \'buyer_id\': buyer_id\n        })\n        \n        print("Transaction completed successfully")\n    else:\n        print("Transaction failed due to validation errors")\n\nif __name__ == \'__main__\':\n    validate_and_process()\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
