Sending keys: ['cat > /app/program.py << \'EOF\'\n#!/usr/bin/env python3\n\ndef read_input_file(filename):\n    """Read the input file and parse the transaction data."""\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    if len(data) == 0:\n        print("Error: Input file is empty")\n        return None\n    \n    # Parse input record\n    buyer_id = data[0:4].decode(\'ascii\')\n    seller_id = data[4:8].decode(\'ascii\')\n    book_id = data[8:12].decode(\'ascii\')\n    \n    # Handle the amount field - COBOL expects 10 bytes but file may have less\n    # When COBOL reads beyond file end, it pads with spaces\n    # PIC 9(10) field starting at position 12\n    amount_bytes = data[12:] if len(data) > 12 else b\'\'\n    # Pad to 10 bytes with spaces (COBOL behavior)\n    amount_str = (amount_bytes + b\' \' * 10)[:10].decode(\'ascii\')\n    # Convert to numeric - spaces on right are treated as zeros in COBOL numeric context\n    # "200       " becomes 2000000000 when interpreted left-to-right\n    amount_str_stripped = amount_str.rstrip()\n    if amount_str_stripped:\n        # Pad with zeros on the right to make 10 digits\n        amount = int(amount_str_stripped.ljust(10, \'0\'))\n    else:\n        amount = 0\n    \n    return {\n        \'buyer_id\': buyer_id,\n        \'seller_id\': seller_id,\n        \'book_id\': book_id,\n        \'amount\': amount\n    }\n\ndef read_accounts(filename):\n    """Read all account records."""\n    accounts = []\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    # Each account record is 34 bytes: ID(4) + Name(20) + Balance(10)\n    record_size = 34\n    for i in range(0, len(data), record_size):\n        if i + record_size <= len(data):\n            record = data[i:i+record_size]\n            account = {\n                \'id\': record[0:4].decode(\'ascii\'),\n                \'name\': record[4:24].decode(\'ascii\'),\n                \'balance\': int(record[24:34].decode(\'ascii\'))\n            }\n            accounts.append(account)\n    \n    return accounts\n\ndef read_books(filename):\n    """Read all book records."""\n    books = []\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    # Each book record is 28 bytes: ID(4) + Title(20) + Owner(4)\n    record_size = 28\n    for i in range(0, len(data), record_size):\n        if i + record_size <= len(data):\n            record = data[i:i+record_size]\n            book = {\n                \'id\': record[0:4].decode(\'ascii\'),\n                \'title\': record[4:24].decode(\'ascii\'),\n                \'owner\': record[24:28].decode(\'ascii\')\n            }\n            books.append(book)\n    \n    return books\n\ndef write_accounts(filename, accounts):\n    """Write all account records."""\n    with open(filename, \'wb\') as f:\n        for account in accounts:\n            # Format: ID(4) + Name(20) + Balance(10)\n            # COBOL PIC 9(10) is unsigned, use modulo to handle overflow/underflow\n            balance = account[\'balance\'] % (10 ** 10)\n            record = (\n                account[\'id\'].encode(\'ascii\') +\n                account[\'name\'].encode(\'ascii\') +\n                f"{balance:010d}".encode(\'ascii\')\n            )\n            f.write(record)\n\ndef write_books(filename, books):\n    """Write all book records."""\n    with open(filename, \'wb\') as f:\n        for book in books:\n            # Format: ID(4) + Title(20) + Owner(4)\n            record = (\n                book[\'id\'].encode(\'ascii\') +\n                book[\'title\'].encode(\'ascii\') +\n                book[\'owner\'].encode(\'ascii\')\n            )\n            f.write(record)\n\ndef append_transaction(filename, book_id, amount, seller_id, buyer_id):\n    """Append a transaction record."""\n    with open(filename, \'ab\') as f:\n        # Format: Book(4) + Amount(10) + Seller(4) + Buyer(4)\n        record = (\n            book_id.encode(\'ascii\') +\n            f"{amount:010d}".encode(\'ascii\') +\n            seller_id.encode(\'ascii\') +\n            buyer_id.encode(\'ascii\')\n        )\n        f.write(record)\n\ndef main():\n    # Read input\n    input_data = read_input_file(\'src/INPUT.DAT\')\n    if input_data is None:\n        return\n    \n    buyer_id = input_data[\'buyer_id\']\n    seller_id = input_data[\'seller_id\']\n    book_id = input_data[\'book_id\']\n    amount = input_data[\'amount\']\n    \n    # Validate users and book\n    accounts = read_accounts(\'data/ACCOUNTS.DAT\')\n    books = read_books(\'data/BOOKS.DAT\')\n    \n    buyer_found = False\n    seller_found = False\n    book_found = False\n    valid_owner = False\n    \n    for account in accounts:\n        if account[\'id\'] == buyer_id:\n            buyer_found = True\n        if account[\'id\'] == seller_id:\n            seller_found = True\n    \n    for book in books:\n        if book[\'id\'] == book_id:\n            book_found = True\n            if book[\'owner\'] == seller_id:\n                valid_owner = True\n    \n    print(" ")\n    \n    # Process transaction if all validations pass\n    if buyer_found and seller_found and book_found and valid_owner:\n        # Update account balances\n        for account in accounts:\n            if account[\'id\'] == buyer_id:\n                account[\'balance\'] -= amount\n            if account[\'id\'] == seller_id:\n                account[\'balance\'] += amount\n        \n        write_accounts(\'data/ACCOUNTS.DAT\', accounts)\n        \n        # Update book ownership\n        for book in books:\n            if book[\'id\'] == book_id:\n                book[\'owner\'] = buyer_id\n        \n        write_books(\'data/BOOKS.DAT\', books)\n        \n        # Append transaction record\n        append_transaction(\'data/TRANSACTIONS.DAT\', book_id, amount, seller_id, buyer_id)\n        \n        print("Transaction completed successfully")\n    else:\n        print("Transaction failed due to validation errors")\n\nif __name__ == \'__main__\':\n    main()\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
