[535.34, "o", "    if len(data) == 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.340044, "o", "> "]
[535.340528, "o", "        print(\"Error: Input file is empty\")\r\n\u001b[?2004l\r"]
[535.340632, "o", "\u001b[?2004h> "]
[535.340858, "o", "        return None\r\n\u001b[?2004l\r \u001b[?2004h"]
[535.341027, "o", ">     \r\n\u001b[?2004l\r"]
[535.341152, "o", "True\r\n\u001b[?2004h> "]
[535.341518, "o", "    # Parse fixed-width fields\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.341654, "o", "> "]
[535.342693, "o", "    # Buyer ID: 4 bytes, Seller ID: 4 bytes, Book ID: 4 bytes, Amount: remaining bytes (numeric)\r\n\u001b[?2004l\r"]
[535.342836, "o", "\u001b[?2004h> "]
[535.343005, "o", "    if len(data) < 12:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.343266, "o", "> "]
[535.343654, "o", "        print(\"Error: Input file too short\")\r\n\u001b[?2004l\r"]
[535.343781, "o", "\u001b[?2004h> "]
[535.343871, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.343992, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.344362, "o", "    buyer_id = data[0:4].decode('ascii')\r\n\u001b[?2004l\r"]
[535.344398, "o", "\u001b[?2004h> "]
[535.344742, "o", "    seller_id = data[4:8].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.345255, "o", "    book_id = data[8:12].decode('ascii')\r\n\u001b[?2004l\r"]
[535.345392, "o", "\u001b[?2004h> "]
[535.345461, "o", "    \r\n\u001b[?2004l\r"]
[535.345695, "o", "\u001b[?2004h> "]
[535.346295, "o", "    # Amount field - read remaining bytes as numeric string\r\n\u001b[?2004l\r"]
[535.346407, "o", "\u001b[?2004h> "]
[535.346673, "o", "    if len(data) > 12:\r\n\u001b[?2004l\r \u001b[?2004h"]
[535.346778, "o", "> "]
[535.347197, "o", "        amount_str = data[12:].decode('ascii').strip()\r\n\u001b[?2004l\r \u001b[?2004h"]
[535.3473, "o", "> "]
[535.347724, "o", "        amount = int(amount_str) if amount_str else 0\r\n\u001b[?2004l\ra\u001b[?2004h"]
[535.347824, "o", "> "]
[535.34794, "o", "    else:\r\n\u001b[?2004l\rd\u001b[?2004h> "]
[535.348027, "o", "        amount = 0\r\n\u001b[?2004l\r"]
[535.348107, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[535.348224, "o", "> "]
[535.34837, "o", "    return {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.348555, "o", "        'buyer_id': buyer_id,\r\n\u001b[?2004l\rh\u001b[?2004h"]
[535.348693, "o", "> "]
[535.348894, "o", "        'seller_id': seller_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.349047, "o", "> "]
[535.349295, "o", "        'book_id': book_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.349392, "o", "> "]
[535.349581, "o", "        'amount': amount\r\n\u001b[?2004l\r"]
[535.349675, "o", "\u001b[?2004h> "]
[535.349747, "o", "    }\r\n\u001b[?2004l\r"]
[535.34988, "o", "\u001b[?2004h> "]
[535.350063, "o", "\r\n\u001b[?2004l\rw\u001b[?2004h> "]
[535.350311, "o", "def read_accounts(filename):\r\n\u001b[?2004l\r \u001b[?2004h"]
[535.350407, "o", "> "]
[535.35096, "o", "    \"\"\"Read all account records from ACCOUNTS.DAT.\"\"\"\r\n\u001b[?2004l\r"]
[535.351139, "o", "\u001b[?2004h> "]
[535.351287, "o", "    accounts = []\r\n\u001b[?2004l\rn\u001b[?2004h"]
[535.351416, "o", "> "]
[535.351866, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[535.352001, "o", "\u001b[?2004h> "]
[535.352319, "o", "        data = f.read()\r\n\u001b[?2004l\r"]
[535.352402, "o", "\u001b[?2004h> "]
[535.352442, "o", "    \r\n"]
[535.35254, "o", "\u001b[?2004l\r"]
[535.35263, "o", "\u001b[?2004h> "]
[535.353614, "o", "    # Each account record is 34 bytes: 4 (ID) + 20 (Name) + 10 (Balance)\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.353733, "o", "> "]
[535.353902, "o", "    record_size = 34\r\n\u001b[?2004l\r,"]
[535.35402, "o", "\u001b[?2004h> "]
[535.354502, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\r"]
[535.354591, "o", "\u001b[?2004h> "]
[535.355197, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r"]
[535.355298, "o", "\u001b[?2004h> "]
[535.355695, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r"]
[535.355825, "o", "\u001b[?2004h> "]
[535.356353, "o", "            account_id = record[0:4].decode('ascii')\r\n\u001b[?2004l\r"]
[535.356527, "o", "\u001b[?2004h> "]
[535.356888, "o", "            account_name = record[4:24].decode('ascii')\r\n\u001b[?2004l\r"]
[535.356977, "o", "\u001b[?2004h> "]
[535.357311, "o", "            account_balance = int(record[24:34].decode('ascii'))\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.357429, "o", "> "]
[535.357509, "o", "            accounts.append({\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.357624, "o", "> "]
[535.357767, "o", "                'id': account_id,\r\n\u001b[?2004l\r"]
[535.357928, "o", "\u001b[?2004h> "]
[535.358056, "o", "                'name': account_name,\r\n\u001b[?2004l\r"]
[535.358145, "o", "\u001b[?2004h> "]
[535.358366, "o", "                'balance': account_balance\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.358496, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.358531, "o", ">     \r\n"]
[535.358637, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[535.358788, "o", "    return accounts\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[535.358902, "o", "\u001b[?2004h> "]
[535.359065, "o", "def write_accounts(filename, accounts):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.359352, "o", "    \"\"\"Write all account records to ACCOUNTS.DAT.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.359446, "o", "> "]
[535.359585, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.359668, "o", "> "]
[535.359835, "o", "        for account in accounts:\r\n\u001b[?2004l\r"]
[535.359929, "o", "\u001b[?2004h> "]
[535.360022, "o", "            record = (\r\n\u001b[?2004l\r"]
[535.360138, "o", "\u001b[?2004h> "]
[535.36037, "o", "                account['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.360509, "o", "> "]
[535.360725, "o", "                account['name'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.360809, "o", "> "]
[535.361096, "o", "                str(account['balance']).zfill(10).encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.361142, "o", "> "]
[535.361314, "o", "            )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.361483, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.361572, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[535.361646, "o", "> "]
[535.361773, "o", "def read_books(filename):\r\n\u001b[?2004l\r"]
[535.361828, "o", "\u001b[?2004h> "]
[535.362103, "o", "    \"\"\"Read all book records from BOOKS.DAT.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.362189, "o", "> "]
[535.362258, "o", "    books = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.362346, "o", "> "]
[535.362495, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.362605, "o", "> "]
[535.362709, "o", "        data = f.read()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[535.362807, "o", "\u001b[?2004h> "]
[535.363093, "o", "    # Each book record is 28 bytes: 4 (ID) + 20 (Title) + 4 (Owner)\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.363182, "o", "> "]
[535.363318, "o", "    record_size = 28\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.363511, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.363598, "o", "> "]
[535.363763, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.363846, "o", "> "]
[535.364014, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.364097, "o", "> "]
[535.364297, "o", "            book_id = record[0:4].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.364384, "o", "> "]
[535.364604, "o", "            book_title = record[4:24].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.36471, "o", "> "]
[535.364912, "o", "            book_owner = record[24:28].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.364998, "o", "> "]
[535.365089, "o", "            books.append({\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.365244, "o", "> "]
[535.365381, "o", "                'id': book_id,\r\n\u001b[?2004l\r"]
[535.365476, "o", "\u001b[?2004h> "]
[535.365668, "o", "                'title': book_title,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.365877, "o", "                'owner': book_owner\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.365978, "o", "> "]
[535.36617, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.36631, "o", "    return books\r\n\u001b[?2004l\r"]
[535.366433, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.36656, "o", "def write_books(filename, books):"]
[535.366668, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.36688, "o", "    \"\"\"Write all book records to BOOKS.DAT.\"\"\"\r\n\u001b[?2004l\r"]
[535.366971, "o", "\u001b[?2004h> "]
[535.367105, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.367208, "o", "> "]
[535.367307, "o", "        for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.36738, "o", "> "]
[535.367486, "o", "            record = (\r\n\u001b[?2004l\r"]
[535.367579, "o", "\u001b[?2004h> "]
[535.367766, "o", "                book['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.367852, "o", "> "]
[535.368043, "o", "                book['title'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.368147, "o", "> "]
[535.368311, "o", "                book['owner'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.368397, "o", "> "]
[535.368484, "o", "            )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.368647, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.368763, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[535.368859, "o", "> "]
[535.368986, "o", "def append_transaction(filename, transaction):\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.369078, "o", "> "]
[535.369371, "o", "    \"\"\"Append a transaction record to TRANSACTIONS.DAT.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.369461, "o", "> "]
[535.369601, "o", "    with open(filename, 'ab') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.369737, "o", "> "]
[535.369855, "o", "        record = (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.370047, "o", "            transaction['book_id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.37013, "o", "> "]
[535.37043, "o", "            str(transaction['amount']).zfill(10).encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.370518, "o", "> "]
[535.370731, "o", "            transaction['seller_id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.370814, "o", "> "]
[535.371034, "o", "            transaction['buyer_id'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.37115, "o", "> "]
[535.371296, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.371329, "o", "        f.write(record)\r\n\u001b[?2004l\r"]
[535.371393, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[535.371483, "o", "> "]
[535.371588, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.371688, "o", "    # Read input\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.371775, "o", "> "]
[535.371952, "o", "    input_data = read_input_file('src/INPUT.DAT')\r\n\u001b[?2004l\r"]
[535.37205, "o", "\u001b[?2004h> "]
[535.372138, "o", "    if input_data is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.372226, "o", "> "]
[535.37235, "o", "        return\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.372452, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[535.372503, "o", "> "]
[535.372703, "o", "    buyer_id = input_data['buyer_id']\r\n\u001b[?2004l\r"]
[535.372817, "o", "\u001b[?2004h> "]
[535.372966, "o", "    seller_id = input_data['seller_id']\r\n\u001b[?2004l\r"]
[535.373094, "o", "\u001b[?2004h> "]
[535.373326, "o", "    book_id = input_data['book_id']\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.373439, "o", "> "]
[535.373567, "o", "    amount = input_data['amount']\r\n\u001b[?2004l\r"]
[535.373881, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.374077, "o", "    # Validate users and book\r\n\u001b[?2004l\r"]
[535.374149, "o", "\u001b[?2004h> "]
[535.374408, "o", "    accounts = read_accounts('data/ACCOUNTS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.374464, "o", "> "]
[535.374694, "o", "    books = read_books('data/BOOKS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.37484, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.374922, "o", "    buyer_found = False\r\n\u001b[?2004l\r"]
[535.375039, "o", "\u001b[?2004h> "]
[535.435599, "o", "    seller_found = False\r\n\u001b[?2004l\r\u001b[?2004h>     book_found = False\r\n\u001b[?2004l\r\u001b[?2004h>     valid_owner = False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h>         if account['id'] == buyer_id:\r\n\u001b[?2004l\r\u001b[?2004h>             buyer_found = True\r\n\u001b[?2004l\r\u001b[?2004h>         if account['id'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h>             seller_found = True\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for book in books:\r\n\u001b[?2004l\r\u001b[?2004h>         if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h>             book_found = True\r\n\u001b[?2004l\r\u001b[?2004h>             if book['owner'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h>                 valid_owner = True\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Display empty line (COBOL does this in VALIDATE-USERS-AND-BOOK)\r\n\u001b[?2004l\r\u001b[?2004h>     print(\" \")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Process transaction if valid\r\n\u001b[?2004l\r\u001b[?2004h>     if buyer_found and seller_found and book_found and valid_owner:\r\n\u001b[?2004l\r"]
[535.435713, "o", "\u001b[?2004h>         # Update account balances\r\n\u001b[?2004l\r\u001b[?2004h>         for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h>             if account['id'] == buyer_id:\r\n\u001b[?2004l\r\u001b[?2004h>                 account['balance'] -= amount\r\n\u001b[?2004l\r\u001b[?2004h>             if account['id'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h>                 account['balance'] += amount\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.435912, "o", "        write_accounts('data/ACCOUNTS.DAT', accounts)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.43614, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.436379, "o", "        # Update book ownership\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.43652, "o", "        for book in books:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.436689, "o", "            if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.43681, "o", "> "]
[535.436982, "o", "                book['owner'] = buyer_id\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.437065, "o", ">         "]
[535.437111, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.437431, "o", "        write_books('data/BOOKS.DAT', books)\r\n\u001b[?2004l\r"]
[535.437527, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[535.437616, "o", "\u001b[?2004h> "]
[535.437754, "o", "        # Append transaction"]
[535.437857, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[535.438082, "o", "        append_transaction('data/TRANSACTIONS.DAT', {\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.438178, "o", "> "]
[535.438309, "o", "            'book_id': book_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[535.438363, "o", "> "]
[535.438614, "o", "            'amount': amount,\r\n\u001b[?2004l\r"]
