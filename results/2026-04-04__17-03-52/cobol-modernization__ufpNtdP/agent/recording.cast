[761.283554, "i", "python3 << 'PYEOF'\n# Final verification test\nimport subprocess\nimport os\nimport shutil\n\n# Create test directories\nfor test_name in ['cobol_final', 'python_final']:\n    test_dir = f'/tmp/{test_name}'\n    os.makedirs(f'{test_dir}/data', exist_ok=True)\n    os.makedirs(f'{test_dir}/src', exist_ok=True)\n    \n    # Copy original data\n    with open(f'{test_dir}/data/ACCOUNTS.DAT', 'wb') as f:\n        f.write(b'U001John Doe            0000001180')\n        f.write(b'U002Jane Smith          0000001800')\n        f.write(b'U003Bob Wilson          0000001520')\n    with open(f'{test_dir}/data/BOOKS.DAT', 'wb') as f:\n        f.write(b'B001Python Basics       U002')\n        f.write(b'B002COBOL Guide         U002')\n        f.write(b'B003Java Tutorial       U002')\n    with open(f'{test_dir}/data/TRANSACTIONS.DAT', 'wb') as f:\n        f.write(b'B0030000000020U003U001')\n        f.write(b'B0030000000050U001U002')\n        f.write(b'B0010000000150U001U002')\n    with open(f'{test_dir}/src/INPUT.DAT', 'wb') as f:\n        f.write(b'U0"]
[761.283763, "i", "01U002B0010000000200')\n\n# Compile COBOL\nsubprocess.run(['cobc', '-x', '-o', '/tmp/cobol_prog', 'src/program.cbl'], cwd='/app', capture_output=True)\n\n# Run COBOL\nos.chdir('/tmp/cobol_final')\nsubprocess.run(['/tmp/cobol_prog'], capture_output=True)\n\n# Run Python\nos.chdir('/tmp/python_final')\nsubprocess.run(['python3', '/app/program.py'], capture_output=True)\n\n# Compare results\nos.chdir('/app')\nimport filecmp\nfor fname in ['ACCOUNTS.DAT', 'BOOKS.DAT', 'TRANSACTIONS.DAT']:\n    if filecmp.cmp(f'/tmp/cobol_final/data/{fname}', f'/tmp/python_final/data/{fname}', shallow=False):\n        print(f'{fname}: IDENTICAL ✓')\n    else:\n        print(f'{fname}: DIFFERENT ✗')\n\nprint('\\nFinal verification complete!')\nPYEOF\n"]
