[724.859978, "i", "cat > final_test.sh << 'TESTEOF'\n#!/bin/bash\nset -e\n\n# Backup original files\ncp src/INPUT.DAT /tmp/INPUT.DAT.orig\ncp data/ACCOUNTS.DAT /tmp/ACCOUNTS.DAT.orig\ncp data/BOOKS.DAT /tmp/BOOKS.DAT.orig\ncp data/TRANSACTIONS.DAT /tmp/TRANSACTIONS.DAT.orig\n\n# Test with valid transaction\nprintf 'U001U002B0010000000200' > src/INPUT.DAT\n\n# Run COBOL\ncobc -x -o /tmp/program src/program.cbl 2>/dev/null\n/tmp/program > /dev/null 2>&1\ncp data/ACCOUNTS.DAT /tmp/ACCOUNTS.DAT.cobol\ncp data/BOOKS.DAT /tmp/BOOKS.DAT.cobol\ncp data/TRANSACTIONS.DAT /tmp/TRANSACTIONS.DAT.cobol\n\n# Restore and run Python\ncp /tmp/ACCOUNTS.DAT.orig data/ACCOUNTS.DAT\ncp /tmp/BOOKS.DAT.orig data/BOOKS.DAT\ncp /tmp/TRANSACTIONS.DAT.orig data/TRANSACTIONS.DAT\npython3 /app/program.py > /dev/null 2>&1\n\n# Compare byte-by-byte\nif cmp -s data/ACCOUNTS.DAT /tmp/ACCOUNTS.DAT.cobol && \\\n   cmp -s data/BOOKS.DAT /tmp/BOOKS.DAT.cobol && \\\n   cmp -s data/TRANSACTIONS.DAT /tmp/TRANSACTIONS.DAT.cobol; then\n    echo \"SUCCESS: Python implementation is byte-for-byte identica"]
[724.860369, "i", "l to COBOL\"\n    RESULT=0\nelse\n    echo \"FAILURE: Outputs differ\"\n    RESULT=1\nfi\n\n# Restore original files\ncp /tmp/INPUT.DAT.orig src/INPUT.DAT\ncp /tmp/ACCOUNTS.DAT.orig data/ACCOUNTS.DAT\ncp /tmp/BOOKS.DAT.orig data/BOOKS.DAT\ncp /tmp/TRANSACTIONS.DAT.orig data/TRANSACTIONS.DAT\n\n# Cleanup\nrm -f /tmp/program /tmp/*.orig /tmp/*.cobol\n\nexit $RESULT\nTESTEOF\nchmod +x final_test.sh\n./final_test.sh\n"]
[724.86042, "o", "cat > final_test.sh << 'TESTEOF'\r\n"]
