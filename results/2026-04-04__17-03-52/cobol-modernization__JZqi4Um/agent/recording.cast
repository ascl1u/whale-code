[650.24112, "i", "cat > test_equivalence.sh << 'EOF'\n#!/bin/bash\n\n# Save original files\ncp src/INPUT.DAT src/INPUT.DAT.orig\ncp data/ACCOUNTS.DAT data/ACCOUNTS.DAT.orig\ncp data/BOOKS.DAT data/BOOKS.DAT.orig\ncp data/TRANSACTIONS.DAT data/TRANSACTIONS.DAT.orig\n\n# Test with valid transaction (B001 owned by U002)\necho \"Testing with valid transaction: U001 buys B001 from U002 for 200\"\npython3 -c \"with open('src/INPUT.DAT', 'wb') as f: f.write(b'U001U002B0010000000200')\"\n\n# Compile and run COBOL\ncobc -x -o program src/program.cbl 2>/dev/null\n./program > /tmp/cobol_out.txt 2>&1\n\n# Save COBOL results\ncp data/ACCOUNTS.DAT data/ACCOUNTS.DAT.cobol_test\ncp data/BOOKS.DAT data/BOOKS.DAT.cobol_test\ncp data/TRANSACTIONS.DAT data/TRANSACTIONS.DAT.cobol_test\n\n# Restore original state\ncp data/ACCOUNTS.DAT.orig data/ACCOUNTS.DAT\ncp data/BOOKS.DAT.orig data/BOOKS.DAT\ncp data/TRANSACTIONS.DAT.orig data/TRANSACTIONS.DAT\n\n# Run Python\npython3 /app/program.py > /tmp/python_out.txt 2>&1\n\n# Compare outputs\necho \"Comparing console outputs:\"\ndiff /tmp/cob"]
[650.2413, "i", "ol_out.txt /tmp/python_out.txt && echo \"✓ Console outputs are identical\"\n\necho \"Comparing ACCOUNTS.DAT:\"\ndiff data/ACCOUNTS.DAT data/ACCOUNTS.DAT.cobol_test && echo \"✓ ACCOUNTS.DAT files are identical\"\n\necho \"Comparing BOOKS.DAT:\"\ndiff data/BOOKS.DAT data/BOOKS.DAT.cobol_test && echo \"✓ BOOKS.DAT files are identical\"\n\necho \"Comparing TRANSACTIONS.DAT:\"\ndiff data/TRANSACTIONS.DAT data/TRANSACTIONS.DAT.cobol_test && echo \"✓ TRANSACTIONS.DAT files are identical\"\n\n# Restore original files and clean up\ncp src/INPUT.DAT.orig src/INPUT.DAT\ncp data/ACCOUNTS.DAT.orig data/ACCOUNTS.DAT\ncp data/BOOKS.DAT.orig data/BOOKS.DAT\ncp data/TRANSACTIONS.DAT.orig data/TRANSACTIONS.DAT\nrm -f src/INPUT.DAT.orig data/*.orig data/*.cobol_test program /tmp/cobol_out.txt /tmp/python_out.txt\n\necho \"\"\necho \"All tests passed! Python implementation is equivalent to COBOL.\"\nEOF\nchmod +x test_equivalence.sh\n./test_equivalence.sh\n"]
