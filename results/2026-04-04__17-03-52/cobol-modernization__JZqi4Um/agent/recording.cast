[401.511284, "o", "chmod +x /app/program.py; printf '%s\\n' '__CMDEND__36__'\r\n\u001b[?2004l\r"]
[401.513705, "o", "__CMDEND__36__\r\n"]
[401.513921, "o", "\u001b[?2004hroot@6859852352d9:/app# "]
[402.017767, "i", "python3 /app/program.py; printf '%s\\n' '__CMDEND__37__'\n"]
[402.018248, "o", "python3 /app/program.py; printf '%s\\n' '__CMDEND__37__'\r\n\u001b[?2004l\r"]
[402.035866, "o", " \r\nTransaction failed due to validation errors\r\n"]
