[367.297454, "o", "        'book_id': book_id,\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.297663, "o", "> "]
[367.297853, "o", "        'amount': amount\r\n\u001b[?2004l\r"]
[367.298018, "o", "\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[367.298231, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[367.29851, "o", "\u001b[?2004h> "]
[367.298946, "o", "def read_accounts(filename):\r\n\u001b[?2004l\r =\u001b[?2004h"]
[367.298984, "o", "> "]
[367.299425, "o", "    \"\"\"Read all account records.\"\"\"\r\n\u001b[?2004l\r"]
[367.299572, "o", "\u001b[?2004h> "]
[367.2999, "o", "    accounts = []\r\n\u001b[?2004l\r"]
[367.300073, "o", "\u001b[?2004h> "]
[367.300476, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[367.300648, "o", "\u001b[?2004h> "]
[367.300807, "o", "        data = f.read()\r\n\u001b[?2004l\r"]
[367.300944, "o", "\u001b[?2004h> "]
[367.301198, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[367.301377, "o", "> "]
[367.301615, "o", "    # Each account record is 34 bytes:\r\n\u001b[?2004l\r"]
[367.301799, "o", "\u001b[?2004h> "]
[367.302647, "o", "    # ACCOUNT-ID        PIC X(4)   - 4 bytes\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.303187, "o", "> "]
[367.304292, "o", "    # ACCOUNT-NAME      PIC X(20)  - 20 bytes\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.304464, "o", "    # ACCOUNT-BALANCE   PIC 9(10)  - 10 bytes\r\n\u001b[?2004l\r"]
[367.304679, "o", "\u001b[?2004h> "]
[367.304774, "o", "    record_size = 34\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r         \u001b[?2004h"]
[367.304871, "o", "> "]
[367.305448, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.306215, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r  #\u001b[?2004h> "]
[367.307047, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r"]
[367.307151, "o", "\u001b[?2004h> "]
[367.307577, "o", "            account = {\r\n\u001b[?2004l\r"]
[367.307799, "o", "\u001b[?2004h> "]
[367.31645, "o", "                'id': record[0:4].decode('ascii'),\r\n\u001b[?2004l\r"]
[367.316777, "o", "\u001b[?2004h> "]
[367.317547, "o", "                'name': record[4:24].decode('ascii'),\r\n\u001b[?2004l\r  p\u001b[?2004h> "]
[367.318578, "o", "                'balance': int(record[24:34].decode('ascii'))\r\n\u001b[?2004l\r"]
[367.318808, "o", "\u001b[?2004h> "]
[367.319058, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.319422, "o", "            accounts.append(account)\r\n\u001b[?2004l\rt\u001b[?2004h> "]
[367.319565, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[367.319762, "o", "> "]
[367.320233, "o", "    return accounts\r\n\u001b[?2004l\r"]
[367.320435, "o", "\u001b[?2004h> "]
[367.320605, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.320958, "o", "def write_accounts(filename, accounts):\r\n\u001b[?2004l\r"]
[367.321092, "o", "\u001b[?2004h> "]
[367.321419, "o", "    \"\"\"Write all account records back to file.\"\"\"\r\n\u001b[?2004l\r"]
[367.321581, "o", "\u001b[?2004h> "]
[367.321745, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r"]
[367.321913, "o", "\u001b[?2004h> "]
[367.322104, "o", "        for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.32232, "o", "            record = (\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.322475, "o", "> "]
[367.322782, "o", "                account['id'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.322921, "o", "> "]
[367.323305, "o", "                account['name'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.323429, "o", "> "]
[367.323918, "o", "                str(account['balance']).zfill(10).encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.324067, "o", ">             )"]
[367.324234, "o", "\r\n\u001b[?2004l\r"]
[367.324422, "o", "\u001b[?2004h> "]
[367.324604, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.324809, "o", "def read_books(filename):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.32502, "o", "    \"\"\"Read all book records.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.325185, "o", "    books = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.325229, "o", "> "]
[367.325519, "o", "    with open(filename, 'rb') as f:\r\n\u001b[?2004l\r"]
[367.32572, "o", "\u001b[?2004h> "]
[367.325881, "o", "        data = f.read()\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.326031, "o", ">     \r\n\u001b[?2004l\r"]
[367.326181, "o", "\u001b[?2004h> "]
[367.326441, "o", "    # Each book record is 28 bytes:\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.326528, "o", "> "]
[367.326902, "o", "    # BOOK-ID          PIC X(4)   - 4 bytes\r\n\u001b[?2004l\r"]
[367.327148, "o", "\u001b[?2004h> "]
[367.327426, "o", "    # BOOK-TITLE       PIC X(20)  - 20 bytes\r\n\u001b[?2004l\r"]
[367.327534, "o", "\u001b[?2004h> "]
[367.327887, "o", "    # BOOK-OWNER       PIC X(4)   - 4 bytes\r\n\u001b[?2004l\r"]
[367.328068, "o", "\u001b[?2004h> "]
[367.32822, "o", "    record_size = 28\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.32846, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.328784, "o", "    for i in range(0, len(data), record_size):\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.329028, "o", "> "]
[367.329216, "o", "        if i + record_size <= len(data):\r\n\u001b[?2004l\r"]
[367.329373, "o", "\u001b[?2004h> "]
[367.32964, "o", "            record = data[i:i+record_size]\r\n\u001b[?2004l\r"]
[367.329694, "o", "\u001b[?2004h> "]
[367.329962, "o", "            book = {\r\n\u001b[?2004l\r"]
[367.330106, "o", "\u001b[?2004h> "]
[367.330472, "o", "                'id': record[0:4].decode('ascii'),\r\n\u001b[?2004l\r"]
[367.330684, "o", "\u001b[?2004h> "]
[367.330984, "o", "                'title': record[4:24].decode('ascii'),\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.331109, "o", "> "]
[367.331463, "o", "                'owner': record[24:28].decode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.331607, "o", "> "]
[367.331755, "o", "            }\r\n\u001b[?2004l\r"]
[367.331893, "o", "\u001b[?2004h> "]
[367.332075, "o", "            books.append(book)\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.332249, "o", ">     \r\n\u001b[?2004l\r"]
[367.332393, "o", "\u001b[?2004h> "]
[367.332547, "o", "    return books\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[367.332643, "o", "\u001b[?2004h> "]
[367.332924, "o", "def write_books(filename, books):\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.333087, "o", "> "]
[367.333348, "o", "    \"\"\"Write all book records back to file.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.33349, "o", "> "]
[367.333747, "o", "    with open(filename, 'wb') as f:\r\n\u001b[?2004l\r"]
[367.333813, "o", "\u001b[?2004h> "]
[367.334113, "o", "        for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.334201, "o", "> "]
[367.334423, "o", "            record = (\r\n\u001b[?2004l\r"]
[367.334607, "o", "\u001b[?2004h> "]
[367.334946, "o", "                book['id'].encode('ascii') +\r\n\u001b[?2004l\r"]
[367.335101, "o", "\u001b[?2004h> "]
[367.335368, "o", "                book['title'].encode('ascii') +\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.335784, "o", "                book['owner'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.336009, "o", "> "]
[367.336091, "o", "            )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.336367, "o", "            f.write(record)\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.33647, "o", "> \r\n\u001b[?2004l\r"]
[367.336622, "o", "\u001b[?2004h> "]
[367.336988, "o", "def append_transaction(filename, transaction):\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.337077, "o", "> "]
[367.337401, "o", "    \"\"\"Append a transaction record to the file.\"\"\"\r\n\u001b[?2004l\r"]
[367.337507, "o", "\u001b[?2004h> "]
[367.337745, "o", "    with open(filename, 'ab') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.338057, "o", "        # Each transaction record is 22 bytes:\r\n\u001b[?2004l\r"]
[367.338274, "o", "\u001b[?2004h> "]
[367.338524, "o", "        # TRANS-BOOK       PIC X(4)   - 4 bytes\r\n\u001b[?2004l\r"]
[367.338671, "o", "\u001b[?2004h> "]
[367.339002, "o", "        # TRANS-AMOUNT     PIC 9(10)  - 10 bytes\r\n\u001b[?2004l\r"]
[367.339161, "o", "\u001b[?2004h> "]
[367.339494, "o", "        # TRANS-SELLER     PIC X(4)   - 4 bytes\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.339645, "o", "> "]
[367.339956, "o", "        # TRANS-BUYER      PIC X(4)   - 4 bytes\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.340126, "o", "> "]
[367.340331, "o", "        record = (\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.340507, "o", "> "]
[367.340677, "o", "            transaction['book_id'].encode('ascii') +\r\n\u001b[?2004l\r"]
[367.340795, "o", "\u001b[?2004h> "]
[367.341302, "o", "            str(transaction['amount']).zfill(10).encode('ascii') +\r\n\u001b[?2004l\r"]
[367.341469, "o", "\u001b[?2004h> "]
[367.341788, "o", "            transaction['seller_id'].encode('ascii') +\r\n\u001b[?2004l\r"]
[367.341837, "o", "\u001b[?2004h> "]
[367.342213, "o", "            transaction['buyer_id'].encode('ascii')\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.34235, "o", "> "]
[367.342502, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.342699, "o", "        f.write(record)\r\n\u001b[?2004l\r"]
[367.342748, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[367.342894, "o", "\u001b[?2004h> "]
[367.343235, "o", "def validate_and_process_transaction():\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.343361, "o", "> "]
[367.343756, "o", "    \"\"\"Main logic to validate and process the transaction.\"\"\"\r\n\u001b[?2004l\r"]
[367.343884, "o", "\u001b[?2004h> "]
[367.344037, "o", "    # Read input\r\n\u001b[?2004l\r"]
[367.344181, "o", "\u001b[?2004h> "]
[367.344508, "o", "    transaction = read_input_file('src/INPUT.DAT')\r\n\u001b[?2004l\r"]
[367.34463, "o", "\u001b[?2004h> "]
[367.344855, "o", "    if transaction is None:\r\n\u001b[?2004l\r"]
[367.345015, "o", "\u001b[?2004h> "]
[367.345138, "o", "        return\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.345404, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[367.3455, "o", "> "]
[367.345792, "o", "    buyer_id = transaction['buyer_id']\r\n\u001b[?2004l\r"]
[367.345911, "o", "\u001b[?2004h> "]
[367.346154, "o", "    seller_id = transaction['seller_id']\r\n\u001b[?2004l\r"]
[367.346321, "o", "\u001b[?2004h> "]
[367.34654, "o", "    book_id = transaction['book_id']\r\n\u001b[?2004l\r"]
[367.34669, "o", "\u001b[?2004h> "]
[367.34692, "o", "    amount = transaction['amount']\r\n\u001b[?2004l\r"]
[367.347059, "o", "\u001b[?2004h> "]
[367.347211, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.347442, "o", "    # Validate users and book\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.347596, "o", "> "]
[367.347868, "o", "    accounts = read_accounts('data/ACCOUNTS.DAT')\r\n\u001b[?2004l\r"]
[367.347915, "o", "\u001b[?2004h> "]
[367.348267, "o", "    books = read_books('data/BOOKS.DAT')\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.348427, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[367.348628, "o", "> "]
[367.3488, "o", "    buyer_found = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.349008, "o", "    seller_found = False\r\n\u001b[?2004l\r"]
[367.349133, "o", "\u001b[?2004h> "]
[367.349302, "o", "    book_found = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.34939, "o", "> "]
[367.349579, "o", "    valid_owner = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.349769, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.350014, "o", "    # Check if buyer and seller exist\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.350197, "o", "    for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.350347, "o", "> "]
[367.350578, "o", "        if account['id'] == buyer_id:\r\n\u001b[?2004l\r"]
[367.350724, "o", "\u001b[?2004h> "]
[367.350945, "o", "            buyer_found = True\r\n\u001b[?2004l\r"]
[367.415496, "o", "\u001b[?2004h>         if account['id'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h>             seller_found = True\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Check if book exists and seller owns it\r\n\u001b[?2004l\r\u001b[?2004h>     for book in books:\r\n\u001b[?2004l\r\u001b[?2004h>         if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h>             book_found = True\r\n\u001b[?2004l\r\u001b[?2004h>             if book['owner'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h>                 valid_owner = True\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(\" \")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # If validation passes, process the transaction\r\n\u001b[?2004l\r\u001b[?2004h>     if buyer_found and seller_found and book_found and valid_owner:\r\n\u001b[?2004l\r\u001b[?2004h>         # Update account balances\r\n\u001b[?2004l\r\u001b[?2004h>         for account in accounts:\r\n\u001b[?2004l\r\u001b[?2004h>             if account['id'] == buyer_id:\r\n\u001b[?2004l\r"]
[367.415666, "o", "\u001b[?2004h> "]
[367.415893, "o", "                account['balance'] -= amount\r\n\u001b[?2004l\r"]
[367.416027, "o", "\u001b[?2004h> "]
[367.41625, "o", "            if account['id'] == seller_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.416338, "o", "> "]
[367.416594, "o", "                account['balance'] += amount\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.416639, "o", "> "]
[367.416989, "o", "        write_accounts('data/ACCOUNTS.DAT', accounts)\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.417141, "o", "> "]
[367.417271, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.417407, "o", "        # Update book ownership\r\n\u001b[?2004l\r"]
[367.417541, "o", "\u001b[?2004h> "]
[367.417689, "o", "        for book in books:\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.41791, "o", "> "]
[367.418136, "o", "            if book['id'] == book_id:\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.418269, "o", "> "]
[367.418492, "o", "                book['owner'] = buyer_id\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.418574, "o", "> "]
[367.41882, "o", "        write_books('data/BOOKS.DAT', books)\r\n\u001b[?2004l\r"]
[367.418969, "o", "\u001b[?2004h> "]
[367.419063, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.419548, "o", "        # Append transaction record\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.420214, "o", "        append_transaction('data/TRANSACTIONS.DAT', transaction)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.420529, "o", "        print(\"Transaction completed successfully\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.420712, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.420784, "o", "> "]
[367.421232, "o", "        print(\"Transaction failed due to validation errors\")\r\n\u001b[?2004l\r"]
[367.421443, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[367.421611, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[367.421758, "o", "\u001b[?2004h> "]
[367.42206, "o", "    validate_and_process_transaction()\r\n\u001b[?2004l\r\u001b[?2004h"]
[367.422209, "o", "> EOF\r\n\u001b[?2004l\r"]
[367.425626, "o", "\u001b[?2004hroot@6859852352d9:/app# "]
