[?2004l[?2004h> def validate_and_process_transaction():
[?2004l[?2004h>     """Main logic to validate and process the transaction."""
[?2004l[?2004h>     # Read input
[?2004l[?2004h>     transaction = read_input_file('src/INPUT.DAT')
[?2004l[?2004h>     if transaction is None:
[?2004l[?2004h>         return
[?2004l[?2004h>     
[?2004l[?2004h>     buyer_id = transaction['buyer_id']
[?2004l[?2004h>     seller_id = transaction['seller_id']
[?2004l[?2004h>     book_id = transaction['book_id']
[?2004l[?2004h>     amount = transaction['amount']
[?2004l[?2004h>     
[?2004l[?2004h>     # Validate users and book
[?2004l[?2004h>     accounts = read_accounts('data/ACCOUNTS.DAT')
[?2004l[?2004h>     books = read_books('data/BOOKS.DAT')
[?2004l[?2004h>     
[?2004l[?2004h>     buyer_found = False
[?2004l[?2004h>     seller_found = False
[?2004l[?2004h>     book_found = False
[?2004l[?2004h>     valid_owner = False
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if buyer and seller exist
[?2004l[?2004h>     for account in accounts:
[?2004l[?2004h>         if account['id'] == buyer_id:
[?2004l[?2004h>             buyer_found = True
[?2004l[?2004h>         if account['id'] == seller_id:
[?2004l[?2004h>             seller_found = True
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if book exists and seller owns it
[?2004l[?2004h>     for book in books:
[?2004l[?2004h>         if book['id'] == book_id:
[?2004l[?2004h>             book_found = True
[?2004l[?2004h>             if book['owner'] == seller_id:
[?2004l[?2004h>                 valid_owner = True
[?2004l[?2004h>     
[?2004l[?2004h>     print(" ")
[?2004l[?2004h>     
[?2004l[?2004h>     # If validation passes, process the transaction
[?2004l[?2004h>     if buyer_found and seller_found and book_found and valid_owner:
[?2004l[?2004h>         # Update account balances
[?2004l[?2004h>         for account in accounts:
