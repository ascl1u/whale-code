[?2004l[?2004h> def read_books(filename):
[?2004l[?2004h>     """Read all book records."""
[?2004l[?2004h>     books = []
[?2004l[?2004h>     with open(filename, 'rb') as f:
[?2004l[?2004h>         data = f.read()
[?2004l[?2004h>     
[?2004l[?2004h>     # Each book record is 28 bytes:
[?2004l[?2004h>     # BOOK-ID          PIC X(4)   - 4 bytes
[?2004l[?2004h>     # BOOK-TITLE       PIC X(20)  - 20 bytes
[?2004l[?2004h>     # BOOK-OWNER       PIC X(4)   - 4 bytes
[?2004l[?2004h>     record_size = 28
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(0, len(data), record_size):
[?2004l[?2004h>         if i + record_size <= len(data):
[?2004l[?2004h>             record = data[i:i+record_size]
[?2004l[?2004h>             book = {
[?2004l[?2004h>                 'id': record[0:4].decode('ascii'),
[?2004l[?2004h>                 'title': record[4:24].decode('ascii'),
[?2004l[?2004h>                 'owner': record[24:28].decode('ascii')
[?2004l[?2004h>             }
[?2004l[?2004h>             books.append(book)
[?2004l[?2004h>     
[?2004l[?2004h>     return books
[?2004l[?2004h> 
[?2004l[?2004h> def write_books(filename, books):
[?2004l[?2004h>     """Write all book records back to file."""
[?2004l[?2004h>     with open(filename, 'wb') as f:
[?2004l[?2004h>         for book in books:
[?2004l[?2004h>             record = (
[?2004l[?2004h>                 book['id'].encode('ascii') +
[?2004l[?2004h>                 book['title'].encode('ascii') +
[?2004l[?2004h>                 book['owner'].encode('ascii')
[?2004l[?2004h>             )
[?2004l[?2004h>             f.write(record)
[?2004l[?2004h> 
[?2004l[?2004h> def append_transaction(filename, transaction):
[?2004l[?2004h>     """Append a transaction record to the file."""
[?2004l[?2004h>     with open(filename, 'ab') as f:
[?2004l[?2004h>         # Each transaction record is 22 bytes:
[?2004l[?2004h>         # TRANS-BOOK       PIC X(4)   - 4 bytes
[?2004l[?2004h>         # TRANS-AMOUNT     PIC 9(10)  - 10 bytes
[?2004l[?2004h>         # TRANS-SELLER     PIC X(4)   - 4 bytes
[?2004l[?2004h>         # TRANS-BUYER      PIC X(4)   - 4 bytes
[?2004l[?2004h>         record = (
[?2004l[?2004h>             transaction['book_id'].encode('ascii') +
[?2004l[?2004h>             str(transaction['amount']).zfill(10).encode('ascii') +
[?2004l[?2004h>             transaction['seller_id'].encode('ascii') +
[?2004l[?2004h>             transaction['buyer_id'].encode('ascii')
[?2004l[?2004h>         )
[?2004l[?2004h>         f.write(record)
