[?2004lRequire Import Arith.

Theorem plus_comm : forall n m : nat,
  n + m = m + n.
Proof.
  intros n m.
  induction n as [|n' IHn'].
  - simpl.
    (* Base case: 0 + m = m + 0 *)
    rewrite <- plus_n_O.
    reflexivity.
  - simpl.
    (* Inductive case: S n' + m = m + S n' *)
    rewrite IHn'.
    rewrite plus_n_Sm.
    reflexivity.
Qed.
__CMDEND__3__
