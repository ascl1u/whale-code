[27.776944, "o", "Require Import Arith.\r\n\r\nTheorem plus_comm : forall n m : nat,\r\n  n + m = m + n.\r\nProof.\r\n  intros n m.\r\n  induction n as [|n' IHn'].\r\n  - simpl.\r\n    (* Base case: 0 + m = m + 0 *)\r\n    (* After simpl: m = m + 0 *)\r\n    rewrite <- plus_n_O.\r\n    reflexivity.\r\n  - simpl.\r\n    (* Inductive case: S n' + m = m + S n' *)\r\n    (* After simpl: S (n' + m) = m + S n' *)\r\n    rewrite IHn'.\r\n    rewrite plus_n_Sm.\r\n    reflexivity.\r\nQed.\r\n"]
