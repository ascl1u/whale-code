[?2004l[?2004h> # Let's verify our understanding
[?2004l[?2004h> # The task says we have:
[?2004l[?2004h> # - input plasmid (circular)
[?2004l[?2004h> # - egfp (linear)
[?2004l[?2004h> # - flag (linear)
[?2004l[?2004h> # - snap (linear)
[?2004l[?2004h> # And we want to make output plasmid
[?2004l[?2004h> 
[?2004l[?2004h> # The question is: do we NEED to PCR all 4 separately?
[?2004l[?2004h> # Since we "have" input, egfp, flag, and snap "on hand", we need to add BsaI sites to each
[?2004l[?2004h> # We cannot combine them before PCR because they're separate sequences
[?2004l[?2004h> # So yes, we need 4 primer pairs minimum
[?2004l[?2004h> 
[?2004l[?2004h> print("Analysis: We need to PCR amplify 4 separate templates:")
[?2004l[?2004h> print("1. Input plasmid - to linearize and add BsaI sites")
[?2004l[?2004h> print("2. eGFP - to add BsaI sites and remove stop codon")
[?2004l[?2004h> print("3. FLAG - to add BsaI sites and remove start/stop codons")
[?2004l[?2004h> print("4. SNAP - to add BsaI sites and remove start codon")
[?2004l[?2004h> print("\nMinimum primer pairs needed: 4")
[?2004l[?2004h> print("Total primers: 8")
