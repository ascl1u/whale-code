[?2004hroot@40713b84f85c:/app# cat > design_primers.py << 'SCRIPT_EOF'
[?2004l[?2004h> import subprocess
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def parse_fasta(filename):
[?2004l[?2004h>     """Parse FASTA file and return dictionary of sequences"""
[?2004l[?2004h>     seqs = {}
[?2004l[?2004h>     current = None
[?2004l[?2004h>     with open(filename, 'r') as f:
[?2004l[?2004h>         for line in f:
[?2004l[?2004h>             line = line.strip()
[?2004l[?2004h>             if line.startswith('>'):
[?2004l[?2004h>                 current = line[1:]
[?2004l[?2004h>                 seqs[current] = ''
[?2004l[?2004h>             else:
[?2004l[?2004h>                 seqs[current] += line
[?2004l[?2004h>     return seqs
[?2004l[?2004h> 
[?2004l[?2004h> def reverse_complement(seq):
[?2004l[?2004h>     """Return reverse complement of DNA sequence"""
[?2004l[?2004h>     complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G'}
[?2004l[?2004h>     return ''.join(complement[base] for base in reversed(seq))
[?2004l[?2004h> 
[?2004l[?2004h> def calculate_tm(seq):
[?2004l[?2004h>     """Calculate melting temperature using oligotm with specified parameters"""
[?2004l[?2004h>     cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq]
[?2004l[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)
[?2004l[?2004h>     try:
[?2004l[?2004h>         return float(result.stdout.strip())
[?2004l[?2004h>     except:
[?2004l[?2004h>         return 0.0
[?2004l[?2004h> 
[?2004l[?2004h> # Parse sequences
[?2004l[?2004h> seqs = parse_fasta('sequences.fasta')
[?2004l[?2004h> 
[?2004l[?2004h> # Define the structure
[?2004l[?2004h> # Input plasmid: replace positions 210-690 with eGFP-FLAG-SNAP fusion
[?2004l[?2004h> # Output structure: input[0:210] + eGFP(no stop) + FLAG(no start/stop) + SNAP(no start) + input[690:]
[?2004l[?2004h> 
[?2004l[?2004h> # For Golden Gate assembly, we need 4 fragments with compatible overhangs:
[?2004l[?2004h> # Fragment 1: Linearized input backbone (input[690:] + input[0:210])
[?2004l[?2004h> # Fragment 2: eGFP (no stop codon)
[?2004l[?2004h> # Fragment 3: FLAG (no start/stop codons)
[?2004l[?2004h> # Fragment 4: SNAP (no start codon)
[?2004l[?2004h> 
[?2004l[?2004h> # Design overhangs (4 bp each)
[?2004l[?2004h> # We need 4 unique overhangs to connect the fragments in order
[?2004l[?2004h> # Overhang selection should avoid self-complementarity and be unique
[?2004l[?2004h> 
[?2004l[?2004h> # Let's use the actual junction sequences as overhangs
[?2004l[?2004h> # Junction 1: Between input and eGFP - use last 4 bp before insertion point
[?2004l[?2004h> # Junction 2: Between eGFP and FLAG
[?2004l[?2004h> # Junction 3: Between FLAG and SNAP  
[?2004l[?2004h> # Junction 4: Between SNAP and input (closing the circle)
[?2004l[?2004h> 
[?2004l[?2004h> print("Analyzing junctions...")
[?2004l[?2004h> input_seq = seqs['input']
[?2004l[?2004h> output_seq = seqs['output']
[?2004l[?2004h> 
[?2004l[?2004h> # Junction sequences from output
[?2004l[?2004h> oh1 = output_seq[206:210]  # Before eGFP: ACAT
[?2004l[?2004h> oh2 = output_seq[924:928]  # Between eGFP and FLAG (after eGFP no-stop)
[?2004l[?2004h> oh3 = output_seq[1008:1012]  # Between FLAG and SNAP
[?2004l[?2004h> oh4 = output_seq[1554:1558]  # After SNAP
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Overhang 1 (input->eGFP): {oh1}")
[?2004l[?2004h> print(f"Overhang 2 (eGFP->FLAG): {oh2}")
[?2004l[?2004h> print(f"Overhang 3 (FLAG->SNAP): {oh3}")
[?2004l[?2004h> print(f"Overhang 4 (SNAP->input): {oh4}")
[?2004l[?2004h> 
[?2004l[?2004h> SCRIPT_EOF
[?2004l[?2004hroot@40713b84f85c:/app# cat >> design_primers.py << 'SCRIPT_EOF'
[?2004l[?2004h> 
[?2004l[?2004h> # Now design primers
[?2004l[?2004h> # BsaI-HF v2 recognition: GGTCTC (forward) and GAGACC (reverse complement)
[?2004l[?2004h> # BsaI cuts 1 nt downstream on top strand, 5 nt on bottom, creating 4 nt overhang
[?2004l[?2004h> # Forward primer: 5'-[tail]-GGTCTC-N-[4bp overhang]-[template binding]-3'
[?2004l[?2004h> # Reverse primer: 5'-[tail]-GGTCTC-N-[4bp overhang RC]-[template binding RC]-3'
[?2004l[?2004h> 
[?2004l[?2004h> def design_primer_pair(template_name, template_seq, left_overhang, right_overhang, 
[?2004l[?2004h>                        min_len=15, max_len=45, min_tm=58, max_tm=72, max_delta_tm=5):
[?2004l[?2004h>     """
[?2004l[?2004h>     Design forward and reverse primers for a template
[?2004l[?2004h>     left_overhang: overhang on the 5' end of the insert
[?2004l[?2004h>     right_overhang: overhang on the 3' end of the insert
[?2004l[?2004h>     """
[?2004l[?2004h>     # For forward primer: adds left_overhang
[?2004l[?2004h>     # Structure: GGTCTC N [left_overhang] [template_start]
[?2004l[?2004h>     # The primer binds to template_start
[?2004l[?2004h>     
[?2004l[?2004h>     # For reverse primer: adds right_overhang (reverse complement)
[?2004l[?2004h>     # Structure: GGTCTC N [right_overhang_RC] [template_end_RC]
[?2004l[?2004h>     # The primer binds to the reverse complement of template_end
[?2004l[?2004h>     
[?2004l[?2004h>     best_fwd = None
[?2004l[?2004h>     best_rev = None
[?2004l[?2004h>     best_delta = float('inf')
[?2004l[?2004h>     
[?2004l[?2004h>     # Try different annealing lengths
[?2004l[?2004h>     for fwd_len in range(min_len, max_len + 1):
[?2004l[?2004h>         for rev_len in range(min_len, max_len + 1):
[?2004l[?2004h>             # Forward primer annealing region
[?2004l[?2004h>             fwd_anneal = template_seq[:fwd_len]
[?2004l[?2004h>             fwd_tm = calculate_tm(fwd_anneal)
[?2004l[?2004h>             
[?2004l[?2004h>             # Reverse primer annealing region (binds to end of template)
[?2004l[?2004h>             rev_anneal = template_seq[-rev_len:]
[?2004l[?2004h>             rev_tm = calculate_tm(rev_anneal)
[?2004l[?2004h>             
[?2004l[?2004h>             # Check constraints
[?2004l[?2004h>             if (min_tm <= fwd_tm <= max_tm and 
[?2004l[?2004h>                 min_tm <= rev_tm <= max_tm and 
[?2004l[?2004h>                 abs(fwd_tm - rev_tm) <= max_delta_tm):
[?2004l[?2004h>                 
[?2004l[?2004h>                 delta = abs(fwd_tm - rev_tm)
[?2004l[?2004h>                 if delta < best_delta:
[?2004l[?2004h>                     best_delta = delta
[?2004l[?2004h>                     
[?2004l[?2004h>                     # Build full primers
[?2004l[?2004h>                     # Forward: GGTCTC-N-[overhang]-[anneal]
[?2004l[?2004h>                     fwd_primer = 'GGTCTC' + 'N' + left_overhang + fwd_anneal
[?2004l[?2004h>                     
[?2004l[?2004h>                     # Reverse: GGTCTC-N-[overhang_RC]-[anneal_RC]
[?2004l[?2004h>                     right_oh_rc = reverse_complement(right_overhang)
[?2004l[?2004h>                     rev_anneal_rc = reverse_complement(rev_anneal)
[?2004l[?2004h>                     rev_primer = 'GGTCTC' + 'N' + right_oh_rc + rev_anneal_rc
[?2004l[?2004h>                     
[?2004l[?2004h>                     best_fwd = (fwd_primer, fwd_anneal, fwd_tm)
[?2004l[?2004h>                     best_rev = (rev_primer, rev_anneal, rev_tm)
[?2004l[?2004h>     
[?2004l[?2004h>     return best_fwd, best_rev
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Designing Primers ===")
[?2004l[?2004h> 
[?2004l[?2004h> # Fragment 1: Input backbone (linearized)
[?2004l[?2004h> # We need to amplify from position 690 to 210 (going around the circle)
[?2004l[?2004h> # This is actually: input[690:] + input[0:210]
[?2004l[?2004h> # But since it's circular, we can amplify the backbone by:
[?2004l[?2004h> # - Forward primer at position 690 (adds oh4 RC for SNAP->input junction)
[?2004l[?2004h> # - Reverse primer at position 210 (adds oh1 RC for input->eGFP junction)
[?2004l[?2004h> 
[?2004l[?2004h> # Actually, let's think about this differently:
[?2004l[?2004h> # The input backbone needs to connect SNAP (with oh4) to eGFP start (with oh1)
[?2004l[?2004h> # So: oh4 -> backbone -> oh1
[?2004l[?2004h> # Forward primer binds after position 690 and adds oh4 on 5' end
[?2004l[?2004h> # Reverse primer binds before position 210 and adds oh1 on 3' end
[?2004l[?2004h> 
[?2004l[?2004h> SCRIPT_EOF
[?2004l[?2004hroot@40713b84f85c:/app# cat >> design_primers.py << 'SCRIPT_EOF'
[?2004l[?2004h> 
[?2004l[?2004h> # For Golden Gate assembly with circular product:
[?2004l[?2004h> # Each fragment needs compatible overhangs to assemble in order
[?2004l[?2004h> # Fragment order: input_backbone -> eGFP -> FLAG -> SNAP -> (back to input_backbone)
[?2004l[?2004h> 
[?2004l[?2004h> # The input backbone will be linearized and will have:
[?2004l[?2004h> # - 5' overhang: compatible with SNAP's 3' end (oh4)
[?2004l[?2004h> # - 3' overhang: compatible with eGFP's 5' start (oh1)
[?2004l[?2004h> 
[?2004l[?2004h> # eGFP (without stop codon):
[?2004l[?2004h> # - 5' overhang: oh1 (connects to input)
[?2004l[?2004h> # - 3' overhang: oh2 (connects to FLAG)
[?2004l[?2004h> 
[?2004l[?2004h> # FLAG (without start/stop):
[?2004l[?2004h> # - 5' overhang: oh2 (connects to eGFP)
[?2004l[?2004h> # - 3' overhang: oh3 (connects to SNAP)
[?2004l[?2004h> 
[?2004l[?2004h> # SNAP (without start codon):
[?2004l[?2004h> # - 5' overhang: oh3 (connects to FLAG)
[?2004l[?2004h> # - 3' overhang: oh4 (connects to input)
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Fragment Design ===")
[?2004l[?2004h> print(f"Fragment 1 (input): oh4 -> backbone -> oh1")
[?2004l[?2004h> print(f"Fragment 2 (eGFP): oh1 -> egfp(no stop) -> oh2")
[?2004l[?2004h> print(f"Fragment 3 (FLAG): oh2 -> flag(no start/stop) -> oh3")
[?2004l[?2004h> print(f"Fragment 4 (SNAP): oh3 -> snap(no start) -> oh4")
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare template sequences
[?2004l[?2004h> egfp_template = seqs['egfp'][:-3]  # Remove stop codon TAA
[?2004l[?2004h> flag_template = seqs['flag'][3:-3]  # Remove start ATG and stop TAA
[?2004l[?2004h> snap_template = seqs['snap'][3:]  # Remove start ATG, keep stop
[?2004l[?2004h> 
[?2004l[?2004h> # Input backbone: from position 690 to end, then start to 210
[?2004l[?2004h> input_backbone = input_seq[690:] + input_seq[:210]
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\neGFP template length: {len(egfp_template)}")
[?2004l[?2004h> print(f"FLAG template length: {len(flag_template)}")
[?2004l[?2004h> print(f"SNAP template length: {len(snap_template)}")
[?2004l[?2004h> print(f"Input backbone length: {len(input_backbone)}")
[?2004l[?2004h> 
[?2004l[?2004h> # Design primers for each fragment
[?2004l[?2004h> print("\n=== Designing eGFP primers ===")
[?2004l[?2004h> egfp_fwd, egfp_rev = design_primer_pair('egfp', egfp_template, oh1, oh2)
[?2004l[?2004h> if egfp_fwd and egfp_rev:
[?2004l[?2004h>     print(f"Forward: Tm={egfp_fwd[2]:.1f}°C, anneal_len={len(egfp_fwd[1])}")
[?2004l[?2004h>     print(f"Reverse: Tm={egfp_rev[2]:.1f}°C, anneal_len={len(egfp_rev[1])}")
[?2004l[?2004h> else:
[?2004l[?2004h>     print("Failed to design eGFP primers")
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Designing FLAG primers ===")
[?2004l[?2004h> flag_fwd, flag_rev = design_primer_pair('flag', flag_template, oh2, oh3)
[?2004l[?2004h> if flag_fwd and flag_rev:
[?2004l[?2004h>     print(f"Forward: Tm={flag_fwd[2]:.1f}°C, anneal_len={len(flag_fwd[1])}")
[?2004l[?2004h>     print(f"Reverse: Tm={flag_rev[2]:.1f}°C, anneal_len={len(flag_rev[1])}")
[?2004l[?2004h> else:
[?2004l[?2004h>     print("Failed to design FLAG primers")
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Designing SNAP primers ===")
[?2004l[?2004h> snap_fwd, snap_rev = design_primer_pair('snap', snap_template, oh3, oh4)
[?2004l[?2004h> if snap_fwd and snap_rev:
[?2004l[?2004h>     print(f"Forward: Tm={snap_fwd[2]:.1f}°C, anneal_len={len(snap_fwd[1])}")
[?2004l[?2004h>     print(f"Reverse: Tm={snap_rev[2]:.1f}°C, anneal_len={len(snap_rev[1])}")
[?2004l[?2004h> else:
[?2004l[?2004h>     print("Failed to design SNAP primers")
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Designing Input backbone primers ===")
[?2004l[?2004h> input_fwd, input_rev = design_primer_pair('input', input_backbone, oh4, oh1)
[?2004l[?2004h> if input_fwd and input_rev:
[?2004l[?2004h>     print(f"Forward: Tm={input_fwd[2]:.1f}°C, anneal_len={len(input_fwd[1])}")
[?2004l[?2004h>     print(f"Reverse: Tm={input_rev[2]:.1f}°C, anneal_len={len(input_rev[1])}")
[?2004l[?2004h> else:
[?2004l[?2004h>     print("Failed to design input primers")
[?2004l[?2004h> 
[?2004l[?2004h> SCRIPT_EOF
[?2004l[?2004hroot@40713b84f85c:/app# cat >> design_primers.py << 'SCRIPT_EOF'
