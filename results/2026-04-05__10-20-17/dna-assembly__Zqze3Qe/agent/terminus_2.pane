[?2004l[?2004h> def calculate_tm(seq):
[?2004l[?2004h>     cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq]
[?2004l[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)
[?2004l[?2004h>     return float(result.stdout.strip())
[?2004l[?2004h> 
[?2004l[?2004h> # Parse primers
[?2004l[?2004h> primers = {}
[?2004l[?2004h> with open('primers.fasta', 'r') as f:
[?2004l[?2004h>     lines = f.readlines()
[?2004l[?2004h>     for i in range(0, len(lines), 2):
[?2004l[?2004h>         name = lines[i].strip()[1:]
[?2004l[?2004h>         seq = lines[i+1].strip()
[?2004l[?2004h>         primers[name] = seq
[?2004l[?2004h> 
[?2004l[?2004h> print("=== Verifying Primers ===")
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # For each primer, extract the annealing region (after GGTCTCN and 4bp overhang)
[?2004l[?2004h> for name, seq in primers.items():
[?2004l[?2004h>     # Structure: GGTCTCN[4bp overhang][annealing region]
[?2004l[?2004h>     # GGTCTCN = 7 characters
[?2004l[?2004h>     # 4bp overhang = 4 characters
[?2004l[?2004h>     # So annealing starts at position 11
[?2004l[?2004h>     anneal = seq[11:]
[?2004l[?2004h>     tm = calculate_tm(anneal)
[?2004l[?2004h>     print(f"{name}:")
[?2004l[?2004h>     print(f"  Full primer: {seq}")
[?2004l[?2004h>     print(f"  Annealing region: {anneal} (length: {len(anneal)})")
[?2004l[?2004h>     print(f"  Tm: {tm:.1f}°C")
[?2004l[?2004h>     print()
