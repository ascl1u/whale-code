[156.065267, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.065448, "o", "    print(\"Failed to design eGFP primers\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
