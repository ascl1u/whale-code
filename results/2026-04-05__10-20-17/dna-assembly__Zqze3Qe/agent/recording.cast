[207.804881, "o", "def design_primer_pair(template_name, template_seq, left_overhang, right_overhang, \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.805644, "o", "                       min_len=15, max_len=45, min_tm=58, max_tm=72, max_delta_tm=5):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     Design forward and reverse primers for a template\r\n\u001b[?2004l\r\r\n  \u001b[?2004h> "]
[207.80647, "o", "    left_overhang: overhang on the 5' end of the insert\r\n\u001b[?2004l\rf\u001b[?2004h> "]
[207.807335, "o", "    right_overhang: overhang on the 3' end of the insert\r\n\u001b[?2004l\r"]
[207.807753, "o", "\u001b[?2004h>     \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.808094, "o", "    best_fwd = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
