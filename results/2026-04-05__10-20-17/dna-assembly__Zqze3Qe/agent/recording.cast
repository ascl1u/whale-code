[138.722234, "i", "cat >> design_primers.py << 'SCRIPT_EOF'\n\n# Now design primers\n# BsaI-HF v2 recognition: GGTCTC (forward) and GAGACC (reverse complement)\n# BsaI cuts 1 nt downstream on top strand, 5 nt on bottom, creating 4 nt overhang\n# Forward primer: 5'-[tail]-GGTCTC-N-[4bp overhang]-[template binding]-3'\n# Reverse primer: 5'-[tail]-GGTCTC-N-[4bp overhang RC]-[template binding RC]-3'\n\ndef design_primer_pair(template_name, template_seq, left_overhang, right_overhang, \n                       min_len=15, max_len=45, min_tm=58, max_tm=72, max_delta_tm=5):\n    \"\"\"\n    Design forward and reverse primers for a template\n    left_overhang: overhang on the 5' end of the insert\n    right_overhang: overhang on the 3' end of the insert\n    \"\"\"\n    # For forward primer: adds left_overhang\n    # Structure: GGTCTC N [left_overhang] [template_start]\n    # The primer binds to template_start\n    \n    # For reverse primer: adds right_overhang (reverse complement)\n    # Structure: GGTCTC N [right_overhang_RC] [template_end_RC]\n    # The primer binds to the reverse complement of template_end\n    \n    best_fwd = None\n    best_rev = None\n    best_delta = float('inf')\n    \n    # Try different annealing lengths\n    for fwd_len in range(min_len, max_len + 1):\n        for rev_len in range(min_len, max_len + 1):\n            # Forward primer annealing region\n            fwd_anneal = template_seq[:fwd_len]\n            fwd_tm = calculate_tm(fwd_anneal)\n            \n            # Reverse primer annealing region (binds to end of template)\n            rev_anneal = template_seq[-rev_len:]\n            rev_tm = calculate_tm(rev_anneal)\n            \n            # Check constraints\n            if (min_tm <= fwd_tm <= max_tm and \n                min_tm <= rev_tm <= max_tm and \n                abs(fwd_tm - rev_tm) <= max_delta_tm):\n                \n                delta = abs(fwd_tm - rev_tm)\n                if delta < best_delta:\n                    best_delta = delta\n                    \n                    # Build full primers\n                    # Forward: GGTCTC-N-[overhang]-[anneal]\n                    fwd_primer = 'GGTCTC' + 'N' + left_overhang + fwd_anneal\n                    \n                    # Reverse: GGTCTC-N-[overhang_RC]-[anneal_RC]\n                    right_oh_rc = reverse_complement(right_overhang)\n                    rev_anneal_rc = reverse_complement(rev_anneal)\n                    rev_primer = 'GGTCTC' + 'N' + right_oh_rc + rev_anneal_rc\n                    \n                    best_fwd = (fwd_primer, fwd_anneal, fwd_tm)\n                    best_rev = (rev_primer, rev_anneal, rev_tm)\n    \n    return best_fwd, best_rev\n\nprint(\"\\n=== Designing Primers ===\")\n\n# Fragment 1: Input backbone (linearized)\n# We need to amplify from position 690 to 210 (going around the circle)\n# This is actually: input[690:] + input[0:210]\n# But since it's circular, we can amplify the backbone by:\n# - Forward primer at position 690 (adds oh4 RC for SNAP->input junction)\n# - Reverse primer at position 210 (adds oh1 RC for input->eGFP junction)\n\n# Actually, let's think about this differently:\n# The input backbone needs to connect SNAP (with oh4) to eGFP start (with oh1)\n# So: oh4 -> backbone -> oh1\n# Forward primer binds after position 690 and adds oh4 on 5' end\n# Reverse primer binds before position 210 and adds oh1 on 3' end\n\nSCRIPT_EOF\n"]
[138.722765, "o", "cat >> design_primers.py << 'SCRIPT_EOF'\r\n\u001b[?2004l\r"]
[138.722992, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.723119, "o", "# Now design primers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.723639, "o", "# BsaI-HF v2 recognition: GGTCTC (forward) and GAGACC (reverse complement)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.724045, "o", "# BsaI cuts 1 nt downstream on top strand, 5 nt on bottom, creating 4 nt overhang\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.72446, "o", "# Forward primer: 5'-[tail]-GGTCTC-N-[4bp overhang]-[template binding]-3'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.725032, "o", "# Reverse primer: 5'-[tail]-GGTCTC-N-[4bp overhang RC]-[template binding RC]-3'\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.725316, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.725855, "o", "def design_primer_pair(template_name, template_seq, left_overhang, right_overhang, \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.726385, "o", "                       min_len=15, max_len=45, min_tm=58, max_tm=72, max_delta_tm=5):\r\n\u001b[?2004l\r"]
[138.726651, "o", "\u001b[?2004h>     \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.726968, "o", "    Design forward and reverse primers for a template\r\n\u001b[?2004l\r"]
[138.727208, "o", "\u001b[?2004h> "]
[138.727402, "o", "    left_overhang: overhang on the 5' end of the insert\r\n\u001b[?2004l\r"]
[138.727602, "o", "\u001b[?2004h> "]
[138.727827, "o", "    right_overhang: overhang on the 3' end of the insert\r\n\u001b[?2004l\r"]
[138.727923, "o", "\u001b[?2004h>     \"\"\""]
[138.72817, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.728331, "o", "    # For forward primer: adds left_overhang\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.728565, "o", "    # Structure: GGTCTC N [left_overhang] [template_start]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.728831, "o", "    # The primer binds to template_start\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.729065, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.729443, "o", "    # For reverse primer: adds right_overhang (reverse complement)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.729856, "o", "    # Structure: GGTCTC N [right_overhang_RC] [template_end_RC]\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.730037, "o", "> "]
[138.730293, "o", "    # The primer binds to the reverse complement of template_end\r\n\u001b[?2004l\r"]
[138.730522, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[138.73074, "o", "\u001b[?2004h>     best_fwd = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.730956, "o", "    best_rev = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.731156, "o", "    best_delta = float('inf')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.731347, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.731511, "o", "    # Try different annealing lengths\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.731736, "o", "    for fwd_len in range(min_len, max_len + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.732024, "o", "        for rev_len in range(min_len, max_len + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.732281, "o", "            # Forward primer annealing region\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.732478, "o", "> "]
[138.732687, "o", "            fwd_anneal = template_seq[:fwd_len]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.732871, "o", "            fwd_tm = calculate_tm(fwd_anneal)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.733061, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.733403, "o", "            # Reverse primer annealing region (binds to end of template)\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.733579, "o", "> "]
[138.733768, "o", "            rev_anneal = template_seq[-rev_len:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.733949, "o", "            rev_tm = calculate_tm(rev_anneal)\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.734051, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.734277, "o", "            # Check constraints\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.734522, "o", "            if (min_tm <= fwd_tm <= max_tm and \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.734789, "o", "                min_tm <= rev_tm <= max_tm and \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.735097, "o", "                abs(fwd_tm - rev_tm) <= max_delta_tm):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.735195, "o", "                \r\n\u001b[?2004l\r"]
[138.735426, "o", "\u001b[?2004h> "]
[138.735631, "o", "                delta = abs(fwd_tm - rev_tm)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.735777, "o", "                if delta < best_delta:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.73595, "o", "                    best_delta = delta\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.736136, "o", "                    \r\n\u001b[?2004l\r"]
[138.736302, "o", "\u001b[?2004h> "]
[138.736465, "o", "                    # Build full primers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.736721, "o", "                    # Forward: GGTCTC-N-[overhang]-[anneal]\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.736888, "o", "> "]
[138.73715, "o", "                    fwd_primer = 'GGTCTC' + 'N' + left_overhang + fwd_anneal\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.737369, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.737698, "o", "                    # Reverse: GGTCTC-N-[overhang_RC]-[anneal_RC]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.738098, "o", "                    right_oh_rc = reverse_complement(right_overhang)\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.738307, "o", "> "]
[138.738462, "o", "                    rev_anneal_rc = reverse_complement(rev_anneal)\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.738616, "o", "> "]
[138.73888, "o", "                    rev_primer = 'GGTCTC' + 'N' + right_oh_rc + rev_anneal_rc\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.739103, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h"]
[138.739283, "o", "> "]
[138.739459, "o", "                    best_fwd = (fwd_primer, fwd_anneal, fwd_tm)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.739761, "o", "                    best_rev = (rev_primer, rev_anneal, rev_tm)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.739965, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.740142, "o", "    return best_fwd, best_rev\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.740345, "o", "print(\"\\n=== Designing Primers ===\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.740525, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.740697, "o", "# Fragment 1: Input backbone (linearized)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.741064, "o", "# We need to amplify from position 690 to 210 (going around the circle)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.741371, "o", "# This is actually: input[690:] + input[0:210]\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.74155, "o", "> "]
[138.741741, "o", "# But since it's circular, we can amplify the backbone by:\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.741956, "o", "> "]
[138.742138, "o", "# - Forward primer at position 690 (adds oh4 RC for SNAP->input junction)\r\n\u001b[?2004l\r"]
[138.742314, "o", "\u001b[?2004h> "]
[138.742583, "o", "# - Reverse primer at position 210 (adds oh1 RC for input->eGFP junction)\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.742767, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.742918, "o", "# Actually, let's think about this differently:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.743321, "o", "# The input backbone needs to connect SNAP (with oh4) to eGFP start (with oh1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[138.743524, "o", "# So: oh4 -> backbone -> oh1\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.743741, "o", "> "]
[138.743927, "o", "# Forward primer binds after position 690 and adds oh4 on 5' end\r\n\u001b[?2004l\r\u001b[?2004h"]
[138.744098, "o", "> "]
[138.744239, "o", "# Reverse primer binds before position 210 and adds oh1 on 3' end\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[138.744428, "o", "\u001b[?2004h> "]
[138.744608, "o", "SCRIPT_EOF\r\n\u001b[?2004l\r"]
[138.746422, "o", "\u001b[?2004hroot@40713b84f85c:/app# "]
[156.053594, "i", "cat >> design_primers.py << 'SCRIPT_EOF'\n\n# For Golden Gate assembly with circular product:\n# Each fragment needs compatible overhangs to assemble in order\n# Fragment order: input_backbone -> eGFP -> FLAG -> SNAP -> (back to input_backbone)\n\n# The input backbone will be linearized and will have:\n# - 5' overhang: compatible with SNAP's 3' end (oh4)\n# - 3' overhang: compatible with eGFP's 5' start (oh1)\n\n# eGFP (without stop codon):\n# - 5' overhang: oh1 (connects to input)\n# - 3' overhang: oh2 (connects to FLAG)\n\n# FLAG (without start/stop):\n# - 5' overhang: oh2 (connects to eGFP)\n# - 3' overhang: oh3 (connects to SNAP)\n\n# SNAP (without start codon):\n# - 5' overhang: oh3 (connects to FLAG)\n# - 3' overhang: oh4 (connects to input)\n\nprint(\"\\n=== Fragment Design ===\")\nprint(f\"Fragment 1 (input): oh4 -> backbone -> oh1\")\nprint(f\"Fragment 2 (eGFP): oh1 -> egfp(no stop) -> oh2\")\nprint(f\"Fragment 3 (FLAG): oh2 -> flag(no start/stop) -> oh3\")\nprint(f\"Fragment 4 (SNAP): oh3 -> snap(no start) -> oh4\")\n\n# Prepare template sequences\negfp_template = seqs['egfp'][:-3]  # Remove stop codon TAA\nflag_template = seqs['flag'][3:-3]  # Remove start ATG and stop TAA\nsnap_template = seqs['snap'][3:]  # Remove start ATG, keep stop\n\n# Input backbone: from position 690 to end, then start to 210\ninput_backbone = input_seq[690:] + input_seq[:210]\n\nprint(f\"\\neGFP template length: {len(egfp_template)}\")\nprint(f\"FLAG template length: {len(flag_template)}\")\nprint(f\"SNAP template length: {len(snap_template)}\")\nprint(f\"Input backbone length: {len(input_backbone)}\")\n\n# Design primers for each fragment\nprint(\"\\n=== Designing eGFP primers ===\")\negfp_fwd, egfp_rev = design_primer_pair('egfp', egfp_template, oh1, oh2)\nif egfp_fwd and egfp_rev:\n    print(f\"Forward: Tm={egfp_fwd[2]:.1f}°C, anneal_len={len(egfp_fwd[1])}\")\n    print(f\"Reverse: Tm={egfp_rev[2]:.1f}°C, anneal_len={len(egfp_rev[1])}\")\nelse:\n    print(\"Failed to design eGFP primers\")\n\nprint(\"\\n=== Designing FLAG primers ===\")\nflag_fwd, flag_rev = design_primer_pair('flag', flag_template, oh2, oh3)\nif flag_fwd and flag_rev:\n    print(f\"Forward: Tm={flag_fwd[2]:.1f}°C, anneal_len={len(flag_fwd[1])}\")\n    print(f\"Reverse: Tm={flag_rev[2]:.1f}°C, anneal_len={len(flag_rev[1])}\")\nelse:\n    print(\"Failed to design FLAG primers\")\n\nprint(\"\\n=== Designing SNAP primers ===\")\nsnap_fwd, snap_rev = design_primer_pair('snap', snap_template, oh3, oh4)\nif snap_fwd and snap_rev:\n    print(f\"Forward: Tm={snap_fwd[2]:.1f}°C, anneal_len={len(snap_fwd[1])}\")\n    print(f\"Reverse: Tm={snap_rev[2]:.1f}°C, anneal_len={len(snap_rev[1])}\")\nelse:\n    print(\"Failed to design SNAP primers\")\n\nprint(\"\\n=== Designing Input backbone primers ===\")\ninput_fwd, input_rev = design_primer_pair('input', input_backbone, oh4, oh1)\nif input_fwd and input_rev:\n    print(f\"Forward: Tm={input_fwd[2]:.1f}°C, anneal_len={len(input_fwd[1])}\")\n    print(f\"Reverse: Tm={input_rev[2]:.1f}°C, anneal_len={len(input_rev[1])}\")\nelse:\n    print(\"Failed to design input primers\")\n\nSCRIPT_EOF\n"]
