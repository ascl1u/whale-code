[57.969022, "i", "python3 << 'EOF'\n# Parse sequences\nwith open('sequences.fasta', 'r') as f:\n    lines = f.readlines()\n\nseqs = {}\ncurrent = None\nfor line in lines:\n    line = line.strip()\n    if line.startswith('>'):\n        current = line[1:]\n        seqs[current] = ''\n    else:\n        seqs[current] += line\n\n# Look at egfp more carefully\nprint(\"eGFP sequence (first 50 bp):\")\nprint(seqs['egfp'][:50])\nprint(\"\\neGFP sequence (last 50 bp):\")\nprint(seqs['egfp'][-50:])\n\n# Look at flag\nprint(\"\\nFLAG sequence (full):\")\nprint(seqs['flag'])\nprint(f\"Length: {len(seqs['flag'])}\")\n\n# Look at snap\nprint(\"\\nSNAP sequence (first 50 bp):\")\nprint(seqs['snap'][:50])\nprint(\"\\nSNAP sequence (last 50 bp):\")\nprint(seqs['snap'][-50:])\n\n# Check if flag is in output without start codon\nflag_no_start = seqs['flag'][3:]  # Remove ATG\nflag_pos = seqs['output'].find(flag_no_start[:30])\nprint(f\"\\nFLAG without start codon: {flag_pos}\")\n\n# Check if flag is in output without stop codon\nflag_no_stop = seqs['flag'][:-3]  # Remove TAA\nflag_pos2 = seqs['output'].find(flag_no_stop[-30:])\nprint(f\"FLAG without stop codon (end): {flag_pos2}\")\n\nEOF\n"]
