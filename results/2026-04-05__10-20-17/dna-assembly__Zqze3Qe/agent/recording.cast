[341.316831, "i", "python3 << 'EOF'\n# Final verification of Golden Gate assembly logic\nprint(\"=== Golden Gate Assembly Verification ===\")\nprint()\nprint(\"After PCR amplification with designed primers:\")\nprint()\nprint(\"Fragment 1 (input backbone):\")\nprint(\"  5'-[BsaI site]-N-TGAG-[backbone]-ACAT-N-[BsaI site]-3'\")\nprint(\"  After BsaI digestion: 5'-TGAG-[backbone]-ACAT-3'\")\nprint()\nprint(\"Fragment 2 (eGFP without stop):\")\nprint(\"  5'-[BsaI site]-N-ACAT-[eGFP]-GGTA-N-[BsaI site]-3'\")\nprint(\"  After BsaI digestion: 5'-ACAT-[eGFP]-GGTA-3'\")\nprint()\nprint(\"Fragment 3 (FLAG without start/stop):\")\nprint(\"  5'-[BsaI site]-N-GGTA-[FLAG]-GACA-N-[BsaI site]-3'\")\nprint(\"  After BsaI digestion: 5'-GGTA-[FLAG]-GACA-3'\")\nprint()\nprint(\"Fragment 4 (SNAP without start):\")\nprint(\"  5'-[BsaI site]-N-GACA-[SNAP]-TGAG-N-[BsaI site]-3'\")\nprint(\"  After BsaI digestion: 5'-GACA-[SNAP]-TGAG-3'\")\nprint()\nprint(\"Assembly order (via compatible overhangs):\")\nprint(\"  Input (TGAG...ACAT) + eGFP (ACAT...GGTA) + FLAG (GGTA...GACA) + SNAP (GACA...TGAG)\")\nprint()\nprint(\"Result: Circular plasmid with fusion protein eGFP-FLAG-SNAP inserted into input\")\nprint()\nprint(\"✓ Assembly logic verified!\")\nEOF\n"]
