[270.326627, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h"]
[270.326834, "o", "> "]
[270.327132, "o", "    return float(result.stdout.strip())\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
