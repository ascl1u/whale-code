[47.256406, "i", "python3 << 'EOF'\n# Parse sequences\nwith open('sequences.fasta', 'r') as f:\n    lines = f.readlines()\n\nseqs = {}\ncurrent = None\nfor line in lines:\n    line = line.strip()\n    if line.startswith('>'):\n        current = line[1:]\n        seqs[current] = ''\n    else:\n        seqs[current] += line\n\n# Find where egfp starts in output\negfp_start = seqs['output'].find(seqs['egfp'][:50])\nprint(f\"eGFP starts at position: {egfp_start}\")\nprint(f\"eGFP in input: {seqs['input'].find(seqs['egfp'][:50])}\")\n\n# Find where flag starts in output\nflag_start = seqs['output'].find(seqs['flag'][:30])\nprint(f\"FLAG starts at position: {flag_start}\")\n\n# Find where snap starts in output\nsnap_start = seqs['output'].find(seqs['snap'][:50])\nprint(f\"SNAP starts at position: {snap_start}\")\n\n# Check the order\nprint(f\"\\nSequence order in output: egfp({egfp_start}) -> flag({flag_start}) -> snap({snap_start})\")\n\n# Find what was replaced\nprint(f\"\\nInput length: {len(seqs['input'])}\")\nprint(f\"Output length: {len(seqs['output'])}\")\nprint(f\"Difference: {len(seqs['output']) - len(seqs['input'])}\")\nprint(f\"Insert lengths: egfp={len(seqs['egfp'])}, flag={len(seqs['flag'])}, snap={len(seqs['snap'])}, total={len(seqs['egfp'])+len(seqs['flag'])+len(seqs['snap'])}\")\n\nEOF\n"]
