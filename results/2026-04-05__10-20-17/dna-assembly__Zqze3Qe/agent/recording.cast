[156.073676, "o", "\u001b[?2004hroot@40713b84f85c:/app# "]
[166.309273, "i", "cat >> design_primers.py << 'SCRIPT_EOF'\n\n# Write primers to FASTA file\nprint(\"\\n=== Writing primers.fasta ===\")\n\nwith open('primers.fasta', 'w') as f:\n    # Input primers\n    if input_fwd and input_rev:\n        f.write(f\">input_fwd\\n\")\n        f.write(f\"{input_fwd[0]}\\n\")\n        f.write(f\">input_rev\\n\")\n        f.write(f\"{input_rev[0]}\\n\")\n    \n    # eGFP primers\n    if egfp_fwd and egfp_rev:\n        f.write(f\">egfp_fwd\\n\")\n        f.write(f\"{egfp_fwd[0]}\\n\")\n        f.write(f\">egfp_rev\\n\")\n        f.write(f\"{egfp_rev[0]}\\n\")\n    \n    # FLAG primers\n    if flag_fwd and flag_rev:\n        f.write(f\">flag_fwd\\n\")\n        f.write(f\"{flag_fwd[0]}\\n\")\n        f.write(f\">flag_rev\\n\")\n        f.write(f\"{flag_rev[0]}\\n\")\n    \n    # SNAP primers\n    if snap_fwd and snap_rev:\n        f.write(f\">snap_fwd\\n\")\n        f.write(f\"{snap_fwd[0]}\\n\")\n        f.write(f\">snap_rev\\n\")\n        f.write(f\"{snap_rev[0]}\\n\")\n\nprint(\"Primers written to primers.fasta\")\nprint(\"\\nSummary:\")\nprint(f\"Total primer pairs: 4\")\nprint(f\"Total primers: 8\")\n\nSCRIPT_EOF\n"]
