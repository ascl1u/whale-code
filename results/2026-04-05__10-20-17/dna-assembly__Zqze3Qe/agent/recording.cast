[286.823567, "o", "=== BsaI Site Verification ===\r\nBsaI-HF v2 recognition: GGTCTC (forward) / GAGACC (reverse complement)\r\nCuts 1 nt downstream on top strand, 5 nt on bottom strand\r\nCreates 4 bp 5' overhang\r\n\r\ninput_fwd: GGTCTC-N-TGAG-TGAGGATCCC...\r\n  Overhang: TGAG\r\ninput_rev: GGTCTC-N-ATGT-ATGTATATCT...\r\n  Overhang: ATGT\r\negfp_fwd: GGTCTC-N-ACAT-ATGAGCAAGG...\r\n  Overhang: ACAT\r\negfp_rev: GGTCTC-N-TACC-TTTGTACAGC...\r\n  Overhang: TACC\r\nflag_fwd: GGTCTC-N-GGTA-GGTAGTGGCT...\r\n  Overhang: GGTA\r\nflag_rev: GGTCTC-N-TGTC-TGAACCACTA...\r\n  Overhang: TGTC\r\nsnap_fwd: GGTCTC-N-GACA-GACAAAGACT...\r\n  Overhang: GACA\r\nsnap_rev: GGTCTC-N-CTCA-TTAACCCAGC...\r\n  Overhang: CTCA\r\n"]
[286.823879, "o", "\r\n=== Expected Assembly ===\r\nFragment 1 (input): TGAG -> backbone -> ACAT\r\nFragment 2 (egfp):  ACAT -> egfp -> GGTA\r\nFragment 3 (flag):  GGTA -> flag -> GACA\r\nFragment 4 (snap):  GACA -> snap -> TGAG\r\n\r\nThis creates a circular assembly: input -> egfp -> flag -> snap -> input\r\n"]
[286.829375, "o", "\u001b[?2004hroot@40713b84f85c:/app# "]
[305.150065, "i", "cat primers.fasta | head -20\n"]
