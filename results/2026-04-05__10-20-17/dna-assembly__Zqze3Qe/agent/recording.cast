[270.331844, "o", "> "]
[270.332008, "o", "    # So annealing starts at position 11\r\n\u001b[?2004l\r\u001b[?2004h> "]
[270.332221, "o", "    anneal = seq[11:]\r\n\u001b[?2004l\r\u001b[?2004h"]
[270.332357, "o", "> "]
