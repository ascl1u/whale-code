[70.196493, "i", "python3 << 'EOF'\n# Parse sequences\nwith open('sequences.fasta', 'r') as f:\n    lines = f.readlines()\n\nseqs = {}\ncurrent = None\nfor line in lines:\n    line = line.strip()\n    if line.startswith('>'):\n        current = line[1:]\n        seqs[current] = ''\n    else:\n        seqs[current] += line\n\n# Find exact positions\negfp_start = seqs['output'].find(seqs['egfp'])\nprint(f\"eGFP in output: {egfp_start} to {egfp_start + len(seqs['egfp'])}\")\n\n# Check flag without start and stop\nflag_core = seqs['flag'][3:-3]  # Remove ATG and TAA\nflag_start = seqs['output'].find(flag_core)\nprint(f\"FLAG (no start/stop) in output: {flag_start} to {flag_start + len(flag_core)}\")\n\n# Check snap without start and stop\nsnap_no_start = seqs['snap'][3:]\nsnap_start = seqs['output'].find(snap_no_start)\nprint(f\"SNAP (no start) in output: {snap_start} to {snap_start + len(snap_no_start)}\")\n\nsnap_no_stop = seqs['snap'][:-3]\nsnap_start2 = seqs['output'].find(snap_no_stop)\nprint(f\"SNAP (no stop) in output: {snap_start2} to {snap_start2 + len(snap_no_stop)}\")\n\nsnap_no_both = seqs['snap'][3:-3]\nsnap_start3 = seqs['output'].find(snap_no_both)\nprint(f\"SNAP (no start/stop) in output: {snap_start3} to {snap_start3 + len(snap_no_both)}\")\n\n# Look at junctions\nprint(\"\\n=== Junction Analysis ===\")\nprint(f\"Before eGFP (output[200:210]): {seqs['output'][200:210]}\")\nprint(f\"eGFP starts with: {seqs['egfp'][:10]}\")\nprint(f\"After eGFP (output[{egfp_start + len(seqs['egfp'])}:{egfp_start + len(seqs['egfp']) + 10}]): {seqs['output'][egfp_start + len(seqs['egfp']):egfp_start + len(seqs['egfp']) + 10]}\")\n\nEOF\n"]
