[156.062159, "o", "> "]
[156.062338, "o", "input_backbone = input_seq[690:] + input_seq[:210]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.062503, "o", "\u001b[?2004h> "]
[156.062685, "o", "print(f\"\\neGFP template length: {len(egfp_template)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.062843, "o", "print(f\"FLAG template length: {len(flag_template)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.063093, "o", "print(f\"SNAP template length: {len(snap_template)}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.063245, "o", "> "]
[156.063356, "o", "print(f\"Input backbone length: {len(input_backbone)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[156.063492, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[156.063684, "o", "# Design primers for each fragment\r\n\u001b[?2004l\r\u001b[?2004h"]
