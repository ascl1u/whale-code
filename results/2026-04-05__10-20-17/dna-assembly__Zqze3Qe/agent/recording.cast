[96.188816, "i", "python3 << 'EOF'\n# Parse sequences\nwith open('sequences.fasta', 'r') as f:\n    lines = f.readlines()\n\nseqs = {}\ncurrent = None\nfor line in lines:\n    line = line.strip()\n    if line.startswith('>'):\n        current = line[1:]\n        seqs[current] = ''\n    else:\n        seqs[current] += line\n\n# Map the complete fusion\negfp_no_stop = seqs['egfp'][:-3]\nflag_no_start_stop = seqs['flag'][3:-3]\nsnap_no_start = seqs['snap'][3:]\n\negfp_start = 210\negfp_end = egfp_start + len(egfp_no_stop)\nflag_start = egfp_end\nflag_end = flag_start + len(flag_no_start_stop)\nsnap_start = flag_end\nsnap_end = snap_start + len(snap_no_start)\n\nprint(\"Fusion protein structure in output:\")\nprint(f\"eGFP (no stop): {egfp_start}-{egfp_end} ({len(egfp_no_stop)} bp)\")\nprint(f\"FLAG (no start/stop): {flag_start}-{flag_end} ({len(flag_no_start_stop)} bp)\")\nprint(f\"SNAP (no start): {snap_start}-{snap_end} ({len(snap_no_start)} bp)\")\nprint(f\"Total insert: {egfp_start}-{snap_end} ({snap_end - egfp_start} bp)\")\n\n# Find what's before and after the insert\nprint(f\"\\nBefore insert (output[200:210]): {seqs['output'][200:210]}\")\nprint(f\"After insert (output[{snap_end}:{snap_end+10}]): {seqs['output'][snap_end:snap_end+10]}\")\n\n# Find corresponding sequence in input\ninput_before = seqs['input'].find(seqs['output'][200:210])\nprint(f\"\\nBefore sequence in input at: {input_before}\")\n\ninput_after = seqs['input'].find(seqs['output'][snap_end:snap_end+20])\nprint(f\"After sequence in input at: {input_after}\")\n\nif input_before >= 0 and input_after >= 0:\n    replaced_seq = seqs['input'][input_before+10:input_after]\n    print(f\"\\nReplaced sequence in input: position {input_before+10} to {input_after}\")\n    print(f\"Replaced sequence length: {len(replaced_seq)} bp\")\n    print(f\"Replaced sequence: {replaced_seq}\")\n\nEOF\n"]
