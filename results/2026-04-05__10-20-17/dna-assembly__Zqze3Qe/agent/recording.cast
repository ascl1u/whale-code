[207.808666, "o", "    best_delta = float('inf')\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.808887, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.809444, "o", "    # Try different annealing lengths\r\n\u001b[?2004l\r"]
[207.809617, "o", "\u001b[?2004h> "]
[207.810211, "o", "    for fwd_len in range(min_len, max_len + 1):\r\n\u001b[?2004l\rw\u001b[?2004h"]
[207.810441, "o", "> "]
[207.81084, "o", "        for rev_len in range(min_len, max_len + 1):\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.811146, "o", "> "]
[207.811702, "o", "            # Forward primer annealing region\r\n\u001b[?2004l\r"]
[207.811911, "o", "\u001b[?2004h> "]
[207.812426, "o", "            fwd_anneal = template_seq[:fwd_len]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.812983, "o", "            fwd_tm = calculate_tm(fwd_anneal)\r\n\u001b[?2004l\r"]
[207.813227, "o", "\u001b[?2004h> "]
[207.813504, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.814382, "o", "            # Reverse primer annealing region (binds to end of template)\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.814592, "o", "> "]
[207.815245, "o", "            rev_anneal = template_seq[-rev_len:]\r\n\u001b[?2004l\r"]
[207.815518, "o", "\u001b[?2004h> "]
[207.816003, "o", "            rev_tm = calculate_tm(rev_anneal)\r\n\u001b[?2004l\r"]
[207.816203, "o", "\u001b[?2004h> "]
[207.816386, "o", "            \r\n\u001b[?2004l\r\\\u001b[?2004h> "]
[207.816941, "o", "            # Check constraints\r\n\u001b[?2004l\r\\\u001b[?2004h"]
[207.81726, "o", "> "]
[207.817716, "o", "            if (min_tm <= fwd_tm <= max_tm and \r\n\u001b[?2004l\r"]
[207.818105, "o", "\u001b[?2004h> "]
[207.818798, "o", "                min_tm <= rev_tm <= max_tm and \r\n\u001b[?2004l\r"]
[207.820133, "o", "\u001b[?2004h> "]
[207.821919, "o", "                abs(fwd_tm - rev_tm) <= max_delta_tm):\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.822194, "o", "> "]
[207.822634, "o", "                \r\n\u001b[?2004l\rIP\u001b[?2004h> "]
[207.823016, "o", "                delta = abs(fwd_tm - rev_tm)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.823305, "o", "                if delta < best_delta:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.82347, "o", "                    best_delta = delta\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.823556, "o", "> "]
[207.823781, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.824251, "o", "                    # Build full primers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.824689, "o", "                    # Forward: GGTCTC-N-[overhang]-[anneal]\r\n\u001b[?2004l\r"]
[207.824975, "o", "\u001b[?2004h> "]
[207.8254, "o", "                    fwd_primer = 'GGTCTCN' + left_overhang + fwd_anneal\r\n\u001b[?2004l\r"]
[207.825655, "o", "\u001b[?2004h> "]
[207.825967, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.826297, "o", "                    # Reverse: GGTCTC-N-[overhang_RC]-[anneal_RC]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.82683, "o", "                    right_oh_rc = reverse_complement(right_overhang)\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.827018, "o", "> "]
[207.827377, "o", "                    rev_anneal_rc = reverse_complement(rev_anneal)\r\n\u001b[?2004l\r"]
[207.827775, "o", "\u001b[?2004h> "]
[207.828103, "o", "                    rev_primer = 'GGTCTCN' + right_oh_rc + rev_anneal_rc\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.82836, "o", "                    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.828768, "o", "                    best_fwd = (fwd_primer, fwd_anneal, fwd_tm)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.829272, "o", "                    best_rev = (rev_primer, rev_anneal, rev_tm)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.829548, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.829731, "o", "    return best_fwd, best_rev\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[207.830003, "o", "\u001b[?2004h> "]
[207.830826, "o", "print(\"\\n=== Fragment Design ===\")\r\n\u001b[?2004l\r"]
[207.83107, "o", "\u001b[?2004h> print(f\"Fragment 1 (input): oh4 -> backbone -> oh1\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.831305, "o", "print(f\"Fragment 2 (eGFP): oh1 -> egfp(no stop) -> oh2\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.83156, "o", "print(f\"Fragment 3 (FLAG): oh2 -> flag(no start/stop) -> oh3\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.831924, "o", "print(f\"Fragment 4 (SNAP): oh3 -> snap(no start) -> oh4\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.832157, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.832479, "o", "# Prepare template sequences\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.832724, "o", "egfp_template = seqs['egfp'][:-3].upper()  # Remove stop codon TAA\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.833218, "o", "flag_template = seqs['flag'][3:-3].upper()  # Remove start ATG and stop TAA\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.833696, "o", "snap_template = seqs['snap'][3:].upper()  # Remove start ATG, keep stop\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[207.833951, "o", "\u001b[?2004h> "]
[207.834202, "o", "# Input backbone: from position 690 to end, then start to 210\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.834602, "o", "input_backbone = (input_seq[690:] + input_seq[:210]).upper()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[207.834787, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[207.835043, "o", "print(f\"\\neGFP template length: {len(egfp_template)}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.83527, "o", "> "]
[207.835541, "o", "print(f\"FLAG template length: {len(flag_template)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.835816, "o", "print(f\"SNAP template length: {len(snap_template)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.836237, "o", "print(f\"Input backbone length: {len(input_backbone)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[207.836487, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[207.836646, "o", "# Design primers for each fragment\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.878624, "o", "print(\"\\n=== Designing eGFP primers ===\")\r\n\u001b[?2004l\r\u001b[?2004h> egfp_fwd, egfp_rev = design_primer_pair('egfp', egfp_template, oh1, oh2)\r\n\u001b[?2004l\r"]
[207.878972, "o", "\u001b[?2004h> if egfp_fwd and egfp_rev:\r\n\u001b[?2004l\r"]
[207.879308, "o", "\u001b[?2004h> "]
[207.879627, "o", "    print(f\"Forward: Tm={egfp_fwd[2]:.1f}°C, anneal_len={len(egfp_fwd[1])}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.879938, "o", "> "]
[207.880367, "o", "    print(f\"Reverse: Tm={egfp_rev[2]:.1f}°C, anneal_len={len(egfp_rev[1])}\")\r\n\u001b[?2004l\r"]
[207.880691, "o", "\u001b[?2004h> else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.88102, "o", "    print(\"Failed to design eGFP primers\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[207.881238, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[207.881669, "o", "print(\"\\n=== Designing FLAG primers ===\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.881985, "o", "> "]
[207.882413, "o", "flag_fwd, flag_rev = design_primer_pair('flag', flag_template, oh2, oh3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.882747, "o", "> "]
[207.883056, "o", "if flag_fwd and flag_rev:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.883483, "o", "    print(f\"Forward: Tm={flag_fwd[2]:.1f}°C, anneal_len={len(flag_fwd[1])}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.884224, "o", "    print(f\"Reverse: Tm={flag_rev[2]:.1f}°C, anneal_len={len(flag_rev[1])}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.884484, "o", "> else:\r\n\u001b[?2004l\r"]
[207.884732, "o", "\u001b[?2004h> "]
[207.884958, "o", "    print(\"Failed to design FLAG primers\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.885478, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[207.885826, "o", "> print(\"\\n=== Designing SNAP primers ===\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.886409, "o", "snap_fwd, snap_rev = design_primer_pair('snap', snap_template, oh3, oh4)\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.88661, "o", "> "]
[207.886973, "o", "if snap_fwd and snap_rev:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.887539, "o", "    print(f\"Forward: Tm={snap_fwd[2]:.1f}°C, anneal_len={len(snap_fwd[1])}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.887817, "o", "> "]
[207.888315, "o", "    print(f\"Reverse: Tm={snap_rev[2]:.1f}°C, anneal_len={len(snap_rev[1])}\")\r\n\u001b[?2004l\r"]
[207.888554, "o", "\u001b[?2004h> else:\r\n\u001b[?2004l\r"]
[207.888838, "o", "\u001b[?2004h> "]
[207.889229, "o", "    print(\"Failed to design SNAP primers\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[207.889544, "o", "\u001b[?2004h> "]
[207.890158, "o", "print(\"\\n=== Designing Input backbone primers ===\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.890929, "o", "input_fwd, input_rev = design_primer_pair('input', input_backbone, oh4, oh1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.891225, "o", "> "]
[207.891757, "o", "if input_fwd and input_rev:\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.892052, "o", "> "]
[207.892625, "o", "    print(f\"Forward: Tm={input_fwd[2]:.1f}°C, anneal_len={len(input_fwd[1])}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.893305, "o", "    print(f\"Reverse: Tm={input_rev[2]:.1f}°C, anneal_len={len(input_rev[1])}\")\r\n\u001b[?2004l\r"]
[207.893596, "o", "\u001b[?2004h> "]
[207.894255, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.894946, "o", "    print(\"Failed to design input primers\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.895649, "o", "# Write primers to FASTA file\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.896407, "o", "print(\"\\n=== Writing primers.fasta ===\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.898194, "o", "with open('primers.fasta', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     # Input primers\r\n\u001b[?2004l\r\u001b[?2004h>     if input_fwd and input_rev:\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(f\">input_fwd\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.898676, "o", "        f.write(f\"{input_fwd[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.899028, "o", "        f.write(f\">input_rev\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[207.899126, "o", "> "]
[207.899715, "o", "        f.write(f\"{input_rev[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.89991, "o", "    # eGFP primers\r\n\u001b[?2004l\r\u001b[?2004h>     if egfp_fwd and egfp_rev:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.900458, "o", "        f.write(f\">egfp_fwd\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.900914, "o", "        f.write(f\"{egfp_fwd[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(f\">egfp_rev\\n\")\r\n\u001b[?2004l\r"]
[207.901199, "o", "\u001b[?2004h> "]
[207.901545, "o", "        f.write(f\"{egfp_rev[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.901875, "o", "    # FLAG primers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.902192, "o", "    if flag_fwd and flag_rev:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.90269, "o", "        f.write(f\">flag_fwd\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.902896, "o", "        f.write(f\"{flag_fwd[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.903192, "o", "        f.write(f\">flag_rev\\n\")\r\n\u001b[?2004l\r"]
[207.903415, "o", "\u001b[?2004h> "]
[207.903696, "o", "        f.write(f\"{flag_rev[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.903897, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.904281, "o", "    # SNAP primers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.90465, "o", "    if snap_fwd and snap_rev:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.904971, "o", "        f.write(f\">snap_fwd\\n\")\r\n\u001b[?2004l\r"]
[207.905332, "o", "\u001b[?2004h> "]
[207.90556, "o", "        f.write(f\"{snap_fwd[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.905927, "o", "        f.write(f\">snap_rev\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[207.906273, "o", "        f.write(f\"{snap_rev[0]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[207.906486, "o", "> "]
[207.907868, "o", "print(\"Primers written to primers.fasta\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\nSummary:\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Total primer pairs: 4\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Total primers: 8\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> SCRIPT_EOF\r\n\u001b[?2004l\r"]
[207.91122, "o", "\u001b[?2004hroot@40713b84f85c:/app# "]
[212.384229, "i", "python3 design_primers.py; printf '%s\\n' '__CMDEND__6__'\n"]
[212.384925, "o", "python3 design_primers.py; printf '%s\\n' '__CMDEND__6__'\r\n\u001b[?2004l\r"]
[212.420733, "o", "Analyzing junctions...\r\nOverhang 1 (input->eGFP): ACAT\r\nOverhang 2 (eGFP->FLAG): GGTA\r\nOverhang 3 (FLAG->SNAP): GACA\r\nOverhang 4 (SNAP->input): TGAG\r\n\r\n=== Fragment Design ===\r\nFragment 1 (input): oh4 -> backbone -> oh1\r\nFragment 2 (eGFP): oh1 -> egfp(no stop) -> oh2\r\nFragment 3 (FLAG): oh2 -> flag(no start/stop) -> oh3\r\nFragment 4 (SNAP): oh3 -> snap(no start) -> oh4\r\n\r\neGFP template length: 714"]
[212.421046, "o", "\r\nFLAG template length: 84\r\nSNAP template length: 546\r\nInput backbone length: 2247\r\n\r\n=== Designing eGFP primers ===\r\n"]
[215.98784, "o", "Forward: Tm=68.5°C, anneal_len=21\r\nReverse: Tm=68.5°C, anneal_len=24\r\n\r\n=== Designing FLAG primers ===\r\n"]
[219.390629, "o", "Forward: Tm=69.5°C, anneal_len=23\r\nReverse: Tm=69.4°C, anneal_len=26\r\n\r\n=== Designing SNAP primers ===\r\n"]
[222.842796, "o", "Forward: Tm=71.2°C, anneal_len=28\r\nReverse: Tm=71.2°C, anneal_len=26\r\n\r\n=== Designing Input backbone primers ===\r\n"]
[226.512015, "o", "Forward: Tm=59.8°C, anneal_len=18\r\nReverse: Tm=59.8°C, anneal_len=32\r\n\r\n=== Writing primers.fasta ===\r\n"]
[226.512326, "o", "Primers written to primers.fasta\r\n\r\nSummary:\r\nTotal primer pairs: 4\r\nTotal primers: 8\r\n"]
[226.517681, "o", "__CMDEND__6__\r\n"]
[226.51791, "o", "\u001b[?2004hroot@40713b84f85c:/app# "]
[233.648852, "i", "cat primers.fasta; printf '%s\\n' '__CMDEND__7__'\n"]
[233.649727, "o", "cat primers.fasta; printf '%s\\n' '__CMDEND__7__'\r\n\u001b[?2004l\r"]
[233.651683, "o", ">input_fwd\r\nGGTCTCNTGAGTGAGGATCCCGGGAATTC\r\n>input_rev\r\nGGTCTCNATGTATGTATATCTCCTTCTTAAAGTTAAACAAAAT\r\n>egfp_fwd\r\nGGTCTCNACATATGAGCAAGGGCGAGGAGCTG\r\n>egfp_rev\r\nGGTCTCNTACCTTTGTACAGCTCGTCCATGCCGAG\r\n>flag_fwd\r\nGGTCTCNGGTAGGTAGTGGCTCCGGTAGCGGTAG\r\n>flag_rev\r\nGGTCTCNTGTCTGAACCACTACCTGAACCAGAACCGG\r\n>snap_fwd\r\nGGTCTCNGACAGACAAAGACTGCGAAATGAAGCGCACCA\r\n>snap_rev\r\nGGTCTCNCTCATTAACCCAGCCCAGGCTTACCCAGTC\r\n"]
[233.652291, "o", "__CMDEND__7__\r\n\u001b[?2004hroot@40713b84f85c:/app# "]
[240.509514, "i", "wc -l primers.fasta; printf '%s\\n' '__CMDEND__8__'\n"]
[240.509961, "o", "wc -l primers.fasta; printf '%s\\n' '__CMDEND__8__'\r\n\u001b[?2004l\r"]
[240.51145, "o", "16 primers.fasta\r\n"]
[240.511776, "o", "__CMDEND__8__\r\n"]
