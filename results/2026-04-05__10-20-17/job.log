Sending keys: ['cat > design_primers.py << \'SCRIPT_EOF\'\nimport subprocess\nimport sys\n\ndef parse_fasta(filename):\n    """Parse FASTA file and return dictionary of sequences"""\n    seqs = {}\n    current = None\n    with open(filename, \'r\') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith(\'>\'):\n                current = line[1:]\n                seqs[current] = \'\'\n            else:\n                seqs[current] += line\n    return seqs\n\ndef reverse_complement(seq):\n    """Return reverse complement of DNA sequence"""\n    seq = seq.upper()\n    complement = {\'A\': \'T\', \'T\': \'A\', \'G\': \'C\', \'C\': \'G\', \'N\': \'N\'}\n    return \'\'.join(complement[base] for base in reversed(seq))\n\ndef calculate_tm(seq):\n    """Calculate melting temperature using oligotm with specified parameters"""\n    cmd = [\'oligotm\', \'-tp\', \'1\', \'-sc\', \'1\', \'-mv\', \'50\', \'-dv\', \'2\', \'-n\', \'0.8\', \'-d\', \'500\', seq]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    try:\n        return float(result.stdout.strip())\n    except:\n        return 0.0\n\n# Parse sequences\nseqs = parse_fasta(\'sequences.fasta\')\n\n# Define the structure\ninput_seq = seqs[\'input\']\noutput_seq = seqs[\'output\']\n\n# Junction sequences from output (convert to uppercase)\noh1 = output_seq[206:210].upper()  # Before eGFP\noh2 = output_seq[924:928].upper()  # Between eGFP and FLAG\noh3 = output_seq[1008:1012].upper()  # Between FLAG and SNAP\noh4 = output_seq[1554:1558].upper()  # After SNAP\n\nprint("Analyzing junctions...")\nprint(f"Overhang 1 (input->eGFP): {oh1}")\nprint(f"Overhang 2 (eGFP->FLAG): {oh2}")\nprint(f"Overhang 3 (FLAG->SNAP): {oh3}")\nprint(f"Overhang 4 (SNAP->input): {oh4}")\n\nSCRIPT_EOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
