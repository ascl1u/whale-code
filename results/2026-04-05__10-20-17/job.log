mplate\negfp_fwd_tail = "GGTCTCNATGA"\negfp_template_start = egfp_template\nfor length in range(15, 46):\n    anneal = egfp_template_start[:length]\n    tm = calc_tm(anneal)\n    if tm and 58 <= tm <= 72:\n        egfp_fwd = egfp_fwd_tail + anneal\n        egfp_fwd_tm = tm\n        egfp_fwd_anneal = anneal\n        print(f"  Forward annealing region: {length}bp, Tm: {tm:.2f}°C")\n        break\n\n# Reverse: need overhang GGTA (on the template strand after EGFP)\n# The reverse primer anneals to the complement, so we need TACC on the product\n# GAGACC N TACC {template_rc}\negfp_rev_tail = "GAGACCNTACC"\negfp_template_end_rc = reverse_complement(egfp_template[-45:])\nfor length in range(15, 46):\n    anneal = egfp_template_end_rc[:length]\n    tm = calc_tm(anneal)\n    if tm and 58 <= tm <= 72 and abs(tm - egfp_fwd_tm) <= 5:\n        egfp_rev = egfp_rev_tail + anneal\n        egfp_rev_tm = tm\n        egfp_rev_anneal = anneal\n        print(f"  Reverse annealing region: {length}bp, Tm: {tm:.2f}°C")\n        print(f"  Tm difference: {abs(tm - egfp_fwd_tm):.2f}°C")\n        break\n\nprimers.append((\'egfp_fwd\', egfp_fwd, egfp_fwd_anneal, egfp_fwd_tm))\nprimers.append((\'egfp_rev\', egfp_rev, egfp_rev_anneal, egfp_rev_tm))\n\nprint("\\nEGFP primers designed.\\n")\nEOFPYTHON\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
