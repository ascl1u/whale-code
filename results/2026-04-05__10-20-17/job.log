hang (to match eGFP end)\nflag_fwd_primer = \'GGTCTCNGGTA\' + flag_fwd_anneal\n\n# FLAG reverse primer: needs to create overhang for SNAP\n# SNAP starts with \'gacaaagactgc\' (after removing ATG)\n# We need first 4bp: \'gaca\'\n# RC of \'gaca\' = \'tgtc\'\nflag_rev_primer_anneal_rc = reverse_complement(flag_rev_anneal)\nflag_rev_primer = flag_rev_primer_anneal_rc + \'GAGACCNTGTC\'\n\nprint(f"FLAG forward primer: {flag_fwd_primer}")\nprint(f"FLAG reverse primer: {flag_rev_primer}")\nprint()\n\nprimers.append((\'>flag_fwd\', flag_fwd_primer))\nprimers.append((\'>flag_rev\', flag_rev_primer))\n\n# 4. SNAP primers (without start codon, with stop codon)\nprint("=" * 80)\nprint("4. SNAP INSERT (without start codon)")\nprint("=" * 80)\n\nsnap_fwd_template = snap_insert[:100]\nsnap_rev_template = snap_insert[-100:]\n\nsnap_fwd_anneal, snap_fwd_tm = find_primer(snap_fwd_template, \'fwd\')\nsnap_rev_anneal, snap_rev_tm = find_primer(snap_rev_template, \'rev\')\n\nprint(f"Forward primer annealing: {snap_fwd_anneal} (Tm: {snap_fwd_tm:.2f}°C)")\nprint(f"Reverse primer annealing: {snap_rev_anneal} (Tm: {snap_rev_tm:.2f}°C)")\nprint(f"Tm difference: {abs(snap_fwd_tm - snap_rev_tm):.2f}°C")\nprint()\n\n# SNAP forward primer: creates \'gaca\' overhang (to match FLAG end)\nsnap_fwd_primer = \'GGTCTCNGACA\' + snap_fwd_anneal\n\n# SNAP reverse primer: needs to create overhang for input backbone\n# Should match \'ttaa\' (input backbone expects this)\n# RC of \'ttaa\' = \'ttaa\' (palindrome!)\nsnap_rev_primer_anneal_rc = reverse_complement(snap_rev_anneal)\nsnap_rev_primer = snap_rev_primer_anneal_rc + \'GAGACCNTTAA\'\n\nprint(f"SNAP forward primer: {snap_fwd_primer}")\nprint(f"SNAP reverse primer: {snap_rev_primer}")\nprint()\n\nprimers.append((\'>snap_fwd\', snap_fwd_primer))\nprimers.append((\'>snap_rev\', snap_rev_primer))\n\n# Write primers to file\nprint("=" * 80)\nprint("Writing primers to primers.fasta...")\nprint("=" * 80)\n\nwith open(\'primers.fasta\', \'w\') as f:\n    for header, seq in primers:\n        f.write(f"{header}\\n{seq}\\n")\n\nprint("Done! Primers written to primers.fasta")\nprint(f"Total primers: {len(primers)}")\n\nEOFMAIN\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
