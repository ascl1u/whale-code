t\'][snap_start+len(snap_seq)-10:snap_start+len(snap_seq)]}|{seqs[\'output\'][snap_start+len(snap_seq):snap_start+len(snap_seq)+10]}...")\n\n# Find what gets removed from input\ninput_seq = seqs[\'input\']\noutput_seq = seqs[\'output\']\n\n# The output before egfp\nbefore_insert = output_seq[:egfp_start]\n# The output after snap\nafter_insert = output_seq[snap_start + len(snap_seq):]\n\nprint(f"\\nVector backbone junctions:")\nprint(f"  End of upstream: {before_insert[-20:]}")\nprint(f"  Start of downstream: {after_insert[:20]}")\n\nEOF\npython3 design_primers.py\n'] min_timeout_sec: 1 max_timeout_sec: 180.0
