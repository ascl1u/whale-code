Sending keys: ['cat > verify_annealing.py << \'EOF\'\nimport subprocess\n\ndef reverse_complement(seq):\n    complement = {\'A\': \'T\', \'T\': \'A\', \'G\': \'C\', \'C\': \'G\'}\n    return \'\'.join(complement[base] for base in reversed(seq))\n\n# Read sequences\nseqs = {}\nwith open(\'sequences.fasta\', \'r\') as f:\n    current_name = None\n    for line in f:\n        line = line.strip()\n        if line.startswith(\'>\'):\n            current_name = line[1:]\n            seqs[current_name] = \'\'\n        else:\n            seqs[current_name] += line.upper()\n\n# Read primers\nprimers = {}\nwith open(\'primers.fasta\', \'r\') as f:\n    current_name = None\n    for line in f:\n        line = line.strip()\n        if line.startswith(\'>\'):\n            current_name = line[1:]\n            primers[current_name] = \'\'\n        else:\n            primers[current_name] += line.upper()\n\nprint("=== VERIFYING PRIMER ANNEALING ===")\nprint()\n\n# Prepare templates\negfp_template = seqs[\'egfp\'][:-3]  # Remove stop codon\nflag_template = seqs[\'flag\'][3:-3]  # Remove ATG and stop\nsnap_template = seqs[\'snap\'][3:]  # Remove ATG\n\ntemplates = {\n    \'input\': seqs[\'input\'],\n    \'egfp\': egfp_template,\n    \'flag\': flag_template,\n    \'snap\': snap_template\n}\n\n# Check each primer\nfor name in [\'input\', \'egfp\', \'flag\', \'snap\']:\n    fwd_primer = primers[f\'{name}_fwd\']\n    rev_primer = primers[f\'{name}_rev\']\n    template = templates[name]\n    \n    # Extract annealing regions\n    fwd_anneal = fwd_primer[11:]  # Skip GGTCTCN + 4bp overhang\n    rev_anneal = rev_primer[11:]  # Skip GAGACCN + 4bp overhang\n    \n    print(f"{name.upper()}:")\n    \n    # Check forward primer\n    if name == \'input\':\n        # Input forward starts at position 1554\n        match_pos = seqs[\'input\'].find(fwd_anneal)\n        print(f"  Fwd anneals at position: {match_pos}")\n        if match_pos == 1554:\n            print(f"  ✓ Forward primer anneals correctly")\n        else:\n            print(f"  Note: Expected position 1554")\n    else:\n        if template.startswith(fwd_anneal):\n            print(f"  ✓ Forward primer anneals to start of template")\n        else:\n            print(f"  ✗ Forward primer does not match template start!")\n    \n    # Check reverse primer\n    rev_anneal_rc = reverse_complement(rev_anneal)\n    if name == \'input\':\n        # Input reverse ends at position 210\n        match_pos = seqs[\'input\'].find(rev_anneal_rc)\n        expected_end = 210\n        actual_end = match_pos + len(rev_anneal_rc)\n        print(f"  Rev anneals at position: {match_pos} to {actual_end}")\n        if actual_end == expected_end:\n            print(f"  ✓ Reverse primer anneals correctly")\n        else:\n            print(f"  Note: Expected to end at position {expected_end}")\n    else:\n        if template.endswith(rev_anneal_rc):\n            print(f"  ✓ Reverse primer anneals to end of template")\n        else:\n            print(f"  ✗ Reverse primer does not match template end!")\n    print()\n\nEOF\npython3 verify_annealing.py\n'] min_timeout_sec: 1 max_timeout_sec: 180.0
