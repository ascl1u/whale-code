Sending keys: ['cat > create_primers.py << \'EOF\'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open(\'sequences.fasta\', \'r\') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith(\'>\'):\n            current_name = line[1:]\n            seqs[current_name] = \'\'\n        else:\n            seqs[current_name] += line\n\ndef reverse_complement(seq):\n    complement = {\'A\': \'T\', \'T\': \'A\', \'G\': \'C\', \'C\': \'G\'}\n    return \'\'.join(complement[base] for base in reversed(seq))\n\ndef calculate_tm(seq):\n    """Calculate Tm using oligotm"""\n    try:\n        result = subprocess.run(\n            [\'oligotm\', \'-tp\', \'1\', \'-sc\', \'1\', \'-mv\', \'50\', \'-dv\', \'2\', \'-n\', \'0.8\', \'-d\', \'500\', seq],\n            capture_output=True, text=True, check=True\n        )\n        return float(result.stdout.strip())\n    except:\n        return None\n\ndef find_optimal_primer(template, min_len=15, max_len=45, target_tm_min=58, target_tm_max=72):\n    """Find optimal primer length for given template"""\n    for length in range(min_len, max_len + 1):\n        primer = template[:length]\n        tm = calculate_tm(primer)\n        if tm and target_tm_min <= tm <= target_tm_max:\n            return primer, tm\n    return None, None\n\nprint("Designing primers for Golden Gate assembly...\\n")\n\n# BsaI-HF v2 site: GGTCTC (cuts 1/5 after the site)\n# After GGTCTC, we add 1 base, then 4-base overhang, then template binding\n\nprimers = []\n\n# ===== EGFP PRIMERS =====\nprint("Designing egfp primers...")\n# egfp needs to be amplified without stop codon\negfp_template = seqs[\'egfp\'][:-3]  # Remove TAA stop codon\n\n# Forward primer: adds BsaI site with ATGA overhang (from input)\n# Structure: GGTCTC-N-ATGA-[template]\nfor length in range(15, 46):\n    template_binding = egfp_template[:length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        egfp_fwd = \'GGTCTCN\' + \'ATGA\' + template_binding\n        egfp_fwd_tm = tm\n        print(f"  Forward: length={length}, Tm={tm:.2f}°C")\n        break\n\n# Reverse primer: adds BsaI site with TACCNNNN overhang (reverse complement of GGTA)\n# The reverse primer binds to the end of egfp (without stop)\n# Structure: GAGACC-N-TACC-[reverse complement of template end]\nfor length in range(15, 46):\n    template_binding = egfp_template[-length:]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        # Check if Tm is within 5°C of forward\n        if abs(tm - egfp_fwd_tm) <= 5:\n            # The overhang should be reverse complement of GGTA = TACC\n            egfp_rev = \'GAGACCN\' + \'TACC\' + reverse_complement(template_binding)\n            egfp_rev_tm = tm\n            print(f"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-egfp_fwd_tm):.2f}°C")\n            primers.append((\'>egfp_fwd\', egfp_fwd))\n            primers.append((\'>egfp_rev\', egfp_rev))\n            break\n\nprint()\n\n# ===== FLAG PRIMERS =====\nprint("Designing flag primers...")\n# flag needs to be amplified without start and stop codons\nflag_template = seqs[\'flag\'][3:-3]  # Remove ATG start and TAA stop\n\n# Forward primer: adds BsaI site with GGTA overhang (from egfp)\nfor length in range(15, 46):\n    template_binding = flag_template[:length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        flag_fwd = \'GGTCTCN\' + \'GGTA\' + template_binding\n        flag_fwd_tm = tm\n        print(f"  Forward: length={length}, Tm={tm:.2f}°C")\n        break\n\n# Reverse primer: adds BsaI site with TGAA overhang (reverse complement of GACA)\nfor length in range(15, 46):\n    template_binding = flag_template[-length:]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        if abs(tm - flag_fwd_tm) <= 5:\n            flag_rev = \'GAGACCN\' + \'TGAA\' + reverse_complement(template_binding)\n            flag_rev_tm = tm\n            print(f"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-flag_fwd_tm):.2f}°C")\n            primers.append((\'>flag_fwd\', flag_fwd))\n            primers.append((\'>flag_rev\', flag_rev))\n            break\n\nprint()\n\n# ===== SNAP PRIMERS =====\nprint("Designing snap primers...")\n# snap needs to be amplified without start codon\nsnap_template = seqs[\'snap\'][3:]  # Remove ATG start, keep stop codon\n\n# Forward primer: adds BsaI site with GACA overhang (from flag)\nfor length in range(15, 46):\n    template_binding = snap_template[:length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        snap_fwd = \'GGTCTCN\' + \'GACA\' + template_binding\n        snap_fwd_tm = tm\n        print(f"  Forward: length={length}, Tm={tm:.2f}°C")\n        break\n\n# Reverse primer: adds BsaI site with CTCA overhang (reverse complement of TGAG)\nfor length in range(15, 46):\n    template_binding = snap_template[-length:]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        if abs(tm - snap_fwd_tm) <= 5:\n            snap_rev = \'GAGACCN\' + \'CTCA\' + reverse_complement(template_binding)\n            snap_rev_tm = tm\n            print(f"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-snap_fwd_tm):.2f}°C")\n            primers.append((\'>snap_fwd\', snap_fwd))\n            primers.append((\'>snap_rev\', snap_rev))\n            break\n\nprint()\n\n# ===== INPUT PRIMERS =====\nprint("Designing input primers...")\n# input needs to be linearized from position 690 to 210 (going around)\n# This means we amplify from 690 to end, then from start to 210\n# Or we can think of it as amplifying the backbone\n\n# The input fragment goes from position 690 to position 210 (circular)\n# Forward primer binds at position 690\n# Reverse primer binds at position 210 (reverse complement)\n\ninput_fwd_start = 690\ninput_rev_end = 210\n\n# Forward primer: adds BsaI site with TGAG overhang (from snap)\nfor length in range(15, 46):\n    template_binding = seqs[\'input\'][input_fwd_start:input_fwd_start+length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        input_fwd = \'GGTCTCN\' + \'TGAG\' + template_binding\n        input_fwd_tm = tm\n        print(f"  Forward: length={length}, Tm={tm:.2f}°C")\n        break\n\n# Reverse primer: adds BsaI site with TCAT overhang (reverse complement of ATGA)\nfor length in range(15, 46):\n    template_binding = seqs[\'input\'][input_rev_end-length:input_rev_end]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        if abs(tm - input_fwd_tm) <= 5:\n            input_rev = \'GAGACCN\' + \'TCAT\' + reverse_complement(template_binding)\n            input_rev_tm = tm\n            print(f"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-input_fwd_tm):.2f}°C")\n            primers.append((\'>input_fwd\', input_fwd))\n            primers.append((\'>input_rev\', input_rev))\n            break\n\nprint()\nprint(f"Total primer pairs designed: {len(primers)//2}")\n\n# Write primers to file\nwith open(\'primers.fasta\', \'w\') as f:\n    for header, seq in primers:\n        f.write(f"{header}\\n{seq}\\n")\n\nprint("\\nPrimers written to primers.fasta")\n\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
