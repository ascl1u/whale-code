int(f"\\nAfter insert (position {snap_end} onwards):")\nprint(f"  output[{snap_end}:{snap_end+20}] = {seqs[\'output\'][snap_end:snap_end+20]}")\n\n# Check if this matches input\nafter_insert = seqs[\'output\'][snap_end:snap_end+50]\nif after_insert in seqs[\'input\']:\n    input_cut2 = seqs[\'input\'].find(after_insert)\n    print(f"  ✓ This is in input, resumes at position {input_cut2}")\n    print(f"  input[{input_cut2}:{input_cut2+20}] = {seqs[\'input\'][input_cut2:input_cut2+20]}")\n\n# Calculate what gets removed from input\nif \'input_cut1\' in locals() and \'input_cut2\' in locals():\n    removed_length = input_cut2 - input_cut1\n    print(f"\\n=== INPUT PLASMID MODIFICATION ===")\n    print(f"  Input is cut from position {input_cut1} to {input_cut2}")\n    print(f"  Removed: {removed_length} bp")\n    print(f"  Inserted: {snap_end - egfp_start} bp (egfp+flag+snap fusion)")\n    print(f"  Net change: {(snap_end - egfp_start) - removed_length:+d} bp")\n    print(f"  Input length: {len(seqs[\'input\'])} bp")\n    print(f"  Output length: {len(seqs[\'output\'])} bp")\n    print(f"  Difference: {len(seqs[\'output\']) - len(seqs[\'input\'])} bp")\n\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
