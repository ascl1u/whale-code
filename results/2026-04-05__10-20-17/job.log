Sending keys: ['cat > verify_primers.py << \'EOF\'\nimport subprocess\n\n# Read primers\nprimers = {}\ncurrent_name = None\nwith open(\'primers.fasta\', \'r\') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith(\'>\'):\n            current_name = line[1:]\n            primers[current_name] = \'\'\n        elif line:  # Check for blank lines\n            primers[current_name] += line\n\ndef calc_tm(seq):\n    cmd = [\'oligotm\', \'-tp\', \'1\', \'-sc\', \'1\', \'-mv\', \'50\', \'-dv\', \'2\', \'-n\', \'0.8\', \'-d\', \'500\', seq.upper()]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    return float(result.stdout.strip())\n\nprint("Verifying primers...\\n")\nprint("="*70)\n\nfor name, seq in primers.items():\n    print(f"\\n{name}:")\n    print(f"  Full sequence: {seq}")\n    print(f"  Length: {len(seq)}bp")\n    \n    # Check for BsaI site\n    if seq.startswith(\'GGTCTCN\'):\n        print(f"  BsaI site: GGTCTCN (forward) ✓")\n        overhang = seq[7:11]\n        binding = seq[11:]\n        print(f"  Overhang: {overhang}")\n        print(f"  Binding region: {binding} ({len(binding)}bp)")\n        tm = calc_tm(binding)\n        print(f"  Tm: {tm:.2f}°C")\n        \n        if 15 <= len(binding) <= 45:\n            print(f"  Binding length: ✓ (15-45bp)")\n        else:\n            print(f"  Binding length: ✗ (should be 15-45bp)")\n            \n        if 58 <= tm <= 72:\n            print(f"  Tm range: ✓ (58-72°C)")\n        else:\n            print(f"  Tm range: ✗ (should be 58-72°C)")\n            \n    elif seq.startswith(\'GAGACCN\'):\n        print(f"  BsaI site: GAGACCN (reverse) ✓")\n        overhang = seq[7:11]\n        binding = seq[11:]\n        print(f"  Overhang (RC): {overhang}")\n        print(f"  Binding region (RC): {binding} ({len(binding)}bp)")\n        tm = calc_tm(binding)\n        print(f"  Tm: {tm:.2f}°C")\n        \n        if 15 <= len(binding) <= 45:\n            print(f"  Binding length: ✓ (15-45bp)")\n        else:\n            print(f"  Binding length: ✗ (should be 15-45bp)")\n            \n        if 58 <= tm <= 72:\n            print(f"  Tm range: ✓ (58-72°C)")\n        else:\n            print(f"  Tm range: ✗ (should be 58-72°C)")\n\n# Check primer pairs\nprint("\\n" + "="*70)\nprint("Checking primer pairs...\\n")\n\nfor template in [\'input\', \'egfp\', \'flag\', \'snap\']:\n    fwd_name = f"{template}_fwd"\n    rev_name = f"{template}_rev"\n    \n    if fwd_name in primers and rev_name in primers:\n        fwd_binding = primers[fwd_name][11:]\n        rev_binding = primers[rev_name][11:]\n        \n        fwd_tm = calc_tm(fwd_binding)\n        rev_tm = calc_tm(rev_binding)\n        tm_diff = abs(fwd_tm - rev_tm)\n        \n        print(f"{template}:")\n        print(f"  Forward Tm: {fwd_tm:.2f}°C")\n        print(f"  Reverse Tm: {rev_tm:.2f}°C")\n        print(f"  ΔTm: {tm_diff:.2f}°C")\n        \n        if tm_diff <= 5:\n            print(f"  Pair Tm difference: ✓ (≤5°C)")\n        else:\n            print(f"  Pair Tm difference: ✗ (should be ≤5°C)")\n        print()\n\nprint("="*70)\nprint(f"\\nTotal primers: {len(primers)}")\nprint("All checks complete!")\n\nEOF\npython3 verify_primers.py\n'] min_timeout_sec: 2 max_timeout_sec: 180.0
