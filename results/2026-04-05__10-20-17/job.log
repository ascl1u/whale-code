Sending keys: ['cat > final_verification.py << \'EOF\'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open(\'sequences.fasta\', \'r\') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith(\'>\'):\n            current_name = line[1:]\n            seqs[current_name] = \'\'\n        else:\n            seqs[current_name] += line.upper()\n\n# Read primers\nprimers = {}\ncurrent_name = None\nwith open(\'primers.fasta\', \'r\') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith(\'>\'):\n            current_name = line[1:]\n            primers[current_name] = \'\'\n        else:\n            primers[current_name] += line\n\ndef calculate_tm(seq):\n    try:\n        result = subprocess.run(\n            [\'oligotm\', \'-tp\', \'1\', \'-sc\', \'1\', \'-mv\', \'50\', \'-dv\', \'2\', \'-n\', \'0.8\', \'-d\', \'500\', seq],\n            capture_output=True, text=True, check=True\n        )\n        return float(result.stdout.strip())\n    except:\n        return None\n\nprint("=== FINAL VERIFICATION ===\\n")\n\nprimer_pairs = []\nfor template in [\'egfp\', \'flag\', \'snap\', \'input\']:\n    fwd_name = f"{template}_fwd"\n    rev_name = f"{template}_rev"\n    \n    if fwd_name in primers and rev_name in primers:\n        fwd_seq = primers[fwd_name]\n        rev_seq = primers[rev_name]\n        \n        # Extract template binding regions\n        fwd_template = fwd_seq[11:]  # After GGTCTCN + 4bp overhang\n        rev_template = rev_seq[11:]  # After GAGACCN + 4bp overhang\n        \n        # Calculate Tm\n        fwd_tm = calculate_tm(fwd_template)\n        rev_tm = calculate_tm(rev_template)\n        \n        print(f"{template.upper()} primers:")\n        print(f"  Forward template binding: {fwd_template} ({len(fwd_template)} bp)")\n        print(f"    Tm = {fwd_tm:.2f}°C")\n        print(f"  Reverse template binding: {rev_template} ({len(rev_template)} bp)")\n        print(f"    Tm = {rev_tm:.2f}°C")\n        print(f"  ΔTm = {abs(fwd_tm - rev_tm):.2f}°C")\n        \n        # Check requirements\n        checks = []\n        checks.append(("Length 15-45bp", 15 <= len(fwd_template) <= 45 and 15 <= len(rev_template) <= 45))\n        checks.append(("Tm 58-72°C", 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72))\n        checks.append(("ΔTm ≤ 5°C", abs(fwd_tm - rev_tm) <= 5))\n        \n        all_pass = all(c[1] for c in checks)\n        print(f"  Requirements: {\'PASS\' if all_pass else \'FAIL\'}")\n        for check_name, passed in checks:\n            print(f"    {check_name}: {\'\\u2713\' if passed else \'\\u2717\'}")\n        print()\n        \n        primer_pairs.append((template, fwd_name, rev_name, all_pass))\n\nprint(f"\\nTotal primer pairs: {len(primer_pairs)}")\nprint(f"All requirements met: {all(p[3] for p in primer_pairs)}")\n\n# Check for blank lines in output file\nwith open(\'primers.fasta\', \'r\') as f:\n    lines = f.readlines()\n    blank_lines = sum(1 for line in lines if line.strip() == \'\')\n    print(f"\\nBlank lines in primers.fasta: {blank_lines}")\n\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
