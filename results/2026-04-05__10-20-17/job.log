nneal)\n    if tm and 58 <= tm <= 72 and abs(tm - snap_fwd_tm) <= 5:\n        snap_rev = snap_rev_tail + anneal\n        snap_rev_tm = tm\n        snap_rev_anneal = anneal\n        print(f"  Reverse annealing region: {length}bp, Tm: {tm:.2f}°C")\n        print(f"  Tm difference: {abs(tm - snap_fwd_tm):.2f}°C")\n        break\n\nprimers.append((\'snap_fwd\', snap_rev, snap_fwd_anneal, snap_fwd_tm))\nprimers.append((\'snap_rev\', snap_rev, snap_rev_anneal, snap_rev_tm))\nprint("\\nSNAP primers designed.\\n")\n\n# === INPUT PLASMID PRIMERS ===\nprint("Designing input plasmid primers...")\n# Need to linearize the input plasmid at position 210\n# Forward primer: starts after the cut, needs overhang TGAG (to connect to SNAP)\n# Reverse primer: ends before the cut, needs overhang ATGA (to connect to EGFP)\n\n# The input is circular, and we\'re cutting at position 210\n# Forward primer amplifies from position 1554 (after SNAP insertion point) onwards\n# Reverse primer amplifies up to position 210 (before EGFP insertion point)\n\ninput_fwd_start = 1554  # After SNAP in output = after insertion in input\ninput_template_fwd = seqs[\'input\'][input_fwd_start:input_fwd_start+45]\ninput_fwd_tail = "GGTCTCNTGAG"\nfor length in range(15, 46):\n    if input_fwd_start + length > len(seqs[\'input\']):\n        break\n    anneal = seqs[\'input\'][input_fwd_start:input_fwd_start+length]\n    tm = calc_tm(anneal)\n    if tm and 58 <= tm <= 72:\n        input_fwd = input_fwd_tail + anneal\n        input_fwd_tm = tm\n        input_fwd_anneal = anneal\n        print(f"  Forward annealing region: {length}bp, Tm: {tm:.2f}°C")\n        break\n\n# Reverse primer: amplifies backwards from position 210\n# Need overhang ACAT (reverse complement of ATGT) - wait, need to think about this\n# The cut is at 210, and we want overhang ATGA after the cut for EGFP\n# So the reverse primer needs to create overhang ACAT before the cut\n# Reverse complement of ACAT is ATGT\ninput_rev_tail = "GAGACCNATGT"\ninput_template_rev_rc = reverse_complement(seqs[\'input\'][210-45:210])\nfor length in range(15, 46):\n    anneal = input_template_rev_rc[:length]\n    tm = calc_tm(anneal)\n    if tm and 58 <= tm <= 72 and abs(tm - input_fwd_tm) <= 5:\n        input_rev = input_rev_tail + anneal\n        input_rev_tm = tm\n        input_rev_anneal = anneal\n        print(f"  Reverse annealing region: {length}bp, Tm: {tm:.2f}°C")\n        print(f"  Tm difference: {abs(tm - input_fwd_tm):.2f}°C")\n        break\n\nprimers.append((\'input_fwd\', input_fwd, input_fwd_anneal, input_fwd_tm))\nprimers.append((\'input_rev\', input_rev, input_rev_anneal, input_rev_tm))\nprint("\\nInput plasmid primers designed.\\n")\n\n# Write to fasta file\nprint("Writing primers to primers.fasta...")\nwith open(\'primers.fasta\', \'w\') as f:\n    f.write(">input_fwd\\n")\n    f.write(input_fwd + "\\n")\n    f.write(">input_rev\\n")\n    f.write(input_rev + "\\n")\n    f.write(">egfp_fwd\\n")\n    f.write(egfp_fwd + "\\n")\n    f.write(">egfp_rev\\n")\n    f.write(egfp_rev + "\\n")\n    f.write(">flag_fwd\\n")\n    f.write(flag_fwd + "\\n")\n    f.write(">flag_rev\\n")\n    f.write(flag_rev + "\\n")\n    f.write(">snap_fwd\\n")\n    f.write(snap_fwd + "\\n")\n    f.write(">snap_rev\\n")\n    f.write(snap_rev + "\\n")\n\nprint("\\nDone! Primers written to primers.fasta")\nprint(f"\\nTotal primer pairs: {len(primers)//2}")\nEOFPYTHON\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
