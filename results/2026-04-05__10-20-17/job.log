Sending keys: ['python3 << \'EOF\'\nimport subprocess\n\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, \'r\') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith(\'>\'):\n                if current_name:\n                    sequences[current_name] = \'\'.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = \'\'.join(current_seq)\n    \n    return sequences\n\ndef get_tm(seq):\n    """Get melting temperature using oligotm"""\n    try:\n        result = subprocess.run(\n            [\'oligotm\', \'-tp\', \'1\', \'-sc\', \'1\', \'-mv\', \'50\', \'-dv\', \'2\', \'-n\', \'0.8\', \'-d\', \'500\', seq.upper()],\n            capture_output=True, text=True, check=True\n        )\n        return float(result.stdout.strip())\n    except Exception as e:\n        return None\n\ndef extract_annealing_region(primer, is_fwd):\n    """Extract the annealing region (template binding part) from primer"""\n    if is_fwd:\n        # Forward: GGTCTCN[NNNN][template]\n        pos = primer.find(\'GGTCTCN\')\n        if pos >= 0:\n            return primer[pos+11:]  # Skip GGTCTCN + 4bp overhang\n    else:\n        # Reverse: [template][NNNN]NGAGACC\n        pos = primer.find(\'NGAGACC\')\n        if pos >= 0:\n            return primer[:pos-4]  # Everything before 4bp overhang + NGAGACC\n    return None\n\nprint("FINAL VALIDATION OF PRIMERS")\nprint("=" * 80)\n\nprimers = read_fasta(\'primers.fasta\')\n\nprint(f"\\n1. Number of primer pairs: {len(primers) // 2}")\nprint(f"   Total primers: {len(primers)}")\n\nprint("\\n2. Header format check:")\nfor name in primers.keys():\n    parts = name.split(\'_\')\n    if len(parts) == 2 and parts[0] in [\'input\', \'egfp\', \'flag\', \'snap\'] and parts[1] in [\'fwd\', \'rev\']:\n        print(f"   ✓ {name}: Correct format")\n    else:\n        print(f"   ✗ {name}: Incorrect format")\n\nprint("\\n3. Annealing region length and Tm check:")\nfor name, seq in primers.items():\n    is_fwd = \'fwd\' in name\n    anneal = extract_annealing_region(seq, is_fwd)\n    if anneal:\n        length = len(anneal)\n        tm = get_tm(anneal)\n        length_ok = 15 <= length <= 45\n        tm_ok = 58 <= tm <= 72 if tm else False\n        \n        status_len = "✓" if length_ok else "✗"\n        status_tm = "✓" if tm_ok else "✗"\n        \n        print(f"   {name}:")\n        print(f"      {status_len} Length: {length} bp (15-45 required)")\n        print(f"      {status_tm} Tm: {tm:.2f}°C (58-72 required)")\n\nprint("\\n4. Primer pair Tm difference check:")\npairs = [(\'input_fwd\', \'input_rev\'), (\'egfp_fwd\', \'egfp_rev\'), \n         (\'flag_fwd\', \'flag_rev\'), (\'snap_fwd\', \'snap_rev\')]\n\nfor fwd_name, rev_name in pairs:\n    fwd_anneal = extract_annealing_region(primers[fwd_name], True)\n    rev_anneal = extract_annealing_region(primers[rev_name], False)\n    \n    tm_fwd = get_tm(fwd_anneal)\n    tm_rev = get_tm(rev_anneal)\n    \n    if tm_fwd and tm_rev:\n        diff = abs(tm_fwd - tm_rev)\n        ok = diff <= 5\n        status = "✓" if ok else "✗"\n        print(f"   {status} {fwd_name.split(\'_\')[0]}: {tm_fwd:.2f}°C vs {tm_rev:.2f}°C (diff: {diff:.2f}°C, max 5°C)")\n\nprint("\\n5. BsaI-HF v2 sites present:")\nfor name, seq in primers.items():\n    has_bsai = \'GGTCTC\' in seq.upper() or \'GAGACC\' in seq.upper()\n    status = "✓" if has_bsai else "✗"\n    print(f"   {status} {name}: BsaI site present")\n\nprint("\\n" + "=" * 80)\nprint("VALIDATION COMPLETE")\nprint("=" * 80)\n\nEOF\n'] min_timeout_sec: 2 max_timeout_sec: 180.0
