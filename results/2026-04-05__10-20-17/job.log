Sending keys: ['cat >> design_primers.py << \'SCRIPT_EOF\'\n\n# Now design primers\n# BsaI-HF v2 recognition: GGTCTC (forward) and GAGACC (reverse complement)\n# BsaI cuts 1 nt downstream on top strand, 5 nt on bottom, creating 4 nt overhang\n# Forward primer: 5\'-[tail]-GGTCTC-N-[4bp overhang]-[template binding]-3\'\n# Reverse primer: 5\'-[tail]-GGTCTC-N-[4bp overhang RC]-[template binding RC]-3\'\n\ndef design_primer_pair(template_name, template_seq, left_overhang, right_overhang, \n                       min_len=15, max_len=45, min_tm=58, max_tm=72, max_delta_tm=5):\n    """\n    Design forward and reverse primers for a template\n    left_overhang: overhang on the 5\' end of the insert\n    right_overhang: overhang on the 3\' end of the insert\n    """\n    # For forward primer: adds left_overhang\n    # Structure: GGTCTC N [left_overhang] [template_start]\n    # The primer binds to template_start\n    \n    # For reverse primer: adds right_overhang (reverse complement)\n    # Structure: GGTCTC N [right_overhang_RC] [template_end_RC]\n    # The primer binds to the reverse complement of template_end\n    \n    best_fwd = None\n    best_rev = None\n    best_delta = float(\'inf\')\n    \n    # Try different annealing lengths\n    for fwd_len in range(min_len, max_len + 1):\n        for rev_len in range(min_len, max_len + 1):\n            # Forward primer annealing region\n            fwd_anneal = template_seq[:fwd_len]\n            fwd_tm = calculate_tm(fwd_anneal)\n            \n            # Reverse primer annealing region (binds to end of template)\n            rev_anneal = template_seq[-rev_len:]\n            rev_tm = calculate_tm(rev_anneal)\n            \n            # Check constraints\n            if (min_tm <= fwd_tm <= max_tm and \n                min_tm <= rev_tm <= max_tm and \n                abs(fwd_tm - rev_tm) <= max_delta_tm):\n                \n                delta = abs(fwd_tm - rev_tm)\n                if delta < best_delta:\n                    best_delta = delta\n                    \n                    # Build full primers\n                    # Forward: GGTCTC-N-[overhang]-[anneal]\n                    fwd_primer = \'GGTCTC\' + \'N\' + left_overhang + fwd_anneal\n                    \n                    # Reverse: GGTCTC-N-[overhang_RC]-[anneal_RC]\n                    right_oh_rc = reverse_complement(right_overhang)\n                    rev_anneal_rc = reverse_complement(rev_anneal)\n                    rev_primer = \'GGTCTC\' + \'N\' + right_oh_rc + rev_anneal_rc\n                    \n                    best_fwd = (fwd_primer, fwd_anneal, fwd_tm)\n                    best_rev = (rev_primer, rev_anneal, rev_tm)\n    \n    return best_fwd, best_rev\n\nprint("\\n=== Designing Primers ===")\n\n# Fragment 1: Input backbone (linearized)\n# We need to amplify from position 690 to 210 (going around the circle)\n# This is actually: input[690:] + input[0:210]\n# But since it\'s circular, we can amplify the backbone by:\n# - Forward primer at position 690 (adds oh4 RC for SNAP->input junction)\n# - Reverse primer at position 210 (adds oh1 RC for input->eGFP junction)\n\n# Actually, let\'s think about this differently:\n# The input backbone needs to connect SNAP (with oh4) to eGFP start (with oh1)\n# So: oh4 -> backbone -> oh1\n# Forward primer binds after position 690 and adds oh4 on 5\' end\n# Reverse primer binds before position 210 and adds oh1 on 3\' end\n\nSCRIPT_EOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
