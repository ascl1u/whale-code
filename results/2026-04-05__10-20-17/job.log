Sending keys: ['cat >> design_primers.py << \'SCRIPT_EOF\'\n\ndef design_primer_pair(template_name, template_seq, left_overhang, right_overhang, \n                       min_len=15, max_len=45, min_tm=58, max_tm=72, max_delta_tm=5):\n    """\n    Design forward and reverse primers for a template\n    left_overhang: overhang on the 5\' end of the insert\n    right_overhang: overhang on the 3\' end of the insert\n    """\n    best_fwd = None\n    best_rev = None\n    best_delta = float(\'inf\')\n    \n    # Try different annealing lengths\n    for fwd_len in range(min_len, max_len + 1):\n        for rev_len in range(min_len, max_len + 1):\n            # Forward primer annealing region\n            fwd_anneal = template_seq[:fwd_len]\n            fwd_tm = calculate_tm(fwd_anneal)\n            \n            # Reverse primer annealing region (binds to end of template)\n            rev_anneal = template_seq[-rev_len:]\n            rev_tm = calculate_tm(rev_anneal)\n            \n            # Check constraints\n            if (min_tm <= fwd_tm <= max_tm and \n                min_tm <= rev_tm <= max_tm and \n                abs(fwd_tm - rev_tm) <= max_delta_tm):\n                \n                delta = abs(fwd_tm - rev_tm)\n                if delta < best_delta:\n                    best_delta = delta\n                    \n                    # Build full primers\n                    # Forward: GGTCTC-N-[overhang]-[anneal]\n                    fwd_primer = \'GGTCTCN\' + left_overhang + fwd_anneal\n                    \n                    # Reverse: GGTCTC-N-[overhang_RC]-[anneal_RC]\n                    right_oh_rc = reverse_complement(right_overhang)\n                    rev_anneal_rc = reverse_complement(rev_anneal)\n                    rev_primer = \'GGTCTCN\' + right_oh_rc + rev_anneal_rc\n                    \n                    best_fwd = (fwd_primer, fwd_anneal, fwd_tm)\n                    best_rev = (rev_primer, rev_anneal, rev_tm)\n    \n    return best_fwd, best_rev\n\nprint("\\n=== Fragment Design ===")\nprint(f"Fragment 1 (input): oh4 -> backbone -> oh1")\nprint(f"Fragment 2 (eGFP): oh1 -> egfp(no stop) -> oh2")\nprint(f"Fragment 3 (FLAG): oh2 -> flag(no start/stop) -> oh3")\nprint(f"Fragment 4 (SNAP): oh3 -> snap(no start) -> oh4")\n\n# Prepare template sequences\negfp_template = seqs[\'egfp\'][:-3].upper()  # Remove stop codon TAA\nflag_template = seqs[\'flag\'][3:-3].upper()  # Remove start ATG and stop TAA\nsnap_template = seqs[\'snap\'][3:].upper()  # Remove start ATG, keep stop\n\n# Input backbone: from position 690 to end, then start to 210\ninput_backbone = (input_seq[690:] + input_seq[:210]).upper()\n\nprint(f"\\neGFP template length: {len(egfp_template)}")\nprint(f"FLAG template length: {len(flag_template)}")\nprint(f"SNAP template length: {len(snap_template)}")\nprint(f"Input backbone length: {len(input_backbone)}")\n\n# Design primers for each fragment\nprint("\\n=== Designing eGFP primers ===")\negfp_fwd, egfp_rev = design_primer_pair(\'egfp\', egfp_template, oh1, oh2)\nif egfp_fwd and egfp_rev:\n    print(f"Forward: Tm={egfp_fwd[2]:.1f}°C, anneal_len={len(egfp_fwd[1])}")\n    print(f"Reverse: Tm={egfp_rev[2]:.1f}°C, anneal_len={len(egfp_rev[1])}")\nelse:\n    print("Failed to design eGFP primers")\n\nprint("\\n=== Designing FLAG primers ===")\nflag_fwd, flag_rev = design_primer_pair(\'flag\', flag_template, oh2, oh3)\nif flag_fwd and flag_rev:\n    print(f"Forward: Tm={flag_fwd[2]:.1f}°C, anneal_len={len(flag_fwd[1])}")\n    print(f"Reverse: Tm={flag_rev[2]:.1f}°C, anneal_len={len(flag_rev[1])}")\nelse:\n    print("Failed to design FLAG primers")\n\nprint("\\n=== Designing SNAP primers ===")\nsnap_fwd, snap_rev = design_primer_pair(\'snap\', snap_template, oh3, oh4)\nif snap_fwd and snap_rev:\n    print(f"Forward: Tm={snap_fwd[2]:.1f}°C, anneal_len={len(snap_fwd[1])}")\n    print(f"Reverse: Tm={snap_rev[2]:.1f}°C, anneal_len={len(snap_rev[1])}")\nelse:\n    print("Failed to design SNAP primers")\n\nprint("\\n=== Designing Input backbone primers ===")\ninput_fwd, input_rev = design_primer_pair(\'input\', input_backbone, oh4, oh1)\nif input_fwd and input_rev:\n    print(f"Forward: Tm={input_fwd[2]:.1f}°C, anneal_len={len(input_fwd[1])}")\n    print(f"Reverse: Tm={input_rev[2]:.1f}°C, anneal_len={len(input_rev[1])}")\nelse:\n    print("Failed to design input primers")\n\n# Write primers to FASTA file\nprint("\\n=== Writing primers.fasta ===")\n\nwith open(\'primers.fasta\', \'w\') as f:\n    # Input primers\n    if input_fwd and input_rev:\n        f.write(f">input_fwd\\n")\n        f.write(f"{input_fwd[0]}\\n")\n        f.write(f">input_rev\\n")\n        f.write(f"{input_rev[0]}\\n")\n    \n    # eGFP primers\n    if egfp_fwd and egfp_rev:\n        f.write(f">egfp_fwd\\n")\n        f.write(f"{egfp_fwd[0]}\\n")\n        f.write(f">egfp_rev\\n")\n        f.write(f"{egfp_rev[0]}\\n")\n    \n    # FLAG primers\n    if flag_fwd and flag_rev:\n        f.write(f">flag_fwd\\n")\n        f.write(f"{flag_fwd[0]}\\n")\n        f.write(f">flag_rev\\n")\n        f.write(f"{flag_rev[0]}\\n")\n    \n    # SNAP primers\n    if snap_fwd and snap_rev:\n        f.write(f">snap_fwd\\n")\n        f.write(f"{snap_fwd[0]}\\n")\n        f.write(f">snap_rev\\n")\n        f.write(f"{snap_rev[0]}\\n")\n\nprint("Primers written to primers.fasta")\nprint("\\nSummary:")\nprint(f"Total primer pairs: 4")\nprint(f"Total primers: 8")\n\nSCRIPT_EOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
