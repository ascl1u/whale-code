[129.724657, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\nseqs = read_fasta('sequences.fasta')\ninput_seq = seqs['input']\noutput_seq = seqs['output']\negfp = seqs['egfp']\nflag = seqs['flag']\nsnap = seqs['snap']\n\nprint(\"Checking assembly structure...\")\n\n# Check eGFP at position 210\negfp_pos = 210\nif output_seq[egfp_pos:egfp_pos+len(egfp)] == egfp:\n    print(f\"✓ eGFP found at position {egfp_pos}\")\n    \n    # Check FLAG after eGFP\n    flag_pos = egfp_pos + len(egfp)\n    if output_seq[flag_pos:flag_pos+len(flag)] == flag:\n        print(f\"✓ FLAG found at position {flag_pos}\")\n        \n        # Check SNAP after FLAG\n        snap_pos = flag_pos + len(flag)\n        if output_seq[snap_pos:snap_pos+len(snap)] == snap:\n            print(f\"✓ SNAP found at position {snap_pos}\")\n            \n            # What comes after SNAP?\n            after_snap = snap_pos + len(snap)\n            print(f\"\\nAfter all inserts (position {after_snap}):\")\n            print(f\"Output: {output_seq[after_snap:after_snap+40]}\")\n            \n            # Find this in input\n            search_seq = output_seq[after_snap:after_snap+30]\n            input_match = input_seq.find(search_seq)\n            if input_match >= 0:\n                print(f\"Found in input at position {input_match}\")\n                \n                # What was before eGFP in output?\n                print(f\"\\nBefore eGFP (output position {egfp_pos}):\")\n                print(f\"Output: {output_seq[egfp_pos-40:egfp_pos]}\")\n                \n                # Find this in input\n                search_before = output_seq[egfp_pos-30:egfp_pos]\n                input_before = input_seq.find(search_before)\n                if input_before >= 0:\n                    print(f\"Found in input at position {input_before}\")\n                    input_before_end = input_before + 30\n                    \n                    print(f\"\\n\" + \"=\"*80)\n                    print(\"ASSEMBLY STRUCTURE:\")\n                    print(f\"Input backbone: positions 0-{input_before_end} and {input_match}-end\")\n                    print(f\"Insert at input position {input_before_end}\")\n                    print(f\"Removed from input: positions {input_before_end}-{input_match} ({input_match - input_before_end} bp)\")\n                    print(f\"Inserted: eGFP + FLAG + SNAP ({len(egfp)+len(flag)+len(snap)} bp)\")\n                    \n                    removed_seq = input_seq[input_before_end:input_match]\n                    print(f\"\\nRemoved sequence: {removed_seq[:60]}...\")\n                    \nEOF\n"]
