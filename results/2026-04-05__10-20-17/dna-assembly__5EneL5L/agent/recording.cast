[498.573018, "o", "python3 final_primers.py; printf '%s\\n' '__CMDEND__12__'\r\n\u001b[?2004l\r"]
[498.603561, "o", "Golden Gate Assembly Design with BsaI-HF v2\r\n================================================================================\r\n\r\nOverhang design:\r\n  OH1 (ACAT): Backbone-left <-> eGFP-left\r\n  OH2 (GGTA): eGFP-right <-> FLAG-left\r\n  OH3 (GACA): FLAG-right <-> SNAP-left\r\n  OH4 (TTAA): SNAP-right <-> Backbone-right\r\n\r\n1. INPUT BACKBONE\r\n--------------------------------------------------------------------------------\r\n"]
[499.684944, "o", "Forward annealing region: tgaggatcccgggaattc (Tm: 59.81°C)\r\nReverse annealing region: attttgtttaactttaagaaggagatatacat (Tm: 59.83°C)\r\nTm difference: 0.03°C\r\nForward primer: GGTCTCNTTAAtgaggatcccgggaattc\r\nReverse primer: atgtatatctccttcttaaagttaaacaaaatACATNGAGACC\r\n"]
[499.685203, "o", "\r\n2. EGFP INSERT (without stop codon)\r\n--------------------------------------------------------------------------------\r\n"]
[500.24866, "o", "Forward annealing region: atgagcaagggcgaggagctg (Tm: 68.53°C)\r\nReverse annealing region: ctcggcatggacgagctgtacaaa (Tm: 68.48°C)\r\nTm difference: 0.05°C\r\nForward primer: GGTCTCNACATatgagcaagggcgaggagctg\r\n"]
[500.248915, "o", "Reverse primer: tttgtacagctcgtccatgccgagGGTANGAGACC\r\n\r\n3. FLAG INSERT (without start and stop codons)\r\n--------------------------------------------------------------------------------\r\n"]
[500.840613, "o", "Forward annealing region: ggtagtggctccggtagcggtag (Tm: 69.51°C)\r\nReverse annealing region: ccggttctggttcaggtagtggttca (Tm: 69.35°C)\r\nTm difference: 0.16°C\r\nForward primer: GGTCTCNGGTAggtagtggctccggtagcggtag\r\nReverse primer: tgaaccactacctgaaccagaaccggGACANGAGACC\r\n\r\n4. SNAP INSERT (without start codon)\r\n--------------------------------------------------------------------------------\r\n"]
[501.386502, "o", "Forward annealing region: gacaaagactgcgaaatgaagcgcacca (Tm: 71.20°C)\r\nReverse annealing region: gactgggtaagcctgggctgggttaa (Tm: 71.25°C)\r\nTm difference: 0.05°C\r\nForward primer: GGTCTCNGACAgacaaagactgcgaaatgaagcgcacca\r\nReverse primer: ttaacccagcccaggcttacccagtcTTAANGAGACC\r\n\r\n================================================================================\r\nWriting primers to primers.fasta...\r\n"]
[501.386765, "o", "Done! 8 primers written.\r\n"]
[501.392181, "o", "__CMDEND__12__\r\n"]
[501.392321, "o", "\u001b[?2004hroot@a0b49dcae9e4:/app# "]
[536.23475, "i", "cat primers.fasta; printf '%s\\n' '__CMDEND__13__'\n"]
[536.235282, "o", "cat primers.fasta; printf '%s\\n' '__CMDEND__13__'\r\n\u001b[?2004l\r"]
[536.236913, "o", ">input_fwd\r\nGGTCTCNTTAATGAGGATCCCGGGAATTC\r\n>input_rev\r\nATGTATATCTCCTTCTTAAAGTTAAACAAAATACATNGAGACC\r\n>egfp_fwd\r\nGGTCTCNACATATGAGCAAGGGCGAGGAGCTG\r\n>egfp_rev\r\nTTTGTACAGCTCGTCCATGCCGAGGGTANGAGACC\r\n>flag_fwd\r\nGGTCTCNGGTAGGTAGTGGCTCCGGTAGCGGTAG\r\n>flag_rev\r\nTGAACCACTACCTGAACCAGAACCGGGACANGAGACC\r\n>snap_fwd\r\nGGTCTCNGACAGACAAAGACTGCGAAATGAAGCGCACCA\r\n>snap_rev\r\nTTAACCCAGCCCAGGCTTACCCAGTCTTAANGAGACC\r\n"]
[536.237416, "o", "__CMDEND__13__\r\n"]
[536.237711, "o", "\u001b[?2004hroot@a0b49dcae9e4:/app# "]
[556.775318, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\ndef extract_overhangs(primer, is_fwd):\n    \"\"\"Extract the 4bp overhang from a primer\"\"\"\n    if is_fwd:\n        # Forward: GGTCTCN[NNNN]template\n        pos = primer.find('GGTCTCN')\n        if pos >= 0:\n            return primer[pos+7:pos+11]\n    else:\n        # Reverse: template[NNNN]NGAGACC\n        pos = primer.find('NGAGACC')\n        if pos >= 0:\n            return primer[pos-4:pos]\n    return None\n\nprimers = read_fasta('primers.fasta')\n\nprint(\"Validating Golden Gate Assembly Overhangs\")\nprint(\"=\" * 80)\n\n# Extract all overhangs\noverhangs = {}\nfor name, seq in primers.items():\n    is_fwd = 'fwd' in name\n    oh = extract_overhangs(seq, is_fwd)\n    overhangs[name] = oh\n    print(f\"{name:15s}: {oh}\")\n\nprint()\nprint(\"=\" * 80)\nprint(\"Checking assembly compatibility:\")\nprint(\"=\" * 80)\n\n# Check if overhangs match for assembly\nchecks = [\n    ('input_rev', 'egfp_fwd', 'Backbone-left <-> eGFP-left'),\n    ('egfp_rev', 'flag_fwd', 'eGFP-right <-> FLAG-left'),\n    ('flag_rev', 'snap_fwd', 'FLAG-right <-> SNAP-left'),\n    ('snap_rev', 'input_fwd', 'SNAP-right <-> Backbone-right'),\n]\n\nall_match = True\nfor primer1, primer2, desc in checks:\n    oh1 = overhangs[primer1]\n    oh2 = overhangs[primer2]\n    match = oh1 == oh2\n    status = \"✓\" if match else \"✗\"\n    print(f\"{status} {desc}: {oh1} == {oh2} : {match}\")\n    if not match:\n        all_match = False\n\nprint()\nif all_match:\n    print(\"✓ All overhangs match correctly! Assembly will work.\")\nelse:\n    print(\"✗ Overhang mismatch detected!\")\n\nEOF\n"]
