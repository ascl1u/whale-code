[441.350707, "o", "Checking assembly compatibility:\r\n================================================================================\r\n✗ Backbone-left <-> eGFP-left: ATGT == ACAT : False\r\n✗ eGFP-right <-> FLAG-left: TACC == GGTA : False\r\n✗ FLAG-right <-> SNAP-left: TGTC == GACA : False\r\n✓ SNAP-right <-> Backbone-right: TTAA == TTAA : True\r\n\r\n✗ Overhang mismatch detected!\r\n"]
