[267.944726, "o", "\u001b[?2004h> "]
[267.944968, "o", "snap_fwd_anneal, snap_fwd_tm = find_primer(snap_fwd_template, 'fwd')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.945345, "o", "snap_rev_anneal, snap_rev_tm = find_primer(snap_rev_template, 'rev')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[267.945557, "o", "\u001b[?2004h> "]
[267.945874, "o", "print(f\"Forward primer annealing: {snap_fwd_anneal} (Tm: {snap_fwd_tm:.2f}°C)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
