[267.926886, "o", "egfp_rev_anneal, egfp_rev_tm = find_primer(egfp_rev_template, 'rev')\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[267.927181, "o", "\u001b[?2004h> "]
[267.927694, "o", "print(f\"Forward primer annealing: {egfp_fwd_anneal} (Tm: {egfp_fwd_tm:.2f}°C)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.9282, "o", "print(f\"Reverse primer annealing: {egfp_rev_anneal} (Tm: {egfp_rev_tm:.2f}°C)\")\r\n\u001b[?2004l\r"]
[267.928318, "o", "\u001b[?2004h> "]
[267.928632, "o", "print(f\"Tm difference: {abs(egfp_fwd_tm - egfp_rev_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.92885, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[267.929056, "o", "\u001b[?2004h> "]
[267.929253, "o", "# eGFP forward primer: creates 'acat' overhang\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.929461, "o", "egfp_fwd_primer = 'GGTCTCNACAT' + egfp_fwd_anneal\r\n\u001b[?2004l\r"]
