[245.3562, "o", "\u001b[?2004h> "]
[245.356972, "o", "    \"\"\"Get melting temperature using oligotm\"\"\"\r\n\u001b[?2004l\r"]
[245.357068, "o", "\u001b[?2004h> "]
[245.357226, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.357408, "o", "> "]
[245.357769, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[245.357867, "o", "\u001b[?2004h> "]
[245.359243, "o", "            ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.359619, "o", "            capture_output=True, text=True, check=True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.359858, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.360075, "o", "        return float(result.stdout.strip())\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.360195, "o", ">     except Exception as e:\r\n\u001b[?2004l\r"]
[245.360438, "o", "\u001b[?2004h> "]
[245.360704, "o", "        print(f\"Error getting Tm for {seq}: {e}\", file=sys.stderr)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.360846, "o", "        return None\r\n\u001b[?2004l\r"]
[245.361104, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.361524, "o", "def find_primer(template, direction, target_tm_min=58, target_tm_max=72, min_len=15, max_len=45):\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.361709, "o", "> "]
[245.361917, "o", "    \"\"\"Find a primer with appropriate Tm\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.362148, "o", "    for length in range(min_len, max_len + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.362426, "o", "        if direction == 'fwd':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.362662, "o", "            primer_anneal = template[:length]\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.362881, "o", ">         else:  # rev\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.36312, "o", "            primer_anneal = template[-length:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.363305, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.363538, "o", "        tm = get_tm(primer_anneal)\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.363733, "o", "> "]
[245.363931, "o", "        if tm and target_tm_min <= tm <= target_tm_max:\r\n\u001b[?2004l\r"]
[245.364132, "o", "\u001b[?2004h> "]
[245.364313, "o", "            return primer_anneal, tm\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.364566, "o", "    # If no perfect match, return the closest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.364788, "o", "    best_primer = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.364983, "o", "    best_tm = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.365166, "o", "    best_diff = float('inf')\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.365374, "o", "    for length in range(min_len, max_len + 1):\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.365544, "o", "> "]
[245.365722, "o", "        if direction == 'fwd':\r\n\u001b[?2004l\r"]
[245.365916, "o", "\u001b[?2004h> "]
[245.366111, "o", "            primer_anneal = template[:length]\r\n\u001b[?2004l\r"]
[245.366307, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r"]
[245.366497, "o", "\u001b[?2004h> "]
[245.366759, "o", "            primer_anneal = template[-length:]\r\n\u001b[?2004l\r"]
[245.366862, "o", "\u001b[?2004h> "]
[245.367164, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.367365, "o", "        tm = get_tm(primer_anneal)\r\n\u001b[?2004l\r"]
[245.367517, "o", "\u001b[?2004h>         if tm:\r\n\u001b[?2004l\r"]
[245.367789, "o", "\u001b[?2004h> "]
[245.368108, "o", "            diff = min(abs(tm - target_tm_min), abs(tm - target_tm_max))\r\n\u001b[?2004l\r"]
[245.368304, "o", "\u001b[?2004h> "]
[245.368468, "o", "            if diff < best_diff:\r\n\u001b[?2004l\r"]
[245.368663, "o", "\u001b[?2004h> "]
[245.368793, "o", "                best_diff = diff\r\n\u001b[?2004l\r"]
[245.368969, "o", "\u001b[?2004h> "]
[245.369159, "o", "                best_primer = primer_anneal\r\n\u001b[?2004l\r"]
[245.369345, "o", "\u001b[?2004h> "]
[245.369562, "o", "                best_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.369781, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.370002, "o", "    return best_primer, best_tm\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.370186, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.370292, "o", "# Read sequences\r\n\u001b[?2004l\r"]
[245.370595, "o", "\u001b[?2004h> "]
[245.370843, "o", "seqs = read_fasta('sequences.fasta')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.371032, "o", "input_seq = seqs['input']\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.371271, "o", "> egfp = seqs['egfp']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.371524, "o", "flag = seqs['flag']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.371766, "o", "snap = seqs['snap']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.372103, "o", "# Prepare the insert sequences (without start/stop codons as needed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.372367, "o", "egfp_insert = egfp[:-3]  # Remove stop codon\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.372586, "o", "> "]
[245.372863, "o", "flag_insert = flag[3:-3]  # Remove start and stop codons\r\n\u001b[?2004l\r"]
[245.373069, "o", "\u001b[?2004h> "]
[245.37334, "o", "snap_insert = snap[3:]  # Remove start codon, keep stop\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.373552, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.373864, "o", "print(\"Designing Golden Gate primers...\")\r\n\u001b[?2004l\r"]
[245.374036, "o", "\u001b[?2004h> print()\r\n\u001b[?2004l\r"]
[245.37431, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.374592, "o", "# For Golden Gate assembly with BsaI-HF v2:\r\n\u001b[?2004l\r"]
[245.374837, "o", "\u001b[?2004h> "]
[245.375172, "o", "# Forward primer: 5' - [template binding] - GGTCTC - N - [4bp overhang] - 3'\r\n\u001b[?2004l\r"]
[245.37536, "o", "\u001b[?2004h> "]
[245.375815, "o", "# Reverse primer: 5' - [template binding RC] - GAGACC - N - [4bp overhang RC] - 3'\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.376051, "o", "> #\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.376194, "o", "> "]
[245.376327, "o", "# When BsaI cuts, it leaves the 4bp overhang\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.376576, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> primers = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[245.376779, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[245.376951, "o", "# 1. INPUT BACKBONE primers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.377421, "o", "# The backbone needs to be linearized with overhangs that match the inserts\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.377628, "o", "> "]
[245.378055, "o", "# Forward primer: adds overhang complementary to snap end (ttaa -> complement of snap's last 4bp)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.378593, "o", "# Reverse primer: adds overhang complementary to egfp start (acat -> complement of egfp's first 4bp)\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.378718, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.378843, "o", "print(\"=\" * 80)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.379077, "o", "print(\"1. INPUT BACKBONE\")\r\n\u001b[?2004l\r"]
[245.37928, "o", "\u001b[?2004h> print(\"=\" * 80)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.379493, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.379697, "o", "# Input forward primer: binds after the cut site (position 690)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.38002, "o", "# Should create overhang that matches end of SNAP: 'ttaa'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.380325, "o", "input_fwd_template_start = 690\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.38056, "o", "> "]
[245.380845, "o", "input_fwd_template = input_seq[input_fwd_template_start:input_fwd_template_start+100]\r\n\u001b[?2004l\r"]
[245.381042, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[245.381271, "o", "> "]
[245.38151, "o", "# Input reverse primer: binds before the cut site (position 210)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.381932, "o", "# Should create overhang that matches start of eGFP: 'acat'\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.382191, "o", "> "]
[245.382481, "o", "input_rev_template_end = 210\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.382935, "o", "input_rev_template = input_seq[max(0, input_rev_template_end-100):input_rev_template_end]\r\n\u001b[?2004l\r"]
[245.38305, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[245.383378, "o", "\u001b[?2004h> "]
[245.383657, "o", "# Find good annealing regions\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.383884, "o", "input_fwd_anneal, input_fwd_tm = find_primer(input_fwd_template, 'fwd')\r\n\u001b[?2004l\r"]
[245.384089, "o", "\u001b[?2004h> "]
[245.384421, "o", "input_rev_anneal, input_rev_tm = find_primer(input_rev_template, 'rev')\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.384637, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.38498, "o", "print(f\"Forward primer annealing: {input_fwd_anneal} (Tm: {input_fwd_tm:.2f}°C)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.385185, "o", "> "]
[245.385532, "o", "print(f\"Reverse primer annealing: {input_rev_anneal} (Tm: {input_rev_tm:.2f}°C)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.385731, "o", "> "]
[245.385969, "o", "print(f\"Tm difference: {abs(input_fwd_tm - input_rev_tm):.2f}°C\")\r\n\u001b[?2004l\r"]
[245.386186, "o", "\u001b[?2004h> print()\r\n\u001b[?2004l\r"]
[245.386362, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.386577, "o", "# Construct full primers\r\n\u001b[?2004l\r"]
[245.386799, "o", "\u001b[?2004h> "]
[245.387093, "o", "# Forward: adds BsaI site and overhang 'ttaa' (matches SNAP end)\r\n\u001b[?2004l\r"]
[245.387342, "o", "\u001b[?2004h> "]
[245.387582, "o", "# BsaI forward: GGTCTC(N)(overhang) then template\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.387802, "o", "# After cutting: leaves 'ttaa' overhang\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.388178, "o", "input_fwd_primer = 'GGTCTCNTTAA' + input_fwd_anneal\r\n\u001b[?2004l\r"]
[245.388502, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.388796, "o", "# Reverse: adds BsaI site and overhang complementary to 'acat'\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.388984, "o", "> "]
[245.389144, "o", "# The overhang should be RC of 'acat' = 'atgt'\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.389342, "o", "> "]
[245.389599, "o", "# BsaI reverse: template-RC then GAGACC(N)(overhang-RC)\r\n\u001b[?2004l\r"]
[245.389846, "o", "\u001b[?2004h> "]
[245.390054, "o", "# After cutting: leaves 'acat' overhang on the other end\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.390268, "o", "> "]
[245.390481, "o", "input_rev_primer_anneal_rc = reverse_complement(input_rev_anneal)\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.390743, "o", "> "]
[245.390994, "o", "input_rev_primer = input_rev_primer_anneal_rc + 'GAGACCNATGT'\r\n\u001b[?2004l\r\u001b[?2004h"]
[245.391302, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.391672, "o", "print(f\"Input forward primer: {input_fwd_primer}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.392122, "o", "print(f\"Input reverse primer: {input_rev_primer}\")\r\n\u001b[?2004l\r\u001b[?2004h> print()\r\n\u001b[?2004l\r"]
[245.392377, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[245.392516, "o", "> "]
[245.39278, "o", "primers.append(('>input_fwd', input_fwd_primer))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.393113, "o", "primers.append(('>input_rev', input_rev_primer))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[245.393367, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> EOFMAIN\r\n\u001b[?2004l\r"]
[245.396183, "o", "\u001b[?2004hroot@a0b49dcae9e4:/app# "]
[267.922173, "i", "cat >> design_gg_primers.py << 'EOFMAIN'\n# 2. EGFP primers (without stop codon)\nprint(\"=\" * 80)\nprint(\"2. EGFP INSERT (without stop codon)\")\nprint(\"=\" * 80)\n\n# eGFP forward: should create overhang 'acat' (to match input left side)\negfp_fwd_template = egfp_insert[:100]\negfp_rev_template = egfp_insert[-100:]\n\negfp_fwd_anneal, egfp_fwd_tm = find_primer(egfp_fwd_template, 'fwd')\negfp_rev_anneal, egfp_rev_tm = find_primer(egfp_rev_template, 'rev')\n\nprint(f\"Forward primer annealing: {egfp_fwd_anneal} (Tm: {egfp_fwd_tm:.2f}°C)\")\nprint(f\"Reverse primer annealing: {egfp_rev_anneal} (Tm: {egfp_rev_tm:.2f}°C)\")\nprint(f\"Tm difference: {abs(egfp_fwd_tm - egfp_rev_tm):.2f}°C\")\nprint()\n\n# eGFP forward primer: creates 'acat' overhang\negfp_fwd_primer = 'GGTCTCNACAT' + egfp_fwd_anneal\n\n# eGFP reverse primer: needs to create overhang for FLAG\n# FLAG starts with 'ggtagtggctcc' (after removing ATG)\n# We need first 4bp: 'ggta'\n# RC of 'ggta' = 'tacc'\negfp_rev_primer_anneal_rc = reverse_complement(egfp_rev_anneal)\negfp_rev_primer = egfp_rev_primer_anneal_rc + 'GAGACCNTACC'\n\nprint(f\"eGFP forward primer: {egfp_fwd_primer}\")\nprint(f\"eGFP reverse primer: {egfp_rev_primer}\")\nprint()\n\nprimers.append(('>egfp_fwd', egfp_fwd_primer))\nprimers.append(('>egfp_rev', egfp_rev_primer))\n\n# 3. FLAG primers (without start and stop codons)\nprint(\"=\" * 80)\nprint(\"3. FLAG INSERT (without start and stop codons)\")\nprint(\"=\" * 80)\n\nflag_fwd_template = flag_insert[:100]\nflag_rev_template = flag_insert[-100:]\n\nflag_fwd_anneal, flag_fwd_tm = find_primer(flag_fwd_template, 'fwd')\nflag_rev_anneal, flag_rev_tm = find_primer(flag_rev_template, 'rev')\n\nprint(f\"Forward primer annealing: {flag_fwd_anneal} (Tm: {flag_fwd_tm:.2f}°C)\")\nprint(f\"Reverse primer annealing: {flag_rev_anneal} (Tm: {flag_rev_tm:.2f}°C)\")\nprint(f\"Tm difference: {abs(flag_fwd_tm - flag_rev_tm):.2f}°C\")\nprint()\n\n# FLAG forward primer: creates 'ggta' overhang (to match eGFP end)\nflag_fwd_primer = 'GGTCTCNGGTA' + flag_fwd_anneal\n\n# FLAG reverse primer: needs to create overhang for SNAP\n# SNAP starts with 'gacaaagactgc' (after removing ATG)\n# We need first 4bp: 'gaca'\n# RC of 'gaca' = 'tgtc'\nflag_rev_primer_anneal_rc = reverse_complement(flag_rev_anneal)\nflag_rev_primer = flag_rev_primer_anneal_rc + 'GAGACCNTGTC'\n\nprint(f\"FLAG forward primer: {flag_fwd_primer}\")\nprint(f\"FLAG reverse primer: {flag_rev_primer}\")\nprint()\n\nprimers.append(('>flag_fwd', flag_fwd_primer))\nprimers.append(('>flag_rev', flag_rev_primer))\n\n# 4. SNAP primers (without start codon, with stop codon)\nprint(\"=\" * 80)\nprint(\"4. SNAP INSERT (without start codon)\")\nprint(\"=\" * 80)\n\nsnap_fwd_template = snap_insert[:100]\nsnap_rev_template = snap_insert[-100:]\n\nsnap_fwd_anneal, snap_fwd_tm = find_primer(snap_fwd_template, 'fwd')\nsnap_rev_anneal, snap_rev_tm = find_primer(snap_rev_template, 'rev')\n\nprint(f\"Forward primer annealing: {snap_fwd_anneal} (Tm: {snap_fwd_tm:.2f}°C)\")\nprint(f\"Reverse primer annealing: {snap_rev_anneal} (Tm: {snap_rev_tm:.2f}°C)\")\nprint(f\"Tm difference: {abs(snap_fwd_tm - snap_rev_tm):.2f}°C\")\nprint()\n\n# SNAP forward primer: creates 'gaca' overhang (to match FLAG end)\nsnap_fwd_primer = 'GGTCTCNGACA' + snap_fwd_anneal\n\n# SNAP reverse primer: needs to create overhang for input backbone\n# Should match 'ttaa' (input backbone expects this)\n# RC of 'ttaa' = 'ttaa' (palindrome!)\nsnap_rev_primer_anneal_rc = reverse_complement(snap_rev_anneal)\nsnap_rev_primer = snap_rev_primer_anneal_rc + 'GAGACCNTTAA'\n\nprint(f\"SNAP forward primer: {snap_fwd_primer}\")\nprint(f\"SNAP reverse primer: {snap_rev_primer}\")\nprint()\n\nprimers.append(('>snap_fwd', snap_fwd_primer))\nprimers.append(('>snap_rev', snap_rev_primer))\n\n# Write primers to file\nprint(\"=\" * 80)\nprint(\"Writing primers to primers.fasta...\")\nprint(\"=\" * 80)\n\nwith open('primers.fasta', 'w') as f:\n    for header, seq in primers:\n        f.write(f\"{header}\\n{seq}\\n\")\n\nprint(\"Done! Primers written to primers.fasta\")\nprint(f\"Total primers: {len(primers)}\")\n\nEOFMAIN\n"]
[267.922858, "o", "cat >> design_gg_primers.py << 'EOFMAIN'\r\n\u001b[?2004l\r"]
[267.922981, "o", "\u001b[?2004h> "]
[267.923297, "o", "# 2. EGFP primers (without stop codon)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.923646, "o", "print(\"=\" * 80)\r\n\u001b[?2004l\r"]
[267.923963, "o", "\u001b[?2004h> print(\"2. EGFP INSERT (without stop codon)\")\r\n\u001b[?2004l\r"]
[267.924126, "o", "\u001b[?2004h> print(\"=\" * 80)\r\n\u001b[?2004l\r"]
[267.924387, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.924881, "o", "# eGFP forward: should create overhang 'acat' (to match input left side)\r\n\u001b[?2004l\r"]
[267.925175, "o", "\u001b[?2004h> "]
[267.925374, "o", "egfp_fwd_template = egfp_insert[:100]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.925661, "o", "egfp_rev_template = egfp_insert[-100:]\r\n\u001b[?2004l\r"]
