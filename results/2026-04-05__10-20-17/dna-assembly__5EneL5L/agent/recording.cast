[556.788989, "o", "    ('snap_rev', 'input_fwd', 'SNAP-right <-> Backbone-right'),\r\n\u001b[?2004l\r\u001b[?2004h"]
[556.789167, "o", "> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[556.78935, "o", "\u001b[?2004h> all_match = True\r\n\u001b[?2004l\r"]
[556.789548, "o", "\u001b[?2004h> "]
[556.789735, "o", "for primer1, primer2, desc in checks:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.789935, "o", "    oh1 = overhangs[primer1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.790112, "o", "    oh2 = overhangs[primer2]\r\n\u001b[?2004l\r"]
[556.790279, "o", "\u001b[?2004h> "]
[556.790473, "o", "    match = oh1 == oh2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.790698, "o", "    status = \"✓\" if match else \"✗\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.79106, "o", "    print(f\"{status} {desc}: {oh1} == {oh2} : {match}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[556.791297, "o", ">     if not match:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.791488, "o", "        all_match = False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.791675, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.791894, "o", "if all_match:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.792093, "o", "    print(\"✓ All overhangs match correctly! Assembly will work.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.792312, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[556.792536, "o", "    print(\"✗ Overhang mismatch detected!\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[556.79278, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[556.808245, "o", "Validating Golden Gate Assembly Overhangs\r\n================================================================================\r\ninput_fwd      : TTAA\r\ninput_rev      : ACAT\r\negfp_fwd       : ACAT\r\n"]
[556.808416, "o", "egfp_rev       : GGTA\r\nflag_fwd       : GGTA\r\nflag_rev       : GACA\r\nsnap_fwd       : GACA\r\nsnap_rev       : TTAA\r\n\r\n================================================================================\r\nChecking assembly compatibility:\r\n================================================================================\r\n"]
[556.8088, "o", "✓ Backbone-left <-> eGFP-left: ACAT == ACAT : True\r\n✓ eGFP-right <-> FLAG-left: GGTA == GGTA : True\r\n✓ FLAG-right <-> SNAP-left: GACA == GACA : True\r\n✓ SNAP-right <-> Backbone-right: TTAA == TTAA : True\r\n\r\n✓ All overhangs match correctly! Assembly will work.\r\n"]
[556.811956, "o", "\u001b[?2004hroot@a0b49dcae9e4:/app# "]
