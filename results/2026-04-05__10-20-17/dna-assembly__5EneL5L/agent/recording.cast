[139.915469, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\nseqs = read_fasta('sequences.fasta')\noutput_seq = seqs['output']\negfp = seqs['egfp']\n\nprint(f\"eGFP length: {len(egfp)}\")\nprint(f\"Output length: {len(output_seq)}\")\nprint(f\"Can fit eGFP at 210: {210 + len(egfp) <= len(output_seq)}\")\n\n# Check exact match\noutput_segment = output_seq[210:210+len(egfp)]\nprint(f\"\\nOutput segment length: {len(output_segment)}\")\nprint(f\"eGFP length: {len(egfp)}\")\nprint(f\"Match: {output_segment == egfp}\")\n\n# Find first mismatch\nif output_segment != egfp:\n    for i in range(min(len(output_segment), len(egfp))):\n        if output_segment[i] != egfp[i]:\n            print(f\"\\nFirst mismatch at position {i}\")\n            print(f\"Output: ...{output_segment[max(0,i-10):i+10]}...\")\n            print(f\"eGFP:   ...{egfp[max(0,i-10):i+10]}...\")\n            break\n    else:\n        print(\"\\nLength mismatch but no character mismatch found\")\n        print(f\"Output segment ends at: {len(output_segment)}\")\n        print(f\"eGFP ends at: {len(egfp)}\")\n\nEOF\n"]
