[361.110981, "o", "# Backbone-left -> eGFP-left\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.111088, "o", "> "]
[361.111443, "o", "# eGFP-right -> FLAG-left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.111668, "o", "# FLAG-right -> SNAP-left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.111931, "o", "# SNAP-right -> Backbone-right (closes the circle)\r\n\u001b[?2004l\r\u001b[?2004h"]
