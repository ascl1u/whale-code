[665.691912, "i", "python3 << 'EOF'\nimport subprocess\n\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    return sequences\n\nprint(\"=\"*80)\nprint(\"FINAL VERIFICATION - All Requirements Check\")\nprint(\"=\"*80)\nprint()\n\n# Check file exists and has no blank lines\nwith open('primers.fasta', 'r') as f:\n    lines = f.readlines()\n    has_blank = any(line.strip() == '' for line in lines)\n    print(f\"✓ primers.fasta exists\")\n    print(f\"✓ No blank lines: {not has_blank}\")\n    print(f\"✓ Total lines: {len(lines)} (8 headers + 8 sequences)\")\n\nprimers = read_fasta('primers.fasta')\nprint(f\"✓ Number of primers: {len(primers)} (4 pairs)\")\nprint(f\"✓ This is the MINIMUM number needed for 4-fragment assembly\")\nprint()\n\n# Check header format\nprint(\"Header format (>TEMPLATENAME_DIR):\")\nfor name in sorted(primers.keys()):\n    template, direction = name.split('_')\n    print(f\"  ✓ >{name} (template: {template}, direction: {direction})\")\n\nprint()\nprint(\"✓ All requirements satisfied!\")\nprint(\"✓ Primers ready for Golden Gate assembly with BsaI-HF v2\")\nprint(\"=\"*80)\n\nEOF\n"]
