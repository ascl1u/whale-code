[272.474164, "o", "python3 design_gg_primers.py; printf '%s\\n' '__CMDEND__8__'\r\n\u001b[?2004l\r"]
[272.501838, "o", "Designing Golden Gate primers...\r\n\r\n================================================================================\r\n1. INPUT BACKBONE\r\n================================================================================\r\n"]
[272.525824, "o", "Forward primer annealing: tgaggatcccgggaatt (Tm: 58.48°C)\r\nReverse primer annealing: tgtttaactttaagaaggagatatacat (Tm: 58.08°C)\r\nTm difference: 0.40°C\r\n\r\nInput forward primer: GGTCTCNTTAAtgaggatcccgggaatt\r\nInput reverse primer: atgtatatctccttcttaaagttaaacaGAGACCNATGT\r\n"]
[272.526062, "o", "\r\n================================================================================\r\n2. EGFP INSERT (without stop codon)\r\n================================================================================\r\n"]
[272.536354, "o", "Forward primer annealing: atgagcaagggcgagg (Tm: 60.45°C)\r\nReverse primer annealing: catggacgagctgtacaaa (Tm: 59.14°C)\r\nTm difference: 1.31°C\r\n\r\neGFP forward primer: GGTCTCNACATatgagcaagggcgagg\r\neGFP reverse primer: tttgtacagctcgtccatgGAGACCNTACC\r\n\r\n================================================================================"]
[272.536597, "o", "\r\n3. FLAG INSERT (without start and stop codons)\r\n================================================================================\r\n"]
[272.545316, "o", "Forward primer annealing: ggtagtggctccggt (Tm: 58.66°C)\r\nReverse primer annealing: tggttcaggtagtggttca (Tm: 59.49°C)\r\nTm difference: 0.83°C\r\n\r\n"]
[272.545615, "o", "FLAG forward primer: GGTCTCNGGTAggtagtggctccggt\r\nFLAG reverse primer: tgaaccactacctgaaccaGAGACCNTGTC\r\n\r\n================================================================================\r\n4. SNAP INSERT (without start codon)\r\n================================================================================\r\n"]
[272.569683, "o", "Forward primer annealing: gacaaagactgcgaaatgaa (Tm: 58.25°C)\r\nReverse primer annealing: gcctgggctgggttaa (Tm: 60.27°C)\r\nTm difference: 2.02°C\r\n\r\nSNAP forward primer: GGTCTCNGACAgacaaagactgcgaaatgaa\r\nSNAP reverse primer: ttaacccagcccaggcGAGACCNTTAA\r\n\r\n================================================================================\r\n"]
[272.569912, "o", "Writing primers to primers.fasta...\r\n================================================================================\r\n"]
[272.570078, "o", "Done! Primers written to primers.fasta\r\nTotal primers: 8\r\n"]
