[168.530413, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\nseqs = read_fasta('sequences.fasta')\noutput_seq = seqs['output']\negfp = seqs['egfp']\nflag = seqs['flag']\nsnap = seqs['snap']\n\n# Check what's at position 210 + 714 (where egfp differs)\npos = 210\nprint(f\"Position {pos} to {pos+30}: {output_seq[pos:pos+30]}\")\nprint(f\"eGFP starts: {egfp[:30]}\")\nprint()\n\n# Check around the mismatch point\nmismatch_pos = pos + 714\nprint(f\"Around position {mismatch_pos}:\")\nprint(f\"Output: {output_seq[mismatch_pos-10:mismatch_pos+20]}\")\nprint(f\"eGFP end: {egfp[704:]}\")\nprint(f\"FLAG start: {flag[:20]}\")\nprint()\n\n# It looks like the stop codon is replaced\nprint(\"Checking if eGFP(no stop) + FLAG + SNAP + stop is in output:\")\negfp_no_stop = egfp[:-3]\nflag_no_stop = flag[:-3]\nsnap_no_stop = snap[:-3]\n\ntest1 = egfp_no_stop + flag + snap\nif test1 in output_seq:\n    print(f\"Found: egfp(no stop) + flag(with stop) + snap(with stop)\")\n    pos = output_seq.find(test1)\n    print(f\"Position: {pos}\")\n\ntest2 = egfp_no_stop + flag_no_stop + snap + 'taa'\nif test2 in output_seq:\n    print(f\"Found: egfp(no stop) + flag(no stop) + snap(with stop) + taa\")\n    pos = output_seq.find(test2)\n    print(f\"Position: {pos}\")\n\ntest3 = egfp_no_stop + flag_no_stop + snap_no_stop + 'taa'\nif test3 in output_seq:\n    print(f\"Found: egfp(no stop) + flag(no stop) + snap(no stop) + taa\")\n    pos = output_seq.find(test3)\n    print(f\"Position: {pos}\")\n\ntest4 = egfp_no_stop + flag_no_stop + snap\nif test4 in output_seq:\n    print(f\"Found: egfp(no stop) + flag(no stop) + snap(with stop)\")\n    pos = output_seq.find(test4)\n    print(f\"Position: {pos}\")\n\nEOF\n"]
