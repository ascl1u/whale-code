[267.931749, "o", "egfp_rev_primer = egfp_rev_primer_anneal_rc + 'GAGACCNTACC'\r\n\u001b[?2004l\r\u001b[?2004h"]
[267.931957, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.932182, "o", "print(f\"eGFP forward primer: {egfp_fwd_primer}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.932519, "o", "print(f\"eGFP reverse primer: {egfp_rev_primer}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.932626, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.932895, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.933112, "o", "primers.append(('>egfp_fwd', egfp_fwd_primer))\r\n\u001b[?2004l\r\u001b[?2004h> "]
