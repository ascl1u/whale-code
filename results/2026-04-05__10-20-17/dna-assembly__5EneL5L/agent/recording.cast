[154.213098, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\nseqs = read_fasta('sequences.fasta')\ninput_seq = seqs['input']\noutput_seq = seqs['output']\negfp = seqs['egfp']\nflag = seqs['flag']\nsnap = seqs['snap']\n\nprint(\"Checking sequences...\")\nprint(f\"eGFP ends with: {egfp[-20:]}\")\nprint(f\"FLAG starts with: {flag[:20]}\")\nprint(f\"SNAP ends with: {snap[-20:]}\")\n\n# Check without stop codons\negfp_no_stop = egfp[:-3] if egfp[-3:] == 'taa' else egfp\nflag_no_stop = flag[:-3] if flag[-3:] == 'taa' else flag\nsnap_no_stop = snap[:-3] if snap[-3:] == 'taa' else snap\n\nprint(f\"\\neGFP without stop: ends with {egfp_no_stop[-10:]}\")\nprint(f\"FLAG without stop: ends with {flag_no_stop[-10:]}\")\nprint(f\"SNAP without stop: ends with {snap_no_stop[-10:]}\")\n\n# Try to find the assembly\ncombined = egfp_no_stop + flag_no_stop + snap_no_stop + 'taa'\nprint(f\"\\nCombined length (no internal stops + final stop): {len(combined)}\")\n\npos = output_seq.find(combined)\nif pos >= 0:\n    print(f\"Found combined sequence at position {pos}!\")\nelse:\n    # Try other combinations\n    combined2 = egfp_no_stop + flag + snap\n    pos2 = output_seq.find(combined2)\n    if pos2 >= 0:\n        print(f\"Found egfp(no stop) + flag + snap at position {pos2}\")\n    else:\n        combined3 = egfp_no_stop + flag_no_stop + snap\n        pos3 = output_seq.find(combined3)\n        if pos3 >= 0:\n            print(f\"Found egfp(no stop) + flag(no stop) + snap at position {pos3}\")\n\nEOF\n"]
