[42.751718, "o", "\u001b[?2004hroot@a0b49dcae9e4:/app# "]
[60.66289, "i", "cat > design_primers.py << 'EOF'\nimport subprocess\nimport re\n\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\ndef reverse_complement(seq):\n    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G'}\n    return ''.join(complement[base] for base in reversed(seq))\n\ndef get_tm(seq):\n    \"\"\"Get melting temperature using oligotm\"\"\"\n    try:\n        result = subprocess.run(\n            ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\n            capture_output=True, text=True, check=True\n        )\n        return float(result.stdout.strip())\n    except:\n        return None\n\ndef find_insertion_site(input_seq, output_seq):\n    \"\"\"Find where the insert goes in the plasmid\"\"\"\n    # Find the common parts\n    # The output should have input sequence with something inserted\n    \n    # Try to find a break point\n    for i in range(len(input_seq)):\n        # Check if input splits at position i\n        left = input_seq[:i]\n        right = input_seq[i:]\n        \n        # Check if output starts with left\n        if output_seq.startswith(left):\n            # Find where right appears in output\n            right_pos = output_seq.find(right)\n            if right_pos > i:\n                # Found the insertion\n                insert = output_seq[i:right_pos]\n                return i, insert, left, right\n    \n    return None, None, None, None\n\n# Read sequences\nseqs = read_fasta('sequences.fasta')\n\nprint(\"Analyzing sequences...\")\nprint(f\"Input length: {len(seqs['input'])}\")\nprint(f\"Output length: {len(seqs['output'])}\")\nprint(f\"eGFP length: {len(seqs['egfp'])}\")\nprint(f\"FLAG length: {len(seqs['flag'])}\")\nprint(f\"SNAP length: {len(seqs['snap'])}\")\n\n# Find insertion site\npos, insert, left, right = find_insertion_site(seqs['input'], seqs['output'])\nif pos:\n    print(f\"\\nInsertion at position {pos}\")\n    print(f\"Insert length: {len(insert)}\")\n    print(f\"Insert sequence (first 50 bp): {insert[:50]}\")\n    print(f\"Left flank (last 20 bp): {left[-20:]}\")\n    print(f\"Right flank (first 20 bp): {right[:20]}\")\n    \n    # Check if insert matches egfp+flag+snap\n    combined = seqs['egfp'] + seqs['flag'] + seqs['snap']\n    print(f\"\\nCombined egfp+flag+snap length: {len(combined)}\")\n    print(f\"Match with insert: {insert == combined}\")\n\nEOF\n"]
