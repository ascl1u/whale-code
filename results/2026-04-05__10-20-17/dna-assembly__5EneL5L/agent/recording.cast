[467.30494, "o", "        if current_name:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.305159, "o", "            sequences[current_name] = ''.join(current_seq)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.305361, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.305564, "o", "    return sequences\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.305683, "o", "def reverse_complement(seq):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.306111, "o", "    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G', \r\n\u001b[?2004l\r\u001b[?2004h"]
[467.306282, "o", "> "]
[467.306551, "o", "                  'a': 't', 't': 'a', 'g': 'c', 'c': 'g', 'N': 'N', 'n': 'n'}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.306987, "o", "    return ''.join(complement.get(base, base) for base in reversed(seq))\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.307088, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.307274, "o", "def get_tm(seq):\r\n\u001b[?2004l\r"]
[467.307476, "o", "\u001b[?2004h> "]
[467.307592, "o", "    \"\"\"Get melting temperature using oligotm\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[467.307752, "o", "\u001b[?2004h> "]
[467.308034, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[467.308214, "o", "\u001b[?2004h> "]
[467.308447, "o", "            ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()],\r\n\u001b[?2004l\r"]
[467.308648, "o", "\u001b[?2004h> "]
[467.308966, "o", "            capture_output=True, text=True, check=True\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r"]
[467.309167, "o", "\u001b[?2004h> "]
[467.309338, "o", "        return float(result.stdout.strip())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.309433, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.309654, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.310003, "o", "def find_primer_pair(template_fwd, template_rev, target_tm_min=58, target_tm_max=72, \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.310512, "o", "                     min_len=15, max_len=45, max_tm_diff=5):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.310839, "o", "    \"\"\"Find a pair of primers with compatible Tm\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.311017, "o", "    best_pair = None\r\n\u001b[?2004l\r"]
[467.311309, "o", "\u001b[?2004h> "]
[467.311544, "o", "    best_tm_diff = float('inf')\r\n\u001b[?2004l\r"]
[467.31172, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.311812, "o", "    for len_fwd in range(min_len, max_len + 1):\r\n\u001b[?2004l\r"]
[467.312064, "o", "\u001b[?2004h> "]
[467.312237, "o", "        primer_fwd = template_fwd[:len_fwd]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.312368, "o", "        tm_fwd = get_tm(primer_fwd)\r\n\u001b[?2004l\r"]
[467.312617, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.312972, "o", "        if not tm_fwd or tm_fwd < target_tm_min or tm_fwd > target_tm_max:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.313155, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.313336, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.313551, "o", "        for len_rev in range(min_len, max_len + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.313819, "o", "            primer_rev = template_rev[-len_rev:]\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.313941, "o", "> "]
[467.314113, "o", "            tm_rev = get_tm(primer_rev)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.314288, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.314604, "o", "            if not tm_rev or tm_rev < target_tm_min or tm_rev > target_tm_max:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.314814, "o", "                continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.315019, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.315194, "o", "            tm_diff = abs(tm_fwd - tm_rev)\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.315372, "o", "> "]
[467.315629, "o", "            if tm_diff <= max_tm_diff and tm_diff < best_tm_diff:\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.315735, "o", "> "]
[467.315936, "o", "                best_tm_diff = tm_diff\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.316234, "o", "                best_pair = (primer_fwd, tm_fwd, primer_rev, tm_rev)\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.316426, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.316588, "o", "    return best_pair\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.316838, "o", "# Read sequences\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.316995, "o", "seqs = read_fasta('sequences.fasta')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.317144, "o", "input_seq = seqs['input']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.317322, "o", "egfp = seqs['egfp']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.317513, "o", "flag = seqs['flag']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.317728, "o", "snap = seqs['snap']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.3179, "o", "# Prepare insert sequences\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.318082, "o", "egfp_insert = egfp[:-3]  # Remove stop codon\r\n\u001b[?2004l\r"]
[467.318256, "o", "\u001b[?2004h> "]
[467.31837, "o", "flag_insert = flag[3:-3]  # Remove start and stop\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.318662, "o", "snap_insert = snap[3:]  # Remove start, keep stop\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[467.318902, "o", "\u001b[?2004h> "]
[467.3191, "o", "print(\"Golden Gate Assembly Design with BsaI-HF v2\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.319283, "o", "print(\"=\" * 80)\r\n\u001b[?2004l\r\u001b[?2004h> print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.319411, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.319692, "o", "# Define the overhangs for ordered assembly\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.319922, "o", "oh1 = 'ACAT'  # Backbone left / eGFP left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.320154, "o", "oh2 = 'GGTA'  # eGFP right / FLAG left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.320397, "o", "oh3 = 'GACA'  # FLAG right / SNAP left\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.320673, "o", "oh4 = 'TTAA'  # SNAP right / Backbone right\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.320868, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.320982, "o", "print(f\"Overhang design:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.321247, "o", "print(f\"  OH1 ({oh1}): Backbone-left <-> eGFP-left\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.321421, "o", "> "]
[467.321592, "o", "print(f\"  OH2 ({oh2}): eGFP-right <-> FLAG-left\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.321848, "o", "print(f\"  OH3 ({oh3}): FLAG-right <-> SNAP-left\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[467.32218, "o", "print(f\"  OH4 ({oh4}): SNAP-right <-> Backbone-right\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[467.322294, "o", "> print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[467.322472, "o", "\u001b[?2004h> "]
[467.322696, "o", "primers = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> EOFMAIN\r\n\u001b[?2004l\r"]
[467.324868, "o", "\u001b[?2004hroot@a0b49dcae9e4:/app# "]
[492.357603, "i", "cat >> final_primers.py << 'EOFMAIN'\n# Design primers for each fragment\n\n# 1. INPUT BACKBONE\nprint(\"1. INPUT BACKBONE\")\nprint(\"-\" * 80)\n\ninput_fwd_template = input_seq[690:790]\ninput_rev_template = input_seq[110:210]\n\nresult = find_primer_pair(input_fwd_template, input_rev_template)\nif result:\n    input_fwd_anneal, input_fwd_tm, input_rev_anneal, input_rev_tm = result\n    print(f\"Forward annealing region: {input_fwd_anneal} (Tm: {input_fwd_tm:.2f}°C)\")\n    print(f\"Reverse annealing region: {input_rev_anneal} (Tm: {input_rev_tm:.2f}°C)\")\n    print(f\"Tm difference: {abs(input_fwd_tm - input_rev_tm):.2f}°C\")\n    \n    # Forward primer creates OH4 (TTAA) overhang\n    input_fwd_primer = f\"GGTCTCN{oh4}{input_fwd_anneal}\"\n    \n    # Reverse primer creates OH1 (ACAT) overhang\n    # The primer sequence is RC of template, and overhang before NGAGACC\n    input_rev_primer = f\"{reverse_complement(input_rev_anneal)}{oh1}NGAGACC\"\n    \n    print(f\"Forward primer: {input_fwd_primer}\")\n    print(f\"Reverse primer: {input_rev_primer}\")\n    primers.append(('>input_fwd', input_fwd_primer.upper()))\n    primers.append(('>input_rev', input_rev_primer.upper()))\nprint()\n\n# 2. EGFP INSERT\nprint(\"2. EGFP INSERT (without stop codon)\")\nprint(\"-\" * 80)\n\negfp_fwd_template = egfp_insert[:100]\negfp_rev_template = egfp_insert[-100:]\n\nresult = find_primer_pair(egfp_fwd_template, egfp_rev_template)\nif result:\n    egfp_fwd_anneal, egfp_fwd_tm, egfp_rev_anneal, egfp_rev_tm = result\n    print(f\"Forward annealing region: {egfp_fwd_anneal} (Tm: {egfp_fwd_tm:.2f}°C)\")\n    print(f\"Reverse annealing region: {egfp_rev_anneal} (Tm: {egfp_rev_tm:.2f}°C)\")\n    print(f\"Tm difference: {abs(egfp_fwd_tm - egfp_rev_tm):.2f}°C\")\n    \n    egfp_fwd_primer = f\"GGTCTCN{oh1}{egfp_fwd_anneal}\"\n    egfp_rev_primer = f\"{reverse_complement(egfp_rev_anneal)}{oh2}NGAGACC\"\n    \n    print(f\"Forward primer: {egfp_fwd_primer}\")\n    print(f\"Reverse primer: {egfp_rev_primer}\")\n    primers.append(('>egfp_fwd', egfp_fwd_primer.upper()))\n    primers.append(('>egfp_rev', egfp_rev_primer.upper()))\nprint()\n\n# 3. FLAG INSERT\nprint(\"3. FLAG INSERT (without start and stop codons)\")\nprint(\"-\" * 80)\n\nflag_fwd_template = flag_insert[:100]\nflag_rev_template = flag_insert[-100:]\n\nresult = find_primer_pair(flag_fwd_template, flag_rev_template)\nif result:\n    flag_fwd_anneal, flag_fwd_tm, flag_rev_anneal, flag_rev_tm = result\n    print(f\"Forward annealing region: {flag_fwd_anneal} (Tm: {flag_fwd_tm:.2f}°C)\")\n    print(f\"Reverse annealing region: {flag_rev_anneal} (Tm: {flag_rev_tm:.2f}°C)\")\n    print(f\"Tm difference: {abs(flag_fwd_tm - flag_rev_tm):.2f}°C\")\n    \n    flag_fwd_primer = f\"GGTCTCN{oh2}{flag_fwd_anneal}\"\n    flag_rev_primer = f\"{reverse_complement(flag_rev_anneal)}{oh3}NGAGACC\"\n    \n    print(f\"Forward primer: {flag_fwd_primer}\")\n    print(f\"Reverse primer: {flag_rev_primer}\")\n    primers.append(('>flag_fwd', flag_fwd_primer.upper()))\n    primers.append(('>flag_rev', flag_rev_primer.upper()))\nprint()\n\n# 4. SNAP INSERT\nprint(\"4. SNAP INSERT (without start codon)\")\nprint(\"-\" * 80)\n\nsnap_fwd_template = snap_insert[:100]\nsnap_rev_template = snap_insert[-100:]\n\nresult = find_primer_pair(snap_fwd_template, snap_rev_template)\nif result:\n    snap_fwd_anneal, snap_fwd_tm, snap_rev_anneal, snap_rev_tm = result\n    print(f\"Forward annealing region: {snap_fwd_anneal} (Tm: {snap_fwd_tm:.2f}°C)\")\n    print(f\"Reverse annealing region: {snap_rev_anneal} (Tm: {snap_rev_tm:.2f}°C)\")\n    print(f\"Tm difference: {abs(snap_fwd_tm - snap_rev_tm):.2f}°C\")\n    \n    snap_fwd_primer = f\"GGTCTCN{oh3}{snap_fwd_anneal}\"\n    snap_rev_primer = f\"{reverse_complement(snap_rev_anneal)}{oh4}NGAGACC\"\n    \n    print(f\"Forward primer: {snap_fwd_primer}\")\n    print(f\"Reverse primer: {snap_rev_primer}\")\n    primers.append(('>snap_fwd', snap_fwd_primer.upper()))\n    primers.append(('>snap_rev', snap_rev_primer.upper()))\nprint()\n\n# Write primers to file\nprint(\"=\" * 80)\nprint(\"Writing primers to primers.fasta...\")\nwith open('primers.fasta', 'w') as f:\n    for header, seq in primers:\n        f.write(f\"{header}\\n{seq}\\n\")\n\nprint("]
[492.357723, "i", "f\"Done! {len(primers)} primers written.\")\n\nEOFMAIN\n"]
