[102.651293, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\nseqs = read_fasta('sequences.fasta')\noutput_seq = seqs['output']\negfp = seqs['egfp']\n\nprint(f\"eGFP length: {len(egfp)}\")\nprint(f\"eGFP starts: {egfp[:50]}\")\nprint(f\"Output at 214: {output_seq[214:264]}\")\nprint(f\"Match: {output_seq[214:214+len(egfp)] == egfp}\")\n\n# Try with 'atg' prefix removed\nif egfp.startswith('atg'):\n    egfp_no_atg = egfp[3:]\n    print(f\"\\nTrying without ATG...\")\n    print(f\"Match: {output_seq[217:217+len(egfp_no_atg)] == egfp_no_atg}\")\n\n# Search for egfp in output\npos = output_seq.find(egfp)\nprint(f\"\\neGFP position in output: {pos}\")\n\nEOF\n"]
