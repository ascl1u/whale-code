[361.114511, "o", "\u001b[?2004h> "]
[361.114798, "o", "print(f\"  OH1 ({oh1}): Backbone-left <-> eGFP-left\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.114977, "o", "> "]
