[267.946948, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[267.947227, "o", "# SNAP forward primer: creates 'gaca' overhang (to match FLAG end)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.947549, "o", "snap_fwd_primer = 'GGTCTCNGACA' + snap_fwd_anneal\r\n\u001b[?2004l\r"]
[267.947742, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.963532, "o", "# SNAP reverse primer: needs to create overhang for input backbone\r\n\u001b[?2004l\r\u001b[?2004h> # Should match 'ttaa' (input backbone expects this)\r\n\u001b[?2004l\r\u001b[?2004h> # RC of 'ttaa' = 'ttaa' (palindrome!)\r\n\u001b[?2004l\r\u001b[?2004h> snap_rev_primer_anneal_rc = reverse_complement(snap_rev_anneal)\r\n\u001b[?2004l\r\u001b[?2004h> snap_rev_primer = snap_rev_primer_anneal_rc + 'GAGACCNTTAA'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(f\"SNAP forward primer: {snap_fwd_primer}\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"SNAP reverse primer: {snap_rev_primer}\")\r\n\u001b[?2004l\r\u001b[?2004h> print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> primers.append(('>snap_fwd', snap_fwd_primer))\r\n\u001b[?2004l\r\u001b[?2004h> primers.append(('>snap_rev', snap_rev_primer))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Write primers to file\r\n\u001b[?2004l\r\u001b[?2004h> print(\"=\" * 80)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.963813, "o", "print(\"Writing primers to primers.fasta...\")\r\n\u001b[?2004l\r\u001b[?2004h> print(\"=\" * 80)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[267.963937, "o", "\u001b[?2004h> "]
[267.964236, "o", "with open('primers.fasta', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.964446, "o", "    for header, seq in primers:\r\n\u001b[?2004l\r\u001b[?2004h"]
[267.964641, "o", "> "]
[267.964865, "o", "        f.write(f\"{header}\\n{seq}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.965076, "o", "print(\"Done! Primers written to primers.fasta\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.965284, "o", "print(f\"Total primers: {len(primers)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.965418, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> EOFMAIN\r\n\u001b[?2004l\r"]
[267.967285, "o", "\u001b[?2004hroot@a0b49dcae9e4:/app# "]
