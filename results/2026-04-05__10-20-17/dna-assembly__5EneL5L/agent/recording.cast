[113.183348, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\nseqs = read_fasta('sequences.fasta')\noutput_seq = seqs['output']\negfp = seqs['egfp']\nflag = seqs['flag']\nsnap = seqs['snap']\n\nprint(f\"Output at 211: {output_seq[211:261]}\")\nprint(f\"eGFP starts:   {egfp[:50]}\")\nprint(f\"\\nMatch at 211: {output_seq[211:211+len(egfp)] == egfp}\")\n\n# Check each position around 211-214\nfor i in range(209, 216):\n    if output_seq[i:i+len(egfp)] == egfp:\n        print(f\"\\nFound eGFP at position {i}!\")\n        break\nelse:\n    # Check if it's similar\n    print(\"\\nChecking similarity...\")\n    for i in range(209, 216):\n        match_count = sum(1 for j in range(min(50, len(egfp))) if output_seq[i+j] == egfp[j])\n        print(f\"Position {i}: {match_count}/50 matches in first 50 bp\")\n        \nEOF\n"]
