[210.380312, "i", "python3 << 'EOF'\ndef read_fasta(filename):\n    sequences = {}\n    current_name = None\n    current_seq = []\n    \n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('>'):\n                if current_name:\n                    sequences[current_name] = ''.join(current_seq)\n                current_name = line[1:]\n                current_seq = []\n            else:\n                current_seq.append(line)\n        if current_name:\n            sequences[current_name] = ''.join(current_seq)\n    \n    return sequences\n\nseqs = read_fasta('sequences.fasta')\ninput_seq = seqs['input']\noutput_seq = seqs['output']\negfp = seqs['egfp']\nflag = seqs['flag']\nsnap = seqs['snap']\n\n# The fusion starts at position 210 in output\nfusion_start = 210\negfp_no_stop = egfp[:-3]\nflag_no_start_no_stop = flag[3:-3]\nsnap_no_start = snap[3:]\nfusion = egfp_no_stop + flag_no_start_no_stop + snap_no_start\nfusion_end = fusion_start + len(fusion)\n\nprint(f\"Fusion in output: positions {fusion_start}-{fusion_end}\")\nprint(f\"Before fusion: {output_seq[fusion_start-30:fusion_start]}\")\nprint(f\"After fusion: {output_seq[fusion_end:fusion_end+30]}\")\nprint()\n\n# Find these sequences in input\nbefore_seq = output_seq[fusion_start-30:fusion_start]\nafter_seq = output_seq[fusion_end:fusion_end+30]\n\ninput_before = input_seq.find(before_seq)\ninput_after = input_seq.find(after_seq)\n\nprint(f\"Before sequence in input at: {input_before}\")\nprint(f\"After sequence in input at: {input_after}\")\nprint()\n\nif input_before >= 0 and input_after >= 0:\n    input_cut_start = input_before + 30\n    input_cut_end = input_after\n    \n    print(f\"Input plasmid cut points: {input_cut_start} and {input_cut_end}\")\n    print(f\"Removed from input: {input_seq[input_cut_start:input_cut_end][:50]}...\")\n    print(f\"Removed length: {input_cut_end - input_cut_start} bp\")\n    print()\n    \n    print(\"Assembly structure:\")\n    print(f\"1. Input backbone: positions 0-{input_cut_start} and {input_cut_end}-end\")\n    print(f\"2. Insert: eGFP(no stop) + FLAG(no ATG, no stop) + SNAP(no ATG)\")\n    print()\n    print(f\"Overhangs needed:\")\n    print(f\"  - Left junction: {input_seq[input_cut_start-4:input_cut_start]} | {egfp[:4]}\")\n    print(f\"  - Right junction: {snap[-4:]} | {input_seq[input_cut_end:input_cut_end+4]}\")\n\nEOF\n"]
