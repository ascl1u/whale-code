[281.200009, "o", "cat primers.fasta; printf '%s\\n' '__CMDEND__9__'\r\n\u001b[?2004l\r"]
[281.202123, "o", ">input_fwd\r\nGGTCTCNTTAAtgaggatcccgggaatt\r\n>input_rev\r\natgtatatctccttcttaaagttaaacaGAGACCNATGT\r\n>egfp_fwd\r\nGGTCTCNACATatgagcaagggcgagg\r\n>egfp_rev\r\ntttgtacagctcgtccatgGAGACCNTACC\r\n>flag_fwd\r\nGGTCTCNGGTAggtagtggctccggt\r\n>flag_rev\r\ntgaaccactacctgaaccaGAGACCNTGTC\r\n>snap_fwd\r\nGGTCTCNGACAgacaaagactgcgaaatgaa\r\n>snap_rev\r\nttaacccagcccaggcGAGACCNTTAA\r\n"]
