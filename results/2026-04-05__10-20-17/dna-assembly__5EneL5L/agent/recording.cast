[304.597326, "i", "python3 << 'EOF'\n# Verify BsaI cutting mechanism\n# BsaI recognition: GGTCTC (forward) or GAGACC (reverse complement)\n# BsaI cuts 1 nt downstream on top strand, 5 nt downstream on bottom strand\n# This creates a 4 nt 5' overhang\n\n# Example for forward primer:\n# 5'- ...primer... GGTCTC N NNNN -template- 3'\n# 3'- ...primer... CCAGAG N NNNN -template- 5'\n#                        |\n#                        Cut position (1 nt after recognition)\n# After cutting:\n# 5'- NNNN -template- 3' (4 nt overhang)\n# 3'- -template- 5'\n\n# For reverse primer:\n# 5'- -template- NNNN N GAGACC ...primer... 3'\n# 3'- -template- NNNN N CTCTGG ...primer... 5'\n#                     |\n#                     Cut position\n# After cutting:\n# 5'- -template- NNNN 3' (4 nt overhang)\n# 3'- -template- 5'\n\nprint(\"BsaI-HF v2 cutting mechanism verified.\")\nprint()\nprint(\"For Golden Gate assembly, the overhangs must be compatible:\")\nprint(\"- Input backbone left end: should have overhang complementary to eGFP start\")\nprint(\"- eGFP: left overhang matches backbone, right overhang matches FLAG\")\nprint(\"- FLAG: left overhang matches eGFP, right overhang matches SNAP\")\nprint(\"- SNAP: left overhang matches FLAG, right overhang matches backbone right end\")\nprint(\"- Input backbone right end: should have overhang complementary to SNAP end\")\nprint()\nprint(\"This creates a circular assembly.\")\n\nEOF\n"]
[304.597776, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r"]
[304.597886, "o", "\u001b[?2004h> "]
[304.598284, "o", "# Verify BsaI cutting mechanism\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.598605, "o", "# BsaI recognition: GGTCTC (forward) or GAGACC (reverse complement)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.599012, "o", "# BsaI cuts 1 nt downstream on top strand, 5 nt downstream on bottom strand\r\n\u001b[?2004l\r\u001b[?2004h"]
[304.59909, "o", "> "]
[304.599497, "o", "# This creates a 4 nt 5' overhang\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.59971, "o", "# Example for forward primer:\r\n\u001b[?2004l\r\u001b[?2004h"]
[304.599943, "o", "> "]
[304.600117, "o", "# 5'- ...primer... GGTCTC N NNNN -template- 3'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.600432, "o", "# 3'- ...primer... CCAGAG N NNNN -template- 5'\r\n\u001b[?2004l\r"]
[304.600633, "o", "\u001b[?2004h> "]
[304.600909, "o", "#                        |\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.60119, "o", "#                        Cut position (1 nt after recognition)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.601438, "o", "# After cutting:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.601731, "o", "# 5'- NNNN -template- 3' (4 nt overhang)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.601889, "o", "# 3'- -template- 5'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[304.602198, "o", "\u001b[?2004h> # For reverse primer:\r\n\u001b[?2004l\r"]
[304.602429, "o", "\u001b[?2004h> "]
[304.602636, "o", "# 5'- -template- NNNN N GAGACC ...primer... 3'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.602843, "o", "# 3'- -template- NNNN N CTCTGG ...primer... 5'\r\n\u001b[?2004l\r"]
[304.603074, "o", "\u001b[?2004h> #                     |\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.60332, "o", "#                     Cut position\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.603557, "o", "# After cutting:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.603727, "o", "# 5'- -template- NNNN 3' (4 nt overhang)\r\n\u001b[?2004l\r"]
[304.603983, "o", "\u001b[?2004h> "]
[304.604244, "o", "# 3'- -template- 5'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.604506, "o", "print(\"BsaI-HF v2 cutting mechanism verified.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.604658, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[304.605063, "o", "print(\"For Golden Gate assembly, the overhangs must be compatible:\")\r\n\u001b[?2004l\r"]
