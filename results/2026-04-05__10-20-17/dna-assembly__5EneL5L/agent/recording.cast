[267.937521, "o", "print(f\"Reverse primer annealing: {flag_rev_anneal} (Tm: {flag_rev_tm:.2f}°C)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.937884, "o", "print(f\"Tm difference: {abs(flag_fwd_tm - flag_rev_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[267.937998, "o", "> print()\r\n\u001b[?2004l\r\u001b[?2004h"]
[267.938226, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.938472, "o", "# FLAG forward primer: creates 'ggta' overhang (to match eGFP end)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.938781, "o", "flag_fwd_primer = 'GGTCTCNGGTA' + flag_fwd_anneal\r\n\u001b[?2004l\r\u001b[?2004h"]
[267.938973, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.939225, "o", "# FLAG reverse primer: needs to create overhang for SNAP\r\n\u001b[?2004l\r\u001b[?2004h"]
[267.939507, "o", "> "]
[267.939754, "o", "# SNAP starts with 'gacaaagactgc' (after removing ATG)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.939948, "o", "# We need first 4bp: 'gaca'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.940221, "o", "# RC of 'gaca' = 'tgtc'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[267.940501, "o", "flag_rev_primer_anneal_rc = reverse_complement(flag_rev_anneal)\r\n\u001b[?2004l\r\u001b[?2004h"]
[267.940758, "o", "> "]
