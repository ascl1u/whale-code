[?2004l[?2004h>     is_fwd = 'fwd' in name
[?2004l[?2004h>     oh = extract_overhangs(seq, is_fwd)
[?2004l[?2004h>     overhangs[name] = oh
[?2004l[?2004h>     print(f"{name:15s}: {oh}")
