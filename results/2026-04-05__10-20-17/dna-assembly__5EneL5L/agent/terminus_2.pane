[?2004l[?2004h>     ('input_rev', 'egfp_fwd', 'Backbone-left <-> eGFP-left'),
[?2004l[?2004h>     ('egfp_rev', 'flag_fwd', 'eGFP-right <-> FLAG-left'),
[?2004l[?2004h>     ('flag_rev', 'snap_fwd', 'FLAG-right <-> SNAP-left'),
