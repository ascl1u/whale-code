[?2004l[?2004h> # Verify BsaI cutting mechanism
[?2004l[?2004h> # BsaI recognition: GGTCTC (forward) or GAGACC (reverse complement)
[?2004l[?2004h> # BsaI cuts 1 nt downstream on top strand, 5 nt downstream on bottom strand
[?2004l[?2004h> # This creates a 4 nt 5' overhang
[?2004l[?2004h> 
[?2004l[?2004h> # Example for forward primer:
[?2004l[?2004h> # 5'- ...primer... GGTCTC N NNNN -template- 3'
[?2004l[?2004h> # 3'- ...primer... CCAGAG N NNNN -template- 5'
[?2004l[?2004h> #                        |
[?2004l[?2004h> #                        Cut position (1 nt after recognition)
[?2004l[?2004h> # After cutting:
