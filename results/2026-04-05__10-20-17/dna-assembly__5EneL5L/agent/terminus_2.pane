[?2004l[?2004h> # Read sequences
[?2004l[?2004h> seqs = read_fasta('sequences.fasta')
[?2004l[?2004h> input_seq = seqs['input']
[?2004l[?2004h> egfp = seqs['egfp']
[?2004l[?2004h> flag = seqs['flag']
[?2004l[?2004h> snap = seqs['snap']
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare insert sequences
[?2004l[?2004h> egfp_insert = egfp[:-3]  # Remove stop codon
[?2004l[?2004h> flag_insert = flag[3:-3]  # Remove start and stop
[?2004l[?2004h> snap_insert = snap[3:]  # Remove start, keep stop
