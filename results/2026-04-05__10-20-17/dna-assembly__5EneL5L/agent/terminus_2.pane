[?2004l[?2004h> 
[?2004l[?2004h> def extract_overhangs(primer, is_fwd):
[?2004l[?2004h>     """Extract the 4bp overhang from a primer"""
[?2004l[?2004h>     if is_fwd:
[?2004l[?2004h>         # Forward: GGTCTCN[NNNN]template
[?2004l[?2004h>         pos = primer.find('GGTCTCN')
[?2004l[?2004h>         if pos >= 0:
[?2004l[?2004h>             return primer[pos+7:pos+11]
[?2004l[?2004h>     else:
[?2004l[?2004h>         # Reverse: template[NNNN]NGAGACC
[?2004l[?2004h>         pos = primer.find('NGAGACC')
[?2004l[?2004h>         if pos >= 0:
[?2004l[?2004h>             return primer[pos-4:pos]
[?2004l[?2004h>     return None
[?2004l[?2004h> 
[?2004l[?2004h> primers = read_fasta('primers.fasta')
