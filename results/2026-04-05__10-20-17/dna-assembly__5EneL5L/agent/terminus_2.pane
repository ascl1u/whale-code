[?2004l[?2004h> print("Golden Gate Assembly Design with BsaI-HF v2")
[?2004l[?2004h> print("=" * 80)
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # Define the overhangs for ordered assembly
[?2004l[?2004h> # We need 4 fragments that will assemble in order:
[?2004l[?2004h> # 1. Input backbone (linearized)
[?2004l[?2004h> # 2. eGFP insert
[?2004l[?2004h> # 3. FLAG insert  
[?2004l[?2004h> # 4. SNAP insert
[?2004l[?2004h> 
[?2004l[?2004h> # The overhangs must form a circular assembly:
[?2004l[?2004h> # Backbone-left -> eGFP-left
[?2004l[?2004h> # eGFP-right -> FLAG-left
[?2004l[?2004h> # FLAG-right -> SNAP-left
[?2004l[?2004h> # SNAP-right -> Backbone-right (closes the circle)
[?2004l[?2004h> 
[?2004l[?2004h> # Choose unique 4bp overhangs
[?2004l[?2004h> oh1 = 'ACAT'  # Backbone left / eGFP left
[?2004l[?2004h> oh2 = 'GGTA'  # eGFP right / FLAG left
[?2004l[?2004h> oh3 = 'GACA'  # FLAG right / SNAP left
[?2004l[?2004h> oh4 = 'TTAA'  # SNAP right / Backbone right
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Overhang design:")
[?2004l[?2004h> print(f"  OH1 ({oh1}): Backbone-left <-> eGFP-left")
[?2004l[?2004h> print(f"  OH2 ({oh2}): eGFP-right <-> FLAG-left")
[?2004l[?2004h> print(f"  OH3 ({oh3}): FLAG-right <-> SNAP-left")
[?2004l[?2004h> print(f"  OH4 ({oh4}): SNAP-right <-> Backbone-right")
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> primers = []
[?2004l[?2004h> 
[?2004l[?2004h> EOFMAIN
[?2004l[?2004hroot@a0b49dcae9e4:/app# cat >> redesign_primers.py << 'EOFMAIN'
[?2004l[?2004h> # Design primers for each fragment
[?2004l[?2004h> 
[?2004lr[?2004h> # 1. INPUT BACKBONE
[?2004l[?2004h> print("1. INPUT BACKBONE")
[?2004l[?2004h> print("-" * 80)
[?2004l[?2004h> 
[?2004l[?2004h> # The backbone is from position 690 onwards, wrapping to position 210
[?2004l[?2004h> # Forward primer: starts at position 690, needs to create OH4 (TTAA) on left side
[?2004l[?2004h> # Reverse primer: ends at position 210, needs to create OH1 (ACAT) on right side
[?2004l[?2004h> 
[?2004lo[?2004h> input_fwd_template = input_seq[690:790]
[?2004l[?2004h> input_rev_template = input_seq[110:210]
[?2004l[?2004h> 
[?2004l[?2004h> result = find_primer_pair(input_fwd_template, input_rev_template)
[?2004l[?2004h> if result:
[?2004l[?2004h>     input_fwd_anneal, input_fwd_tm, input_rev_anneal, input_rev_tm = result
[?2004l[?2004h>     print(f"Forward annealing region: {input_fwd_anneal} (Tm: {input_fwd_tm:.2f}°C)")
[?2004l[?2004h>     print(f"Reverse annealing region: {input_rev_anneal} (Tm: {input_rev_tm:.2f}°C)")
[?2004l[?2004h>     print(f"Tm difference: {abs(input_fwd_tm - input_rev_tm):.2f}°C")
[?2004l[?2004h>     
[?2004l[?2004h>     # Forward primer creates OH4 (TTAA) overhang
[?2004l[?2004h>     input_fwd_primer = f"GGTCTCN{oh4}{input_fwd_anneal}"
[?2004l[?2004h>     
[?2004l[?2004h>     # Reverse primer creates OH1 (ACAT) overhang
[?2004l[?2004h>     # Need to add RC of OH1 to the primer
[?2004l[?2004h>     input_rev_primer = f"{reverse_complement(input_rev_anneal)}{reverse_complement(oh1)}NGAGACC"
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Forward primer: {input_fwd_primer}")
[?2004l[?2004h>     print(f"Reverse primer: {input_rev_primer}")
[?2004l[?2004h>     primers.append(('>input_fwd', input_fwd_primer.upper()))
[?2004l[?2004h>     primers.append(('>input_rev', input_rev_primer.upper()))
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # 2. EGFP INSERT
[?2004l[?2004h> print("2. EGFP INSERT (without stop codon)")
[?2004l[?2004h> print("-" * 80)
[?2004l[?2004h> 
[?2004l[?2004h> # eGFP needs OH1 (ACAT) on left, OH2 (GGTA) on right
[?2004l[?2004h> egfp_fwd_template = egfp_insert[:100]
[?2004l[?2004h> egfp_rev_template = egfp_insert[-100:]
[?2004l[?2004h> 
[?2004l[?2004h> result = find_primer_pair(egfp_fwd_template, egfp_rev_template)
[?2004l[?2004h> if result:
[?2004l[?2004h>     egfp_fwd_anneal, egfp_fwd_tm, egfp_rev_anneal, egfp_rev_tm = result
[?2004l[?2004h>     print(f"Forward annealing region: {egfp_fwd_anneal} (Tm: {egfp_fwd_tm:.2f}°C)")
[?2004l[?2004h>     print(f"Reverse annealing region: {egfp_rev_anneal} (Tm: {egfp_rev_tm:.2f}°C)")
[?2004l[?2004h>     print(f"Tm difference: {abs(egfp_fwd_tm - egfp_rev_tm):.2f}°C")
[?2004l[?2004h>     
[?2004l[?2004h>     egfp_fwd_primer = f"GGTCTCN{oh1}{egfp_fwd_anneal}"
[?2004l[?2004h>     egfp_rev_primer = f"{reverse_complement(egfp_rev_anneal)}{reverse_complement(oh2)}NGAGACC"
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Forward primer: {egfp_fwd_primer}")
[?2004l[?2004h>     print(f"Reverse primer: {egfp_rev_primer}")
[?2004l[?2004h>     primers.append(('>egfp_fwd', egfp_fwd_primer.upper()))
[?2004l[?2004h>     primers.append(('>egfp_rev', egfp_rev_primer.upper()))
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # 3. FLAG INSERT
[?2004l[?2004h> print("3. FLAG INSERT (without start and stop codons)")
[?2004l[?2004h> print("-" * 80)
[?2004l[?2004h> 
[?2004l[?2004h> # FLAG needs OH2 (GGTA) on left, OH3 (GACA) on right
[?2004l[?2004h> flag_fwd_template = flag_insert[:100]
[?2004l[?2004h> flag_rev_template = flag_insert[-100:]
[?2004l[?2004h> 
[?2004l[?2004h> result = find_primer_pair(flag_fwd_template, flag_rev_template)
[?2004l[?2004h> if result:
