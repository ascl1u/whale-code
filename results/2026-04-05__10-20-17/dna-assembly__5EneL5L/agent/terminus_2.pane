[?2004l[?2004h> import subprocess
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def read_fasta(filename):
[?2004l[?2004h>     sequences = {}
[?2004lprimer ann[?2004h>     current_name = None
[?2004l[?2004h>     current_seq = []
[?2004l[?2004h>     
[?2004l[?2004h>     with open(filename, 'r') as f:
[?2004l[?2004h>         for line in f:
[?2004l[?2004h>             line = line.strip()
[?2004l[?2004h>             if line.startswith('>'):
[?2004l[?2004h>                 if current_name:
[?2004l[?2004h>                     sequences[current_name] = ''.join(current_seq)
[?2004l[?2004h>                 current_name = line[1:]
[?2004lu[?2004h>                 current_seq = []
[?2004l[?2004h>             else:
[?2004l[?2004h>                 current_seq.append(line)
[?2004l[?2004h>         if current_name:
[?2004l[?2004h>             sequences[current_name] = ''.join(current_seq)
[?2004l[?2004h>     
[?2004l[?2004h>     return sequences
[?2004l[?2004h> 
[?2004l[?2004h> def reverse_complement(seq):
[?2004l: [?2004h>     complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G', 
[?2004l[?2004h>                   'a': 't', 't': 'a', 'g': 'c', 'c': 'g'}
[?2004l[?2004h>     return ''.join(complement.get(base, base) for base in reversed(seq))
[?2004l[?2004h> 
[?2004l[?2004h> def get_tm(seq):
[?2004l[?2004h>     """Get melting temperature using oligotm"""
[?2004l[?2004h>     try:
[?2004l[?2004h>         result = subprocess.run(
[?2004l[?2004h>             ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()],
[?2004l[?2004h>             capture_output=True, text=True, check=True
[?2004l[?2004h>         )
[?2004l[?2004h>         return float(result.stdout.strip())
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         print(f"Error getting Tm for {seq}: {e}", file=sys.stderr)
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h> def find_primer(template, direction, target_tm_min=58, target_tm_max=72, min_len=15, max_len=45):
[?2004l[?2004h>     """Find a primer with appropriate Tm"""
[?2004l[?2004h>     for length in range(min_len, max_len + 1):
[?2004l[?2004h>         if direction == 'fwd':
[?2004l[?2004h>             primer_anneal = template[:length]
[?2004l[?2004h>         else:  # rev
[?2004l[?2004h>             primer_anneal = template[-length:]
[?2004l[?2004h>         
[?2004l[?2004h>         tm = get_tm(primer_anneal)
[?2004l[?2004h>         if tm and target_tm_min <= tm <= target_tm_max:
[?2004l[?2004h>             return primer_anneal, tm
[?2004l[?2004h>     
[?2004l[?2004h>     # If no perfect match, return the closest
[?2004l[?2004h>     best_primer = None
[?2004l[?2004h>     best_tm = None
[?2004l[?2004h>     best_diff = float('inf')
[?2004l[?2004h>     
[?2004l[?2004h>     for length in range(min_len, max_len + 1):
[?2004l[?2004h>         if direction == 'fwd':
[?2004l[?2004h>             primer_anneal = template[:length]
[?2004l[?2004h>         else:
[?2004l[?2004h>             primer_anneal = template[-length:]
[?2004l[?2004h>         
[?2004l[?2004h>         tm = get_tm(primer_anneal)
[?2004l[?2004h>         if tm:
[?2004l[?2004h>             diff = min(abs(tm - target_tm_min), abs(tm - target_tm_max))
[?2004l[?2004h>             if diff < best_diff:
[?2004l[?2004h>                 best_diff = diff
[?2004l[?2004h>                 best_primer = primer_anneal
[?2004l[?2004h>                 best_tm = tm
[?2004l[?2004h>     
[?2004l[?2004h>     return best_primer, best_tm
[?2004l[?2004h> 
[?2004l[?2004h> # Read sequences
[?2004l[?2004h> seqs = read_fasta('sequences.fasta')
[?2004l[?2004h> input_seq = seqs['input']
[?2004l[?2004h> egfp = seqs['egfp']
[?2004l[?2004h> flag = seqs['flag']
[?2004l[?2004h> snap = seqs['snap']
[?2004l[?2004h> 
[?2004l[?2004h> # Prepare the insert sequences (without start/stop codons as needed)
[?2004l[?2004h> egfp_insert = egfp[:-3]  # Remove stop codon
[?2004l[?2004h> flag_insert = flag[3:-3]  # Remove start and stop codons
[?2004l[?2004h> snap_insert = snap[3:]  # Remove start codon, keep stop
[?2004l[?2004h> 
[?2004l[?2004h> print("Designing Golden Gate primers...")
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # For Golden Gate assembly with BsaI-HF v2:
[?2004l[?2004h> # Forward primer: 5' - [template binding] - GGTCTC - N - [4bp overhang] - 3'
[?2004l[?2004h> # Reverse primer: 5' - [template binding RC] - GAGACC - N - [4bp overhang RC] - 3'
[?2004l[?2004h> #
[?2004l[?2004h> # When BsaI cuts, it leaves the 4bp overhang
[?2004l[?2004h> 
[?2004l[?2004h> primers = []
[?2004l[?2004h> 
[?2004l[?2004h> # 1. INPUT BACKBONE primers
[?2004l[?2004h> # The backbone needs to be linearized with overhangs that match the inserts
[?2004l[?2004h> # Forward primer: adds overhang complementary to snap end (ttaa -> complement of snap's last 4bp)
[?2004l[?2004h> # Reverse primer: adds overhang complementary to egfp start (acat -> complement of egfp's first 4bp)
[?2004l[?2004h> 
[?2004l[?2004h> print("=" * 80)
[?2004l[?2004h> print("1. INPUT BACKBONE")
[?2004l[?2004h> print("=" * 80)
[?2004l[?2004h> 
[?2004l[?2004h> # Input forward primer: binds after the cut site (position 690)
[?2004l[?2004h> # Should create overhang that matches end of SNAP: 'ttaa'
[?2004l[?2004h> input_fwd_template_start = 690
[?2004l[?2004h> input_fwd_template = input_seq[input_fwd_template_start:input_fwd_template_start+100]
[?2004l[?2004h> 
[?2004l[?2004h> # Input reverse primer: binds before the cut site (position 210)
[?2004l[?2004h> # Should create overhang that matches start of eGFP: 'acat'
[?2004l[?2004h> input_rev_template_end = 210
[?2004l[?2004h> input_rev_template = input_seq[max(0, input_rev_template_end-100):input_rev_template_end]
[?2004l[?2004h> 
[?2004l[?2004h> # Find good annealing regions
[?2004l[?2004h> input_fwd_anneal, input_fwd_tm = find_primer(input_fwd_template, 'fwd')
[?2004l[?2004h> input_rev_anneal, input_rev_tm = find_primer(input_rev_template, 'rev')
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Forward primer annealing: {input_fwd_anneal} (Tm: {input_fwd_tm:.2f}°C)")
[?2004l[?2004h> print(f"Reverse primer annealing: {input_rev_anneal} (Tm: {input_rev_tm:.2f}°C)")
[?2004l[?2004h> print(f"Tm difference: {abs(input_fwd_tm - input_rev_tm):.2f}°C")
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # Construct full primers
[?2004l[?2004h> # Forward: adds BsaI site and overhang 'ttaa' (matches SNAP end)
[?2004l[?2004h> # BsaI forward: GGTCTC(N)(overhang) then template
[?2004l[?2004h> # After cutting: leaves 'ttaa' overhang
[?2004l[?2004h> input_fwd_primer = 'GGTCTCNTTAA' + input_fwd_anneal
[?2004l[?2004h> 
[?2004l[?2004h> # Reverse: adds BsaI site and overhang complementary to 'acat'
[?2004l[?2004h> # The overhang should be RC of 'acat' = 'atgt'
[?2004l[?2004h> # BsaI reverse: template-RC then GAGACC(N)(overhang-RC)
[?2004l[?2004h> # After cutting: leaves 'acat' overhang on the other end
[?2004l[?2004h> input_rev_primer_anneal_rc = reverse_complement(input_rev_anneal)
[?2004l[?2004h> input_rev_primer = input_rev_primer_anneal_rc + 'GAGACCNATGT'
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Input forward primer: {input_fwd_primer}")
[?2004l[?2004h> print(f"Input reverse primer: {input_rev_primer}")
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> primers.append(('>input_fwd', input_fwd_primer))
[?2004l[?2004h> primers.append(('>input_rev', input_rev_primer))
[?2004l[?2004h> 
[?2004l[?2004h> EOFMAIN
