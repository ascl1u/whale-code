[?2004l[?2004h>     print(f"Reverse annealing region: {flag_rev_anneal} (Tm: {flag_rev_tm:.2f}°C)")
[?2004l[?2004h>     print(f"Tm difference: {abs(flag_fwd_tm - flag_rev_tm):.2f}°C")
[?2004l[?2004h>     
[?2004l[?2004h>     flag_fwd_primer = f"GGTCTCN{oh2}{flag_fwd_anneal}"
[?2004l[?2004h>     flag_rev_primer = f"{reverse_complement(flag_rev_anneal)}{reverse_complement(oh3)}NGAGACC"
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Forward primer: {flag_fwd_primer}")
[?2004l[?2004h>     print(f"Reverse primer: {flag_rev_primer}")
[?2004l[?2004h>     primers.append(('>flag_fwd', flag_fwd_primer.upper()))
[?2004l[?2004h>     primers.append(('>flag_rev', flag_rev_primer.upper()))
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # 4. SNAP INSERT
[?2004l[?2004h> print("4. SNAP INSERT (without start codon)")
[?2004l[?2004h> print("-" * 80)
[?2004l[?2004h> 
