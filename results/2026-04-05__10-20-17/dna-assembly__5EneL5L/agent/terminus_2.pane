[?2004l[?2004h>                   'a': 't', 't': 'a', 'g': 'c', 'c': 'g', 'N': 'N', 'n': 'n'}
[?2004l[?2004h>     return ''.join(complement.get(base, base) for base in reversed(seq))
[?2004l[?2004h> 
[?2004l[?2004h> def get_tm(seq):
[?2004l[?2004h>     """Get melting temperature using oligotm"""
[?2004l[?2004h>     try:
[?2004l[?2004h>         result = subprocess.run(
[?2004l[?2004h>             ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()],
[?2004l[?2004h>             capture_output=True, text=True, check=True
[?2004l[?2004h>         )
[?2004l[?2004h>         return float(result.stdout.strip())
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h> def find_primer_pair(template_fwd, template_rev, target_tm_min=58, target_tm_max=72, 
[?2004l[?2004h>                      min_len=15, max_len=45, max_tm_diff=5):
[?2004l[?2004h>     """Find a pair of primers with compatible Tm"""
[?2004l[?2004h>     best_pair = None
[?2004l[?2004h>     best_tm_diff = float('inf')
[?2004l[?2004h>     
[?2004l[?2004h>     for len_fwd in range(min_len, max_len + 1):
[?2004l[?2004h>         primer_fwd = template_fwd[:len_fwd]
[?2004l[?2004h>         tm_fwd = get_tm(primer_fwd)
[?2004l[?2004h>         
[?2004l[?2004h>         if not tm_fwd or tm_fwd < target_tm_min or tm_fwd > target_tm_max:
[?2004l[?2004h>             continue
[?2004l[?2004h>             
[?2004l[?2004h>         for len_rev in range(min_len, max_len + 1):
[?2004l[?2004h>             primer_rev = template_rev[-len_rev:]
[?2004l[?2004h>             tm_rev = get_tm(primer_rev)
[?2004l[?2004h>             
[?2004l[?2004h>             if not tm_rev or tm_rev < target_tm_min or tm_rev > target_tm_max:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             
[?2004l[?2004h>             tm_diff = abs(tm_fwd - tm_rev)
[?2004l[?2004h>             if tm_diff <= max_tm_diff and tm_diff < best_tm_diff:
[?2004l[?2004h>                 best_tm_diff = tm_diff
[?2004l[?2004h>                 best_pair = (primer_fwd, tm_fwd, primer_rev, tm_rev)
[?2004l[?2004h>     
[?2004l[?2004h>     return best_pair
