[?2004l[?2004h> snap_template = seqs['snap'][3:]  # Remove ATG
[?2004l[?2004h> 
[?2004l[?2004h> print("Designing primers for Golden Gate assembly...\n")
[?2004l[?2004h> 
[?2004l[?2004h> # BsaI recognition site: GGTCTC (forward) or GAGACC (reverse)
[?2004l[?2004h> # BsaI cuts to create 4bp overhangs
[?2004l[?2004h> # For forward primer: 5'-GGTCTC N {overhang} {template}-3'
[?2004l[?2004h> # For reverse primer: 5'-GAGACC N {overhang} {template_rc}-3'
[?2004l[?2004h> 
[?2004l[?2004h> primers = []
[?2004l[?2004h> 
[?2004l[?2004h> # === EGFP PRIMERS ===
[?2004l[?2004h> print("Designing EGFP primers...")
[?2004l[?2004h> # Forward: need overhang ATGA
