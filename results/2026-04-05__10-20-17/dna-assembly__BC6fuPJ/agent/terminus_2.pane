[?2004l[?2004h> import subprocess
[?2004l[?2004h> 
[?2004l[?2004h> def calc_tm(seq):
[?2004l[?2004h>     result = subprocess.run(
[?2004l[?2004h>         ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],
[?2004l[?2004h>         capture_output=True, text=True, check=True
[?2004l[?2004h>     )
[?2004l[?2004h>     return float(result.stdout.strip())
[?2004l[?2004h> 
[?2004l[?2004h> # Read primers
[?2004l[?2004h> primers = {}
[?2004l[?2004h> with open('primers.fasta', 'r') as f:
[?2004l[?2004h>     current_name = None
[?2004l[?2004h>     for line in f:
[?2004l[?2004h>         line = line.strip()
[?2004l[?2004h>         if line.startswith('>'):
[?2004l[?2004h>             current_name = line[1:]
[?2004l[?2004h>             primers[current_name] = ''
[?2004l[?2004h>         else:
[?2004l[?2004h>             primers[current_name] += line.upper()
[?2004l[?2004h> 
[?2004l[?2004h> print("=== FINAL REQUIREMENTS CHECK ===")
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # Check file format
[?2004l[?2004h> with open('primers.fasta', 'r') as f:
[?2004l[?2004h>     lines = f.readlines()
[?2004l[?2004h>     has_blank = any(line.strip() == '' for line in lines)
[?2004l[?2004h>     print(f"✓ No blank lines: {not has_blank}")
[?2004l[?2004h> 
[?2004l[?2004h> # Check headers
[?2004l[?2004h> all_headers_valid = True
[?2004l[?2004h> for name in primers.keys():
[?2004l[?2004h>     parts = name.split('_')
[?2004l[?2004h>     if len(parts) != 2 or parts[1] not in ['fwd', 'rev']:
[?2004l[?2004h>         all_headers_valid = False
[?2004l[?2004h>         break
[?2004l[?2004h> print(f"✓ All headers in format TEMPLATENAME_DIR: {all_headers_valid}")
[?2004l[?2004h> 
[?2004l[?2004h> # Check primer pairs
[?2004l[?2004h> print(f"✓ Number of primer pairs: {len(primers)//2}")
[?2004l[?2004h> print(f"✓ Minimum number used: {len(primers)//2 == 4}")
[?2004l[?2004h> 
[?2004l[?2004h> # Check each primer pair
[?2004l[?2004h> print()
[?2004l[?2004h> print("Primer pair requirements:")
[?2004l[?2004h> all_pass = True
[?2004l[?2004h> for template in ['input', 'egfp', 'flag', 'snap']:
[?2004l[?2004h>     fwd = primers[f'{template}_fwd']
[?2004l[?2004h>     rev = primers[f'{template}_rev']
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract annealing regions
[?2004l[?2004h>     fwd_anneal = fwd[11:]  # After GGTCTCN + 4bp overhang
[?2004l[?2004h>     rev_anneal = rev[11:]  # After GAGACCN + 4bp overhang
[?2004l[?2004h>     
[?2004l[?2004h>     fwd_tm = calc_tm(fwd_anneal)
[?2004l[?2004h>     rev_tm = calc_tm(rev_anneal)
[?2004l[?2004h>     
[?2004l[?2004h>     # Check requirements
[?2004l[?2004h>     len_ok = 15 <= len(fwd_anneal) <= 45 and 15 <= len(rev_anneal) <= 45
[?2004l[?2004h>     tm_ok = 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72
[?2004l[?2004h>     tm_diff_ok = abs(fwd_tm - rev_tm) <= 5
[?2004l[?2004h>     
[?2004l[?2004h>     status = '✓' if (len_ok and tm_ok and tm_diff_ok) else '✗'
[?2004l[?2004h>     print(f"  {status} {template}: len={len(fwd_anneal)},{len(rev_anneal)} Tm={fwd_tm:.1f},{rev_tm:.1f} diff={abs(fwd_tm-rev_tm):.1f}")
[?2004l[?2004h>     
[?2004l[?2004h>     if not (len_ok and tm_ok and tm_diff_ok):
[?2004l[?2004h>         all_pass = False
[?2004l[?2004h> 
[?2004l[?2004h> print()
[?2004l[?2004h> print(f"✓ All primer pairs meet requirements: {all_pass}")
[?2004l[?2004h> print()
