[?2004l[?2004h> egfp_fwd_tail = "GGTCTCNATGA"
[?2004l[?2004h> egfp_template_start = egfp_template
[?2004l[?2004h> for length in range(15, 46):
[?2004l[?2004h>     anneal = egfp_template_start[:length]
[?2004l[?2004h>     tm = calc_tm(anneal)
[?2004l[?2004h>     if tm and 58 <= tm <= 72:
[?2004l[?2004h>         egfp_fwd = egfp_fwd_tail + anneal
[?2004l[?2004h>         egfp_fwd_tm = tm
[?2004l[?2004h>         egfp_fwd_anneal = anneal
[?2004l[?2004h>         print(f"  Forward annealing region: {length}bp, Tm: {tm:.2f}°C")
[?2004l[?2004h>         break
[?2004l[?2004h> 
[?2004l[?2004h> # Reverse: need overhang GGTA (on the template strand after EGFP)
[?2004l[?2004h> # The reverse primer anneals to the complement, so we need TACC on the product
[?2004l[?2004h> # GAGACC N TACC {template_rc}
[?2004l[?2004h> egfp_rev_tail = "GAGACCNTACC"
[?2004l[?2004h> egfp_template_end_rc = reverse_complement(egfp_template[-45:])
[?2004l[?2004h> for length in range(15, 46):
[?2004l[?2004h>     anneal = egfp_template_end_rc[:length]
[?2004l[?2004h>     tm = calc_tm(anneal)
[?2004l[?2004h>     if tm and 58 <= tm <= 72 and abs(tm - egfp_fwd_tm) <= 5:
[?2004l[?2004h>         egfp_rev = egfp_rev_tail + anneal
[?2004l[?2004h>         egfp_rev_tm = tm
[?2004l[?2004h>         egfp_rev_anneal = anneal
[?2004l[?2004h>         print(f"  Reverse annealing region: {length}bp, Tm: {tm:.2f}°C")
[?2004l[?2004h>         print(f"  Tm difference: {abs(tm - egfp_fwd_tm):.2f}°C")
[?2004l[?2004h>         break
[?2004l[?2004h> 
[?2004l[?2004h> primers.append(('egfp_fwd', egfp_fwd, egfp_fwd_anneal, egfp_fwd_tm))
[?2004l[?2004h> primers.append(('egfp_rev', egfp_rev, egfp_rev_anneal, egfp_rev_tm))
