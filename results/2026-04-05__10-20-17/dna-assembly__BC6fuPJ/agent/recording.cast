[125.552317, "i", "cat > check_sequences3.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\negfp_start = 210\negfp_no_stop = seqs['egfp'][:-3]  # Remove TAA\negfp_end = egfp_start + len(egfp_no_stop)\n\nprint(f\"EGFP (no stop) ends at: {egfp_end}\")\nprint(f\"After EGFP: {seqs['output'][egfp_end:egfp_end+30]}\")\nprint(f\"FLAG: {seqs['flag']}\")\nprint(f\"FLAG without ATG: {seqs['flag'][3:]}\")\n\n# Check if FLAG without start codon follows\nflag_no_start = seqs['flag'][3:]  # Remove ATG\nif seqs['output'][egfp_end:egfp_end+len(flag_no_start)] == flag_no_start:\n    print(\"\\n*** FLAG (no ATG) follows EGFP! ***\")\n    flag_end = egfp_end + len(flag_no_start)\n    print(f\"FLAG ends at: {flag_end}\")\n    \n    # Check if FLAG has stop codon\n    print(f\"\\nFLAG ends with: {seqs['flag'][-10:]}\")\n    print(f\"Is it a stop codon? {seqs['flag'][-3:] in ['TAA', 'TAG', 'TGA']}\")\n    \n    # Check for SNAP\n    if seqs['flag'][-3:] in ['TAA', 'TAG', 'TGA']:\n        flag_no_stop = seqs['flag'][3:-3]  # Remove ATG and stop\n        flag_end = egfp_end + len(flag_no_stop)\n        print(f\"FLAG (no ATG, no stop) ends at: {flag_end}\")\n        print(f\"\\nAfter FLAG: {seqs['output'][flag_end:flag_end+30]}\")\n        print(f\"SNAP: {seqs['snap'][:30]}\")\n        print(f\"SNAP without ATG: {seqs['snap'][3:33]}\")\n        \n        snap_no_start = seqs['snap'][3:]\n        if seqs['output'][flag_end:flag_end+len(snap_no_start)] == snap_no_start:\n            print(\"\\n*** SNAP (no ATG) follows FLAG! ***\")\n            snap_end = flag_end + len(snap_no_start)\n            print(f\"SNAP ends at: {snap_end}\")\n            print(f\"\\nAfter SNAP: {seqs['output'][snap_end:snap_end+20]}\")\n            print(f\"SNAP ends with: {seqs['snap'][-10:]}\")\n\nEOF\npython3 check_sequences3.py\n"]
