[190.872197, "o", "# The cut is at 210, and we want overhang ATGA after the cut for EGFP\r\n\u001b[?2004l\r"]
[190.872461, "o", "\u001b[?2004h> "]
[190.872853, "o", "# So the reverse primer needs to create overhang ACAT before the cut\r\n\u001b[?2004l\r"]
[190.873055, "o", "\u001b[?2004h> "]
[190.873244, "o", "# Reverse complement of ACAT is ATGT\r\n\u001b[?2004l\r"]
[190.873479, "o", "\u001b[?2004h> "]
[190.873593, "o", "input_rev_tail = \"GAGACCNATGT\"\r\n\u001b[?2004l\r"]
[190.873672, "o", "\u001b[?2004h> "]
[190.924982, "o", "input_template_rev_rc = reverse_complement(seqs['input'][210-45:210])\r\n\u001b[?2004l\r\u001b[?2004h> for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h>     anneal = input_template_rev_rc[:length]\r\n\u001b[?2004l\r\u001b[?2004h>     tm = calc_tm(anneal)\r\n\u001b[?2004l\r\u001b[?2004h>     if tm and 58 <= tm <= 72 and abs(tm - input_fwd_tm) <= 5:\r\n\u001b[?2004l\r\u001b[?2004h>         input_rev = input_rev_tail + anneal\r\n\u001b[?2004l\r\u001b[?2004h>         input_rev_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h>         input_rev_anneal = anneal\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  Reverse annealing region: {length}bp, Tm: {tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  Tm difference: {abs(tm - input_fwd_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h>         break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> primers.append(('input_fwd', input_fwd, input_fwd_anneal, input_fwd_tm))\r\n\u001b[?2004l\r\u001b[?2004h> primers.append(('input_rev', input_rev, input_rev_anneal, input_rev_tm))\r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\nInput plasmid primers designed.\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Write to fasta file\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Writing primers to primers.fasta...\")\r\n\u001b[?2004l\r"]
[190.925185, "o", "\u001b[?2004h> "]
