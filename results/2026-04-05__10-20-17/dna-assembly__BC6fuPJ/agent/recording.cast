[59.428355, "o", "python3 design_primers.py; printf '%s\\n' '__CMDEND__6__'\r\n\u001b[?2004l\r"]
[59.457687, "o", "Input length: 2727\r\nOutput length: 3591\r\nEGFP length: 717\r\nFLAG length: 90\r\nSNAP length: 549\r\n\r\nEGFP starts at position 210 in output\r\nSNAP ends at position 1554 in output\r\n\r\nBefore EGFP in output: ...TTTAAGAAGGAGATATACAT\r\nStart of EGFP: ATGAGCAAGGGCGAGGAGCT...\r\n\r\nEnd of SNAP: ...GTAAGCCTGGGCTGGGTTAA\r\nAfter SNAP in output: TGAGGATCCCGGGAATTCTC...\r\n"]
[59.463453, "o", "__CMDEND__6__\r\n"]
[59.463717, "o", "\u001b[?2004hroot@b088ecd58d39:/app# "]
[73.475001, "i", "cat > analyze_assembly.py << 'EOF'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\n# Find junctions in output\negfp_start = seqs['output'].find(seqs['egfp'][:50])\nflag_start = seqs['output'].find(seqs['flag'][:30])\nsnap_start = seqs['output'].find(seqs['snap'][:50])\n\nprint(f\"EGFP starts at: {egfp_start}\")\nprint(f\"FLAG starts at: {flag_start}\")\nprint(f\"SNAP starts at: {snap_start}\")\n\n# Get junction sequences (4bp overhangs)\nprint(f\"\\nJunction before EGFP: {seqs['output'][egfp_start-4:egfp_start]} | {seqs['output'][egfp_start:egfp_start+4]}\")\nprint(f\"Junction after EGFP: {seqs['output'][egfp_start+len(seqs['egfp'])-4:egfp_start+len(seqs['egfp'])]} | {seqs['output'][egfp_start+len(seqs['egfp']):egfp_start+len(seqs['egfp'])+4]}\")\nprint(f\"Junction after FLAG: {seqs['output'][flag_start+len(seqs['flag'])-4:flag_start+len(seqs['flag'])]} | {seqs['output'][flag_start+len(seqs['flag']):flag_start+len(seqs['flag'])+4]}\")\nprint(f\"Junction after SNAP: {seqs['output'][snap_start+len(seqs['snap'])-4:snap_start+len(seqs['snap'])]} | {seqs['output'][snap_start+len(seqs['snap']):snap_start+len(seqs['snap'])+4]}\")\n\n# Find what was replaced in input\ninput_before_insert = seqs['output'][:egfp_start]\nsnap_end = snap_start + len(seqs['snap'])\ninput_after_insert = seqs['output'][snap_end:]\n\nprint(f\"\\nInput plasmid part before insert: {len(input_before_insert)} bp\")\nprint(f\"Input plasmid part after insert: {len(input_after_insert)} bp\")\n\n# Find where these match in input\nif input_before_insert in seqs['input']:\n    cut_start = len(input_before_insert)\n    print(f\"Cut starts at position {cut_start} in input\")\n    \nif input_after_insert in seqs['input']:\n    cut_end = seqs['input'].find(input_after_insert)\n    print(f\"Cut ends at position {cut_end} in input\")\n    print(f\"Removed sequence length: {cut_end - cut_start}\")\n    print(f\"Removed sequence: {seqs['input'][cut_start:cut_end][:50]}...\")\n\nEOF\npython3 analyze_assembly.py\n"]
