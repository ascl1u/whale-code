[337.000687, "o", "    for line in f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.000943, "o", "        line = line.strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.00118, "o", "        if line.startswith('>'):\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.001371, "o", "> "]
[337.001632, "o", "            current_name = line[1:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.001853, "o", "            primers[current_name] = ''\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.002007, "o", "> "]
[337.002208, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.002482, "o", "            primers[current_name] += line.upper()\r\n\u001b[?2004l\r"]
[337.002701, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[337.002963, "o", "> "]
[337.003239, "o", "print(\"=== FINAL REQUIREMENTS CHECK ===\")\r\n\u001b[?2004l\r\u001b[?2004h> print()\r\n\u001b[?2004l\r"]
[337.003446, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Check file format\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.00372, "o", "> "]
[337.00398, "o", "with open('primers.fasta', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.004205, "o", "    lines = f.readlines()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.004503, "o", "    has_blank = any(line.strip() == '' for line in lines)\r\n\u001b[?2004l\r"]
[337.004613, "o", "\u001b[?2004h> "]
[337.004922, "o", "    print(f\"✓ No blank lines: {not has_blank}\")\r\n\u001b[?2004l\r"]
[337.005211, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Check headers\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.005468, "o", "> "]
[337.00573, "o", "all_headers_valid = True\r\n\u001b[?2004l\r\u001b[?2004h> for name in primers.keys():\r\n\u001b[?2004l\r"]
[337.006013, "o", "\u001b[?2004h> "]
[337.006253, "o", "    parts = name.split('_')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.006542, "o", "    if len(parts) != 2 or parts[1] not in ['fwd', 'rev']:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.006816, "o", "        all_headers_valid = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.006938, "o", ">         break\r\n"]
[337.007043, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[337.007599, "o", "print(f\"✓ All headers in format TEMPLATENAME_DIR: {all_headers_valid}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[337.007834, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[337.007973, "o", "# Check primer pairs\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.008526, "o", "print(f\"✓ Number of primer pairs: {len(primers)//2}\")\r\n\u001b[?2004l\r"]
[337.008733, "o", "\u001b[?2004h> "]
[337.008956, "o", "print(f\"✓ Minimum number used: {len(primers)//2 == 4}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.009189, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.009415, "o", "# Check each primer pair\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.00961, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.009791, "o", "print(\"Primer pair requirements:\")\r\n\u001b[?2004l\r"]
[337.010023, "o", "\u001b[?2004h> all_pass = True\r\n\u001b[?2004l\r"]
[337.010215, "o", "\u001b[?2004h> "]
[337.010427, "o", "for template in ['input', 'egfp', 'flag', 'snap']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.010641, "o", "> "]
[337.010896, "o", "    fwd = primers[f'{template}_fwd']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.011103, "o", "    rev = primers[f'{template}_rev']\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[337.011302, "o", "\u001b[?2004h> "]
[337.011481, "o", "    # Extract annealing regions\r\n\u001b[?2004l\r"]
[337.011671, "o", "\u001b[?2004h> "]
[337.011919, "o", "    fwd_anneal = fwd[11:]  # After GGTCTCN + 4bp overhang\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.012035, "o", "> "]
[337.012445, "o", "    rev_anneal = rev[11:]  # After GAGACCN + 4bp overhang\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.012637, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.012874, "o", "    fwd_tm = calc_tm(fwd_anneal)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.013048, "o", "    rev_tm = calc_tm(rev_anneal)\r\n\u001b[?2004l\r"]
[337.01325, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[337.01345, "o", ">     # Check requirements\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.013864, "o", "    len_ok = 15 <= len(fwd_anneal) <= 45 and 15 <= len(rev_anneal) <= 45\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.014094, "o", "> "]
[337.014417, "o", "    tm_ok = 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72\r\n\u001b[?2004l\r"]
[337.014638, "o", "\u001b[?2004h> "]
[337.01488, "o", "    tm_diff_ok = abs(fwd_tm - rev_tm) <= 5\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.015227, "o", "    status = '✓' if (len_ok and tm_ok and tm_diff_ok) else '✗'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.015946, "o", "    print(f\"  {status} {template}: len={len(fwd_anneal)},{len(rev_anneal)} Tm={fwd_tm:.1f},{rev_tm:.1f} diff={abs(fwd_tm-rev_tm):.1f}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.01616, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.016391, "o", "    if not (len_ok and tm_ok and tm_diff_ok):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.016703, "o", "        all_pass = False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[337.016814, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[337.017068, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.017285, "o", "print(f\"✓ All primer pairs meet requirements: {all_pass}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.017474, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.017851, "o", "print(\"✓ BsaI-HF v2 recognition sites present: GGTCTC (fwd) and GAGACC (rev)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.018051, "o", "> "]
[337.01824, "o", "print(\"✓ Primers designed for one-pot Golden Gate assembly\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.018428, "o", "> "]
[337.018628, "o", "print(\"✓ Output file: primers.fasta\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.018821, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[337.019011, "o", "print(\"=== ALL REQUIREMENTS MET ===\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[337.019207, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[337.021441, "o", "\u001b[?2004hroot@b088ecd58d39:/app# "]
[337.021638, "o", "python3 final_check.py\r\n\u001b[?2004l\r"]
[337.048335, "o", "=== FINAL REQUIREMENTS CHECK ===\r\n\r\n✓ No blank lines: True\r\n"]
[337.048496, "o", "✓ All headers in format TEMPLATENAME_DIR: True\r\n✓ Number of primer pairs: 4\r\n✓ Minimum number used: True\r\n\r\nPrimer pair requirements:\r\n"]
[337.052115, "o", "  ✓ input: len=18,28 Tm=58.8,58.1 diff=0.7\r\n"]
[337.055161, "o", "  ✓ egfp: len=16,19 Tm=60.4,59.1 diff=1.3\r\n"]
