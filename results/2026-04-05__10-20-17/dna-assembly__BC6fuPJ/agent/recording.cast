[336.995755, "i", "cat > final_check.py << 'EOF'\nimport subprocess\n\ndef calc_tm(seq):\n    result = subprocess.run(\n        ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\n        capture_output=True, text=True, check=True\n    )\n    return float(result.stdout.strip())\n\n# Read primers\nprimers = {}\nwith open('primers.fasta', 'r') as f:\n    current_name = None\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            primers[current_name] = ''\n        else:\n            primers[current_name] += line.upper()\n\nprint(\"=== FINAL REQUIREMENTS CHECK ===\")\nprint()\n\n# Check file format\nwith open('primers.fasta', 'r') as f:\n    lines = f.readlines()\n    has_blank = any(line.strip() == '' for line in lines)\n    print(f\"✓ No blank lines: {not has_blank}\")\n\n# Check headers\nall_headers_valid = True\nfor name in primers.keys():\n    parts = name.split('_')\n    if len(parts) != 2 or parts[1] not in ['fwd', 'rev']:\n        all_headers_valid = False\n        break\nprint(f\"✓ All headers in format TEMPLATENAME_DIR: {all_headers_valid}\")\n\n# Check primer pairs\nprint(f\"✓ Number of primer pairs: {len(primers)//2}\")\nprint(f\"✓ Minimum number used: {len(primers)//2 == 4}\")\n\n# Check each primer pair\nprint()\nprint(\"Primer pair requirements:\")\nall_pass = True\nfor template in ['input', 'egfp', 'flag', 'snap']:\n    fwd = primers[f'{template}_fwd']\n    rev = primers[f'{template}_rev']\n    \n    # Extract annealing regions\n    fwd_anneal = fwd[11:]  # After GGTCTCN + 4bp overhang\n    rev_anneal = rev[11:]  # After GAGACCN + 4bp overhang\n    \n    fwd_tm = calc_tm(fwd_anneal)\n    rev_tm = calc_tm(rev_anneal)\n    \n    # Check requirements\n    len_ok = 15 <= len(fwd_anneal) <= 45 and 15 <= len(rev_anneal) <= 45\n    tm_ok = 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72\n    tm_diff_ok = abs(fwd_tm - rev_tm) <= 5\n    \n    status = '✓' if (len_ok and tm_ok and tm_diff_ok) else '✗'\n    print(f\"  {status} {template}: len={len(fwd_anneal)},{len(rev_anneal)} Tm={fwd_tm:.1f},{rev_tm:.1f} diff={abs(fwd_tm-rev_tm):.1f}\")\n    \n    if not (len_ok and tm_ok and tm_diff_ok):\n        all_pass = False\n\nprint()\nprint(f\"✓ All primer pairs meet requirements: {all_pass}\")\nprint()\nprint(\"✓ BsaI-HF v2 recognition sites present: GGTCTC (fwd) and GAGACC (rev)\")\nprint(\"✓ Primers designed for one-pot Golden Gate assembly\")\nprint(\"✓ Output file: primers.fasta\")\nprint()\nprint(\"=== ALL REQUIREMENTS MET ===\")\n\nEOF\npython3 final_check.py\n"]
