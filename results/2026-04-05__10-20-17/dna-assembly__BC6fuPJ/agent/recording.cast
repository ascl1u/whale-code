[87.751436, "i", "cat > analyze_assembly2.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\n# Check if egfp, flag, snap are consecutive in output\negfp_in_output = seqs['output'].find(seqs['egfp'])\nif egfp_in_output != -1:\n    egfp_end = egfp_in_output + len(seqs['egfp'])\n    print(f\"EGFP found at {egfp_in_output}, ends at {egfp_end}\")\n    print(f\"After EGFP: {seqs['output'][egfp_end:egfp_end+30]}\")\n    print(f\"FLAG sequence: {seqs['flag'][:30]}\")\n    \n    # Check if FLAG follows\n    if seqs['output'][egfp_end:egfp_end+len(seqs['flag'])] == seqs['flag']:\n        print(\"\\nFLAG immediately follows EGFP\")\n        flag_end = egfp_end + len(seqs['flag'])\n        print(f\"FLAG ends at {flag_end}\")\n        print(f\"After FLAG: {seqs['output'][flag_end:flag_end+30]}\")\n        print(f\"SNAP sequence: {seqs['snap'][:30]}\")\n        \n        # Check if SNAP follows\n        if seqs['output'][flag_end:flag_end+len(seqs['snap'])] == seqs['snap']:\n            print(\"\\nSNAP immediately follows FLAG\")\n            snap_end = flag_end + len(seqs['snap'])\n            print(f\"SNAP ends at {snap_end}\")\n            \n            # Now determine the 4bp overhangs for Golden Gate\n            print(\"\\n=== Golden Gate Assembly Junctions ===\")\n            print(f\"Input -> EGFP: {seqs['output'][egfp_in_output-4:egfp_in_output]} | {seqs['output'][egfp_in_output:egfp_in_output+4]}\")\n            print(f\"EGFP -> FLAG: {seqs['output'][egfp_end-4:egfp_end]} | {seqs['output'][egfp_end:egfp_end+4]}\")\n            print(f\"FLAG -> SNAP: {seqs['output'][flag_end-4:flag_end]} | {seqs['output'][flag_end:flag_end+4]}\")\n            print(f\"SNAP -> Input: {seqs['output'][snap_end-4:snap_end]} | {seqs['output'][snap_end:snap_end+4]}\")\n            \n            # Store overhangs\n            oh1 = seqs['output'][egfp_in_output:egfp_in_output+4]  # Input->EGFP\n            oh2 = seqs['output'][egfp_end:egfp_end+4]  # EGFP->FLAG\n            oh3 = seqs['output'][flag_end:flag_end+4]  # FLAG->SNAP\n            oh4 = seqs['output'][snap_end:snap_end+4]  # SNAP->Input\n            \n            print(f\"\\nOverhangs: {oh1}, {oh2}, {oh3}, {oh4}\")\n\nEOF\npython3 analyze_assembly2.py\n"]
