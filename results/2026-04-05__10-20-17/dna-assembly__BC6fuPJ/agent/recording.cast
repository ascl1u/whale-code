[98.693194, "i", "cat > check_sequences.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\n# Look for egfp in output\negfp_start = seqs['output'].find(seqs['egfp'][:100])\nprint(f\"First 100bp of EGFP found at: {egfp_start}\")\n\nif egfp_start != -1:\n    # Check if full egfp matches\n    output_egfp = seqs['output'][egfp_start:egfp_start+len(seqs['egfp'])]\n    if output_egfp == seqs['egfp']:\n        print(\"Full EGFP matches!\")\n        egfp_end = egfp_start + len(seqs['egfp'])\n        \n        # Check what comes after\n        after_egfp = seqs['output'][egfp_end:egfp_end+100]\n        print(f\"\\nAfter EGFP (100bp): {after_egfp}\")\n        print(f\"\\nFLAG start (100bp): {seqs['flag'][:100]}\")\n        \n        # Check if they match\n        if after_egfp.startswith(seqs['flag']):\n            print(\"\\n*** FLAG immediately follows EGFP! ***\")\n        else:\n            print(\"\\nFLAG does not immediately follow EGFP\")\n            # Check character by character\n            for i in range(min(len(after_egfp), len(seqs['flag']))):\n                if after_egfp[i] != seqs['flag'][i]:\n                    print(f\"First mismatch at position {i}: output={after_egfp[i]}, flag={seqs['flag'][i]}\")\n                    print(f\"Context: ...{after_egfp[max(0,i-10):i+10]}...\")\n                    break\n    else:\n        print(\"Full EGFP does not match\")\n        for i in range(len(seqs['egfp'])):\n            if output_egfp[i] != seqs['egfp'][i]:\n                print(f\"First mismatch at position {i}\")\n                break\n\nEOF\npython3 check_sequences.py\n"]
