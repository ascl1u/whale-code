[73.487487, "o", "    print(f\"Cut ends at position {cut_end} in input\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[73.48779, "o", "    print(f\"Removed sequence length: {cut_end - cut_start}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[73.487943, "o", "> "]
