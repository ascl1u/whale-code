[55.782821, "i", "cat > design_primers.py << 'EOF'\nimport subprocess\nimport re\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\nprint(f\"Input length: {len(seqs['input'])}\")\nprint(f\"Output length: {len(seqs['output'])}\")\nprint(f\"EGFP length: {len(seqs['egfp'])}\")\nprint(f\"FLAG length: {len(seqs['flag'])}\")\nprint(f\"SNAP length: {len(seqs['snap'])}\")\n\n# Find where egfp starts in output\negfp_start_in_output = seqs['output'].find(seqs['egfp'][:50])\nprint(f\"\\nEGFP starts at position {egfp_start_in_output} in output\")\n\n# Find where snap ends in output\nsnap_end_seq = seqs['snap'][-50:]\nsnap_end_in_output = seqs['output'].find(snap_end_seq) + len(snap_end_seq)\nprint(f\"SNAP ends at position {snap_end_in_output} in output\")\n\n# Check what comes before egfp in output\nprint(f\"\\nBefore EGFP in output: ...{seqs['output'][egfp_start_in_output-20:egfp_start_in_output]}\")\nprint(f\"Start of EGFP: {seqs['egfp'][:20]}...\")\n\n# Check what comes after snap in output  \nprint(f\"\\nEnd of SNAP: ...{seqs['snap'][-20:]}\")\nprint(f\"After SNAP in output: {seqs['output'][snap_end_in_output:snap_end_in_output+20]}...\")\n\nEOF\n"]
