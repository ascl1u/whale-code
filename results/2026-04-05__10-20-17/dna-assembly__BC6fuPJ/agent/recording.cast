[139.233232, "i", "cat > check_sequences4.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\negfp_start = 210\negfp_no_stop = seqs['egfp'][:-3]  # Remove TAA\negfp_end = egfp_start + len(egfp_no_stop)\n\nflag_no_start_stop = seqs['flag'][3:-3]  # Remove ATG and TAA\nflag_end = egfp_end + len(flag_no_start_stop)\n\nprint(f\"EGFP (no stop) ends at: {egfp_end}\")\nprint(f\"FLAG (no ATG, no stop) ends at: {flag_end}\")\nprint(f\"\\nAfter FLAG: {seqs['output'][flag_end:flag_end+30]}\")\nprint(f\"SNAP without ATG: {seqs['snap'][3:33]}\")\n\nsnap_no_start = seqs['snap'][3:]\nif seqs['output'][flag_end:flag_end+len(snap_no_start)] == snap_no_start:\n    print(\"\\n*** SNAP (no ATG) follows FLAG! ***\")\n    snap_end = flag_end + len(snap_no_start)\n    print(f\"SNAP ends at: {snap_end}\")\n    print(f\"\\nAfter SNAP: {seqs['output'][snap_end:snap_end+20]}\")\n    \n    # Now print the junctions for Golden Gate\n    print(\"\\n=== ASSEMBLY STRUCTURE ===\")\n    print(f\"Input backbone: 0 to {egfp_start}\")\n    print(f\"EGFP (no stop): {egfp_start} to {egfp_end}\")\n    print(f\"FLAG (no ATG, no stop): {egfp_end} to {flag_end}\")\n    print(f\"SNAP (no ATG): {flag_end} to {snap_end}\")\n    print(f\"Input backbone: {snap_end} to end\")\n    \n    print(\"\\n=== 4BP OVERHANGS FOR GOLDEN GATE ===\")\n    oh1 = seqs['output'][egfp_start:egfp_start+4]\n    oh2 = seqs['output'][egfp_end:egfp_end+4]\n    oh3 = seqs['output'][flag_end:flag_end+4]\n    oh4 = seqs['output'][snap_end:snap_end+4]\n    \n    print(f\"Input -> EGFP: {oh1}\")\n    print(f\"EGFP -> FLAG: {oh2}\")\n    print(f\"FLAG -> SNAP: {oh3}\")\n    print(f\"SNAP -> Input: {oh4}\")\n    \n    # Also need the overhang that closes the vector\n    print(f\"\\nVector cut site in input at position {egfp_start}\")\n    print(f\"4bp before cut: {seqs['input'][egfp_start-4:egfp_start]}\")\n    print(f\"4bp after cut: {seqs['input'][egfp_start:egfp_start+4]}\")\n\nEOF\npython3 check_sequences4.py\n"]
[139.233738, "o", "cat > check_sequences4.py << 'EOF'\r\n\u001b[?2004l\r"]
[139.234028, "o", "\u001b[?2004h> # Read sequences\r\n"]
[139.234292, "o", "\u001b[?2004l\r\u001b[?2004h> seqs = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[139.234598, "o", "current_name = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[139.234731, "o", "with open('sequences.fasta', 'r') as f:\r\n\u001b[?2004l\r"]
[139.234827, "o", "\u001b[?2004h> "]
[139.235481, "o", "    for line in f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
