[112.368192, "i", "cat > check_sequences2.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\negfp_start = 210\noutput_egfp = seqs['output'][egfp_start:egfp_start+len(seqs['egfp'])]\n\nprint(f\"EGFP length: {len(seqs['egfp'])}\")\nprint(f\"Position 714 in EGFP: {seqs['egfp'][710:720]}\")\nprint(f\"Position 714 in output: {output_egfp[710:720]}\")\nprint(f\"\\nLast 20bp of EGFP: {seqs['egfp'][-20:]}\")\nprint(f\"Last 20bp of output_egfp: {output_egfp[-20:]}\")\n\n# Check if EGFP without stop codon matches\negfp_no_stop = seqs['egfp'][:-3] if seqs['egfp'].endswith('TAA') or seqs['egfp'].endswith('TAG') or seqs['egfp'].endswith('TGA') else seqs['egfp']\nprint(f\"\\nEGFP ends with: {seqs['egfp'][-10:]}\")\nprint(f\"Is it a stop codon? {seqs['egfp'][-3:] in ['TAA', 'TAG', 'TGA']}\")\n\nif seqs['egfp'][-3:] in ['TAA', 'TAG', 'TGA']:\n    print(\"\\nTrying without stop codon...\")\n    output_egfp_no_stop = seqs['output'][egfp_start:egfp_start+len(egfp_no_stop)]\n    if output_egfp_no_stop == egfp_no_stop:\n        print(\"EGFP without stop codon matches!\")\n        egfp_end = egfp_start + len(egfp_no_stop)\n        print(f\"EGFP ends at position {egfp_end}\")\n        print(f\"\\nAfter EGFP: {seqs['output'][egfp_end:egfp_end+20]}\")\n        print(f\"FLAG starts: {seqs['flag'][:20]}\")\n\nEOF\npython3 check_sequences2.py\n"]
