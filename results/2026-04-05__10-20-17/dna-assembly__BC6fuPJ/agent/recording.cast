[252.545519, "o", "        if actual_end == expected_end:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.545982, "o", "            print(f\"  ✓ Reverse primer anneals correctly\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[252.546184, "o", ">         else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[252.546389, "o", "> "]
[252.546668, "o", "            print(f\"  Note: Expected to end at position {expected_end}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.546896, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.54715, "o", "        if template.endswith(rev_anneal_rc):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.54747, "o", "            print(f\"  ✓ Reverse primer anneals to end of template\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.547708, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.548078, "o", "            print(f\"  ✗ Reverse primer does not match template end!\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[252.548335, "o", "    print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[252.548588, "o", "\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
