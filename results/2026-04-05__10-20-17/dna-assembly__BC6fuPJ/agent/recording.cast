[203.28589, "o", ">input_fwd\r\nGGTCTCNTGAGTTTGGTATCTGCGCTCTG\r\n>input_rev\r\nGAGACCNATGTATGTATATCTCCTTCTTAAAGTTAAACA\r\n>egfp_fwd\r\nGGTCTCNATGAATGAGCAAGGGCGAGG\r\n>egfp_rev\r\nGAGACCNTACCTTTGTACAGCTCGTCCATG\r\n>flag_fwd\r\nGGTCTCNGGTAGGTAGTGGCTCCGGT\r\n>flag_rev\r\nGAGACCNTGTCTGAACCACTACCTGAACCA\r\n>snap_fwd\r\nGGTCTCNGACAGACAAAGACTGCGAAATGAA\r\n>snap_rev\r\nGAGACCNCTCATTAACCCAGCCCAGGC\r\n"]
[203.286273, "o", "__CMDEND__8__\r\n"]
[203.286582, "o", "\u001b[?2004hroot@b088ecd58d39:/app# "]
[223.596405, "i", "cat > verify_primers.py << 'EOF'\nimport subprocess\n\ndef reverse_complement(seq):\n    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G'}\n    return ''.join(complement[base] for base in reversed(seq))\n\ndef calc_tm(seq):\n    result = subprocess.run(\n        ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\n        capture_output=True, text=True, check=True\n    )\n    return float(result.stdout.strip())\n\n# Read primers\nprimers = {}\nwith open('primers.fasta', 'r') as f:\n    current_name = None\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            primers[current_name] = ''\n        else:\n            primers[current_name] += line.upper()\n\n# Read original sequences\nseqs = {}\nwith open('sequences.fasta', 'r') as f:\n    current_name = None\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\nprint(\"=== PRIMER VERIFICATION ===\")\nprint()\n\n# Check each primer pair\nfor template_name in ['input', 'egfp', 'flag', 'snap']:\n    fwd_name = f\"{template_name}_fwd\"\n    rev_name = f\"{template_name}_rev\"\n    \n    fwd_primer = primers[fwd_name]\n    rev_primer = primers[rev_name]\n    \n    print(f\"\\n{template_name.upper()} primers:\")\n    print(f\"  Forward: {fwd_primer}\")\n    print(f\"  Reverse: {rev_primer}\")\n    \n    # Extract BsaI site and overhang from forward primer\n    if fwd_primer.startswith('GGTCTCN'):\n        fwd_overhang = fwd_primer[7:11]\n        fwd_anneal = fwd_primer[11:]\n        print(f\"  Fwd overhang: {fwd_overhang}\")\n        print(f\"  Fwd annealing: {fwd_anneal} ({len(fwd_anneal)}bp)\")\n        fwd_tm = calc_tm(fwd_anneal)\n        print(f\"  Fwd Tm: {fwd_tm:.2f}°C\")\n    \n    # Extract BsaI site and overhang from reverse primer\n    if rev_primer.startswith('GAGACCN'):\n        rev_overhang = rev_primer[7:11]\n        rev_anneal = rev_primer[11:]\n        print(f\"  Rev overhang: {rev_overhang}\")\n        print(f\"  Rev annealing: {rev_anneal} ({len(rev_anneal)}bp)\")\n        rev_tm = calc_tm(rev_anneal)\n        print(f\"  Rev Tm: {rev_tm:.2f}°C\")\n        print(f\"  Tm difference: {abs(fwd_tm - rev_tm):.2f}°C\")\n        \n        # Check Tm requirements\n        if 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72:\n            print(f\"  ✓ Both Tms in range [58, 72]\")\n        else:\n            print(f\"  ✗ Tm out of range!\")\n            \n        if abs(fwd_tm - rev_tm) <= 5:\n            print(f\"  ✓ Tm difference <= 5°C\")\n        else:\n            print(f\"  ✗ Tm difference > 5°C!\")\n            \n        if 15 <= len(fwd_anneal) <= 45 and 15 <= len(rev_anneal) <= 45:\n            print(f\"  ✓ Annealing lengths in range [15, 45]\")\n        else:\n            print(f\"  ✗ Annealing length out of range!\")\n\nprint(\"\\n=== EXPECTED OVERHANGS FOR ASSEMBLY ===\")\nprint(\"Input -> EGFP: ATGA\")\nprint(\"EGFP -> FLAG: GGTA\")\nprint(\"FLAG -> SNAP: GACA\")\nprint(\"SNAP -> Input: TGAG\")\nprint(\"\\nInput vector closes with: ACAT -> ATGA (ACAT is reverse of ATGT overhang)\")\n\nEOF\npython3 verify_primers.py\n"]
