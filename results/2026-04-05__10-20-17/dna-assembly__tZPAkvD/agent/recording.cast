[365.308005, "o", "Verifying primers...\r\n\r\negfp_fwd:\r\n  Full sequence: GGTCTCNATGAATGAGCAAGGGCGAGG\r\n  Length: 27 bp\r\n  BsaI site: GGTCTCN\r\n  Overhang: ATGA\r\n"]
[365.308243, "o", "  Template binding: ATGAGCAAGGGCGAGG (16 bp)\r\n\r\negfp_rev:\r\n  Full sequence: GAGACCNTACCTTTGTACAGCTCGTCCATG\r\n  Length: 30 bp\r\n  BsaI site: GAGACCN\r\n  Overhang: TACC\r\n  Template binding (RC): TTTGTACAGCTCGTCCATG (19 bp)\r\n\r\nflag_fwd:\r\n  Full sequence: GGTCTCNGGTAGGTAGTGGCTCCGGT\r\n  Length: 26 bp\r\n  BsaI site: GGTCTCN\r\n  Overhang: GGTA\r\n  Template binding: GGTAGTGGCTCCGGT (15 bp)\r\n\r\nflag_rev:\r\n  Full sequence: GAGACCNTGAATGAACCACTACCTGAACCA\r\n  Length: 30 bp\r\n  BsaI site: GAGACCN\r\n  Overhang: TGAA\r\n  Template binding (RC): TGAACCACTACCTGAACCA (19 bp)\r\n\r\nsnap_fwd:\r\n"]
[365.308443, "o", "  Full sequence: GGTCTCNGACAGACAAAGACTGCGAAATGAA\r\n  Length: 31 bp\r\n  BsaI site: GGTCTCN\r\n  Overhang: GACA\r\n  Template binding: GACAAAGACTGCGAAATGAA (20 bp)\r\n\r\nsnap_rev:\r\n  Full sequence: GAGACCNCTCATTAACCCAGCCCAGGC\r\n  Length: 27 bp\r\n"]
