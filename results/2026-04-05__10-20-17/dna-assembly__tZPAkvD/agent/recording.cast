[166.017645, "i", "cat > verify_fusion.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\nprint(\"Checking fusion protein structure...\\n\")\n\n# egfp without stop codon\negfp_no_stop = seqs['egfp'][:-3]  # Remove TAA\nprint(f\"egfp without stop codon: {len(egfp_no_stop)} bp\")\nprint(f\"  Ends with: ...{egfp_no_stop[-30:]}\")\n\n# flag without start codon\nflag_no_start = seqs['flag'][3:]  # Remove ATG\nprint(f\"\\nflag without start codon: {len(flag_no_start)} bp\")\nprint(f\"  Starts with: {flag_no_start[:30]}...\")\nprint(f\"  Ends with: ...{flag_no_start[-30:]}\")\n\n# snap without start codon\nsnap_no_start = seqs['snap'][3:]  # Remove ATG\nprint(f\"\\nsnap without start codon: {len(snap_no_start)} bp\")\nprint(f\"  Starts with: {snap_no_start[:30]}...\")\nprint(f\"  Ends with: ...{snap_no_start[-30:]}\")\n\n# Check in output\negfp_start = 210\negfp_end = egfp_start + len(egfp_no_stop)\nprint(f\"\\n=== Checking in output ===\")\nprint(f\"\\negfp (no stop) should be at output[{egfp_start}:{egfp_end}]\")\nif seqs['output'][egfp_start:egfp_end] == egfp_no_stop:\n    print(\"  ✓ egfp matches!\")\n    \n    flag_start = egfp_end\n    flag_end = flag_start + len(flag_no_start)\n    print(f\"\\nflag (no start) should be at output[{flag_start}:{flag_end}]\")\n    if seqs['output'][flag_start:flag_end] == flag_no_start:\n        print(\"  ✓ flag matches!\")\n        \n        snap_start = flag_end\n        snap_end = snap_start + len(snap_no_start)\n        print(f\"\\nsnap (no start) should be at output[{snap_start}:{snap_end}]\")\n        if seqs['output'][snap_start:snap_end] == snap_no_start:\n            print(\"  ✓ snap matches!\")\n            print(f\"\\nFusion protein ends at position {snap_end}\")\n            print(f\"After fusion: {seqs['output'][snap_end:snap_end+30]}\")\n        else:\n            print(\"  ✗ snap doesn't match\")\n            # Check if snap WITH start codon matches\n            if seqs['output'][snap_start:snap_start+len(seqs['snap'])] == seqs['snap']:\n                print(\"  But snap WITH start codon matches!\")\n                snap_end = snap_start + len(seqs['snap'])\n                print(f\"  snap ends at position {snap_end}\")\n    else:\n        print(\"  ✗ flag doesn't match\")\nelse:\n    print(\"  ✗ egfp doesn't match\")\n\n# Summary\nprint(\"\\n=== SUMMARY ===\")\nprint(f\"Expected structure in output:\")\nprint(f\"  Position {egfp_start}: start of egfp (without stop codon)\")\nprint(f\"  Position {egfp_end}: start of flag (without start codon)\")\nif 'flag_end' in locals():\n    print(f\"  Position {flag_end}: start of snap (check if with or without start codon)\")\n\nEOF\n"]
[166.018278, "o", "cat > verify_fusion.py << 'EOF'\r\n\u001b[?2004l\r"]
[166.018457, "o", "\u001b[?2004h> "]
[166.018661, "o", "# Read sequences\r\n\u001b[?2004l\r\u001b[?2004h> "]
[166.018939, "o", "seqs = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
