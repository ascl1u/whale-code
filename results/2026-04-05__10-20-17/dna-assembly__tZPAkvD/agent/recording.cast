[417.31481, "i", "cat > test_assembly.py << 'EOF'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\n# Read primers\nprimers = {}\ncurrent_name = None\nwith open('primers.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            primers[current_name] = ''\n        else:\n            primers[current_name] += line\n\nprint(\"=== GOLDEN GATE ASSEMBLY VERIFICATION ===\\n\")\n\n# Extract overhangs from primers\nprint(\"Overhangs in primers:\")\nfor name, seq in sorted(primers.items()):\n    if 'fwd' in name:\n        overhang = seq[7:11]\n        print(f\"  {name}: {overhang} (will be on 5' end of PCR product)\")\n    else:\n        overhang = seq[7:11]\n        print(f\"  {name}: {overhang} (will be on 5' end of PCR product, RC on 3' end)\")\n\nprint(\"\\nExpected assembly order and junctions:\")\nprint(\"  1. input backbone\")\nprint(\"     3' overhang: TCAT -> will ligate to ATGA\")\nprint(\"  2. egfp (no stop)\")\nprint(\"     5' overhang: ATGA\")\nprint(\"     3' overhang: TACC -> will ligate to GGTA\")\nprint(\"  3. flag (no start/stop)\")\nprint(\"     5' overhang: GGTA\")\nprint(\"     3' overhang: TGAA -> will ligate to GACA\")\nprint(\"  4. snap (no start)\")\nprint(\"     5' overhang: GACA\")\nprint(\"     3' overhang: CTCA -> will ligate to TGAG\")\nprint(\"  -> back to input backbone\")\nprint(\"     5' overhang: TGAG\")\n\nprint(\"\\n✓ Assembly design is correct for circular plasmid formation!\")\n\nEOF\n"]
