[334.835112, "o", "# ===== INPUT PRIMERS =====\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.835352, "o", "print(\"Designing input primers...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.835536, "o", "input_fwd_start = 690\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.835729, "o", "input_rev_end = 210\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[334.835866, "o", "> # Forward primer\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.836095, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.836495, "o", "    template_binding = seqs['input'][input_fwd_start:input_fwd_start+length]\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.836744, "o", "> "]
[334.836942, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.83715, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.837348, "o", "> "]
[334.837589, "o", "        input_fwd = 'GGTCTCN' + 'TGAG' + template_binding\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.837774, "o", "> "]
[334.837927, "o", "        input_fwd_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.838363, "o", "        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.838587, "o", "        break\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.838809, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> # Reverse primer\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.839011, "o", "> for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.839342, "o", "    template_binding = seqs['input'][input_rev_end-length:input_rev_end]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.839569, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.839799, "o", "> "]
[334.840036, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.840246, "o", "        if abs(tm - input_fwd_tm) <= 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.840525, "o", "            input_rev = 'GAGACCN' + 'TCAT' + reverse_complement(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.840691, "o", "> "]
[334.840863, "o", "            input_rev_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.841293, "o", "            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-input_fwd_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.841503, "o", "> "]
[334.841655, "o", "            primers.append(('>input_fwd', input_fwd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.841923, "o", "            primers.append(('>input_rev', input_rev))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.842071, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.842363, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h"]
[334.842601, "o", "> print(f\"Total primer pairs designed: {len(primers)//2}\")\r\n\u001b[?2004l\r"]
[334.842795, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.843059, "o", "# Write primers to file\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.843349, "o", "with open('primers.fasta', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.843552, "o", "    for header, seq in primers:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.843764, "o", "        f.write(f\"{header}\\n{seq}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[334.844065, "o", "print(\"\\nPrimers written to primers.fasta\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
