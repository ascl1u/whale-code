[303.210619, "o", "            return primer, tm\r\n\u001b[?2004l\r"]
[303.210756, "o", "\u001b[?2004h> "]
[303.211087, "o", "    return None, None\r\n\u001b[?2004l\r"]
[303.211336, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rs\u001b[?2004h> "]
[303.212398, "o", "print(\"Designing primers for Golden Gate assembly...\\n\")\r\n\u001b[?2004l\r"]
[303.212585, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\r\n\u001b[?2004h> "]
[303.213529, "o", "# BsaI-HF v2 site: GGTCTC (cuts 1/5 after the site)\r\n\u001b[?2004l\r"]
[303.213707, "o", "\u001b[?2004h> "]
[303.214932, "o", "# After GGTCTC, we add 1 base, then 4-base overhang, then template binding\r\n\u001b[?2004l\r"]
[303.21513, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rr\u001b[?2004h"]
[303.215366, "o", "> primers = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.215547, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.215923, "o", "# ===== EGFP PRIMERS =====\r\n\u001b[?2004l\rr"]
[303.216095, "o", "\u001b[?2004h> "]
[303.216563, "o", "print(\"Designing egfp primers...\")\r\n\u001b[?2004l\r"]
[303.216752, "o", "\u001b[?2004h> "]
[303.217418, "o", "# egfp needs to be amplified without stop codon\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.217661, "o", "> "]
[303.218661, "o", "egfp_template = seqs['egfp'][:-3]  # Remove TAA stop codon\r\n\u001b[?2004l\r"]
[303.218855, "o", "\u001b[?2004h> \r\n\u001b[?2004l\re\u001b[?2004h> "]
[303.219627, "o", "# Forward primer: adds BsaI site with ATGA overhang (from input)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.219839, "o", "> "]
[303.220118, "o", "# Structure: GGTCTC-N-ATGA-[template]\r\n\u001b[?2004l\r"]
[303.220369, "o", "\u001b[?2004h> "]
[303.220583, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.220781, "o", "> "]
[303.221181, "o", "    template_binding = egfp_template[:length]\r\n\u001b[?2004l\r"]
[303.221367, "o", "\u001b[?2004h> "]
[303.221728, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r"]
[303.221828, "o", "\u001b[?2004h> "]
[303.222139, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\rd\u001b[?2004h"]
[303.222369, "o", "> "]
[303.222998, "o", "        egfp_fwd = 'GGTCTCN' + 'ATGA' + template_binding\r\n\u001b[?2004l\r"]
[303.223166, "o", "\u001b[?2004h> "]
[303.223507, "o", "        egfp_fwd_tm = tm\r\n\u001b[?2004l\r"]
[303.22369, "o", "\u001b[?2004h> "]
[303.224467, "o", "        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\r\n\u001b[?2004l\r"]
[303.224657, "o", "\u001b[?2004h> "]
[303.224892, "o", "        break\r\n\u001b[?2004l\rg\u001b[?2004h> \r\n\u001b[?2004l\r"]
[303.225083, "o", "\u001b[?2004h> "]
[303.232928, "o", "# Reverse primer: adds BsaI site with TACCNNNN overhang (reverse complement of GGTA)\r\n\u001b[?2004l\r"]
[303.233065, "o", "\u001b[?2004h> "]
[303.233652, "o", "# The reverse primer binds to the end of egfp (without stop)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.233859, "o", "> "]
[303.234458, "o", "# Structure: GAGACC-N-TACC-[reverse complement of template end]\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.234647, "o", "> "]
[303.23478, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r"]
[303.234967, "o", "\u001b[?2004h> "]
[303.235321, "o", "    template_binding = egfp_template[-length:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.235676, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r  \u001b[?2004h"]
[303.235763, "o", "> "]
[303.235971, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r \u001b[?2004h> "]
[303.236573, "o", "        # Check if Tm is within 5°C of forward\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.236813, "o", "> "]
[303.23716, "o", "        if abs(tm - egfp_fwd_tm) <= 5:\r\n\u001b[?2004l\r"]
[303.237375, "o", "\u001b[?2004h> "]
[303.238113, "o", "            # The overhang should be reverse complement of GGTA = TACC\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.238471, "o", "> "]
[303.239747, "o", "            egfp_rev = 'GAGACCN' + 'TACC' + reverse_complement(template_binding)\r\n\u001b[?2004l\r"]
[303.240027, "o", "\u001b[?2004h> "]
[303.240104, "o", "            egfp_rev_tm = tm\r\n\u001b[?2004l\r"]
[303.240254, "o", "\u001b[?2004h> "]
[303.241223, "o", "            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-egfp_fwd_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.241734, "o", "            primers.append(('>egfp_fwd', egfp_fwd))\r\n\u001b[?2004l\rn\u001b[?2004h"]
[303.241821, "o", "> "]
[303.242363, "o", "            primers.append(('>egfp_rev', egfp_rev))\r\n\u001b[?2004l\rEOF\u001b[?2004h> "]
[303.242537, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.242713, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> print()\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.242893, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.24307, "o", "# ===== FLAG PRIMERS =====\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.243208, "o", "print(\"Designing flag primers...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.243536, "o", "# flag needs to be amplified without start and stop codons\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.243879, "o", "flag_template = seqs['flag'][3:-3]  # Remove ATG start and TAA stop\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.244046, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.244301, "o", "# Forward primer: adds BsaI site with GGTA overhang (from egfp)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.244511, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r"]
[303.244704, "o", "\u001b[?2004h> "]
[303.244926, "o", "    template_binding = flag_template[:length]\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.245114, "o", "> "]
[303.245307, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.245466, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.245725, "o", "        flag_fwd = 'GGTCTCN' + 'GGTA' + template_binding\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.245926, "o", "        flag_fwd_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.246134, "o", "> "]
[303.246417, "o", "        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.246617, "o", "        break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[303.246831, "o", "\u001b[?2004h> "]
[303.247112, "o", "# Reverse primer: adds BsaI site with TGAA overhang (reverse complement of GACA)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.247325, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.247664, "o", "    template_binding = flag_template[-length:]\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.247848, "o", "> "]
[303.248031, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r"]
[303.248234, "o", "\u001b[?2004h>     if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.248446, "o", "        if abs(tm - flag_fwd_tm) <= 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.248858, "o", "            flag_rev = 'GAGACCN' + 'TGAA' + reverse_complement(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.24903, "o", "> "]
[303.249257, "o", "            flag_rev_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.249568, "o", "            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-flag_fwd_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.249741, "o", "> "]
[303.24994, "o", "            primers.append(('>flag_fwd', flag_fwd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.250132, "o", "            primers.append(('>flag_rev', flag_rev))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.250267, "o", "            break\r\n\u001b[?2004l\r"]
[303.250504, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.250683, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.250865, "o", "# ===== SNAP PRIMERS =====\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.250965, "o", "print(\"Designing snap primers...\")\r\n\u001b[?2004l\r"]
[303.251188, "o", "\u001b[?2004h> "]
[303.251356, "o", "# snap needs to be amplified without start codon\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.251699, "o", "snap_template = seqs['snap'][3:]  # Remove ATG start, keep stop codon\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.25189, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.252222, "o", "# Forward primer: adds BsaI site with GACA overhang (from flag)\r\n\u001b[?2004l\r"]
[303.252384, "o", "\u001b[?2004h> "]
[303.25262, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.252887, "o", "    template_binding = snap_template[:length]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.253147, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.253318, "o", "> "]
[303.253511, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.25369, "o", "        snap_fwd = 'GGTCTCN' + 'GACA' + template_binding\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.253935, "o", "        snap_fwd_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.254139, "o", "> "]
[303.254427, "o", "        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.254636, "o", "        break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.255041, "o", "# Reverse primer: adds BsaI site with CTCA overhang (reverse complement of TGAG)\r\n\u001b[?2004l\r"]
[303.255154, "o", "\u001b[?2004h> "]
[303.255427, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.25557, "o", ">     template_binding = snap_template[-length:]\r\n\u001b[?2004l\r"]
[303.255736, "o", "\u001b[?2004h> "]
[303.255922, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r"]
[303.25614, "o", "\u001b[?2004h> "]
[303.256328, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.256535, "o", "        if abs(tm - snap_fwd_tm) <= 5:\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.256738, "o", "> "]
[303.256981, "o", "            snap_rev = 'GAGACCN' + 'CTCA' + reverse_complement(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.257156, "o", "> "]
[303.25733, "o", "            snap_rev_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.257741, "o", "            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-snap_fwd_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.258033, "o", "            primers.append(('>snap_fwd', snap_fwd))\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.258267, "o", "> "]
[303.258508, "o", "            primers.append(('>snap_rev', snap_rev))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.258764, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print()\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.259004, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.259206, "o", "# ===== INPUT PRIMERS =====\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.25942, "o", "print(\"Designing input primers...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.259812, "o", "# input needs to be linearized from position 690 to 210 (going around)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.260259, "o", "# This means we amplify from 690 to end, then from start to 210\r\n\u001b[?2004l\r"]
[303.260452, "o", "\u001b[?2004h> "]
[303.260694, "o", "# Or we can think of it as amplifying the backbone\r\n\u001b[?2004l\r"]
[303.260879, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[303.261068, "o", "\u001b[?2004h> "]
[303.261409, "o", "# The input fragment goes from position 690 to position 210 (circular)\r\n\u001b[?2004l\r"]
[303.261603, "o", "\u001b[?2004h> "]
[303.261832, "o", "# Forward primer binds at position 690\r\n\u001b[?2004l\r"]
[303.261966, "o", "\u001b[?2004h> "]
[303.262336, "o", "# Reverse primer binds at position 210 (reverse complement)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.26252, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.262751, "o", "input_fwd_start = 690\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.262923, "o", "input_rev_end = 210\r\n\u001b[?2004l\r"]
[303.263109, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[303.263237, "o", "> "]
[303.263554, "o", "# Forward primer: adds BsaI site with TGAG overhang (from snap)\r\n\u001b[?2004l\r"]
[303.263736, "o", "\u001b[?2004h> "]
[303.263967, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.26444, "o", "    template_binding = seqs['input'][input_fwd_start:input_fwd_start+length]\r\n\u001b[?2004l\r"]
[303.264634, "o", "\u001b[?2004h> "]
[303.264826, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.264938, "o", "> "]
[303.265156, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r"]
[303.265347, "o", "\u001b[?2004h> "]
[303.265659, "o", "        input_fwd = 'GGTCTCN' + 'TGAG' + template_binding\r\n\u001b[?2004l\r"]
[303.26584, "o", "\u001b[?2004h> "]
[303.266057, "o", "        input_fwd_tm = tm\r\n\u001b[?2004l\r"]
[303.266194, "o", "\u001b[?2004h> "]
[303.266566, "o", "        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.266819, "o", ">         break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[303.267036, "o", "\u001b[?2004h> "]
[303.267529, "o", "# Reverse primer: adds BsaI site with TCAT overhang (reverse complement of ATGA)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.267716, "o", "> "]
[303.2679, "o", "for length in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.268129, "o", "> "]
[303.268417, "o", "    template_binding = seqs['input'][input_rev_end-length:input_rev_end]\r\n\u001b[?2004l\r"]
[303.2686, "o", "\u001b[?2004h> "]
[303.268862, "o", "    tm = calculate_tm(template_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.269035, "o", "> "]
[303.269258, "o", "    if tm and 58 <= tm <= 72:\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.269398, "o", "> "]
[303.269682, "o", "        if abs(tm - input_fwd_tm) <= 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.270193, "o", "            input_rev = 'GAGACCN' + 'TCAT' + reverse_complement(template_binding)\r\n\u001b[?2004l\r"]
[303.270448, "o", "\u001b[?2004h> "]
[303.270674, "o", "            input_rev_tm = tm\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.271324, "o", "            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-input_fwd_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.271747, "o", "            primers.append(('>input_fwd', input_fwd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.272103, "o", "            primers.append(('>input_rev', input_rev))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.272325, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.272602, "o", "print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.272825, "o", "print(f\"Total primer pairs designed: {len(primers)//2}\")\r\n\u001b[?2004l\r"]
[303.272983, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[303.273069, "o", "# Write primers to file\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.273143, "o", "> "]
[303.273442, "o", "with open('primers.fasta', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[303.273528, "o", "> "]
[303.333169, "o", "    for header, seq in primers:\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(f\"{header}\\n{seq}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"\\nPrimers written to primers.fasta\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[303.333383, "o", "\u001b[?2004h> EOF"]
[303.333622, "o", "\r\n\u001b[?2004l\r"]
[303.336037, "o", "\u001b[?2004hroot@5727c976f434:/app# "]
[314.395809, "i", "python3 create_primers.py; printf '%s\\n' '__CMDEND__15__'\n"]
[314.396381, "o", "python3 create_primers.py; printf '%s\\n' '__CMDEND__15__'\r\n\u001b[?2004l\r"]
