[462.718554, "o", "> "]
[462.719201, "o", "    print(f\"   {status} {template}: fwd={len(fwd_binding)}bp/{fwd_tm:.1f}°C, rev={len(rev_binding)}bp/{rev_tm:.1f}°C, ΔTm={delta_tm:.1f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.7194, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.719629, "o", "    if not (length_ok and tm_ok and delta_ok):\r\n\u001b[?2004l\r\u001b[?2004h"]
[462.719852, "o", ">         all_pass = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[462.720026, "o", "> print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[462.720197, "o", "\u001b[?2004h> # Check 4: BsaI sites\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.720411, "o", "print(\"4. BsaI-HF v2 sites:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.720632, "o", "for name, seq in sorted(primers.items()):\r\n\u001b[?2004l\r\u001b[?2004h"]
[462.72084, "o", ">     if 'fwd' in name:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.721066, "o", "        site = seq[:6]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.721282, "o", "        if site == 'GGTCTC':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.721529, "o", "            print(f\"   ✓ {name}: {site}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.721623, "o", "        else:\r\n\u001b[?2004l\r"]
[462.72181, "o", "\u001b[?2004h> "]
[462.722065, "o", "            print(f\"   ✗ {name}: {site} (expected GGTCTC)\")\r\n\u001b[?2004l\r"]
[462.722293, "o", "\u001b[?2004h> "]
[462.722497, "o", "            all_pass = False\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r"]
[462.722678, "o", "\u001b[?2004h> "]
[462.722881, "o", "        site = seq[:6]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.723041, "o", "        if site == 'GAGACC':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.723238, "o", "            print(f\"   ✓ {name}: {site}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.723426, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[462.723608, "o", "> "]
[462.723796, "o", "            print(f\"   ✗ {name}: {site} (expected GAGACC)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.723981, "o", "            all_pass = False\r\n\u001b[?2004l\r\u001b[?2004h> print()\r\n\u001b[?2004l\r\u001b[?2004h"]
[462.724156, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.724338, "o", "# Check 5: No blank lines\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.724529, "o", "with open('primers.fasta', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.724816, "o", "    lines = f.readlines()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.725059, "o", "    blank_lines = sum(1 for line in lines if line.strip() == '')\r\n\u001b[?2004l\r"]
[462.725268, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.725507, "o", "print(f\"5. No blank lines: {blank_lines} blank lines found\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.725771, "o", "if blank_lines == 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.725979, "o", "    print(\"   ✓ PASS\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[462.726245, "o", ">     print(\"   ✗ FAIL\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.72647, "o", "    all_pass = False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[462.726666, "o", "\u001b[?2004h> print(\"=\" * 50)\r\n"]
[462.726881, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[462.727024, "o", "if all_pass:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.727237, "o", "    print(\"ALL REQUIREMENTS MET ✓\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.727456, "o", "    sys.exit(0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.727707, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.727868, "o", "    print(\"SOME REQUIREMENTS FAILED ✗\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[462.728007, "o", "    sys.exit(1)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[462.728172, "o", "\u001b[?2004h> EOF\r\n"]
