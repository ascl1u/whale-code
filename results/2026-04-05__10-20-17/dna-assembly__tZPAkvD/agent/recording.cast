[83.88806, "i", "cat > detailed_analysis.py << 'EOF'\nimport re\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\nprint(\"Sequence lengths:\")\nfor name in ['input', 'egfp', 'flag', 'snap', 'output']:\n    print(f\"  {name}: {len(seqs[name])} bp\")\n\n# Find where egfp starts and ends in output\negfp_start = seqs['output'].find(seqs['egfp'])\negfp_end = egfp_start + len(seqs['egfp'])\nprint(f\"\\negfp: positions {egfp_start}-{egfp_end} in output\")\n\n# Find where flag starts and ends in output  \nflag_start = seqs['output'].find(seqs['flag'])\nflag_end = flag_start + len(seqs['flag'])\nprint(f\"flag: positions {flag_start}-{flag_end} in output\")\n\n# Find where snap starts and ends in output\nsnap_start = seqs['output'].find(seqs['snap'])\nsnap_end = snap_start + len(seqs['snap'])\nprint(f\"snap: positions {snap_start}-{snap_end} in output\")\n\n# Find the junction sequences\nprint(\"\\nJunction analysis:\")\nprint(f\"Output[0:{egfp_start}] = {seqs['output'][:egfp_start][-30:]}\")\nprint(f\"Input match: checking if this is in input...\")\n\n# Check if the beginning of output matches input\nif seqs['output'][:egfp_start] in seqs['input']:\n    print(\"  YES - beginning of output matches input\")\n    input_cut_pos = seqs['input'].find(seqs['output'][:egfp_start]) + egfp_start\n    print(f\"  Input is cut at position {input_cut_pos}\")\nelse:\n    # Find the longest match\n    for i in range(egfp_start, 0, -1):\n        if seqs['output'][:i] in seqs['input']:\n            print(f\"  Match found: output[0:{i}] is in input\")\n            input_cut_pos = seqs['input'].find(seqs['output'][:i]) + i\n            print(f\"  Input cut position: {input_cut_pos}\")\n            break\n\n# Check what comes after snap in output\nafter_snap = seqs['output'][snap_end:snap_end+30]\nprint(f\"\\nAfter snap in output: {after_snap}\")\nif after_snap in seqs['input']:\n    print(\"  This sequence is in input\")\n    input_resume_pos = seqs['input'].find(after_snap)\n    print(f\"  Input resumes at position {input_resume_pos}\")\n\nEOF\n"]
