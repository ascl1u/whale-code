[100.501188, "i", "cat > find_junctions.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\nprint(\"Sequence lengths:\")\nfor name in ['input', 'egfp', 'flag', 'snap', 'output']:\n    print(f\"  {name}: {len(seqs[name])} bp\")\n\n# Search for egfp in output\nfor i in range(len(seqs['output']) - len(seqs['egfp']) + 1):\n    if seqs['output'][i:i+len(seqs['egfp'])] == seqs['egfp']:\n        print(f\"\\nFound egfp at position {i} in output\")\n        egfp_start = i\n        egfp_end = i + len(seqs['egfp'])\n        print(f\"  Before egfp: ...{seqs['output'][max(0,i-20):i]}\")\n        print(f\"  After egfp: {seqs['output'][egfp_end:egfp_end+20]}...\")\n        break\nelse:\n    print(\"\\negfp not found exactly in output\")\n    # Try finding partial match\n    egfp_start = seqs['output'].find(seqs['egfp'][:100])\n    if egfp_start >= 0:\n        print(f\"  Found first 100bp of egfp at position {egfp_start}\")\n\n# Search for flag in output\nfor i in range(len(seqs['output']) - len(seqs['flag']) + 1):\n    if seqs['output'][i:i+len(seqs['flag'])] == seqs['flag']:\n        print(f\"\\nFound flag at position {i} in output\")\n        flag_start = i\n        flag_end = i + len(seqs['flag'])\n        print(f\"  Before flag: ...{seqs['output'][max(0,i-20):i]}\")\n        print(f\"  After flag: {seqs['output'][flag_end:flag_end+20]}...\")\n        break\nelse:\n    print(\"\\nflag not found exactly in output\")\n\n# Search for snap in output\nfor i in range(len(seqs['output']) - len(seqs['snap']) + 1):\n    if seqs['output'][i:i+len(seqs['snap'])] == seqs['snap']:\n        print(f\"\\nFound snap at position {i} in output\")\n        snap_start = i\n        snap_end = i + len(seqs['snap'])\n        print(f\"  Before snap: ...{seqs['output'][max(0,i-20):i]}\")\n        print(f\"  After snap: {seqs['output'][snap_end:snap_end+20]}...\")\n        break\nelse:\n    print(\"\\nsnap not found exactly in output\")\n\nEOF\n"]
