[387.931551, "i", "cat > final_verification.py << 'EOF'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\n# Read primers\nprimers = {}\ncurrent_name = None\nwith open('primers.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            primers[current_name] = ''\n        else:\n            primers[current_name] += line\n\ndef calculate_tm(seq):\n    try:\n        result = subprocess.run(\n            ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\n            capture_output=True, text=True, check=True\n        )\n        return float(result.stdout.strip())\n    except:\n        return None\n\nprint(\"=== FINAL VERIFICATION ===\\n\")\n\nprimer_pairs = []\nfor template in ['egfp', 'flag', 'snap', 'input']:\n    fwd_name = f\"{template}_fwd\"\n    rev_name = f\"{template}_rev\"\n    \n    if fwd_name in primers and rev_name in primers:\n        fwd_seq = primers[fwd_name]\n        rev_seq = primers[rev_name]\n        \n        # Extract template binding regions\n        fwd_template = fwd_seq[11:]  # After GGTCTCN + 4bp overhang\n        rev_template = rev_seq[11:]  # After GAGACCN + 4bp overhang\n        \n        # Calculate Tm\n        fwd_tm = calculate_tm(fwd_template)\n        rev_tm = calculate_tm(rev_template)\n        \n        print(f\"{template.upper()} primers:\")\n        print(f\"  Forward template binding: {fwd_template} ({len(fwd_template)} bp)\")\n        print(f\"    Tm = {fwd_tm:.2f}°C\")\n        print(f\"  Reverse template binding: {rev_template} ({len(rev_template)} bp)\")\n        print(f\"    Tm = {rev_tm:.2f}°C\")\n        print(f\"  ΔTm = {abs(fwd_tm - rev_tm):.2f}°C\")\n        \n        # Check requirements\n        checks = []\n        checks.append((\"Length 15-45bp\", 15 <= len(fwd_template) <= 45 and 15 <= len(rev_template) <= 45))\n        checks.append((\"Tm 58-72°C\", 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72))\n        checks.append((\"ΔTm ≤ 5°C\", abs(fwd_tm - rev_tm) <= 5))\n        \n        all_pass = all(c[1] for c in checks)\n        print(f\"  Requirements: {'PASS' if all_pass else 'FAIL'}\")\n        for check_name, passed in checks:\n            print(f\"    {check_name}: {'\\u2713' if passed else '\\u2717'}\")\n        print()\n        \n        primer_pairs.append((template, fwd_name, rev_name, all_pass))\n\nprint(f\"\\nTotal primer pairs: {len(primer_pairs)}\")\nprint(f\"All requirements met: {all(p[3] for p in primer_pairs)}\")\n\n# Check for blank lines in output file\nwith open('primers.fasta', 'r') as f:\n    lines = f.readlines()\n    blank_lines = sum(1 for line in lines if line.strip() == '')\n    print(f\"\\nBlank lines in primers.fasta: {blank_lines}\")\n\nEOF\n"]
[387.932168, "o", "cat > final_verification.py << 'EOF'\r\n\u001b[?2004l\r"]
[387.932438, "o", "\u001b[?2004h> import subprocess\r\n\u001b[?2004l\r"]
[387.932581, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[387.932688, "o", "> # Read sequences\r\n\u001b[?2004l\r"]
[387.932939, "o", "\u001b[?2004h> seqs = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.933235, "o", "current_name = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.933514, "o", "with open('sequences.fasta', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.933755, "o", "    for line in f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.934066, "o", "        line = line.strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.934276, "o", "        if line.startswith('>'):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.934596, "o", "            current_name = line[1:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.934885, "o", "            seqs[current_name] = ''\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.935183, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.935446, "o", "            seqs[current_name] += line.upper()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.935595, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.935832, "o", "# Read primers\r\n\u001b[?2004l\r\u001b[?2004h> primers = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.936135, "o", "current_name = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.936387, "o", "with open('primers.fasta', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     for line in f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.936643, "o", "        line = line.strip()\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.936859, "o", "> "]
[387.937, "o", "        if line.startswith('>'):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.937193, "o", "            current_name = line[1:]\r\n\u001b[?2004l\r"]
[387.937391, "o", "\u001b[?2004h> "]
[387.937616, "o", "            primers[current_name] = ''\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.937874, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.938085, "o", "            primers[current_name] += line\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[387.938309, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[387.938519, "o", "def calculate_tm(seq):\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.938815, "o", "> "]
[387.938963, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.939519, "o", "            ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.939935, "o", "            capture_output=True, text=True, check=True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.940121, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.940441, "o", "        return float(result.stdout.strip())\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.94065, "o", ">     except:\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.940747, "o", ">         return None\r\n\u001b[?2004l\r"]
[387.940995, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[387.941174, "o", "> print(\"=== FINAL VERIFICATION ===\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.941383, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.941594, "o", "primer_pairs = []\r\n\u001b[?2004l\r"]
[387.941852, "o", "\u001b[?2004h> "]
[387.942063, "o", "for template in ['egfp', 'flag', 'snap', 'input']:\r\n\u001b[?2004l\r"]
[387.942295, "o", "\u001b[?2004h>     fwd_name = f\"{template}_fwd\"\r\n\u001b[?2004l\r"]
[387.942418, "o", "\u001b[?2004h> "]
[387.942625, "o", "    rev_name = f\"{template}_rev\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.942804, "o", ">     \r\n\u001b[?2004l\r"]
[387.943, "o", "\u001b[?2004h> "]
[387.943162, "o", "    if fwd_name in primers and rev_name in primers:\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.94334, "o", "> "]
[387.943522, "o", "        fwd_seq = primers[fwd_name]\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.943705, "o", "> "]
[387.943883, "o", "        rev_seq = primers[rev_name]\r\n\u001b[?2004l\r"]
[387.944079, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.944341, "o", "        # Extract template binding regions\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.944534, "o", "> "]
[387.944888, "o", "        fwd_template = fwd_seq[11:]  # After GGTCTCN + 4bp overhang\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.945067, "o", "> "]
[387.945374, "o", "        rev_template = rev_seq[11:]  # After GAGACCN + 4bp overhang\r\n\u001b[?2004l\r"]
[387.945566, "o", "\u001b[?2004h> "]
[387.945782, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.945988, "o", "        # Calculate Tm\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.94621, "o", "        fwd_tm = calculate_tm(fwd_template)\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.94644, "o", "> "]
[387.946608, "o", "        rev_tm = calculate_tm(rev_template)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.946797, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.947093, "o", "        print(f\"{template.upper()} primers:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.947271, "o", "> "]
[387.947737, "o", "        print(f\"  Forward template binding: {fwd_template} ({len(fwd_template)} bp)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.947917, "o", "> "]
[387.948098, "o", "        print(f\"    Tm = {fwd_tm:.2f}°C\")\r\n\u001b[?2004l\r"]
[387.948279, "o", "\u001b[?2004h> "]
[387.948747, "o", "        print(f\"  Reverse template binding: {rev_template} ({len(rev_template)} bp)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.948988, "o", "> "]
[387.949188, "o", "        print(f\"    Tm = {rev_tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.949484, "o", "        print(f\"  ΔTm = {abs(fwd_tm - rev_tm):.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.949714, "o", ">         \r\n\u001b[?2004l\r"]
[387.949946, "o", "\u001b[?2004h>         # Check requirements\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.950237, "o", ">         checks = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.95078, "o", "        checks.append((\"Length 15-45bp\", 15 <= len(fwd_template) <= 45 and 15 <= len(rev_template) <= 45))\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.950968, "o", "> "]
[387.951269, "o", "        checks.append((\"Tm 58-72°C\", 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.951647, "o", "        checks.append((\"ΔTm ≤ 5°C\", abs(fwd_tm - rev_tm) <= 5))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.951881, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.952166, "o", "        all_pass = all(c[1] for c in checks)\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.952359, "o", "> "]
[387.952638, "o", "        print(f\"  Requirements: {'PASS' if all_pass else 'FAIL'}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.952765, "o", "> "]
[387.953073, "o", "        for check_name, passed in checks:\r\n\u001b[?2004l\r"]
[387.95331, "o", "\u001b[?2004h> "]
[387.953619, "o", "            print(f\"    {check_name}: {'\\u2713' if passed else '\\u2717'}\")\r\n\u001b[?2004l\r"]
[387.953852, "o", "\u001b[?2004h> "]
[387.954068, "o", "        print()\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.954625, "o", "        primer_pairs.append((template, fwd_name, rev_name, all_pass))\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.954854, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.955243, "o", "print(f\"\\nTotal primer pairs: {len(primer_pairs)}\")\r\n\u001b[?2004l\r"]
[387.955461, "o", "\u001b[?2004h> "]
[387.955692, "o", "print(f\"All requirements met: {all(p[3] for p in primer_pairs)}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.955986, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[387.956265, "o", "> # Check for blank lines in output file\r\n\u001b[?2004l\r"]
[387.956403, "o", "\u001b[?2004h> "]
[387.956693, "o", "with open('primers.fasta', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.956935, "o", "    lines = f.readlines()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.957397, "o", "    blank_lines = sum(1 for line in lines if line.strip() == '')\r\n\u001b[?2004l\r\u001b[?2004h"]
[387.957644, "o", "> "]
[387.95786, "o", "    print(f\"\\nBlank lines in primers.fasta: {blank_lines}\")\r\n\u001b[?2004l\r"]
[387.95814, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[387.958456, "o", "EOF\r\n\u001b[?2004l\r"]
[387.96053, "o", "\u001b[?2004hroot@5727c976f434:/app# "]
