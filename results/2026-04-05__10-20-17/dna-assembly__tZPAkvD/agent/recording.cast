[123.587442, "i", "cat > compare_sequences.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\n# Find where egfp starts in output (first 100bp match)\negfp_start = seqs['output'].find(seqs['egfp'][:100])\nprint(f\"egfp starts at position {egfp_start} in output\")\nprint(f\"\\nComparing egfp with output[{egfp_start}:{egfp_start+len(seqs['egfp'])}]:\")\n\n# Compare egfp with output\nfor i in range(min(len(seqs['egfp']), len(seqs['output']) - egfp_start)):\n    if seqs['egfp'][i] != seqs['output'][egfp_start + i]:\n        print(f\"  First mismatch at position {i}\")\n        print(f\"    egfp[{i}:{i+30}] = {seqs['egfp'][i:i+30]}\")\n        print(f\"    output[{egfp_start+i}:{egfp_start+i+30}] = {seqs['output'][egfp_start+i:egfp_start+i+30]}\")\n        break\nelse:\n    print(f\"  egfp matches perfectly for {min(len(seqs['egfp']), len(seqs['output']) - egfp_start)} bp\")\n    egfp_end = egfp_start + len(seqs['egfp'])\n    print(f\"\\negfp ends at position {egfp_end}\")\n    print(f\"After egfp in output: {seqs['output'][egfp_end:egfp_end+100]}\")\n    print(f\"\\nChecking if flag starts here...\")\n    print(f\"flag starts with: {seqs['flag'][:100]}\")\n    \n    # Check if flag follows egfp\n    if seqs['output'][egfp_end:egfp_end+len(seqs['flag'])] == seqs['flag']:\n        print(\"  YES! flag immediately follows egfp\")\n        flag_end = egfp_end + len(seqs['flag'])\n        print(f\"\\nflag ends at position {flag_end}\")\n        print(f\"After flag in output: {seqs['output'][flag_end:flag_end+100]}\")\n        print(f\"\\nChecking if snap starts here...\")\n        print(f\"snap starts with: {seqs['snap'][:100]}\")\n        \n        # Check if snap follows flag\n        if seqs['output'][flag_end:flag_end+len(seqs['snap'])] == seqs['snap']:\n            print(\"  YES! snap immediately follows flag\")\n            snap_end = flag_end + len(seqs['snap'])\n            print(f\"\\nsnap ends at position {snap_end}\")\n        else:\n            # Find where they differ\n            for i in range(min(len(seqs['snap']), len(seqs['output']) - flag_end)):\n                if seqs['snap'][i] != seqs['output'][flag_end + i]:\n                    print(f\"  First mismatch at position {i}\")\n                    print(f\"    snap[{i}:{i+30}] = {seqs['snap'][i:i+30]}\")\n                    print(f\"    output[{flag_end+i}:{flag_end+i+30}] = {seqs['output'][flag_end+i:flag_end+i+30]}\")\n                    break\n    else:\n        # Find where they differ\n        for i in range(min(len(seqs['flag']), len(seqs['output']) - egfp_end)):\n            if seqs['flag'][i] != seqs['output'][egfp_end + i]:\n                print(f\"  First mismatch at position {i}\")\n                print(f\"    flag[{i}:{i+30}] = {seqs['flag'][i:i+30]}\")\n                print(f\"    output[{egfp_end+i}:{egfp_end+i+30}] = {seqs['output'][egfp_end+i:egfp_end+i+30]}\")\n                break\n\nEOF\n"]
