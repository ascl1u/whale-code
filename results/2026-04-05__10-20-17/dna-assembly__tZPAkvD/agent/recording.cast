[462.704152, "i", "cat > final_check.py << 'EOF'\nimport subprocess\nimport sys\n\n# Read primers\nprimers = {}\nwith open('primers.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            primers[current_name] = ''\n        else:\n            primers[current_name] += line\n\ndef calculate_tm(seq):\n    result = subprocess.run(\n        ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\n        capture_output=True, text=True, check=True\n    )\n    return float(result.stdout.strip())\n\nprint(\"FINAL REQUIREMENTS CHECK:\\n\")\n\nall_pass = True\n\n# Check 1: Correct number of primer pairs (minimum necessary)\nprint(f\"1. Minimum primer pairs: {len(primers)//2} pairs\")\nif len(primers) == 8:  # 4 pairs\n    print(\"   ✓ PASS: 4 pairs for 4-fragment assembly\\n\")\nelse:\n    print(\"   ✗ FAIL\\n\")\n    all_pass = False\n\n# Check 2: Header format\nprint(\"2. Header format (>TEMPLATENAME_DIR):\")\nexpected_names = ['egfp_fwd', 'egfp_rev', 'flag_fwd', 'flag_rev', 'snap_fwd', 'snap_rev', 'input_fwd', 'input_rev']\nfor name in expected_names:\n    if name in primers:\n        print(f\"   ✓ {name}\")\n    else:\n        print(f\"   ✗ {name} MISSING\")\n        all_pass = False\nprint()\n\n# Check 3: Template binding length and Tm\nprint(\"3. Template binding regions (15-45 bp, Tm 58-72°C):\")\npairs = [('egfp', 'egfp_fwd', 'egfp_rev'),\n         ('flag', 'flag_fwd', 'flag_rev'),\n         ('snap', 'snap_fwd', 'snap_rev'),\n         ('input', 'input_fwd', 'input_rev')]\n\nfor template, fwd, rev in pairs:\n    fwd_binding = primers[fwd][11:]\n    rev_binding = primers[rev][11:]\n    fwd_tm = calculate_tm(fwd_binding)\n    rev_tm = calculate_tm(rev_binding)\n    delta_tm = abs(fwd_tm - rev_tm)\n    \n    length_ok = 15 <= len(fwd_binding) <= 45 and 15 <= len(rev_binding) <= 45\n    tm_ok = 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72\n    delta_ok = delta_tm <= 5\n    \n    status = \"✓\" if (length_ok and tm_ok and delta_ok) else \"✗\"\n    print(f\"   {status} {template}: fwd={len(fwd_binding)}bp/{fwd_tm:.1f}°C, rev={len(rev_binding)}bp/{rev_tm:.1f}°C, ΔTm={delta_tm:.1f}°C\")\n    \n    if not (length_ok and tm_ok and delta_ok):\n        all_pass = False\nprint()\n\n# Check 4: BsaI sites\nprint(\"4. BsaI-HF v2 sites:\")\nfor name, seq in sorted(primers.items()):\n    if 'fwd' in name:\n        site = seq[:6]\n        if site == 'GGTCTC':\n            print(f\"   ✓ {name}: {site}\")\n        else:\n            print(f\"   ✗ {name}: {site} (expected GGTCTC)\")\n            all_pass = False\n    else:\n        site = seq[:6]\n        if site == 'GAGACC':\n            print(f\"   ✓ {name}: {site}\")\n        else:\n            print(f\"   ✗ {name}: {site} (expected GAGACC)\")\n            all_pass = False\nprint()\n\n# Check 5: No blank lines\nwith open('primers.fasta', 'r') as f:\n    lines = f.readlines()\n    blank_lines = sum(1 for line in lines if line.strip() == '')\n\nprint(f\"5. No blank lines: {blank_lines} blank lines found\")\nif blank_lines == 0:\n    print(\"   ✓ PASS\\n\")\nelse:\n    print(\"   ✗ FAIL\\n\")\n    all_pass = False\n\nprint(\"=\" * 50)\nif all_pass:\n    print(\"ALL REQUIREMENTS MET ✓\")\n    sys.exit(0)\nelse:\n    print(\"SOME REQUIREMENTS FAILED ✗\")\n    sys.exit(1)\n\nEOF\n"]
