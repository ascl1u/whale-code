[361.21151, "i", "cat > verify_primers.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line.upper()\n\n# Read primers\nprimers = {}\ncurrent_name = None\nwith open('primers.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            primers[current_name] = ''\n        else:\n            primers[current_name] += line\n\nprint(\"Verifying primers...\\n\")\n\nfor name, seq in primers.items():\n    print(f\"{name}:\")\n    print(f\"  Full sequence: {seq}\")\n    print(f\"  Length: {len(seq)} bp\")\n    \n    # Extract parts\n    if 'fwd' in name:\n        bsai_site = seq[:7]  # GGTCTCN\n        overhang = seq[7:11]  # 4 bases\n        template_binding = seq[11:]  # Rest\n        print(f\"  BsaI site: {bsai_site}\")\n        print(f\"  Overhang: {overhang}\")\n        print(f\"  Template binding: {template_binding} ({len(template_binding)} bp)\")\n    else:  # rev\n        bsai_site = seq[:7]  # GAGACCN\n        overhang = seq[7:11]  # 4 bases\n        template_binding = seq[11:]  # Rest\n        print(f\"  BsaI site: {bsai_site}\")\n        print(f\"  Overhang: {overhang}\")\n        print(f\"  Template binding (RC): {template_binding} ({len(template_binding)} bp)\")\n    \n    print()\n\nEOF\n"]
