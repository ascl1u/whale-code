[220.969765, "i", "cat > final_structure.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\nprint(\"=== FINAL STRUCTURE ANALYSIS ===\\n\")\n\n# Define positions\negfp_start = 210\negfp_no_stop = seqs['egfp'][:-3]\negfp_end = egfp_start + len(egfp_no_stop)\n\nflag_start = egfp_end\nflag_no_start_stop = seqs['flag'][3:-3]\nflag_end = flag_start + len(flag_no_start_stop)\n\nsnap_start = flag_end\nsnap_no_start = seqs['snap'][3:]\n\nprint(f\"egfp: output[{egfp_start}:{egfp_end}] = egfp[0:-3]\")\nprint(f\"flag: output[{flag_start}:{flag_end}] = flag[3:-3]\")\nprint(f\"snap: output[{snap_start}:{snap_start + len(snap_no_start)}] = snap[3:]\")\n\n# Verify snap\nif seqs['output'][snap_start:snap_start + len(snap_no_start)] == snap_no_start:\n    print(\"\\n✓ snap (no start) matches!\")\n    snap_end = snap_start + len(snap_no_start)\n    print(f\"snap ends at position {snap_end}\")\nelse:\n    print(\"\\n✗ snap (no start) doesn't match\")\n    # Try with start\n    if seqs['output'][snap_start:snap_start + len(seqs['snap'])] == seqs['snap']:\n        print(\"  But snap WITH start matches!\")\n        snap_end = snap_start + len(seqs['snap'])\n\n# Find junction with input plasmid\nprint(f\"\\n=== JUNCTION ANALYSIS ===\")\nprint(f\"\\nBefore insert (position 0 to {egfp_start}):\")\nprint(f\"  output[{egfp_start-20}:{egfp_start}] = {seqs['output'][egfp_start-20:egfp_start]}\")\n\n# Check if this matches input\nif seqs['output'][:egfp_start] in seqs['input']:\n    input_cut1 = seqs['input'].find(seqs['output'][:egfp_start]) + egfp_start\n    print(f\"  ✓ This is in input, cut at position {input_cut1}\")\n    print(f\"  input[{input_cut1-20}:{input_cut1}] = {seqs['input'][input_cut1-20:input_cut1]}\")\n\nprint(f\"\\nAfter insert (position {snap_end} onwards):\")\nprint(f\"  output[{snap_end}:{snap_end+20}] = {seqs['output'][snap_end:snap_end+20]}\")\n\n# Check if this matches input\nafter_insert = seqs['output'][snap_end:snap_end+50]\nif after_insert in seqs['input']:\n    input_cut2 = seqs['input'].find(after_insert)\n    print(f\"  ✓ This is in input, resumes at position {input_cut2}\")\n    print(f\"  input[{input_cut2}:{input_cut2+20}] = {seqs['input'][input_cut2:input_cut2+20]}\")\n\n# Calculate what gets removed from input\nif 'input_cut1' in locals() and 'input_cut2' in locals():\n    removed_length = input_cut2 - input_cut1\n    print(f\"\\n=== INPUT PLASMID MODIFICATION ===\")\n    print(f\"  Input is cut from position {input_cut1} to {input_cut2}\")\n    print(f\"  Removed: {removed_length} bp\")\n    print(f\"  Inserted: {snap_end - egfp_start} bp (egfp+flag+snap fusion)\")\n    print(f\"  Net change: {(snap_end - egfp_start) - removed_length:+d} bp\")\n    print(f\"  Input length: {len(seqs['input'])} bp\")\n    print(f\"  Output length: {len(seqs['output'])} bp\")\n    print(f\"  Difference: {len(seqs['output']) - len(seqs['input'])} bp\")\n\nEOF\n"]
