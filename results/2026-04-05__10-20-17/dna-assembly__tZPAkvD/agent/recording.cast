[64.654503, "i", "cat > analyze_sequences.py << 'EOF'\nimport re\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\n# Print sequence lengths\nfor name, seq in seqs.items():\n    print(f\"{name}: {len(seq)} bp\")\n\n# Find where egfp starts in output\negfp_start = seqs['output'].find(seqs['egfp'][:50])\nprint(f\"\\negfp starts at position {egfp_start} in output\")\n\n# Find where snap ends in output\nsnap_end_pos = seqs['output'].find(seqs['snap'][-50:])\nif snap_end_pos >= 0:\n    snap_end_pos += 50\n    print(f\"snap ends at position {snap_end_pos} in output\")\n\n# Find junction sequences\nif egfp_start > 0:\n    print(f\"\\nBefore egfp (input): ...{seqs['output'][egfp_start-20:egfp_start]}\")\n    print(f\"egfp start: {seqs['egfp'][:20]}...\")\n\nEOF\n"]
