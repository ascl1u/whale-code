[255.325561, "o", "def calculate_tm(seq):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.325757, "o", "    \"\"\"Calculate Tm using oligotm with specified parameters\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.325958, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.326257, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.326897, "o", "            ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.32708, "o", "> "]
[255.32736, "o", "            capture_output=True, text=True, check=True\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.327602, "o", ">         )\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.327864, "o", "> "]
[255.328053, "o", "        return float(result.stdout.strip())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.328277, "o", "    except:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.328551, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[255.328821, "o", "\u001b[?2004h> "]
[255.329036, "o", "print(\"=== GOLDEN GATE ASSEMBLY DESIGN ===\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.329268, "o", "# Define the junctions\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.329427, "o", "# Junction 1: input -> egfp (at position 210)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.329727, "o", "junc1_input = seqs['input'][210-4:210]  # 4 bases before cut\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.330058, "o", "junc1_egfp = seqs['egfp'][:4]  # First 4 bases of egfp\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.330508, "o", "print(f\"Junction 1 (input -> egfp):\")\r\n\u001b[?2004l\r"]
[255.330713, "o", "\u001b[?2004h"]
[255.330847, "o", "> "]
[255.331035, "o", "print(f\"  Input ends: ...{seqs['input'][206:210]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.331271, "o", "print(f\"  egfp starts: {seqs['egfp'][:4]}...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.331501, "o", "print(f\"  Overhang needed: {junc1_egfp}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[255.331694, "o", "\u001b[?2004h> "]
[255.331956, "o", "# Junction 2: egfp -> flag (egfp without stop, flag without start)\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.332154, "o", "> "]
[255.332328, "o", "egfp_no_stop = seqs['egfp'][:-3]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.332707, "o", "junc2_egfp = egfp_no_stop[-4:]  # Last 4 bases of egfp (no stop)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.332995, "o", "flag_no_start_stop = seqs['flag'][3:-3]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.333449, "o", "junc2_flag = flag_no_start_stop[:4]  # First 4 bases of flag (no start/stop)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.333721, "o", "print(f\"\\nJunction 2 (egfp -> flag):\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.334051, "o", "print(f\"  egfp ends (no stop): ...{egfp_no_stop[-4:]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.334228, "o", "> "]
[255.334603, "o", "print(f\"  flag starts (no start): {flag_no_start_stop[:4]}...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.334899, "o", "print(f\"  Overhang needed: {junc2_flag}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.335109, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.335395, "o", "# Junction 3: flag -> snap (flag without start/stop, snap without start)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.335818, "o", "junc3_flag = flag_no_start_stop[-4:]  # Last 4 bases of flag (no start/stop)\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.335956, "o", "> "]
[255.336267, "o", "snap_no_start = seqs['snap'][3:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.336614, "o", "junc3_snap = snap_no_start[:4]  # First 4 bases of snap (no start)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.336882, "o", "print(f\"\\nJunction 3 (flag -> snap):\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.337293, "o", "print(f\"  flag ends (no start/stop): ...{flag_no_start_stop[-4:]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.33763, "o", "print(f\"  snap starts (no start): {snap_no_start[:4]}...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.337829, "o", "> "]
[255.338028, "o", "print(f\"  Overhang needed: {junc3_snap}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.338466, "o", "# Junction 4: snap -> input (snap without start, back to input at position 690)\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.338705, "o", "> "]
[255.33894, "o", "snap_no_start = seqs['snap'][3:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.339153, "o", "junc4_snap = snap_no_start[-4:]  # Last 4 bases of snap (no start)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.339474, "o", "junc4_input = seqs['input'][690:694]  # First 4 bases after cut\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.339743, "o", "print(f\"\\nJunction 4 (snap -> input):\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.340085, "o", "print(f\"  snap ends (no start): ...{snap_no_start[-4:]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.34029, "o", "> "]
[255.340492, "o", "print(f\"  input resumes: {seqs['input'][690:694]}...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.340692, "o", "> "]
[255.340878, "o", "print(f\"  Overhang needed: {junc4_input}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.341106, "o", "print(\"\\n\" + \"=\"*50)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.341324, "o", "print(\"Golden Gate Assembly Strategy:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.341529, "o", "print(\"=\"*50)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.341792, "o", "print(\"\\nWe need primers for:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[255.341996, "o", "> "]
[255.342234, "o", "print(\"1. input backbone (position 690 -> 210, circular)\")\r\n\u001b[?2004l\r"]
[255.342437, "o", "\u001b[?2004h> "]
[255.34263, "o", "print(\"2. egfp (without stop codon)\")\r\n\u001b[?2004l\r"]
[255.342848, "o", "\u001b[?2004h> "]
[255.343044, "o", "print(\"3. flag (without start and stop codons)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[255.343295, "o", "print(\"4. snap (without start codon)\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[255.34355, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[255.345908, "o", "\u001b[?2004hroot@5727c976f434:/app# "]
[261.511855, "i", "python3 design_primers.py; printf '%s\\n' '__CMDEND__14__'\n"]
[261.512526, "o", "python3 design_primers.py; printf '%s\\n' '__CMDEND__14__'\r\n\u001b[?2004l\r"]
[261.541621, "o", "=== GOLDEN GATE ASSEMBLY DESIGN ===\r\n\r\nJunction 1 (input -> egfp):\r\n  Input ends: ...acat\r\n  egfp starts: atga...\r\n  Overhang needed: atga\r\n\r\nJunction 2 (egfp -> flag):\r\n  egfp ends (no stop): ...caaa\r\n  flag starts (no start): ggta...\r\n  Overhang needed: ggta\r\n\r\nJunction 3 (flag -> snap):\r\n  flag ends (no start/stop): ...ttca\r\n  snap starts (no start): gaca...\r\n"]
[261.541771, "o", "  Overhang needed: gaca\r\n\r\nJunction 4 (snap -> input):\r\n  snap ends (no start): ...ttaa\r\n  input resumes: tgag...\r\n  Overhang needed: tgag\r\n\r\n==================================================\r\nGolden Gate Assembly Strategy:\r\n==================================================\r\n\r\nWe need primers for:"]
[261.542188, "o", "\r\n1. input backbone (position 690 -> 210, circular)\r\n2. egfp (without stop codon)\r\n3. flag (without start and stop codons)\r\n4. snap (without start codon)\r\n"]
[261.547239, "o", "__CMDEND__14__\r\n\u001b[?2004h"]
[261.547499, "o", "root@5727c976f434:/app# "]
[303.192822, "i", "cat > create_primers.py << 'EOF'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\ndef reverse_complement(seq):\n    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G'}\n    return ''.join(complement[base] for base in reversed(seq))\n\ndef calculate_tm(seq):\n    \"\"\"Calculate Tm using oligotm\"\"\"\n    try:\n        result = subprocess.run(\n            ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],\n            capture_output=True, text=True, check=True\n        )\n        return float(result.stdout.strip())\n    except:\n        return None\n\ndef find_optimal_primer(template, min_len=15, max_len=45, target_tm_min=58, target_tm_max=72):\n    \"\"\"Find optimal primer length for given template\"\"\"\n    for length in range(min_len, max_len + 1):\n        primer = template[:length]\n        tm = calculate_tm(primer)\n        if tm and target_tm_min <= tm <= target_tm_max:\n            return primer, tm\n    return None, None\n\nprint(\"Designing primers for Golden Gate assembly...\\n\")\n\n# BsaI-HF v2 site: GGTCTC (cuts 1/5 after the site)\n# After GGTCTC, we add 1 base, then 4-base overhang, then template binding\n\nprimers = []\n\n# ===== EGFP PRIMERS =====\nprint(\"Designing egfp primers...\")\n# egfp needs to be amplified without stop codon\negfp_template = seqs['egfp'][:-3]  # Remove TAA stop codon\n\n# Forward primer: adds BsaI site with ATGA overhang (from input)\n# Structure: GGTCTC-N-ATGA-[template]\nfor length in range(15, 46):\n    template_binding = egfp_template[:length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        egfp_fwd = 'GGTCTCN' + 'ATGA' + template_binding\n        egfp_fwd_tm = tm\n        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\n        break\n\n# Reverse primer: adds BsaI site with TACCNNNN overhang (reverse complement of GGTA)\n# The reverse primer binds to the end of egfp (without stop)\n# Structure: GAGACC-N-TACC-[reverse complement of template end]\nfor length in range(15, 46):\n    template_binding = egfp_template[-length:]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        # Check if Tm is within 5°C of forward\n        if abs(tm - egfp_fwd_tm) <= 5:\n            # The overhang should be reverse complement of GGTA = TACC\n            egfp_rev = 'GAGACCN' + 'TACC' + reverse_complement(template_binding)\n            egfp_rev_tm = tm\n            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-egfp_fwd_tm):.2f}°C\")\n            primers.append(('>egfp_fwd', egfp_fwd))\n            primers.append(('>egfp_rev', egfp_rev))\n            break\n\nprint()\n\n# ===== FLAG PRIMERS =====\nprint(\"Designing flag primers...\")\n# flag needs to be amplified without start and stop codons\nflag_template = seqs['flag'][3:-3]  # Remove ATG start and TAA stop\n\n# Forward primer: adds BsaI site with GGTA overhang (from egfp)\nfor length in range(15, 46):\n    template_binding = flag_template[:length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        flag_fwd = 'GGTCTCN' + 'GGTA' + template_binding\n        flag_fwd_tm = tm\n        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\n        break\n\n# Reverse primer: adds BsaI site with TGAA overhang (reverse complement of GACA)\nfor length in range(15, 46):\n    template_binding = flag_template[-length:]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        if abs(tm - flag_fwd_tm) <= 5:\n            flag_rev = 'GAGACCN' + 'TGAA' + reverse_complement(template_binding)\n            flag_rev_tm = tm\n            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-flag_fwd_tm):.2f}°C\")\n            primers.append(('>flag_fwd', flag_fwd))\n            primers.append(('>flag_rev', flag_rev))\n            break\n\nprint()\n\n# ===== SNAP PRIMERS =====\nprint(\"Designing snap primers...\")\n# snap needs to"]
[303.193103, "i", " be amplified without start codon\nsnap_template = seqs['snap'][3:]  # Remove ATG start, keep stop codon\n\n# Forward primer: adds BsaI site with GACA overhang (from flag)\nfor length in range(15, 46):\n    template_binding = snap_template[:length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        snap_fwd = 'GGTCTCN' + 'GACA' + template_binding\n        snap_fwd_tm = tm\n        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\n        break\n\n# Reverse primer: adds BsaI site with CTCA overhang (reverse complement of TGAG)\nfor length in range(15, 46):\n    template_binding = snap_template[-length:]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        if abs(tm - snap_fwd_tm) <= 5:\n            snap_rev = 'GAGACCN' + 'CTCA' + reverse_complement(template_binding)\n            snap_rev_tm = tm\n            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-snap_fwd_tm):.2f}°C\")\n            primers.append(('>snap_fwd', snap_fwd))\n            primers.append(('>snap_rev', snap_rev))\n            break\n\nprint()\n\n# ===== INPUT PRIMERS =====\nprint(\"Designing input primers...\")\n# input needs to be linearized from position 690 to 210 (going around)\n# This means we amplify from 690 to end, then from start to 210\n# Or we can think of it as amplifying the backbone\n\n# The input fragment goes from position 690 to position 210 (circular)\n# Forward primer binds at position 690\n# Reverse primer binds at position 210 (reverse complement)\n\ninput_fwd_start = 690\ninput_rev_end = 210\n\n# Forward primer: adds BsaI site with TGAG overhang (from snap)\nfor length in range(15, 46):\n    template_binding = seqs['input'][input_fwd_start:input_fwd_start+length]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        input_fwd = 'GGTCTCN' + 'TGAG' + template_binding\n        input_fwd_tm = tm\n        print(f\"  Forward: length={length}, Tm={tm:.2f}°C\")\n        break\n\n# Reverse primer: adds BsaI site with TCAT overhang (reverse complement of ATGA)\nfor length in range(15, 46):\n    template_binding = seqs['input'][input_rev_end-length:input_rev_end]\n    tm = calculate_tm(template_binding)\n    if tm and 58 <= tm <= 72:\n        if abs(tm - input_fwd_tm) <= 5:\n            input_rev = 'GAGACCN' + 'TCAT' + reverse_complement(template_binding)\n            input_rev_tm = tm\n            print(f\"  Reverse: length={length}, Tm={tm:.2f}°C, ΔTm={abs(tm-input_fwd_tm):.2f}°C\")\n            primers.append(('>input_fwd', input_fwd))\n            primers.append(('>input_rev', input_rev))\n            break\n\nprint()\nprint(f\"Total primer pairs designed: {len(primers)//2}\")\n\n# Write primers to file\nwith open('primers.fasta', 'w') as f:\n    for header, seq in primers:\n        f.write(f\"{header}\\n{seq}\\n\")\n\nprint(\"\\nPrimers written to primers.fasta\")\n\nEOF\n"]
