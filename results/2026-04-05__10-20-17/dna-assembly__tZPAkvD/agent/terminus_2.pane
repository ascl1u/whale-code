[?2004hroot@5727c976f434:/app# cat > design_primers.py << 'EOF'
[?2004l[?2004h> import subprocess
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> # Read sequences
[?2004l[?2004h> seqs = {}
[?2004l[?2004h> current_name = None
[?2004l[?2004h> with open('sequences.fasta', 'r') as f:
[?2004l[?2004h>     for line in f:
[?2004l[?2004h>         line = line.strip()
[?2004l[?2004h>         if line.startswith('>'):
[?2004l[?2004h>             current_name = line[1:]
[?2004l[?2004h>             seqs[current_name] = ''
[?2004l[?2004h>         else:
[?2004l[?2004h>             seqs[current_name] += line
[?2004l[?2004h> 
[?2004l[?2004h> def reverse_complement(seq):
[?2004l[?2004h>     complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G'}
[?2004l[?2004h>     return ''.join(complement[base] for base in reversed(seq))
[?2004l[?2004h> 
[?2004l[?2004h> def calculate_tm(seq):
[?2004l[?2004h>     """Calculate Tm using oligotm with specified parameters"""
[?2004l[?2004h>     try:
[?2004l[?2004h>         result = subprocess.run(
[?2004l[?2004h>             ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],
[?2004l[?2004h>             capture_output=True, text=True, check=True
[?2004l[?2004h>         )
[?2004l[?2004h>         return float(result.stdout.strip())
[?2004l[?2004h>     except:
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h> print("=== GOLDEN GATE ASSEMBLY DESIGN ===\n")
[?2004l[?2004h> 
[?2004l[?2004h> # Define the junctions
[?2004l[?2004h> # Junction 1: input -> egfp (at position 210)
[?2004l[?2004h> junc1_input = seqs['input'][210-4:210]  # 4 bases before cut
[?2004l[?2004h> junc1_egfp = seqs['egfp'][:4]  # First 4 bases of egfp
[?2004l[?2004h> print(f"Junction 1 (input -> egfp):")
[?2004l[?2004h> print(f"  Input ends: ...{seqs['input'][206:210]}")
[?2004l[?2004h> print(f"  egfp starts: {seqs['egfp'][:4]}...")
[?2004l[?2004h> print(f"  Overhang needed: {junc1_egfp}")
[?2004l[?2004h> 
[?2004l[?2004h> # Junction 2: egfp -> flag (egfp without stop, flag without start)
