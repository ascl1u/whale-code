[?2004l[?2004h>     for line in f:
[?2004l[?2004h>         line = line.strip()
[?2004l[?2004h>         if line.startswith('>'):
[?2004l[?2004h>             current_name = line[1:]
[?2004l[?2004h>             seqs[current_name] = ''
[?2004l[?2004h>         else:
[?2004l[?2004h>             seqs[current_name] += line.upper()
[?2004l[?2004h> 
[?2004l[?2004h> # Read primers
[?2004l[?2004h> primers = {}
[?2004l[?2004h> current_name = None
[?2004l[?2004h> with open('primers.fasta', 'r') as f:
[?2004l[?2004h>     for line in f:
[?2004l[?2004h>         line = line.strip()
[?2004l[?2004h>         if line.startswith('>'):
[?2004l[?2004h>             current_name = line[1:]
[?2004l[?2004h>             primers[current_name] = ''
[?2004l[?2004h>         else:
[?2004l[?2004h>             primers[current_name] += line
[?2004l[?2004h> 
[?2004l[?2004h> def calculate_tm(seq):
[?2004l[?2004h>     try:
[?2004l[?2004h>         result = subprocess.run(
[?2004l[?2004h>             ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq],
[?2004l[?2004h>             capture_output=True, text=True, check=True
[?2004l[?2004h>         )
[?2004l[?2004h>         return float(result.stdout.strip())
[?2004l[?2004h>     except:
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h> print("=== FINAL VERIFICATION ===\n")
[?2004l[?2004h> 
[?2004l[?2004h> primer_pairs = []
[?2004l[?2004h> for template in ['egfp', 'flag', 'snap', 'input']:
[?2004l[?2004h>     fwd_name = f"{template}_fwd"
[?2004l[?2004h>     rev_name = f"{template}_rev"
[?2004l[?2004h>     
[?2004l[?2004h>     if fwd_name in primers and rev_name in primers:
[?2004l[?2004h>         fwd_seq = primers[fwd_name]
[?2004l[?2004h>         rev_seq = primers[rev_name]
[?2004l[?2004h>         
[?2004l[?2004h>         # Extract template binding regions
[?2004l[?2004h>         fwd_template = fwd_seq[11:]  # After GGTCTCN + 4bp overhang
[?2004l[?2004h>         rev_template = rev_seq[11:]  # After GAGACCN + 4bp overhang
[?2004l[?2004h>         
[?2004l[?2004h>         # Calculate Tm
[?2004l[?2004h>         fwd_tm = calculate_tm(fwd_template)
[?2004l[?2004h>         rev_tm = calculate_tm(rev_template)
[?2004l[?2004h>         
[?2004l[?2004h>         print(f"{template.upper()} primers:")
[?2004l[?2004h>         print(f"  Forward template binding: {fwd_template} ({len(fwd_template)} bp)")
[?2004l[?2004h>         print(f"    Tm = {fwd_tm:.2f}°C")
[?2004l[?2004h>         print(f"  Reverse template binding: {rev_template} ({len(rev_template)} bp)")
[?2004l[?2004h>         print(f"    Tm = {rev_tm:.2f}°C")
[?2004l[?2004h>         print(f"  ΔTm = {abs(fwd_tm - rev_tm):.2f}°C")
[?2004l[?2004h>         
[?2004l[?2004h>         # Check requirements
[?2004l[?2004h>         checks = []
[?2004l[?2004h>         checks.append(("Length 15-45bp", 15 <= len(fwd_template) <= 45 and 15 <= len(rev_template) <= 45))
[?2004l[?2004h>         checks.append(("Tm 58-72°C", 58 <= fwd_tm <= 72 and 58 <= rev_tm <= 72))
[?2004l[?2004h>         checks.append(("ΔTm ≤ 5°C", abs(fwd_tm - rev_tm) <= 5))
[?2004l[?2004h>         
[?2004l[?2004h>         all_pass = all(c[1] for c in checks)
[?2004l[?2004h>         print(f"  Requirements: {'PASS' if all_pass else 'FAIL'}")
[?2004l[?2004h>         for check_name, passed in checks:
[?2004l[?2004h>             print(f"    {check_name}: {'\u2713' if passed else '\u2717'}")
[?2004l[?2004h>         print()
[?2004l[?2004h>         
[?2004l[?2004h>         primer_pairs.append((template, fwd_name, rev_name, all_pass))
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nTotal primer pairs: {len(primer_pairs)}")
[?2004l[?2004h> print(f"All requirements met: {all(p[3] for p in primer_pairs)}")
