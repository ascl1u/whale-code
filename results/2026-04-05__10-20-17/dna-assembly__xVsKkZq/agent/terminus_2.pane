[?2004l[?2004h> no_blanks = '\n\n' not in content
[?2004l[?2004h> checks.append(("No blank lines", no_blanks, "Clean file"))
[?2004l[?2004h> 
[?2004l[?2004h> # 4. Check BsaI sites
