[?2004l[?2004h>         header_ok = False
[?2004l[?2004h> checks.append(("Header format (TEMPLATENAME_DIR)", header_ok, "All correct"))
[?2004l[?2004h> 
[?2004l[?2004h> # 3. Check for blank lines
[?2004l[?2004h> with open('primers.fasta', 'r') as f:
