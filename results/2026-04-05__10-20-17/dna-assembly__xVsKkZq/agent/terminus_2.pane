[?2004l[?2004h>     lines = [l.rstrip('\n') for l in f]
[?2004l[?2004h>     for i in range(0, len(lines), 2):
[?2004l[?2004h>         name = lines[i][1:]
[?2004l[?2004h>         seq = lines[i+1]
[?2004l[?2004h>         primers[name] = seq
[?2004l[?2004h> 
[?2004l[?2004h> def calc_tm(seq):
[?2004l[?2004h>     cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()]
[?2004l[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)
[?2004l[?2004h>     return float(result.stdout.strip())
[?2004l[?2004h> 
[?2004l[?2004h> print("FINAL VALIDATION CHECKLIST")
[?2004l[?2004h> print("="*70)
[?2004l[?2004h> 
[?2004l[?2004h> checks = []
[?2004l[?2004h> 
[?2004l[?2004h> # 1. Check number of primers
[?2004l[?2004h> num_primers = len(primers)
[?2004l[?2004h> checks.append(("Minimum number of primer pairs", num_primers == 8, f"{num_primers//2} pairs"))
[?2004l[?2004h> 
[?2004l[?2004h> # 2. Check header format
[?2004l[?2004h> header_ok = True
[?2004l[?2004h> for name in primers.keys():
