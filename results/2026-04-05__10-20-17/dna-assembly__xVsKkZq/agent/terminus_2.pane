[?2004lwd_p,[?2004h>     # If no perfect match, return the closest
[?2004l[?2004h>     if direction == 'forward':
[?2004l[?2004h>         primer_seq = template[start_pos:start_pos + max_len]
[?2004l[?2004h>     else:
[?2004l[?2004h>         primer_seq = template[start_pos - max_len + 1:start_pos + 1]
[?2004l[?2004h>     tm = calc_tm(primer_seq)
