[?2004l[?2004h>     tm = calc_tm(binding)
[?2004l[?2004h>     if not (58 <= tm <= 72):
[?2004l[?2004h>         tm_ok = False
[?2004l[?2004h> checks.append(("Tm values 58-72°C", tm_ok, "All in range"))
[?2004l[?2004h> 
[?2004l[?2004h> # 7. Check primer pair Tm differences
