[?2004l[?2004h>     if not (15 <= binding_len <= 45):
[?2004l[?2004h>         lengths_ok = False
[?2004l[?2004h> checks.append(("Binding regions 15-45bp", lengths_ok, "All in range"))
[?2004l[?2004h> 
[?2004l[?2004h> # 6. Check Tm values
[?2004l[?2004h> tm_ok = True
[?2004l[?2004h> for seq in primers.values():
