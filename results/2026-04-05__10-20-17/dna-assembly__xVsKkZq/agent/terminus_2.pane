[?2004l[?2004h>         print(f"  ΔTm: {best_tm_diff:.2f}°C")
[?2004l[?2004h>         
[?2004l[?2004h>         return fwd_primer, rev_primer, best_fwd[1], best_rev[1]
[?2004l[?2004h>     else:
