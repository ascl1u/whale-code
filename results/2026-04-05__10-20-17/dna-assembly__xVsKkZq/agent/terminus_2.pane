[?2004l[?2004h> def design_primer_pair(template, fwd_start, rev_end, fwd_overhang, rev_overhang, name):
[?2004l[?2004h>     """Design a primer pair with BsaI sites and overhangs"""
[?2004l[?2004h>     print(f"\nDesigning primers for {name}...")
[?2004ln[?2004h>     
[?2004l[?2004h>     # Find optimal forward primer
[?2004l[?2004h>     best_fwd = None
[?2004l[?2004h>     best_rev = None
[?2004l[?2004h>     best_tm_diff = 100
[?2004l[?2004h>     
[?2004l[?2004h>     for fwd_len in range(15, 46):
[?2004l[?2004h>         fwd_binding = template[fwd_start:fwd_start + fwd_len]
[?2004l[?2004h>         if len(fwd_binding) < fwd_len:
[?2004l[?2004h>             continue
[?2004l[?2004h>         fwd_tm = calc_tm(fwd_binding)
[?2004l[?2004h>         
[?2004l[?2004h>         if not (58 <= fwd_tm <= 72):
[?2004l[?2004h>             continue
[?2004l[?2004h>         
[?2004l[?2004h>         for rev_len in range(15, 46):
[?2004l[?2004h>             rev_binding = template[rev_end - rev_len + 1:rev_end + 1]
[?2004l[?2004h>             if len(rev_binding) < rev_len:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             rev_tm = calc_tm(rev_binding)
[?2004l[?2004h>             
[?2004l[?2004h>             if not (58 <= rev_tm <= 72):
[?2004l[?2004h>                 continue
[?2004l[?2004h>             
[?2004l[?2004h>             tm_diff = abs(fwd_tm - rev_tm)
[?2004l[?2004h>             if tm_diff <= 5 and tm_diff < best_tm_diff:
[?2004l[?2004h>                 best_tm_diff = tm_diff
[?2004l[?2004h>                 best_fwd = (fwd_binding, fwd_tm, fwd_len)
[?2004l[?2004h>                 best_rev = (rev_binding, rev_tm, rev_len)
[?2004l[?2004h>     
[?2004l[?2004h>     if best_fwd and best_rev:
[?2004l[?2004h>         # Build full primers with BsaI sites
[?2004l[?2004h>         fwd_primer = "GGTCTCN" + fwd_overhang + best_fwd[0]
[?2004l[?2004h>         rev_primer_binding_rc = reverse_complement(best_rev[0])
[?2004l[?2004h>         rev_overhang_rc = reverse_complement(rev_overhang)
[?2004l[?2004h>         rev_primer = "GAGACCN" + rev_overhang_rc + rev_primer_binding_rc
[?2004l[?2004h>         
[?2004l[?2004h>         print(f"  Forward: {best_fwd[1]:.2f}°C (binding: {best_fwd[2]}bp)")
