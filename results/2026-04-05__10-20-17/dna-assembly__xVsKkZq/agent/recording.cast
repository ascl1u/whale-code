[131.838314, "i", "cat > map_exact.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\nprint(\"Checking egfp:\")\negfp_modified = seqs['egfp'][:-3] + 'ggt'  # Replace TAA with GGT\npos = seqs['output'].find(egfp_modified)\nprint(f\"  Modified egfp found at: {pos}\")\nif pos >= 0:\n    egfp_end = pos + len(egfp_modified)\n    print(f\"  Ends at: {egfp_end}\")\n    print(f\"  Last 10bp: {seqs['output'][egfp_end-10:egfp_end]}\")\n    print(f\"  Next 30bp: {seqs['output'][egfp_end:egfp_end+30]}\")\n\nprint(\"\\nChecking flag (no ATG, no stop):\")\nflag_modified = seqs['flag'][3:-3]  # Remove ATG and TAA\nprint(f\"  Looking for: {flag_modified[:30]}\")\npos = seqs['output'].find(flag_modified)\nprint(f\"  Found at: {pos}\")\nif pos >= 0:\n    flag_end = pos + len(flag_modified)\n    print(f\"  Ends at: {flag_end}\")\n    print(f\"  Last 10bp: {seqs['output'][flag_end-10:flag_end]}\")\n    print(f\"  Next 30bp: {seqs['output'][flag_end:flag_end+30]}\")\n\nprint(\"\\nChecking snap (no ATG):\")\nsnap_modified = seqs['snap'][3:]  # Remove ATG, keep TAA\nprint(f\"  Looking for: {snap_modified[:30]}\")\npos = seqs['output'].find(snap_modified)\nprint(f\"  Found at: {pos}\")\nif pos >= 0:\n    snap_end = pos + len(snap_modified)\n    print(f\"  Ends at: {snap_end}\")\n    print(f\"  Last 10bp: {seqs['output'][snap_end-10:snap_end]}\")\n    print(f\"  Next 30bp: {seqs['output'][snap_end:snap_end+30]}\")\n\n# Now let's understand the assembly\nprint(\"\\n\" + \"=\"*60)\nprint(\"ASSEMBLY STRUCTURE:\")\nprint(\"=\"*60)\n\n# Find in input where the break is\ninput_seq = seqs['input']\noutput_seq = seqs['output']\n\n# The output before position 210\nbefore = output_seq[:210]\nprint(f\"\\nBefore insert (0-210): {len(before)} bp\")\nprint(f\"  Ends with: {before[-20:]}\")\n\n# After snap\nafter_start = 1557\nafter = output_seq[after_start:]\nprint(f\"\\nAfter insert ({after_start}-end): {len(after)} bp\")\nprint(f\"  Starts with: {after[:20]}\")\n\n# Find these in input\nif before in input_seq:\n    print(f\"\\nBefore sequence found in input: YES\")\nelse:\n    # Try last 50bp\n    if before[-50:] in input_seq:\n        pos = input_seq.find(before[-50:])\n        print(f\"\\nLast 50bp of before found in input at: {pos}\")\n        print(f\"  Input continues with: {input_seq[pos+50:pos+70]}\")\n\nif after[:50] in input_seq:\n    pos = input_seq.find(after[:50])\n    print(f\"\\nFirst 50bp of after found in input at: {pos}\")\n    print(f\"  Input before this: {input_seq[pos-20:pos]}\")\n\nEOF\npython3 map_exact.py\n"]
