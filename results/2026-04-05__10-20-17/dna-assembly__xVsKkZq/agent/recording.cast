[213.485277, "o", "            if tm_diff <= 5 and tm_diff < best_tm_diff:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.485524, "o", "                best_tm_diff = tm_diff\r\n\u001b[?2004l\r\u001b[?2004h> "]
