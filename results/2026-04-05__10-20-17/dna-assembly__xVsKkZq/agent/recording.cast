[213.498893, "o", "print(\"\\n\" + \"=\"*70)\r\n\u001b[?2004l\r"]
[213.49905, "o", "\u001b[?2004h> "]
[213.499166, "o", "print(\"FRAGMENT 3: FLAG\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.499251, "o", "print(\"=\"*70)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.499543, "o", "# Amplify flag without ATG and without stop\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.499809, "o", "# Forward at position 3 (skip ATG), creates AGTG overhang\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.499982, "o", "> "]
[213.500204, "o", "# Reverse at end-3 (skip stop), creates GACA overhang\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.500363, "o", "flag_seq = seqs['flag']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.500563, "o", "flag_no_atg_stop = flag_seq[3:-3]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.500674, "o", "fwd_p, rev_p, fwd_tm, rev_tm = design_primer_pair(\r\n\u001b[?2004l\r"]
[213.500859, "o", "\u001b[?2004h> "]
[213.501044, "o", "    flag_seq, 3, len(flag_seq) - 4, \"AGTG\", \"GACA\", \"flag\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.501145, "o", ")\r\n\u001b[?2004l\r\u001b[?2004h> if fwd_p:\r\n\u001b[?2004l\r"]
[213.501435, "o", "\u001b[?2004h> "]
[213.501608, "o", "    primers.append((\"flag_fwd\", fwd_p))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.501766, "o", "    primers.append((\"flag_rev\", rev_p))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[213.501932, "o", "\u001b[?2004h> # Fragment 4: SNAP\r\n\u001b[?2004l\r"]
[213.502098, "o", "\u001b[?2004h> print(\"\\n\" + \"=\"*70)\r\n\u001b[?2004l\r"]
[213.502244, "o", "\u001b[?2004h> print(\"FRAGMENT 4: SNAP\")\r\n\u001b[?2004l\r"]
[213.502472, "o", "\u001b[?2004h> print(\"=\"*70)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.502648, "o", "# Amplify snap without ATG but keep stop\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.502988, "o", "# Forward at position 3 (skip ATG), creates GACA overhang\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.503282, "o", "# Reverse at end, creates TGAG overhang\r\n\u001b[?2004l\r\u001b[?2004h> "]
