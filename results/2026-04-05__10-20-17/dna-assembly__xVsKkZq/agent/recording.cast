[213.591907, "o", "======================================================================\r\nDESIGNING PRIMERS FOR GOLDEN GATE ASSEMBLY\r\n======================================================================\r\n\r\n======================================================================\r\nFRAGMENT 1: INPUT VECTOR BACKBONE\r\n======================================================================\r\n\r\nDesigning primers for input...\r\n"]
[214.635237, "o", "  Forward: 59.81°C (binding: 18bp)\r\n  Reverse: 59.83°C (binding: 32bp)\r\n  ΔTm: 0.03°C\r\n\r\n======================================================================\r\nFRAGMENT 2: EGFP\r\n======================================================================\r\n\r\nDesigning primers for egfp...\r\n"]
[215.29579, "o", "  Forward: 68.53°C (binding: 21bp)\r\n  Reverse: 68.48°C (binding: 24bp)\r\n  ΔTm: 0.05°C\r\n\r\n======================================================================\r\nFRAGMENT 3: FLAG\r\n======================================================================\r\n\r\nDesigning primers for flag...\r\n"]
[215.996778, "o", "  Forward: 69.51°C (binding: 23bp)\r\n  Reverse: 69.35°C (binding: 26bp)\r\n  ΔTm: 0.16°C\r\n\r\n======================================================================"]
[215.997062, "o", "\r\nFRAGMENT 4: SNAP\r\n======================================================================\r\n\r\nDesigning primers for snap...\r\n"]
[216.738551, "o", "  Forward: 71.20°C (binding: 28bp)\r\n  Reverse: 71.25°C (binding: 26bp)\r\n  ΔTm: 0.05°C\r\n\r\n======================================================================\r\nWRITING PRIMERS TO primers.fasta\r\n======================================================================\r\n"]
[216.738841, "o", "\r\nWrote 8 primers to primers.fasta\r\n"]
