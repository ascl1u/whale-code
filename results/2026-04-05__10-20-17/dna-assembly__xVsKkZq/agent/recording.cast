[58.499055, "i", "cat > analyze_sequences.py << 'EOF'\nimport re\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\n# Print sequence lengths\nfor name, seq in seqs.items():\n    print(f\"{name}: {len(seq)} bp\")\n\n# Find where egfp starts in output\negfp_start = seqs['output'].find(seqs['egfp'][:50])\nprint(f\"\\negfp starts at position {egfp_start} in output\")\n\n# Find where snap ends in output\nsnap_end_seq = seqs['snap'][-50:]\nsnap_end = seqs['output'].find(snap_end_seq)\nif snap_end != -1:\n    snap_end += len(snap_end_seq)\nprint(f\"snap ends at position {snap_end} in output\")\n\n# Find the junction point in input\ninput_before_insert = seqs['output'][:egfp_start]\ninput_after_insert = seqs['output'][snap_end:]\n\nprint(f\"\\nBefore insert: {len(input_before_insert)} bp\")\nprint(f\"After insert: {len(input_after_insert)} bp\")\n\n# Find these in input\nbefore_pos = seqs['input'].find(input_before_insert[-50:])\nafter_pos = seqs['input'].find(input_after_insert[:50])\n\nprint(f\"\\nBefore sequence found at: {before_pos}\")\nprint(f\"After sequence found at: {after_pos}\")\n\nif before_pos != -1:\n    print(f\"Last 20bp before insert: {seqs['input'][before_pos+30:before_pos+50]}\")\nif after_pos != -1:\n    print(f\"First 20bp after insert: {seqs['input'][after_pos:after_pos+20]}\")\n\nEOF\npython3 analyze_sequences.py\n"]
