[213.506075, "o", "> "]
[213.5063, "o", "print(\"=\"*70)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.506554, "o", "with open('primers.fasta', 'w') as f:\r\n\u001b[?2004l\r"]
