[268.673325, "i", "cat > check_overhangs.py << 'EOF'\n# Check that overhangs create correct assembly order\n\nprint(\"Checking overhang compatibility...\\n\")\nprint(\"Expected assembly order: input -> egfp -> flag -> snap -> input (circular)\\n\")\n\n# From the verification:\nprint(\"Fragment overhangs (5' -> 3'):\")\nprint(\"  input:  5'-TGAG ... ATGA-3' (after BsaI digestion)\")\nprint(\"  egfp:   5'-ATGA ... AGTG-3'\")\nprint(\"  flag:   5'-AGTG ... GACA-3'\")\nprint(\"  snap:   5'-GACA ... TGAG-3'\")\n\nprint(\"\\nAssembly compatibility:\")\nprint(\"  input-3'(ATGA) + egfp-5'(ATGA) ✓\")\nprint(\"  egfp-3'(AGTG) + flag-5'(AGTG) ✓\") \nprint(\"  flag-3'(GACA) + snap-5'(GACA) ✓\")\nprint(\"  snap-3'(TGAG) + input-5'(TGAG) ✓ (circular closure)\")\n\nprint(\"\\nAll overhangs are compatible for ordered assembly!\")\n\n# Check for blank lines in primers.fasta\nprint(\"\\n\" + \"=\"*70)\nprint(\"Checking for blank lines in primers.fasta...\")\n\nwith open('primers.fasta', 'r') as f:\n    lines = f.readlines()\n    \nblank_lines = [i+1 for i, line in enumerate(lines) if line.strip() == '']\n\nif blank_lines:\n    print(f\"  Found blank lines at: {blank_lines}\")\n    print(\"  ✗ File should not contain blank lines\")\nelse:\n    print(\"  ✓ No blank lines found\")\n\nprint(\"\\nTotal lines in file:\", len(lines))\nprint(\"Expected: 16 lines (8 headers + 8 sequences)\")\n\nEOF\npython3 check_overhangs.py\n"]
