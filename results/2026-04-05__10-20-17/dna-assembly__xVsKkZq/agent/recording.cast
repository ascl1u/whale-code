[213.43676, "o", "import subprocess\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.436955, "o", "import sys\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.43725, "o", "# Read sequences\r\n\u001b[?2004l\r"]
[213.437361, "o", "\u001b[?2004h> "]
[213.437531, "o", "seqs = {}\r\n\u001b[?2004l\r\r\nif fwd_p:\u001b[?2004h> "]
[213.437905, "o", "current_name = None\r\n\u001b[?2004l\r"]
[213.438087, "o", "\u001b[?2004h> "]
[213.438455, "o", "with open('sequences.fasta', 'r') as f:\r\n\u001b[?2004l\r"]
[213.438747, "o", "\u001b[?2004h> "]
[213.439003, "o", "    for line in f:\r\n\u001b[?2004l\r"]
[213.439261, "o", "\u001b[?2004h> "]
[213.43966, "o", "        line = line.strip()\r\n\u001b[?2004l\r"]
[213.439782, "o", "\u001b[?2004h> "]
[213.440408, "o", "        if line.startswith('>'):\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.440646, "o", "> "]
[213.441059, "o", "            current_name = line[1:]\r\n\u001b[?2004l\r"]
[213.44133, "o", "\u001b[?2004h> "]
[213.441573, "o", "            seqs[current_name] = ''\r\n\u001b[?2004l\r"]
[213.441723, "o", "\u001b[?2004h> "]
[213.441948, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.442082, "o", "> "]
[213.442476, "o", "            seqs[current_name] += line\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.44276, "o", "\r\n\u001b[?2004l\r(\u001b[?2004h> "]
[213.443243, "o", "def reverse_complement(seq):\r\n\u001b[?2004l\r"]
[213.443397, "o", "\u001b[?2004h> "]
[213.444753, "o", "    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G', 'a': 't', 't': 'a', 'g': 'c', 'c': 'g'}\r\n\u001b[?2004l\r"]
[213.444903, "o", "\u001b[?2004h> "]
[213.445613, "o", "    return ''.join(complement[base] for base in reversed(seq))\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.44576, "o", "> \r\n\u001b[?2004l\ra\u001b[?2004h> "]
[213.446034, "o", "def calc_tm(seq):\r\n\u001b[?2004l\r \u001b[?2004h"]
[213.446459, "o", "> "]
[213.44668, "o", "    \"\"\"Calculate Tm using oligotm\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.448248, "o", "    cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.449007, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.449703, "o", "    return float(result.stdout.strip())\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.44982, "o", "> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[213.451962, "o", "def find_primer_length(template, start_pos, direction='forward', target_tm_min=58, target_tm_max=72, min_len=15, max_len=45):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.452799, "o", "    \"\"\"Find optimal primer length for target Tm range\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.452969, "o", "> "]
[213.453519, "o", "    for length in range(min_len, max_len + 1):\r\n\u001b[?2004l\ra\u001b[?2004h"]
[213.453721, "o", "> "]
[213.454012, "o", "        if direction == 'forward':\r\n\u001b[?2004l\r"]
[213.454238, "o", "\u001b[?2004h> "]
[213.454794, "o", "            primer_seq = template[start_pos:start_pos + length]\r\n\u001b[?2004l\ra\u001b[?2004h"]
[213.455008, "o", "> "]
[213.455209, "o", "        else:  # reverse\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.455938, "o", "            primer_seq = template[start_pos - length + 1:start_pos + 1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.456125, "o", ">         \r\n\u001b[?2004l\rFR\u001b[?2004h"]
[213.456268, "o", "> "]
[213.456665, "o", "        if len(primer_seq) < length:\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.456814, "o", ">             continue\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.457301, "o", "        tm = calc_tm(primer_seq)\r\n\u001b[?2004l\rT\u001b[?2004h> "]
[213.458186, "o", "        if target_tm_min <= tm <= target_tm_max:\r\n\u001b[?2004l\r"]
[213.458401, "o", "\u001b[?2004h> "]
[213.459039, "o", "            return primer_seq, tm, length\r\n\u001b[?2004l\r"]
[213.459225, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\rwd_p,"]
[213.459461, "o", "\u001b[?2004h> "]
[213.460152, "o", "    # If no perfect match, return the closest\r\n\u001b[?2004l\r"]
[213.460328, "o", "\u001b[?2004h> "]
[213.460819, "o", "    if direction == 'forward':\r\n\u001b[?2004l\r"]
[213.460908, "o", "\u001b[?2004h> "]
[213.462196, "o", "        primer_seq = template[start_pos:start_pos + max_len]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.46242, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.463731, "o", "        primer_seq = template[start_pos - max_len + 1:start_pos + 1]\r\n\u001b[?2004l\r"]
[213.463975, "o", "\u001b[?2004h> "]
[213.464399, "o", "    tm = calc_tm(primer_seq)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.464941, "o", "    return primer_seq, tm, len(primer_seq)\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.465107, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.466291, "o", "def design_primer_pair(template, fwd_start, rev_end, fwd_overhang, rev_overhang, name):\r\n\u001b[?2004l\r"]
[213.466515, "o", "\u001b[?2004h> "]
