[250.544745, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.544914, "o", "# Check primer pairs\r\n\u001b[?2004l\r\u001b[?2004h"]
[250.545137, "o", "> print(\"\\n\" + \"=\"*70)\r\n\u001b[?2004l\r\u001b[?2004h"]
[250.545341, "o", "> print(\"Checking primer pairs...\\n\")\r\n\u001b[?2004l\r"]
[250.545538, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.545881, "o", "for template in ['input', 'egfp', 'flag', 'snap']:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.546101, "o", "    fwd_name = f\"{template}_fwd\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.546307, "o", "    rev_name = f\"{template}_rev\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.546506, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.5467, "o", "    if fwd_name in primers and rev_name in primers:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.546939, "o", "        fwd_binding = primers[fwd_name][11:]\r\n\u001b[?2004l\r\u001b[?2004h"]
[250.547158, "o", "> "]
[250.547347, "o", "        rev_binding = primers[rev_name][11:]\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[250.547448, "o", "\u001b[?2004h> "]
[250.54768, "o", "        fwd_tm = calc_tm(fwd_binding)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.547865, "o", "        rev_tm = calc_tm(rev_binding)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.548007, "o", "        tm_diff = abs(fwd_tm - rev_tm)\r\n\u001b[?2004l\r\u001b[?2004h"]
[250.548111, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.548321, "o", "        print(f\"{template}:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.54859, "o", "        print(f\"  Forward Tm: {fwd_tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.548865, "o", "        print(f\"  Reverse Tm: {rev_tm:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[250.549034, "o", "> "]
[250.549239, "o", "        print(f\"  ΔTm: {tm_diff:.2f}°C\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.549347, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.549577, "o", "        if tm_diff <= 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.549793, "o", "            print(f\"  Pair Tm difference: ✓ (≤5°C)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.549973, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.550271, "o", "            print(f\"  Pair Tm difference: ✗ (should be ≤5°C)\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[250.550457, "o", ">         print()\r\n\u001b[?2004l\r"]
[250.550649, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"=\"*70)\r\n\u001b[?2004l\r"]
