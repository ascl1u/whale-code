[99.226542, "i", "cat > check_junctions.py << 'EOF'\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\n# Find egfp in output\negfp_start = seqs['output'].find(seqs['egfp'][:30])\nprint(f\"egfp starts at: {egfp_start}\")\n\n# Check what comes after egfp\negfp_end = egfp_start + len(seqs['egfp'])\nprint(f\"egfp ends at: {egfp_end}\")\nprint(f\"\\nLast 30bp of egfp in file:\")\nprint(seqs['egfp'][-30:])\nprint(f\"\\nLast 30bp of egfp in output:\")\nprint(seqs['output'][egfp_end-30:egfp_end])\nprint(f\"\\nNext 90bp after egfp in output:\")\nprint(seqs['output'][egfp_end:egfp_end+90])\n\nprint(f\"\\nflag sequence:\")\nprint(seqs['flag'])\n\n# Check if flag without stop codon\nflag_no_stop = seqs['flag'][:-3]  # Remove TAA stop\nprint(f\"\\nflag without stop codon:\")\nprint(flag_no_stop)\nprint(f\"Is it in output? {flag_no_stop in seqs['output']}\")\n\n# Check snap\nprint(f\"\\nsnap sequence ends with:\")\nprint(seqs['snap'][-30:])\nsnap_no_stop = seqs['snap'][:-3]  # Remove TAA stop\nprint(f\"\\nsnap without stop codon ends with:\")\nprint(snap_no_stop[-30:])\nprint(f\"Is it in output? {snap_no_stop in seqs['output']}\")\n\nEOF\npython3 check_junctions.py\n"]
