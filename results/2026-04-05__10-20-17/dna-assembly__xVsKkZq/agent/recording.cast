[87.02717, "o", "Sequence lengths:\r\n  input: 2727 bp\r\n  egfp: 717 bp\r\n  flag: 90 bp\r\n  snap: 549 bp\r\n  output: 3591 bp\r\n"]
[87.027438, "o", "\r\negfp in output: False\r\nflag in output: False\r\nsnap in output: False\r\n\r\negfp starts with: atgagcaagggcgaggagctgttcaccggg\r\nflag starts with: atgggtagtggctccggtagcggtagcggc\r\nsnap starts with: atggacaaagactgcgaaatgaagcgcacc\r\n\r\negfp start found at position: 210\r\n  Context: ...tttaagaaggagatatacat[atgagcaagggcgaggagctgttcaccggg]...\r\n\r\nflag start found at position: -1\r\n\r\nsnap start found at position: -1\r\n"]
