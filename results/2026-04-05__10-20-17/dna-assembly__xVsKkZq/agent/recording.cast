[180.413851, "o", "======================================================================\r\nGOLDEN GATE ASSEMBLY PRIMER DESIGN\r\n======================================================================\r\n\r\nOverhangs:\r\n  OH1 (vector->egfp): ATGA\r\n  OH2 (egfp->flag): AGTG\r\n  OH3 (flag->snap): GACA\r\n  OH4 (snap->vector): TGAG\r\n\r\n======================================================================\r\nFRAGMENT 1: INPUT VECTOR BACKBONE\r\n======================================================================\r\n\r\nLooking for: tgaggatcccgggaattctc\r\nFound at input position: 690\r\n\r\nLooking for: tttaagaaggagatatacat\r\nFound at input position: 190\r\nThis ends at: 210\r\n"]
[180.419977, "o", "\u001b[?2004hroot@11eec39dc770:/app# "]
[213.435198, "i", "cat > final_primer_design.py << 'ENDOFSCRIPT'\nimport subprocess\nimport sys\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\ndef reverse_complement(seq):\n    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G', 'a': 't', 't': 'a', 'g': 'c', 'c': 'g'}\n    return ''.join(complement[base] for base in reversed(seq))\n\ndef calc_tm(seq):\n    \"\"\"Calculate Tm using oligotm\"\"\"\n    cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    return float(result.stdout.strip())\n\ndef find_primer_length(template, start_pos, direction='forward', target_tm_min=58, target_tm_max=72, min_len=15, max_len=45):\n    \"\"\"Find optimal primer length for target Tm range\"\"\"\n    for length in range(min_len, max_len + 1):\n        if direction == 'forward':\n            primer_seq = template[start_pos:start_pos + length]\n        else:  # reverse\n            primer_seq = template[start_pos - length + 1:start_pos + 1]\n        \n        if len(primer_seq) < length:\n            continue\n            \n        tm = calc_tm(primer_seq)\n        if target_tm_min <= tm <= target_tm_max:\n            return primer_seq, tm, length\n    \n    # If no perfect match, return the closest\n    if direction == 'forward':\n        primer_seq = template[start_pos:start_pos + max_len]\n    else:\n        primer_seq = template[start_pos - max_len + 1:start_pos + 1]\n    tm = calc_tm(primer_seq)\n    return primer_seq, tm, len(primer_seq)\n\ndef design_primer_pair(template, fwd_start, rev_end, fwd_overhang, rev_overhang, name):\n    \"\"\"Design a primer pair with BsaI sites and overhangs\"\"\"\n    print(f\"\\nDesigning primers for {name}...\")\n    \n    # Find optimal forward primer\n    best_fwd = None\n    best_rev = None\n    best_tm_diff = 100\n    \n    for fwd_len in range(15, 46):\n        fwd_binding = template[fwd_start:fwd_start + fwd_len]\n        if len(fwd_binding) < fwd_len:\n            continue\n        fwd_tm = calc_tm(fwd_binding)\n        \n        if not (58 <= fwd_tm <= 72):\n            continue\n        \n        for rev_len in range(15, 46):\n            rev_binding = template[rev_end - rev_len + 1:rev_end + 1]\n            if len(rev_binding) < rev_len:\n                continue\n            rev_tm = calc_tm(rev_binding)\n            \n            if not (58 <= rev_tm <= 72):\n                continue\n            \n            tm_diff = abs(fwd_tm - rev_tm)\n            if tm_diff <= 5 and tm_diff < best_tm_diff:\n                best_tm_diff = tm_diff\n                best_fwd = (fwd_binding, fwd_tm, fwd_len)\n                best_rev = (rev_binding, rev_tm, rev_len)\n    \n    if best_fwd and best_rev:\n        # Build full primers with BsaI sites\n        fwd_primer = \"GGTCTCN\" + fwd_overhang + best_fwd[0]\n        rev_primer_binding_rc = reverse_complement(best_rev[0])\n        rev_overhang_rc = reverse_complement(rev_overhang)\n        rev_primer = \"GAGACCN\" + rev_overhang_rc + rev_primer_binding_rc\n        \n        print(f\"  Forward: {best_fwd[1]:.2f}°C (binding: {best_fwd[2]}bp)\")\n        print(f\"  Reverse: {best_rev[1]:.2f}°C (binding: {best_rev[2]}bp)\")\n        print(f\"  ΔTm: {best_tm_diff:.2f}°C\")\n        \n        return fwd_primer, rev_primer, best_fwd[1], best_rev[1]\n    else:\n        print(f\"  WARNING: Could not find optimal pair within constraints\")\n        return None, None, None, None\n\noutput = seqs['output']\ninput_seq = seqs['input']\n\nprint(\"=\"*70)\nprint(\"DESIGNING PRIMERS FOR GOLDEN GATE ASSEMBLY\")\nprint(\"=\"*70)\n\nprimers = []\n\n# Fragment 1: INPUT VECTOR (linearized backbone)\nprint(\"\\n\" + \"=\"*70)\nprint(\"FRAGMENT 1: INPUT VECTOR BACKBONE\")\nprint(\"=\"*70)\n# Amplify from position 690 (after insert) to position 210 (before insert)\n# Forward at 690, creates TGAG overhang\n# Reverse at 210, creates ATGA overhang (so vector -> egfp)\nfwd_p, r"]
[213.435322, "i", "ev_p, fwd_tm, rev_tm = design_primer_pair(\n    input_seq, 690, 209, \"TGAG\", \"ATGA\", \"input\"\n)\nif fwd_p:\n    primers.append((\"input_fwd\", fwd_p))\n    primers.append((\"input_rev\", rev_p))\n\n# Fragment 2: EGFP\nprint(\"\\n\" + \"=\"*70)\nprint(\"FRAGMENT 2: EGFP\")\nprint(\"=\"*70)\n# Amplify egfp, but modify the stop codon\n# Forward at start, creates ATGA overhang\n# Reverse at end (before stop), creates AGTG overhang\n# Need to handle the TAA->GGT conversion\negfp_seq = seqs['egfp']\negfp_no_stop = egfp_seq[:-3]  # Remove TAA\nfwd_p, rev_p, fwd_tm, rev_tm = design_primer_pair(\n    egfp_seq, 0, len(egfp_no_stop) - 1, \"ATGA\", \"AGTG\", \"egfp\"\n)\nif fwd_p:\n    primers.append((\"egfp_fwd\", fwd_p))\n    primers.append((\"egfp_rev\", rev_p))\n\n# Fragment 3: FLAG\nprint(\"\\n\" + \"=\"*70)\nprint(\"FRAGMENT 3: FLAG\")\nprint(\"=\"*70)\n# Amplify flag without ATG and without stop\n# Forward at position 3 (skip ATG), creates AGTG overhang\n# Reverse at end-3 (skip stop), creates GACA overhang\nflag_seq = seqs['flag']\nflag_no_atg_stop = flag_seq[3:-3]\nfwd_p, rev_p, fwd_tm, rev_tm = design_primer_pair(\n    flag_seq, 3, len(flag_seq) - 4, \"AGTG\", \"GACA\", \"flag\"\n)\nif fwd_p:\n    primers.append((\"flag_fwd\", fwd_p))\n    primers.append((\"flag_rev\", rev_p))\n\n# Fragment 4: SNAP\nprint(\"\\n\" + \"=\"*70)\nprint(\"FRAGMENT 4: SNAP\")\nprint(\"=\"*70)\n# Amplify snap without ATG but keep stop\n# Forward at position 3 (skip ATG), creates GACA overhang\n# Reverse at end, creates TGAG overhang\nsnap_seq = seqs['snap']\nfwd_p, rev_p, fwd_tm, rev_tm = design_primer_pair(\n    snap_seq, 3, len(snap_seq) - 1, \"GACA\", \"TGAG\", \"snap\"\n)\nif fwd_p:\n    primers.append((\"snap_fwd\", fwd_p))\n    primers.append((\"snap_rev\", rev_p))\n\n# Write to file\nprint(\"\\n\" + \"=\"*70)\nprint(\"WRITING PRIMERS TO primers.fasta\")\nprint(\"=\"*70)\n\nwith open('primers.fasta', 'w') as f:\n    for name, seq in primers:\n        f.write(f\">{name}\\n{seq.upper()}\\n\")\n\nprint(f\"\\nWrote {len(primers)} primers to primers.fasta\")\n\nENDOFSCRIPT\npython3 final_primer_design.py\n"]
