[213.497938, "o", "    egfp_seq, 0, len(egfp_no_stop) - 1, \"ATGA\", \"AGTG\", \"egfp\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.49812, "o", ")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.498296, "o", "if fwd_p:\r\n\u001b[?2004l\r\u001b[?2004h> "]
