[213.48616, "o", "                best_rev = (rev_binding, rev_tm, rev_len)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.486357, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.486521, "o", "    if best_fwd and best_rev:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.486711, "o", "        # Build full primers with BsaI sites\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.487046, "o", "        fwd_primer = \"GGTCTCN\" + fwd_overhang + best_fwd[0]\r\n\u001b[?2004l\r"]
[213.487222, "o", "\u001b[?2004h> "]
