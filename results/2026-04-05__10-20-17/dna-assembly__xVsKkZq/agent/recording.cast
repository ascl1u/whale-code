[213.482902, "o", "        for rev_len in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.483235, "o", "            rev_binding = template[rev_end - rev_len + 1:rev_end + 1]\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.483404, "o", "> "]
[213.483573, "o", "            if len(rev_binding) < rev_len:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.483724, "o", "                continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.483967, "o", "            rev_tm = calc_tm(rev_binding)\r\n\u001b[?2004l\r\u001b[?2004h"]
[213.48415, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.484316, "o", "            if not (58 <= rev_tm <= 72):\r\n\u001b[?2004l\r"]
[213.484477, "o", "\u001b[?2004h>                 continue\r\n\u001b[?2004l\r"]
[213.484691, "o", "\u001b[?2004h> "]
[213.484851, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
