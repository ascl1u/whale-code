[351.069253, "o", "\u001b[?2004h> "]
[351.070008, "o", "    if len(parts) != 2 or parts[0] not in ['input', 'egfp', 'flag', 'snap'] or parts[1] not in ['fwd', 'rev']:\r\n\u001b[?2004l\r"]
[351.070302, "o", "\u001b[?2004h>         header_ok = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.070708, "o", "checks.append((\"Header format (TEMPLATENAME_DIR)\", header_ok, \"All correct\"))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[351.070953, "o", "\u001b[?2004h> "]
[351.071245, "o", "# 3. Check for blank lines\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.071622, "o", "with open('primers.fasta', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.071926, "o", "    content = f.read()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.072182, "o", "no_blanks = '\\n\\n' not in content\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.072496, "o", "checks.append((\"No blank lines\", no_blanks, \"Clean file\"))\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.072842, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.072988, "o", "# 4. Check BsaI sites\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.073621, "o", "bsai_ok = all(seq.startswith('GGTCTCN') or seq.startswith('GAGACCN') for seq in primers.values())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.07406, "o", "checks.append((\"BsaI-HFv2 sites present\", bsai_ok, \"All primers\"))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[351.074214, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[351.074465, "o", "# 5. Check binding region lengths\r\n\u001b[?2004l\r"]
[351.074606, "o", "\u001b[?2004h> "]
[351.074984, "o", "lengths_ok = True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.075125, "o", "for seq in primers.values():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.075576, "o", "    binding_len = len(seq) - 11  # Remove BsaI site + spacer + overhang\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.0758, "o", "> "]
[351.075973, "o", "    if not (15 <= binding_len <= 45):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.076181, "o", "        lengths_ok = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.07663, "o", "checks.append((\"Binding regions 15-45bp\", lengths_ok, \"All in range\"))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.076979, "o", "# 6. Check Tm values\r\n\u001b[?2004l\r\u001b[?2004h> tm_ok = True\r\n\u001b[?2004l\r"]
[351.077331, "o", "\u001b[?2004h> "]
[351.077622, "o", "for seq in primers.values():\r\n\u001b[?2004l\r\u001b[?2004h>     binding = seq[11:]\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.077814, "o", "> "]
[351.078057, "o", "    tm = calc_tm(binding)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.078244, "o", "    if not (58 <= tm <= 72):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.078545, "o", "        tm_ok = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.079242, "o", "checks.append((\"Tm values 58-72°C\", tm_ok, \"All in range\"))\r\n\u001b[?2004l\r"]
[351.079511, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[351.079667, "o", "\u001b[?2004h> "]
[351.079905, "o", "# 7. Check primer pair Tm differences\r\n\u001b[?2004l\r\u001b[?2004h> pair_tm_ok = True\r\n\u001b[?2004l\r"]
[351.08028, "o", "\u001b[?2004h> "]
[351.080587, "o", "for template in ['input', 'egfp', 'flag', 'snap']:\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.080803, "o", "> "]
[351.081009, "o", "    fwd = primers[f\"{template}_fwd\"][11:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.081375, "o", "    rev = primers[f\"{template}_rev\"][11:]\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.081605, "o", "> "]
[351.081791, "o", "    tm_diff = abs(calc_tm(fwd) - calc_tm(rev))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.082023, "o", "    if tm_diff > 5:\r\n\u001b[?2004l\r"]
[351.082231, "o", "\u001b[?2004h>         pair_tm_ok = False\r\n\u001b[?2004l\r"]
[351.082505, "o", "\u001b[?2004h> "]
[351.08272, "o", "checks.append((\"Primer pairs ΔTm ≤ 5°C\", pair_tm_ok, \"All pairs matched\"))\r\n\u001b[?2004l\r"]
[351.082981, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.083243, "o", "# 8. Check overhang compatibility\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.083496, "o", "overhang_ok = True\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.083757, "o", "> oh = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.084053, "o", "    'input_fwd': 'TGAG', 'input_rev': 'TCAT',  # RC of ATGA\r\n\u001b[?2004l\r"]
[351.084334, "o", "\u001b[?2004h> "]
[351.084637, "o", "    'egfp_fwd': 'ATGA', 'egfp_rev': 'CACT',   # RC of AGTG\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.084911, "o", "    'flag_fwd': 'AGTG', 'flag_rev': 'TGTC',   # RC of GACA\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.085355, "o", "    'snap_fwd': 'GACA', 'snap_rev': 'CTCA'    # RC of TGAG\r\n\u001b[?2004l\r"]
[351.085587, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.085813, "o", "> for name, expected_oh in oh.items():\r\n\u001b[?2004l\r"]
[351.08617, "o", "\u001b[?2004h> "]
[351.086332, "o", "    actual_oh = primers[name][7:11]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.086588, "o", "    if actual_oh != expected_oh:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.086675, "o", "        overhang_ok = False\r\n\u001b[?2004l\r"]
[351.086895, "o", "\u001b[?2004h> "]
[351.087427, "o", "checks.append((\"Correct overhangs for assembly\", overhang_ok, \"Circular compatible\"))\r\n\u001b[?2004l\r"]
[351.087734, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.087899, "o", "# Print results\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.088153, "o", "all_passed = True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.08844, "o", "for check_name, passed, detail in checks:\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.088563, "o", "> "]
[351.088787, "o", "    status = \"✓\" if passed else \"✗\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.089032, "o", "    print(f\"{status} {check_name}: {detail}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.089374, "o", "    if not passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.089673, "o", "        all_passed = False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[351.089947, "o", "print(\"\\n\" + \"=\"*70)\r\n\u001b[?2004l\r\u001b[?2004h> if all_passed:\r\n\u001b[?2004l\r"]
[351.090221, "o", "\u001b[?2004h> "]
[351.090575, "o", "    print(\"✓✓✓ ALL REQUIREMENTS MET - primers.fasta is ready! ✓✓✓\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.090811, "o", "> else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.090974, "o", "> "]
[351.091068, "o", "    print(\"✗ Some requirements not met\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[351.091216, "o", "> print(\"=\"*70)\r\n\u001b[?2004l\r"]
[351.091516, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[351.091625, "o", "> EOF\r\n\u001b[?2004l\r"]
[351.094113, "o", "\u001b[?2004hroot@11eec39dc770:/app# "]
[351.094401, "o", "python3 final_check.py\r\n\u001b[?2004l\r"]
[351.124216, "o", "FINAL VALIDATION CHECKLIST\r\n======================================================================\r\n"]
[351.151695, "o", "✓ Minimum number of primer pairs: 4 pairs\r\n✓ Header format (TEMPLATENAME_DIR): All correct\r\n✓ No blank lines: Clean file\r\n✓ BsaI-HFv2 sites present: All primers\r\n"]
[351.151932, "o", "✓ Binding regions 15-45bp: All in range\r\n✓ Tm values 58-72°C: All in range\r\n✓ Primer pairs ΔTm ≤ 5°C: All pairs matched\r\n✓ Correct overhangs for assembly: Circular compatible\r\n\r\n======================================================================\r\n✓✓✓ ALL REQUIREMENTS MET - primers.fasta is ready! ✓✓✓\r\n"]
[351.152197, "o", "======================================================================\r\n"]
[351.183597, "o", "\u001b[?2004hroot@11eec39dc770:/app# "]
[363.362951, "i", "rm final_check.py; printf '%s\\n' '__CMDEND__12__'\n"]
[363.363572, "o", "rm final_check.py; printf '%s\\n' '__CMDEND__12__'\r\n\u001b[?2004l\r"]
[363.365825, "o", "__CMDEND__12__\r\n\u001b[?2004hroot@11eec39dc770:/app# "]
