[250.550991, "o", "print(f\"\\nTotal primers: {len(primers)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[250.551157, "o", "print(\"All checks complete!\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
