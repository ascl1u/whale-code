[213.497153, "o", "egfp_seq = seqs['egfp']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.497403, "o", "egfp_no_stop = egfp_seq[:-3]  # Remove TAA\r\n\u001b[?2004l\r\u001b[?2004h> "]
