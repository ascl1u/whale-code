[213.467883, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.468128, "o", "    # Find optimal forward primer\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.468362, "o", "    best_fwd = None\r\n\u001b[?2004l\r\u001b[?2004h>     best_rev = None\r\n\u001b[?2004l\r"]
[213.468647, "o", "\u001b[?2004h>     best_tm_diff = 100\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.468759, "o", "    for fwd_len in range(15, 46):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[213.481623, "o", "        fwd_binding = template[fwd_start:fwd_start + fwd_len]\r\n\u001b[?2004l\r\u001b[?2004h>         if len(fwd_binding) < fwd_len:\r\n\u001b[?2004l\r"]
