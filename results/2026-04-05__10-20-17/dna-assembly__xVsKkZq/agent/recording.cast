[351.059037, "i", "cat > final_check.py << 'EOF'\nimport subprocess\n\n# Read primers\nprimers = {}\nwith open('primers.fasta', 'r') as f:\n    lines = [l.rstrip('\\n') for l in f]\n    for i in range(0, len(lines), 2):\n        name = lines[i][1:]\n        seq = lines[i+1]\n        primers[name] = seq\n\ndef calc_tm(seq):\n    cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    return float(result.stdout.strip())\n\nprint(\"FINAL VALIDATION CHECKLIST\")\nprint(\"=\"*70)\n\nchecks = []\n\n# 1. Check number of primers\nnum_primers = len(primers)\nchecks.append((\"Minimum number of primer pairs\", num_primers == 8, f\"{num_primers//2} pairs\"))\n\n# 2. Check header format\nheader_ok = True\nfor name in primers.keys():\n    parts = name.split('_')\n    if len(parts) != 2 or parts[0] not in ['input', 'egfp', 'flag', 'snap'] or parts[1] not in ['fwd', 'rev']:\n        header_ok = False\nchecks.append((\"Header format (TEMPLATENAME_DIR)\", header_ok, \"All correct\"))\n\n# 3. Check for blank lines\nwith open('primers.fasta', 'r') as f:\n    content = f.read()\nno_blanks = '\\n\\n' not in content\nchecks.append((\"No blank lines\", no_blanks, \"Clean file\"))\n\n# 4. Check BsaI sites\nbsai_ok = all(seq.startswith('GGTCTCN') or seq.startswith('GAGACCN') for seq in primers.values())\nchecks.append((\"BsaI-HFv2 sites present\", bsai_ok, \"All primers\"))\n\n# 5. Check binding region lengths\nlengths_ok = True\nfor seq in primers.values():\n    binding_len = len(seq) - 11  # Remove BsaI site + spacer + overhang\n    if not (15 <= binding_len <= 45):\n        lengths_ok = False\nchecks.append((\"Binding regions 15-45bp\", lengths_ok, \"All in range\"))\n\n# 6. Check Tm values\ntm_ok = True\nfor seq in primers.values():\n    binding = seq[11:]\n    tm = calc_tm(binding)\n    if not (58 <= tm <= 72):\n        tm_ok = False\nchecks.append((\"Tm values 58-72°C\", tm_ok, \"All in range\"))\n\n# 7. Check primer pair Tm differences\npair_tm_ok = True\nfor template in ['input', 'egfp', 'flag', 'snap']:\n    fwd = primers[f\"{template}_fwd\"][11:]\n    rev = primers[f\"{template}_rev\"][11:]\n    tm_diff = abs(calc_tm(fwd) - calc_tm(rev))\n    if tm_diff > 5:\n        pair_tm_ok = False\nchecks.append((\"Primer pairs ΔTm ≤ 5°C\", pair_tm_ok, \"All pairs matched\"))\n\n# 8. Check overhang compatibility\noverhang_ok = True\noh = {\n    'input_fwd': 'TGAG', 'input_rev': 'TCAT',  # RC of ATGA\n    'egfp_fwd': 'ATGA', 'egfp_rev': 'CACT',   # RC of AGTG\n    'flag_fwd': 'AGTG', 'flag_rev': 'TGTC',   # RC of GACA\n    'snap_fwd': 'GACA', 'snap_rev': 'CTCA'    # RC of TGAG\n}\nfor name, expected_oh in oh.items():\n    actual_oh = primers[name][7:11]\n    if actual_oh != expected_oh:\n        overhang_ok = False\nchecks.append((\"Correct overhangs for assembly\", overhang_ok, \"Circular compatible\"))\n\n# Print results\nall_passed = True\nfor check_name, passed, detail in checks:\n    status = \"✓\" if passed else \"✗\"\n    print(f\"{status} {check_name}: {detail}\")\n    if not passed:\n        all_passed = False\n\nprint(\"\\n\" + \"=\"*70)\nif all_passed:\n    print(\"✓✓✓ ALL REQUIREMENTS MET - primers.fasta is ready! ✓✓✓\")\nelse:\n    print(\"✗ Some requirements not met\")\nprint(\"=\"*70)\n\nEOF\npython3 final_check.py\n"]
[351.059661, "o", "cat > final_check.py << 'EOF'\r\n\u001b[?2004l\r"]
