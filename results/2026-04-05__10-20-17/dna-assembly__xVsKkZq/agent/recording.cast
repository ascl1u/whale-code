[131.857322, "o", "> print(\"=\"*60)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[131.85761, "o", "\u001b[?2004h> "]
[131.857898, "o", "# Find in input where the break is\r\n\u001b[?2004l\r"]
[131.858094, "o", "\u001b[?2004h> "]
[131.858325, "o", "input_seq = seqs['input']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.858498, "o", "output_seq = seqs['output']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[131.858722, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[131.858941, "o", "# The output before position 210\r\n\u001b[?2004l\r"]
[131.859075, "o", "\u001b[?2004h> before = output_seq[:210]\r\n\u001b[?2004l\r"]
[131.859404, "o", "\u001b[?2004h> "]
[131.859654, "o", "print(f\"\\nBefore insert (0-210): {len(before)} bp\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.85997, "o", "print(f\"  Ends with: {before[-20:]}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[131.860083, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[131.860418, "o", "# After snap\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.860557, "o", "after_start = 1557\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.860813, "o", "after = output_seq[after_start:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.861179, "o", "print(f\"\\nAfter insert ({after_start}-end): {len(after)} bp\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.861559, "o", "print(f\"  Starts with: {after[:20]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.86171, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.861958, "o", "# Find these in input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.862244, "o", "if before in input_seq:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.862486, "o", "    print(f\"\\nBefore sequence found in input: YES\")\r\n\u001b[?2004l\r"]
[131.862784, "o", "\u001b[?2004h> else:\r\n\u001b[?2004l\r"]
[131.863012, "o", "\u001b[?2004h>     # Try last 50bp\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.863156, "o", "    if before[-50:] in input_seq:\r\n\u001b[?2004l\r"]
[131.863464, "o", "\u001b[?2004h> "]
[131.863712, "o", "        pos = input_seq.find(before[-50:])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.863955, "o", "        print(f\"\\nLast 50bp of before found in input at: {pos}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.864352, "o", "        print(f\"  Input continues with: {input_seq[pos+50:pos+70]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.864556, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.864773, "o", "if after[:50] in input_seq:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.865024, "o", "    pos = input_seq.find(after[:50])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.865364, "o", "    print(f\"\\nFirst 50bp of after found in input at: {pos}\")\r\n\u001b[?2004l\r"]
[131.881705, "o", "\u001b[?2004h> "]
[131.882124, "o", "    print(f\"  Input before this: {input_seq[pos-20:pos]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.882391, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[131.884752, "o", "\u001b[?2004hroot@11eec39dc770:/app# "]
[131.885028, "o", "python3 map_exact.py\r\n\u001b[?2004l\r"]
[131.901599, "o", "Checking egfp:\r\n  Modified egfp found at: 210\r\n  Ends at: 927\r\n  Last 10bp: gtacaaaggt\r\n  Next 30bp: agtggctccggtagcggtagcggcagcgac\r\n\r\nChecking flag (no ATG, no stop):\r\n  Looking for: ggtagtggctccggtagcggtagcggcagc\r\n  Found at: 924\r\n"]
[131.901966, "o", "  Ends at: 1008\r\n  Last 10bp: tagtggttca\r\n  Next 30bp: gacaaagactgcgaaatgaagcgcaccacc\r\n\r\nChecking snap (no ATG):\r\n  Looking for: gacaaagactgcgaaatgaagcgcaccacc\r\n  Found at: 1008\r\n  Ends at: 1554\r\n  Last 10bp: gctgggttaa\r\n  Next 30bp: tgaggatcccgggaattctcgagtaaggtt\r\n\r\n============================================================\r\nASSEMBLY STRUCTURE:\r\n============================================================\r\n\r\nBefore insert (0-210): 210 bp\r\n  Ends with: tttaagaaggagatatacat\r\n\r\nAfter insert (1557-end): 2034 bp\r\n  Starts with: ggatcccgggaattctcgag\r\n\r\nBefore sequence found in input: YES\r\n\r\nFirst 50bp of after found in input at: 693\r\n  Input before this: ttctggagcggcggtaatga\r\n"]
[131.90553, "o", "\u001b[?2004hroot@11eec39dc770:/app# "]
[155.696366, "i", "cat > design_gg_primers.py << 'EOF'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\ndef reverse_complement(seq):\n    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G', 'a': 't', 't': 'a', 'g': 'c', 'c': 'g'}\n    return ''.join(complement[base] for base in reversed(seq))\n\ndef calc_tm(seq):\n    \"\"\"Calculate Tm using oligotm\"\"\"\n    cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq.upper()]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    return float(result.stdout.strip())\n\nprint(\"Golden Gate Assembly Design\")\nprint(\"=\"*60)\n\n# Assembly order:\n# Vector_upstream -> egfp -> flag -> snap -> Vector_downstream\n\n# The junctions in the output:\n# Position 210: ...atatacat|atgagcaa... (vector -> egfp)\n# Position 927: ...acaaaggt|agtggctc... (egfp -> flag, with 3bp overlap)\n# Position 1008: ...tggttca|gacaaaga... (flag -> snap)\n# Position 1554: ...gggttaa|tgaggatc... (snap -> vector)\n\n# For the input vector, we need to remove the section from ~210 to ~693\n# and add BsaI sites\n\n# Extract the junction sequences (4bp overhangs)\noutput = seqs['output']\n\n# Overhang 1: vector to egfp (position 210)\noverhang1 = output[210:214].upper()  # ATGA\nprint(f\"Overhang 1 (vector->egfp): {overhang1}\")\n\n# Overhang 2: egfp to flag  \n# egfp ends at 927 with ...ggt\n# flag starts at 924 with ggt...\n# The junction is at 927: ggt|agt\noverhang2 = output[927:931].upper()  # AGTG\nprint(f\"Overhang 2 (egfp->flag): {overhang2}\")\n\n# Overhang 3: flag to snap (position 1008)\noverhang3 = output[1008:1012].upper()  # GACA\nprint(f\"Overhang 3 (flag->snap): {overhang3}\")\n\n# Overhang 4: snap to vector (position 1554)\noverhang4 = output[1554:1558].upper()  # TGAG\nprint(f\"Overhang 4 (snap->vector): {overhang4}\")\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"PRIMER DESIGN\")\nprint(\"=\"*60)\n\n# For BsaI-HFv2:\n# Recognition: GGTCTC\n# Cuts after: GGTCTC(N)1/5 - leaves 4bp overhang\n# Forward primer: GGTCTC N [4bp overhang] [template binding]\n# Reverse primer: GAGACC N [4bp overhang RC] [template binding RC]\n\nprint(\"\\nBsaI site: GGTCTC (cuts 1bp downstream on top, 5bp on bottom)\")\nprint(\"This creates a 4bp overhang\")\n\nEOF\npython3 design_gg_primers.py\n"]
