[75.591079, "o", "# Analyze junctions\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.591242, "o", "print(\"Analyzing sequences...\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.591578, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.591858, "o", "# Find where the insert goes in the output\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.59211, "o", "egfp_seq = seqs['egfp']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.592353, "o", "flag_seq = seqs['flag']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.592521, "o", "snap_seq = seqs['snap']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[75.592838, "o", "\u001b[?2004h> "]
[75.593107, "o", "# Find positions in output\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.593403, "o", "egfp_start = seqs['output'].find(egfp_seq)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.593628, "o", "flag_start = seqs['output'].find(flag_seq)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.5939, "o", "snap_start = seqs['output'].find(snap_seq)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.594053, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.594388, "o", "print(f\"In output plasmid:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.594705, "o", "print(f\"  egfp: {egfp_start} to {egfp_start + len(egfp_seq)}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[75.594944, "o", "> "]
[75.59518, "o", "print(f\"  flag: {flag_start} to {flag_start + len(flag_seq)}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.595801, "o", "print(f\"  snap: {snap_start} to {snap_start + len(snap_seq)}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.596073, "o", "# Get junction sequences\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.596315, "o", "print(f\"\\nJunction sequences:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.596888, "o", "print(f\"  Before egfp (output): ...{seqs['output'][egfp_start-10:egfp_start]}|{seqs['output'][egfp_start:egfp_start+10]}...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[75.59719, "o", "> "]
[75.597775, "o", "print(f\"  egfp to flag: ...{seqs['output'][egfp_start+len(egfp_seq)-10:egfp_start+len(egfp_seq)]}|{seqs['output'][flag_start:flag_start+10]}...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.598857, "o", "print(f\"  flag to snap: ...{seqs['output'][flag_start+len(flag_seq)-10:flag_start+len(flag_seq)]}|{seqs['output'][snap_start:snap_start+10]}...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.599901, "o", "print(f\"  After snap: ...{seqs['output'][snap_start+len(snap_seq)-10:snap_start+len(snap_seq)]}|{seqs['output'][snap_start+len(snap_seq):snap_start+len(snap_seq)+10]}...\")\r\n\u001b[?2004l\r"]
[75.600374, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.600441, "o", "# Find what gets removed from input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.600871, "o", "input_seq = seqs['input']\r\n\u001b[?2004l\r\u001b[?2004h> output_seq = seqs['output']\r\n\u001b[?2004l\r"]
[75.601142, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.601387, "o", "# The output before egfp\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.601639, "o", "before_insert = output_seq[:egfp_start]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.601844, "o", "# The output after snap\r\n\u001b[?2004l\r"]
[75.602361, "o", "\u001b[?2004h> "]
[75.60265, "o", "after_insert = output_seq[snap_start + len(snap_seq):]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[75.602951, "o", "\u001b[?2004h> "]
[75.603255, "o", "print(f\"\\nVector backbone junctions:\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.603756, "o", "print(f\"  End of upstream: {before_insert[-20:]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.604175, "o", "print(f\"  Start of downstream: {after_insert[:20]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[75.60445, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[75.607217, "o", "\u001b[?2004hroot@11eec39dc770:/app# "]
[75.607615, "o", "python3 design_primers.py\r\n\u001b[?2004l\r"]
[75.68445, "o", "Analyzing sequences...\r\n\r\nIn output plasmid:\r\n  egfp: -1 to 716\r\n  flag: -1 to 89\r\n  snap: -1 to 548\r\n\r\nJunction sequences:"]
[75.684772, "o", "\r\n  Before egfp (output): ...tgaatactca|...\r\n  egfp to flag: ...agatccgcca|...\r\n  flag to snap: ...aaaaataaac|...\r\n  After snap: ...ccgaggtgaa|gttcgagggc...\r\n\r\nVector backbone junctions:\r\n  End of upstream: acggaaatgttgaatactca\r\n  Start of downstream: gttcgagggcgacaccctgg\r\n"]
[75.691639, "o", "\u001b[?2004hroot@11eec39dc770:/app# "]
[86.987926, "i", "cat > analyze_better.py << 'EOF'\nimport subprocess\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\nprint(\"Sequence lengths:\")\nfor name in ['input', 'egfp', 'flag', 'snap', 'output']:\n    print(f\"  {name}: {len(seqs[name])} bp\")\n\n# Check if egfp is in output\negfp_in_output = seqs['egfp'] in seqs['output']\nflag_in_output = seqs['flag'] in seqs['output']\nsnap_in_output = seqs['snap'] in seqs['output']\n\nprint(f\"\\negfp in output: {egfp_in_output}\")\nprint(f\"flag in output: {flag_in_output}\")\nprint(f\"snap in output: {snap_in_output}\")\n\n# Let's check the start of each\nprint(f\"\\negfp starts with: {seqs['egfp'][:30]}\")\nprint(f\"flag starts with: {seqs['flag'][:30]}\")\nprint(f\"snap starts with: {seqs['snap'][:30]}\")\n\n# Search for these in output\nfor name in ['egfp', 'flag', 'snap']:\n    start_seq = seqs[name][:30]\n    pos = seqs['output'].find(start_seq)\n    print(f\"\\n{name} start found at position: {pos}\")\n    if pos >= 0:\n        print(f\"  Context: ...{seqs['output'][max(0,pos-20):pos]}[{seqs['output'][pos:pos+30]}]...\")\n\nEOF\npython3 analyze_better.py\n"]
