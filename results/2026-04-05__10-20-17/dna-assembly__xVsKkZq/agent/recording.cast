[75.582177, "i", "cat > design_primers.py << 'EOF'\nimport subprocess\nimport re\n\n# Read sequences\nseqs = {}\ncurrent_name = None\nwith open('sequences.fasta', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line.startswith('>'):\n            current_name = line[1:]\n            seqs[current_name] = ''\n        else:\n            seqs[current_name] += line\n\ndef reverse_complement(seq):\n    complement = {'A': 'T', 'T': 'A', 'G': 'C', 'C': 'G'}\n    return ''.join(complement[base] for base in reversed(seq))\n\ndef calc_tm(seq):\n    \"\"\"Calculate Tm using oligotm with specified parameters\"\"\"\n    cmd = ['oligotm', '-tp', '1', '-sc', '1', '-mv', '50', '-dv', '2', '-n', '0.8', '-d', '500', seq]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    return float(result.stdout.strip())\n\n# Analyze junctions\nprint(\"Analyzing sequences...\\n\")\n\n# Find where the insert goes in the output\negfp_seq = seqs['egfp']\nflag_seq = seqs['flag']\nsnap_seq = seqs['snap']\n\n# Find positions in output\negfp_start = seqs['output'].find(egfp_seq)\nflag_start = seqs['output'].find(flag_seq)\nsnap_start = seqs['output'].find(snap_seq)\n\nprint(f\"In output plasmid:\")\nprint(f\"  egfp: {egfp_start} to {egfp_start + len(egfp_seq)}\")\nprint(f\"  flag: {flag_start} to {flag_start + len(flag_seq)}\")\nprint(f\"  snap: {snap_start} to {snap_start + len(snap_seq)}\")\n\n# Get junction sequences\nprint(f\"\\nJunction sequences:\")\nprint(f\"  Before egfp (output): ...{seqs['output'][egfp_start-10:egfp_start]}|{seqs['output'][egfp_start:egfp_start+10]}...\")\nprint(f\"  egfp to flag: ...{seqs['output'][egfp_start+len(egfp_seq)-10:egfp_start+len(egfp_seq)]}|{seqs['output'][flag_start:flag_start+10]}...\")\nprint(f\"  flag to snap: ...{seqs['output'][flag_start+len(flag_seq)-10:flag_start+len(flag_seq)]}|{seqs['output'][snap_start:snap_start+10]}...\")\nprint(f\"  After snap: ...{seqs['output'][snap_start+len(snap_seq)-10:snap_start+len(snap_seq)]}|{seqs['output'][snap_start+len(snap_seq):snap_start+len(snap_seq)+10]}...\")\n\n# Find what gets removed from input\ninput_seq = seqs['input']\noutput_seq = seqs['output']\n\n# The output before egfp\nbefore_insert = output_seq[:egfp_start]\n# The output after snap\nafter_insert = output_seq[snap_start + len(snap_seq):]\n\nprint(f\"\\nVector backbone junctions:\")\nprint(f\"  End of upstream: {before_insert[-20:]}\")\nprint(f\"  Start of downstream: {after_insert[:20]}\")\n\nEOF\npython3 design_primers.py\n"]
