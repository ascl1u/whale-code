[256.164867, "i", "cat > /tmp/fix_numpy_types.py << 'EOF'\nimport os\nimport re\n\n# Define replacements\nreplacements = [\n    (r'\\bn\\.float\\b(?!64|32|16)', 'n.float64'),\n    (r'\\bnp\\.float\\b(?!64|32|16)', 'np.float64'),\n    (r'\\bn\\.complex\\b(?!128|64)', 'n.complex128'),\n    (r'\\bn\\.int\\b(?!64|32|16|8|_)', 'n.int_'),\n]\n\ndef fix_file(filepath):\n    with open(filepath, 'r') as f:\n        content = f.read()\n    \n    original_content = content\n    for pattern, replacement in replacements:\n        content = re.sub(pattern, replacement, content)\n    \n    if content != original_content:\n        with open(filepath, 'w') as f:\n            f.write(content)\n        print(f\"Fixed: {filepath}\")\n        return True\n    return False\n\n# Find and fix all Python files\nfor root, dirs, files in os.walk('/app/pyknotid/pyknotid'):\n    for file in files:\n        if file.endswith('.py'):\n            filepath = os.path.join(root, file)\n            fix_file(filepath)\n\nprint(\"\\nAll numpy type deprecations fixed!\")\nEOF\n"]
