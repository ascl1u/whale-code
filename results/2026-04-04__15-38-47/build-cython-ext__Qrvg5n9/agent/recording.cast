[245.47406, "i", "cat > /tmp/fix_numpy_types.py << 'EOFPY'\nimport os\nimport re\n\ndef fix_numpy_types(filepath):\n    with open(filepath, 'r') as f:\n        content = f.read()\n    \n    original = content\n    \n    # Replace n.float with n.float64 (but not n.float16, n.float32, n.float64, n.float128)\n    content = re.sub(r'\\bn\\.float(?![0-9])', 'n.float64', content)\n    \n    # Replace n.int with n.intp (but not n.int8, n.int16, n.int32, n.int64)\n    content = re.sub(r'\\bn\\.int(?![0-9_])', 'n.intp', content)\n    \n    # Replace n.complex with n.complex128 (but not n.complex64, n.complex128, n.complex256)\n    content = re.sub(r'\\bn\\.complex(?![0-9])', 'n.complex128', content)\n    \n    if content != original:\n        with open(filepath, 'w') as f:\n            f.write(content)\n        print(f\"Fixed: {filepath}\")\n        return True\n    return False\n\n# Find all Python files\nfor root, dirs, files in os.walk('/app/pyknotid/pyknotid'):\n    for file in files:\n        if file.endswith('.py'):\n            filepath = os.path.join(root, file)\n  "]
[245.474386, "i", "          fix_numpy_types(filepath)\n\nprint(\"\\nAll numpy type aliases have been fixed!\")\nEOFPY\n"]
