[457.35065, "i", "python3 << 'EOF'\n# Final test with exact README code\nimport pyknotid\nfrom pyknotid.spacecurves import chelpers, ccomplexity\nfrom pyknotid import cinvariants\nimport pyknotid.make as mk\nimport pyknotid.spacecurves as sp\n\nk = sp.Knot(mk.three_twist(num_points=100))\nout = k.alexander_polynomial(-1)\nprint(f\"\\n[SUCCESS] Alexander polynomial result: {out}\")\nprint(\"[SUCCESS] All Cython extensions working with Numpy 2.3.0!\\n\")\nEOF\n"]
