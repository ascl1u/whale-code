[364.87415, "i", "python3 << 'EOF'\nimport numpy\nimport pyknotid\nfrom pyknotid.spacecurves import chelpers, ccomplexity\nfrom pyknotid import cinvariants\nimport pyknotid.make as mk\nimport pyknotid.spacecurves as sp\n\nprint(\"=\" * 70)\nprint(\"COMPREHENSIVE TEST RESULTS\")\nprint(\"=\" * 70)\nprint(f\"\\nNumpy version: {numpy.__version__}\")\nprint(f\"Pyknotid version: {pyknotid.__version__}\")\n\nprint(\"\\n1. Testing Cython extensions import:\")\nprint(f\"   - chelpers: {chelpers.__file__}\")\nprint(f\"   - ccomplexity: {ccomplexity.__file__}\")\nprint(f\"   - cinvariants: {cinvariants.__file__}\")\n\nprint(\"\\n2. Testing README example code:\")\nk = sp.Knot(mk.three_twist(num_points=100))\nout = k.alexander_polynomial(-1)\nprint(f\"   Alexander polynomial at -1: {out}\")\nprint(f\"   Result type: {type(out)}\")\n\nprint(\"\\n3. Testing additional functionality:\")\n# Test that the extensions are actually being used\nimport sys\nif hasattr(chelpers, '__file__') and chelpers.__file__.endswith('.so'):\n    print(\"   ✓ chelpers Cython extension is compiled and loaded\")\nif hasat"]
[364.874424, "i", "tr(ccomplexity, '__file__') and ccomplexity.__file__.endswith('.so'):\n    print(\"   ✓ ccomplexity Cython extension is compiled and loaded\")\nif hasattr(cinvariants, '__file__') and cinvariants.__file__.endswith('.so'):\n    print(\"   ✓ cinvariants Cython extension is compiled and loaded\")\n\nprint(\"\\n\" + \"=\" * 70)\nprint(\"ALL TESTS PASSED SUCCESSFULLY!\")\nprint(\"Pyknotid is working correctly with Numpy 2.3.0\")\nprint(\"=\" * 70)\nEOF\n"]
[364.87458, "o", "python3 << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
