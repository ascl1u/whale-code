[433.828022, "o", "diff --git a/pyknotid/invariants.py b/pyknotid/invariants.py\r\nindex c4ab998..2db3472 100644\r\n--- a/pyknotid/invariants.py\r\n+++ b/pyknotid/invariants.py\r\n@@ -134,7 +134,7 @@ def _alexander_numpy(crossings, variable=-1.0, quadrant='lr'):\r\n     '''\r\n     import numpy as n\r\n     num_crossings = int(len(crossings)/2)\r\n-    dtype = n.complex if isinstance(variable, n.complex) else n.float\r\n+    dtype = n.complex128 if isinstance(variable, (complex, n.complexfloating)) else n.float64\r\n     matrix = n.zeros((num_crossings, num_crossings), dtype=dtype)\r\n     line_num = 0\r\n     crossing_num_counter = 0\r\n@@ -174,7 +174,7 @@ def _alexander_numpy(crossings, variable=-1.0, quadrant='lr'):\r\n"]
[433.828275, "o", "         poly_val = n.linalg.det(matrix[:-1:, :-1])\r\n     elif quadrant == 'll':\r\n         poly_val = n.linalg.det(matrix[1:, :-1])\r\n-    if not isinstance(poly_val, n.complex):\r\n+    if not isinstance(poly_val, (complex, n.complexfloating)):\r\n         poly_val = n.abs(poly_val)\r\n     return poly_val\r\n \r\n"]
