[608.593871, "i", "cd /tmp && python3 << 'EOF'\nimport numpy\nprint(f\"Testing pyknotid installation with Numpy {numpy.__version__}\")\nprint(\"=\"*60)\n\nimport pyknotid\nfrom pyknotid.spacecurves import chelpers, ccomplexity\nfrom pyknotid import cinvariants\nimport pyknotid.make as mk\nimport pyknotid.spacecurves as sp\n\nprint(\"✓ All Cython extensions imported successfully\")\nprint(\"  - chelpers\")\nprint(\"  - ccomplexity\")\nprint(\"  - cinvariants\")\nprint()\n\nk = sp.Knot(mk.three_twist(num_points=100))\nout = k.alexander_polynomial(-1)\nprint(f\"Alexander polynomial at -1: {out}\")\nprint()\nprint(\"=\"*60)\nprint(\"SUCCESS: pyknotid is fully functional with Numpy 2.3.0!\")\nprint(\"=\"*60)\nEOF\n"]
