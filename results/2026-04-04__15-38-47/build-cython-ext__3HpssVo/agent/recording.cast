[515.650997, "i", "python3 << 'EOF'\nimport numpy\nprint(f\"Numpy version: {numpy.__version__}\")\nprint()\nimport pyknotid\nfrom pyknotid.spacecurves import chelpers, ccomplexity\nfrom pyknotid import cinvariants\nimport pyknotid.make as mk\nimport pyknotid.spacecurves as sp\n\nk = sp.Knot(mk.three_twist(num_points=100))\nout = k.alexander_polynomial(-1)\nprint(f\"Alexander polynomial at -1: {out}\")\nprint(\"\\n✓ Test completed successfully!\")\nprint(\"✓ Cython extensions (chelpers, ccomplexity, cinvariants) are working\")\nprint(\"✓ Compatible with Numpy 2.3.0\")\nEOF\n"]
